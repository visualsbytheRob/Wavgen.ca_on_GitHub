    ctx.fillStyle='rgba(74,88,120,0.4)'; ctx.font='10px Courier New';
    ctx.textAlign='center'; ctx.fillText('Human FOV ~200°',W/2,16); ctx.textAlign='left';

    params.forEach((p,i)=>{
      const angle=p.fov/2*Math.PI/180;
