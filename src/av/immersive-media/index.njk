        <div class="disp-bar-row">
          <div class="disp-bar-label">${p.name}</div>
          <div class="disp-bar-track"><div class="disp-bar-fill" style="width:${frac*100}%;background:${p.col}"></div></div>
          <div class="disp-bar-val" style="color:${p.col}">${bd.values[i]}${bd.unit}</div>
        </div>`;
    });
