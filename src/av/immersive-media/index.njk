    ctx.fillStyle='#04060E'; ctx.fillRect(0,0,W,H);

    // human FoV reference
    ctx.strokeStyle='rgba(232,240,255,0.1)'; ctx.lineWidth=1; ctx.setLineDash([4,6]);
