  const barsDiv=document.getElementById('display-bars');
  barsData.forEach(bd=>{
    const row=document.createElement('div'); row.style.marginBottom='1rem';
    row.innerHTML=`<div style="font-size:0.6rem;color:var(--muted);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.5rem;">${bd.label}</div>`;
    params.forEach((p,i)=>{
      const frac=bd.values[i]/bd.max;
