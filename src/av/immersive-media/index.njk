  headsets.forEach((hs, i) => {
    const card = document.createElement('div');
    card.className = 'headset-card' + (i===0?' active':'');
    card.innerHTML = `
      <div class="hs-name">${hs.name}</div>
      <div class="hs-maker">${hs.maker} · ${hs.type}</div>
      <div class="hs-specs">${hs.specs.split('·').join('<br>')}</div>
    `;
    card.addEventListener('click',()=>{
      activeHS=i; cards.forEach((c,j)=>c.classList.toggle('active',j===i));
    });
    grid.appendChild(card); cards.push(card);
  });

  const canvas = document.getElementById('headset-radar');
  const ctx = canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  const labels=['Resolution','FOV','Tracking','Display','Refresh','Standalone'];
  const N=labels.length;
  const cx=W/2, cy=H/2, R=100;

  let lastHS=performance.now();
  const radarFilters=headsets.map(hs=>hs.vals.map(v=>new LagFilter(v,0.5)));

  function animHS(ts) {
    const dt=clamp((ts-lastHS)/1000,0,0.05); lastHS=ts;
    ctx.fillStyle='#04060E'; ctx.fillRect(0,0,W,H);

    // radar grid
    [0.25,0.5,0.75,1.0].forEach(r=>{
      ctx.strokeStyle=`rgba(32,96,255,${r*0.15})`; ctx.lineWidth=1;
      ctx.beginPath();
      for(let i=0;i<N;i++){
        const a=i/N*Math.PI*2-Math.PI/2;
        const x=cx+Math.cos(a)*R*r, y=cy+Math.sin(a)*R*r;
        i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
      }
      ctx.closePath(); ctx.stroke();
    });
    for(let i=0;i<N;i++){
      const a=i/N*Math.PI*2-Math.PI/2;
      ctx.strokeStyle='rgba(32,96,255,0.15)'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(cx+Math.cos(a)*R,cy+Math.sin(a)*R); ctx.stroke();
      ctx.fillStyle='rgba(74,88,120,0.8)'; ctx.font='10px Courier New';
      ctx.textAlign='center';
      const lx=cx+Math.cos(a)*(R+18), ly=cy+Math.sin(a)*(R+18);
      ctx.fillText(labels[i],lx,ly+4);
    }

    // draw each headset (dimmed) + active bright
    headsets.forEach((hs,hi)=>{
      const isActive=hi===activeHS;
      const vals=hs.vals.map((v,vi)=>radarFilters[hi][vi].update(v,dt));
      ctx.strokeStyle=isActive?hs.color:hs.color+'44';
      ctx.lineWidth=isActive?2:1;
      ctx.fillStyle=hs.color+(isActive?'33':'11');
      ctx.beginPath();
      vals.forEach((v,i)=>{
        const a=i/N*Math.PI*2-Math.PI/2;
        const x=cx+Math.cos(a)*R*v, y=cy+Math.sin(a)*R*v;
        i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
      });
      ctx.closePath(); ctx.fill(); ctx.stroke();
      if(isActive){
        vals.forEach((v,i)=>{
          const a=i/N*Math.PI*2-Math.PI/2;
          ctx.beginPath(); ctx.arc(cx+Math.cos(a)*R*v,cy+Math.sin(a)*R*v,4,0,Math.PI*2);
          ctx.fillStyle=hs.color; ctx.fill();
        });
      }
    });

    // legend
    const lx=W-180;
    headsets.forEach((hs,i)=>{
      ctx.fillStyle=activeHS===i?hs.color:'rgba(74,88,120,0.6)';
      ctx.font=activeHS===i?'bold 10px Courier New':'10px Courier New';
      ctx.textAlign='left';
      ctx.fillText('■ '+hs.name, lx, 20+i*18);
    });
    ctx.textAlign='left';

    requestAnimationFrame(animHS);
  }
  requestAnimationFrame(animHS);
})();

