  const artists = [
    { name:'Nonny de la Peña', title:'VR Journalism Pioneer', bio:'The "Godmother of VR" created immersive journalism pieces like Hunger in Los Angeles and Project Syria, establishing narrative presence as a journalistic tool.', shape:'circle', color:'#2060FF' },
    { name:'Chris Milk', title:'VR Director', bio:'Co-founded Within and directed Clouds Over Sidra for UNICEF. His TED talk "How Virtual Reality Can Create the Ultimate Empathy Machine" defined immersive media\'s humanitarian potential.', shape:'hex', color:'#60A0FF' },
    { name:'teamLab', title:'Art Collective', bio:'Tokyo collective creating room-scale digital art environments where participants immerse in reactive ecosystems of light, sound, and biology — dissolving the boundary between viewer and artwork.', shape:'triangle', color:'#00D4C8' },
    { name:'Marshmallow Laser Feast', title:'Immersive Studio', bio:'UK collective creating sensory VR experiences like Treehugger and In the Eyes of the Animal that position the viewer inside biological and geological systems beyond human perception.', shape:'diamond', color:'#FF9040' },
    { name:'Olafur Eliasson', title:'Artist', bio:'Danish-Icelandic artist whose immersive installations at massive scale — The Weather Project, Your Rainbow Panorama — preceded digital XR by transforming architecture into perceptual experience.', shape:'square', color:'#00FF88' },
    { name:'Char Davies', title:'VR Artist', bio:'Created Osmose (1995) and Ephémère (1998) — early landmark VR works using breath and balance as navigation controls, exploring embodied presence in living virtual ecologies.', shape:'hex', color:'#FF00CC' },
    { name:'Kent Bye', title:'XR Journalist', bio:'Voices of VR podcast host who has documented the immersive media ecosystem through thousands of interviews, building the definitive oral history of VR as a medium and artform.', shape:'circle', color:'#FFCC00' },
    { name:'Alan Milligan (USC ICT)', title:'Researcher', bio:'Institute for Creative Technologies researchers developed EmotionAR, ICT World Builder, and pioneered therapeutic and training applications for XR including virtual reality exposure therapy.', shape:'triangle', color:'#CC00FF' }
  ];

  const grid=document.getElementById('artists-grid');
  const svgNS='http://www.w3.org/2000/svg';
  artists.forEach(a=>{
    const card=document.createElement('div'); card.className='artist-card';
    const svg=document.createElementNS(svgNS,'svg'); svg.setAttribute('class','artist-avatar'); svg.setAttribute('viewBox','0 0 52 52');
    const S={
      circle:()=>{const c=document.createElementNS(svgNS,'circle');c.setAttribute('cx','26');c.setAttribute('cy','26');c.setAttribute('r','22');c.setAttribute('fill','none');c.setAttribute('stroke',a.color);c.setAttribute('stroke-width','2');const c2=document.createElementNS(svgNS,'circle');c2.setAttribute('cx','26');c2.setAttribute('cy','26');c2.setAttribute('r','11');c2.setAttribute('fill',a.color);c2.setAttribute('opacity','0.3');svg.appendChild(c);svg.appendChild(c2);},
      hex:()=>{const pts=Array.from({length:6},(_,i)=>{const ang=i*Math.PI/3-Math.PI/6;return`${26+22*Math.cos(ang)},${26+22*Math.sin(ang)}`;}).join(' ');const p=document.createElementNS(svgNS,'polygon');p.setAttribute('points',pts);p.setAttribute('fill','none');p.setAttribute('stroke',a.color);p.setAttribute('stroke-width','2');svg.appendChild(p);},
      triangle:()=>{const p=document.createElementNS(svgNS,'polygon');p.setAttribute('points','26,4 48,46 4,46');p.setAttribute('fill','none');p.setAttribute('stroke',a.color);p.setAttribute('stroke-width','2');svg.appendChild(p);},
      diamond:()=>{const p=document.createElementNS(svgNS,'polygon');p.setAttribute('points','26,2 50,26 26,50 2,26');p.setAttribute('fill','none');p.setAttribute('stroke',a.color);p.setAttribute('stroke-width','2');svg.appendChild(p);},
      square:()=>{const r=document.createElementNS(svgNS,'rect');r.setAttribute('x','4');r.setAttribute('y','4');r.setAttribute('width','44');r.setAttribute('height','44');r.setAttribute('fill','none');r.setAttribute('stroke',a.color);r.setAttribute('stroke-width','2');svg.appendChild(r);}
    };
    (S[a.shape]||S.circle)();
    card.innerHTML=`<div class="ph"></div><div class="artist-name">${a.name}</div><div class="artist-title">${a.title}</div><div class="artist-bio">${a.bio}</div>`;
    card.querySelector('.ph').replaceWith(svg); grid.appendChild(card);
  });
})();

/* ═══════════════════════════════════════════════════════
   SECTION 9 — GLOSSARY
   ═══════════════════════════════════════════════════════ */
(function initGlossary() {
  const terms=[
    {term:'Extended Reality (XR)',def:'Umbrella term for the full spectrum of Augmented, Mixed, and Virtual Reality technologies that modify or replace perceived reality.'},
    {term:'Head-Mounted Display',def:'Wearable display device worn on the head with screens positioned in front of one or both eyes, delivering stereoscopic visual content.'},
    {term:'Field of View (FOV)',def:'The angular extent of the visible scene in a headset, measured diagonally or per-axis. Wider FOV increases immersion but requires more pixels.'},
    {term:'Pixels Per Degree (PPD)',def:'Resolution metric for XR displays measuring how many pixels subtend one degree of visual arc. The human visual system resolves ~60 PPD at peak foveal acuity.'},
    {term:'SLAM',def:'Simultaneous Localization and Mapping — computing the camera\'s 6DoF pose while building a 3D map of the environment from sensor data.'},
    {term:'6DoF Tracking',def:'Six degrees of freedom — three rotational (pitch, yaw, roll) plus three translational (surge, heave, sway) — enabling room-scale VR movement.'},
    {term:'Inside-Out Tracking',def:'Headset self-localization using onboard cameras and SLAM, eliminating external base stations required by outside-in optical systems.'},
    {term:'Reprojection',def:'Technique to reduce perceived latency by rendering at a lower frame rate and extrapolating the last frame to match the current head pose before display.'},
    {term:'HRTF',def:'Head-Related Transfer Function — the direction-dependent acoustic filter imposed by the head, pinnae, and torso, used to spatialize audio binaurally.'},
    {term:'Interpupillary Distance (IPD)',def:'The distance between the centers of the pupils, typically 54–72mm. Headsets require adjustable IPD for correct stereo convergence and lens alignment.'},
    {term:'Vergence-Accommodation Conflict',def:'Perceptual conflict in current HMDs where the eyes converge to a virtual depth but must accommodate (focus) to the fixed display plane, causing fatigue.'},
    {term:'Equirectangular Projection',def:'A 2:1 image mapping the full sphere onto a rectangle using longitude for the horizontal axis and latitude for the vertical — the standard 360° video format.'},
    {term:'Passthrough AR',def:'Video see-through augmented reality where headset cameras capture the real world and composite digital content onto the live camera feed displayed to the user.'},
    {term:'Spatial Anchor',def:'A persistent coordinate in physical space tagged with a device identifier, allowing virtual objects to remain spatially fixed across sessions and multiple users.'},
    {term:'Foveated Rendering',def:'Eye-tracked rendering that reduces GPU load by computing full resolution only in the foveal region where the eye is focused, with lower resolution in periphery.'},
    {term:'World Locking',def:'Keeping virtual content anchored to physical space coordinates even as the user\'s head moves, using SLAM to maintain spatial consistency.'},
    {term:'Stereoscopy',def:'Presenting slightly offset images to each eye to create the perception of depth through binocular disparity — the primary depth cue exploited by HMDs.'},
    {term:'Presence',def:'The subjective sensation of "being there" in a virtual environment, dependent on tracking quality, display resolution, latency, and content quality.'},
    {term:'Latency (Motion to Photon)',def:'The total delay from physical head movement to the corresponding display update. Below 20ms is perceptually acceptable; below 7ms is ideal for preventing VR sickness.'},
    {term:'Haptic Feedback',def:'Force, vibration, or texture sensations delivered through controllers, gloves, or suits to reinforce the sense of touching virtual objects.'},
    {term:'Social VR',def:'Multi-user virtual environments with embodied avatars enabling shared presence, communication, and activity — platforms include VRChat, Rec Room, and Horizon Worlds.'},
    {term:'Varifocal Display',def:'Experimental XR display technology with adjustable optical focus that matches the eye\'s accommodation depth to the vergence target, resolving the VAC problem.'}
  ];

  const grid=document.getElementById('gloss-grid');
  terms.forEach(t=>{
    const d=document.createElement('div'); d.className='gloss-item';
    d.innerHTML=`<div class="gloss-term">${t.term}</div><div class="gloss-def">${t.def}</div>`;
    grid.appendChild(d);
  });
})();

/* ═══════════════════════════════════════════════════════
   INTERSECTION OBSERVER
   ═══════════════════════════════════════════════════════ */
const observer=new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target);} });
},{threshold:0.08});
document.querySelectorAll('.hidden').forEach(el=>observer.observe(el));
</script>
