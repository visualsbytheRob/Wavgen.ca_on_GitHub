})();

/* ═══════════════════════════════════════════════════════
   SECTION 7 — SPATIAL AUDIO / HRTF
   ═══════════════════════════════════════════════════════ */
(function initHRTF() {
  const hc=document.getElementById('hrtf-canvas');
  const bc=document.getElementById('binaural-canvas');
  const hCtx=hc.getContext('2d'), bCtx=bc.getContext('2d');
  const W=hc.width,H=hc.height;

  let mx=W/2, my=H/2;
  hc.addEventListener('mousemove',e=>{
    const r=hc.getBoundingClientRect();
    mx=(e.clientX-r.left)/hc.clientWidth*W;
    my=(e.clientY-r.top)/hc.clientHeight*H;
  });

  const LHIST=new Float32Array(W).fill(0), RHIST=new Float32Array(W).fill(0);
  let lastH=performance.now();

  function animHRTF(ts) {
    const dt=clamp((ts-lastH)/1000,0,0.05); lastH=ts;
    const t=ts/1000;
    const sx=lagHRTFX.update(mx,dt), sy=lagHRTFY.update(my,dt);

    // HRTF canvas: top-down view with source position
    hCtx.fillStyle='rgba(2,4,8,0.2)'; hCtx.fillRect(0,0,W,H);
    const cx=W/2, cy=H/2;
    // head outline
    hCtx.beginPath(); hCtx.arc(cx,cy,30,0,Math.PI*2);
    hCtx.strokeStyle='rgba(232,240,255,0.5)'; hCtx.lineWidth=2; hCtx.stroke();
    hCtx.fillStyle='rgba(32,96,255,0.1)'; hCtx.fill();
    // ears
    hCtx.beginPath(); hCtx.arc(cx-30,cy,5,0,Math.PI*2); hCtx.fillStyle='rgba(96,160,255,0.7)'; hCtx.fill();
    hCtx.beginPath(); hCtx.arc(cx+30,cy,5,0,Math.PI*2); hCtx.fill();
    // ITD distance circles
    [80,140,200].forEach(r=>{
      hCtx.beginPath(); hCtx.arc(cx,cy,r,0,Math.PI*2);
      hCtx.strokeStyle=`rgba(32,96,255,${0.08+r*0.0002})`; hCtx.lineWidth=0.5; hCtx.stroke();
    });
    // angle lines
    for(let a=0;a<Math.PI*2;a+=Math.PI/6){
      hCtx.strokeStyle='rgba(32,96,255,0.06)'; hCtx.lineWidth=0.5;
      hCtx.beginPath(); hCtx.moveTo(cx,cy); hCtx.lineTo(cx+Math.cos(a)*220,cy+Math.sin(a)*220); hCtx.stroke();
    }
    // sound source
    hCtx.beginPath(); hCtx.arc(sx,sy,10,0,Math.PI*2);
    hCtx.fillStyle='rgba(255,144,64,0.9)'; hCtx.fill();
    hCtx.shadowColor='#FF9040'; hCtx.shadowBlur=15;
    hCtx.beginPath(); hCtx.arc(sx,sy,10,0,Math.PI*2); hCtx.fill();
    hCtx.shadowBlur=0;
    // line to ears
    [[cx-30,cy,'L'],[cx+30,cy,'R']].forEach(([ex,ey,label])=>{
      const dist=Math.sqrt((sx-ex)**2+(sy-ey)**2);
      hCtx.strokeStyle='rgba(255,144,64,0.3)'; hCtx.lineWidth=1;
      hCtx.setLineDash([3,4]);
      hCtx.beginPath(); hCtx.moveTo(sx,sy); hCtx.lineTo(ex,ey); hCtx.stroke();
      hCtx.setLineDash([]);
      hCtx.fillStyle='rgba(96,160,255,0.8)'; hCtx.font='9px Courier New';
      hCtx.fillText(`${label}: ${dist.toFixed(0)}px`,ex+6,ey-6);
    });
    // position info
    const ang=Math.atan2(sy-cy,sx-cx)*180/Math.PI;
    hCtx.fillStyle='rgba(96,160,255,0.8)'; hCtx.font='10px Courier New';
    hCtx.fillText(`AZ: ${ang.toFixed(0)}°  EL: ${((0.5-sy/H)*90).toFixed(0)}°`,8,H-10);

    // binaural waveforms
    const distL=Math.sqrt((sx-(cx-30))**2+(sy-cy)**2)/W;
    const distR=Math.sqrt((sx-(cx+30))**2+(sy-cy)**2)/W;
    const angRad=Math.atan2(sy-cy,sx-cx);
    const ampL=clamp(1-(distL*0.6),0.2,1)*(angRad<0?1:0.7);
    const ampR=clamp(1-(distR*0.6),0.2,1)*(angRad>0?1:0.7);
    const phase=distL*8;

    LHIST.copyWithin(0,1); LHIST[W-1]=ampL*Math.sin(t*8+phase)*0.8+(noise21(t*4,1)*2-1)*0.1;
    RHIST.copyWithin(0,1); RHIST[W-1]=ampR*Math.sin(t*8+phase+distR*8)*0.8+(noise21(t*4,2)*2-1)*0.1;
    lagWave.update(ampL, dt);

    bCtx.fillStyle='rgba(2,4,8,0.25)'; bCtx.fillRect(0,0,W,H);
    [['L',LHIST,'#2060FF',H/4],[' R',RHIST,'#60A0FF',3*H/4]].forEach(([label,hist,col,cy2])=>{
      bCtx.strokeStyle='rgba(232,240,255,0.06)'; bCtx.lineWidth=1;
      bCtx.beginPath(); bCtx.moveTo(0,cy2); bCtx.lineTo(W,cy2); bCtx.stroke();
      bCtx.strokeStyle=col; bCtx.lineWidth=1.5;
      bCtx.beginPath();
      hist.forEach((v,x)=>{ const y=cy2-v*(H/5); x===0?bCtx.moveTo(x,y):bCtx.lineTo(x,y); });
      bCtx.stroke();
      bCtx.fillStyle=col; bCtx.font='10px Courier New';
      bCtx.fillText(`${label} Channel`,8,cy2-H/5-4);
    });

    requestAnimationFrame(animHRTF);
  }
  requestAnimationFrame(animHRTF);
})();

