      // label
      ctx.fillStyle=p.col; ctx.font='10px Courier New';
      ctx.textAlign='center';
      ctx.fillText(p.name,cx2,H-10);
      ctx.fillText(p.fov+'°',cx2,H*0.5-scale-8);
      ctx.textAlign='left';
    });

    requestAnimationFrame(animDisplay);
  }
