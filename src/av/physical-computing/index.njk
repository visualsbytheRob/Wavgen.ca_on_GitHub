// SECTION 8 — GLOSSARY (22 terms)
// ═══════════════════════════════════════════════════════════
(function buildGlossary() {
  const terms = [
    { term: 'Arduino', def: 'Open-source microcontroller platform. Reads analog/digital sensors and controls actuators via PWM, I2C, SPI, and UART. Communicates with software via USB serial or USB MIDI.' },
    { term: 'Raspberry Pi', def: 'Credit-card-sized Linux single-board computer. Runs Python, OpenCV, and OSC bridges. Pi 5 capable of MediaPipe body tracking. The minimal headless node in distributed installations.' },
    { term: 'Sensor', def: 'A transducer converting physical phenomena (light, pressure, motion, temperature, sound) into electrical signals measurable by a microcontroller via analog voltage, I2C, or SPI.' },
    { term: 'Actuator', def: 'A device converting digital signals back into physical action. Motors, solenoids, LEDs, speakers, and pneumatic valves are all actuators — the outputs of a cybernetic loop.' },
    { term: 'OSC (Open Sound Control)', def: 'Network messaging protocol using hierarchical address patterns (/sensor/accel/x) over UDP/TCP. Sub-millisecond latency on LAN. The standard bridge between physical computing and visual software.' },
    { term: 'MIDI', def: 'Musical Instrument Digital Interface — 31.25 kbaud serial protocol with 128 note values, 128 CC parameters, 16 channels. USB MIDI is universally supported by DAWs, synths, and VJ tools.' },
    { term: 'DMX', def: 'DMX512-A — 512-channel lighting control protocol via RS-485 serial at 250kbaud. ArtNet and sACN are Ethernet encapsulations enabling DMX control over standard network infrastructure.' },
    { term: 'Serial Protocol', def: 'Asynchronous UART communication. Arduino\'s default interface to a host computer via USB-CDC. pyserial and Node.js serialport libraries bridge serial data to OSC or web sockets.' },
    { term: 'I2C', def: 'Two-wire synchronous bus (SDA + SCL) connecting microcontrollers to sensor chips. Up to 128 device addresses. 100kHz–400kHz clock. IMUs, barometers, and OLEDs typically use I2C.' },
    { term: 'SPI', def: 'Serial Peripheral Interface — four-wire synchronous protocol (MOSI, MISO, SCK, CS). Higher bandwidth than I2C. Used for high-speed sensors, flash memory, and color displays.' },
    { term: 'PWM', def: 'Pulse Width Modulation — rapid switching of a digital output at variable duty cycle. Controls servo position, DC motor speed, and LED brightness from binary digital pins.' },
    { term: 'Interrupt', def: 'A hardware signal that pauses the main program to execute a priority handler. Essential for button debounce, encoder counting, and time-critical sensor events in microcontroller firmware.' },
    { term: 'Debounce', def: 'Filtering technique that eliminates spurious transitions from mechanical switches. Implemented in firmware (ignore changes within 10–50ms) or hardware (RC filter). Critical for reliable button input.' },
    { term: 'Latency', def: 'Time elapsed between a physical event and its audiovisual response. Interactive installations require <100ms for perceived immediacy. Serial + Python + OSC chains typically achieve 20–50ms latency.' },
    { term: 'Feedback Loop', def: 'A system where outputs are fed back as inputs. In cybernetics, feedback enables self-regulation. In AV installations, feedback creates emergent, evolving behaviors that no single moment controls.' },
    { term: 'Cybernetics', def: 'The study of regulatory systems and feedback in machines, organisms, and organizations. Founded by Norbert Wiener in 1948. Physical computing is applied cybernetics — organisms made from sensors and actuators.' },
    { term: 'Interactive Installation', def: 'An artwork or environment that responds to audience presence and behavior in real time. Distinguishes itself from passive media by making the audience\'s physical action constitutive of the work.' },
    { term: 'Responsive Environment', def: 'An architectural or physical space equipped with sensing and actuation systems that modify their behavior based on occupant activity — temperature, density, movement, or biometrics.' },
    { term: 'Sensor Fusion', def: 'Combining multiple sensor streams to derive quantities unavailable from any single sensor. Accelerometer + gyroscope + magnetometer fused into orientation estimate is the canonical example.' },
    { term: 'Microcontroller', def: 'A single-chip computer integrating CPU, memory, and I/O peripherals. Arduino (AVR/ARM), ESP32, and Teensy are common platforms. Operates on deterministic real-time loops unlike general OS.' },
    { term: 'Single-Board Computer', def: 'A complete computer on one PCB — CPU, RAM, storage, I/O. Raspberry Pi, BeagleBone, and Jetson Nano are SBCs. Run full Linux OS, unlike microcontrollers. Bridge between embedded and compute-intensive tasks.' },
    { term: 'GPIO', def: 'General Purpose Input/Output — configurable digital pins on a microcontroller or SBC. Can read digital sensors (HIGH/LOW), output digital signals, or serve as PWM outputs when the hardware supports it.' },
  ];

  const grid = document.getElementById('glossaryGrid');
  terms.forEach(t => {
    const item = document.createElement('div');
    item.className = 'glossary-item';
    item.innerHTML = `<div class="glossary-term">${t.term}</div><div class="glossary-def">${t.def}</div>`;
    grid.appendChild(item);
  });
})();

// ═══════════════════════════════════════════════════════════
// INTERSECTION OBSERVER — scroll reveal
// ═══════════════════════════════════════════════════════════
(function initReveal() {
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
})();
</script>
