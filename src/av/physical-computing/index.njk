<script>
// ═══════════════════════════════════════════════════════════
// LAG FILTER ENGINE — 17 instances
// value += (1 - Math.exp(-dt/tau)) * (target - value)
// ═══════════════════════════════════════════════════════════
function makeLag(tau) {
  return { value: 0, target: 0, tau,
    step(dt) {
      const alpha = 1 - Math.exp(-dt / this.tau);
      this.value += alpha * (this.target - this.value);
      return this.value;
    }
  };
}

const lagHMX          = makeLag(0.08);
const lagHMY          = makeLag(0.08);
const lagHPulse       = makeLag(0.15);
const lagAccelX       = makeLag(0.04);
const lagAccelY       = makeLag(0.05);
const lagPressure     = makeLag(0.12);
const lagLightLevel   = makeLag(0.25);
const lagMIDIVel      = makeLag(0.03);
const lagOSCFloat     = makeLag(0.07);
const lagRouteDensity = makeLag(0.18);
const lagInstallMode  = makeLag(0.20);
const lagActuatorPower= makeLag(0.10);
const lagSignalNoise  = makeLag(0.06);
const lagProtocolFlow = makeLag(0.14);
const lagSerialBaud   = makeLag(0.09);
const lagInstallAnim  = makeLag(0.16);
const lagGlowIntensity= makeLag(0.22);

// ═══════════════════════════════════════════════════════════
// SECTION 1 — WEBGL HERO (circuit board cybernetic organism)
// ═══════════════════════════════════════════════════════════
(function initHero() {
  const canvas = document.getElementById('heroCanvas');
  const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
  if (!gl) { canvas.style.background='#020408'; return; }

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    gl.viewport(0, 0, canvas.width, canvas.height);
  }
  window.addEventListener('resize', resize);
  resize();

  const vsSrc = `
    attribute vec2 a_pos;
    void main() { gl_Position = vec4(a_pos, 0.0, 1.0); }
  `;

  const fsSrc = `
    precision highp float;
    uniform vec2  u_res;
    uniform float u_time;
    uniform vec2  u_mouse;
    uniform float u_pulse;

    // Hash
    float hash(vec2 p) {
      return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
    }
    float hash1(float v) { return fract(sin(v * 127.1) * 43758.5453); }

    // Smooth noise
    float noise(vec2 p) {
      vec2 i = floor(p); vec2 f = fract(p);
      vec2 u = f * f * (3.0 - 2.0 * f);
      return mix(mix(hash(i), hash(i+vec2(1,0)), u.x),
                 mix(hash(i+vec2(0,1)), hash(i+vec2(1,1)), u.x), u.y);
    }

    // Circuit board grid
    float circuit(vec2 uv, float scale) {
      vec2 g = fract(uv * scale) - 0.5;
      float h = hash(floor(uv * scale));
      // Traces — horizontal or vertical
      float trace = 0.0;
      if (h > 0.5) {
        trace = smoothstep(0.03, 0.01, abs(g.y)) * step(abs(g.x), 0.45);
      } else {
        trace = smoothstep(0.03, 0.01, abs(g.x)) * step(abs(g.y), 0.45);
      }
      // Nodes at intersections
      float node = smoothstep(0.06, 0.03, length(g));
      return max(trace, node * 0.8);
    }

    // Pulse ring emanating from a node
    float pulseRing(vec2 uv, vec2 center, float t, float speed) {
      float r = length(uv - center);
      float phase = fract(t * speed);
      float ring = smoothstep(0.005, 0.0, abs(r - phase * 0.6)) * (1.0 - phase);
      return ring;
    }

    void main() {
      vec2 uv = (gl_FragCoord.xy - u_res * 0.5) / u_res.y;
      float aspect = u_res.x / u_res.y;
      uv.x *= aspect;

      vec2 mouse = (u_mouse - u_res * 0.5) / u_res.y;
      mouse.x *= aspect;

      float t = u_time;

      // ── Base background
      vec3 col = vec3(0.008, 0.016, 0.031);

      // ── Circuit layers — multiple scales
      float c1 = circuit(uv + vec2(t * 0.01, 0.0), 6.0);
      float c2 = circuit(uv * 1.4 + vec2(0.0, t * 0.008), 10.0);
      float c3 = circuit(uv * 0.6 + vec2(t * 0.005), 4.0);

      // Green circuit traces
      col += vec3(0.0, 0.59, 0.62) * c1 * 0.5;
      col += vec3(0.0, 0.4, 0.42) * c2 * 0.3;
      col += vec3(0.0, 0.25, 0.27) * c3 * 0.2;

      // ── Signal pulse nodes — fixed positions
      vec2 nodes[6];
      nodes[0] = vec2(-0.3 * aspect, 0.1);
      nodes[1] = vec2(0.2 * aspect, -0.15);
      nodes[2] = vec2(0.0, 0.25);
      nodes[3] = vec2(-0.15 * aspect, -0.2);
      nodes[4] = vec2(0.35 * aspect, 0.2);
      nodes[5] = vec2(-0.4 * aspect, -0.1);

      for (int i = 0; i < 6; i++) {
        float offset = float(i) * 0.37;
        float ring = pulseRing(uv, nodes[i], t + offset, 0.4);
        col += vec3(0.0, 0.59, 0.62) * ring * 0.8;
        // Inner node glow
        float glow = smoothstep(0.12, 0.0, length(uv - nodes[i]));
        float blink = 0.5 + 0.5 * sin(t * 3.0 + offset * 6.28);
        col += vec3(0.0, 0.59, 0.62) * glow * 0.15 * blink;
        // Infrared accent on some nodes
        if (i == 1 || i == 4) {
          col += vec3(1.0, 0.24, 0.0) * glow * 0.12 * blink;
        }
      }

      // ── Mouse interaction — signal radiates from cursor
      float mdist = length(uv - mouse);
      float mGlow = smoothstep(0.5, 0.0, mdist);
      col += vec3(0.0, 0.59, 0.62) * mGlow * 0.25 * u_pulse;
      // Mouse pulse rings
      for (float fi = 0.0; fi < 3.0; fi++) {
        float ring = pulseRing(uv, mouse, t + fi * 0.33, 0.6);
        col += vec3(1.0, 0.24, 0.0) * ring * 0.6 * u_pulse;
      }

      // ── Organic noise overlay (organism texture)
      float n = noise(uv * 3.0 + t * 0.1);
      float n2 = noise(uv * 7.0 - t * 0.07);
      col += vec3(0.0, 0.08, 0.09) * n * 0.3;
      col += vec3(0.04, 0.0, 0.0) * n2 * 0.15;

      // ── Vignette
      float vig = 1.0 - smoothstep(0.3, 1.4, length(uv));
      col *= vig;

      // ── Bloom
      col = pow(max(col, vec3(0.0)), vec3(0.9));

      // ── Scanlines
      float scan = 0.95 + 0.05 * sin(gl_FragCoord.y * 3.14159 * 2.0);
      col *= scan;

      gl_FragColor = vec4(col, 1.0);
    }
  `;

  function compileShader(src, type) {
    const s = gl.createShader(type);
    gl.shaderSource(s, src);
    gl.compileShader(s);
    return s;
  }
  const prog = gl.createProgram();
  gl.attachShader(prog, compileShader(vsSrc, gl.VERTEX_SHADER));
  gl.attachShader(prog, compileShader(fsSrc, gl.FRAGMENT_SHADER));
  gl.linkProgram(prog);
  gl.useProgram(prog);

  const buf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, buf);
  gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
  const aPos = gl.getAttribLocation(prog, 'a_pos');
  gl.enableVertexAttribArray(aPos);
  gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

  const uRes   = gl.getUniformLocation(prog, 'u_res');
  const uTime  = gl.getUniformLocation(prog, 'u_time');
  const uMouse = gl.getUniformLocation(prog, 'u_mouse');
  const uPulse = gl.getUniformLocation(prog, 'u_pulse');

  let mx = canvas.width / 2, my = canvas.height / 2;
  let lastT = 0;
  document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });

  function frame(ts) {
    const t = ts / 1000;
    const dt = Math.min(t - lastT, 0.05);
    lastT = t;

    // Update lag filters for hero
    lagHMX.target = mx;    lagHMX.step(dt);
    lagHMY.target = my;    lagHMY.step(dt);
    lagHPulse.target = 1.0; lagHPulse.step(dt);
    lagGlowIntensity.target = 0.8 + 0.2 * Math.sin(t * 1.3); lagGlowIntensity.step(dt);

    gl.uniform2f(uRes, canvas.width, canvas.height);
    gl.uniform1f(uTime, t);
    gl.uniform2f(uMouse, lagHMX.value, canvas.height - lagHMY.value);
    gl.uniform1f(uPulse, lagGlowIntensity.value);
    gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();

// ═══════════════════════════════════════════════════════════
// SECTION 2 — SENSOR SIGNAL EXPLORER (Canvas 2D oscilloscope)
// ═══════════════════════════════════════════════════════════
(function initScope() {
  const canvas = document.getElementById('scopeCanvas');
  const ctx = canvas.getContext('2d');

  const CHANNELS = [
    { name: 'Accelerometer X', color: '#00979D', freq: 1.2,  amp: 0.7, phase: 0,   mode: 'sine',   noise: 0.05, lagRef: lagAccelX },
    { name: 'Accelerometer Y', color: '#00C8D0', freq: 0.9,  amp: 0.5, phase: 1.2, mode: 'cosine', noise: 0.06, lagRef: lagAccelY },
    { name: 'Pressure',        color: '#FF3D00', freq: 0.35, amp: 0.65, phase: 2.1, mode: 'smooth', noise: 0.03, lagRef: lagPressure },
    { name: 'Light Level',     color: '#F7C948', freq: 0.15, amp: 0.4,  phase: 0.5, mode: 'drift',  noise: 0.02, lagRef: lagLightLevel },
    { name: 'MIDI Velocity',   color: '#9B59B6', freq: 2.0,  amp: 0.8,  phase: 0.0, mode: 'spike',  noise: 0.01, lagRef: lagMIDIVel },
    { name: 'OSC Float',       color: '#2ECC71', freq: 0.7,  amp: 0.55, phase: 3.4, mode: 'combined',noise:0.04, lagRef: lagOSCFloat },
  ];

  // User-controllable params per channel
  const params = CHANNELS.map(c => ({ amp: c.amp, freq: c.freq }));

  // Build controls
  const container = document.getElementById('scopeControls');
  CHANNELS.forEach((ch, i) => {
    const div = document.createElement('div');
    div.className = 'scope-channel';
    div.style.borderLeftColor = ch.color;
    div.innerHTML = `
      <div class="scope-channel-name" style="color:${ch.color}">${ch.name}</div>
      <label><span>Amplitude</span><span id="ampVal${i}">${(params[i].amp*100).toFixed(0)}%</span></label>
      <input type="range" min="5" max="100" value="${params[i].amp*100}" id="ampSlider${i}">
      <label style="margin-top:8px"><span>Frequency</span><span id="freqVal${i}">${params[i].freq.toFixed(2)}Hz</span></label>
      <input type="range" min="10" max="300" value="${params[i].freq*100}" id="freqSlider${i}">
    `;
    container.appendChild(div);
    div.querySelector(`#ampSlider${i}`).addEventListener('input', e => {
      params[i].amp = e.target.value / 100;
      div.querySelector(`#ampVal${i}`).textContent = e.target.value + '%';
    });
    div.querySelector(`#freqSlider${i}`).addEventListener('input', e => {
      params[i].freq = e.target.value / 100;
      div.querySelector(`#freqVal${i}`).textContent = params[i].freq.toFixed(2) + 'Hz';
    });
  });

  // Signal generators
  let spikeTimers = CHANNELS.map(() => 0);

  function getSignal(ch, i, t, x, width) {
    const p = params[i];
    const f = p.freq;
    const a = p.amp;
    const ph = ch.phase;
    const n = (Math.random() - 0.5) * ch.noise;
    let v = 0;
    switch(ch.mode) {
      case 'sine':     v = Math.sin(t * f * Math.PI * 2 + ph) * a; break;
      case 'cosine':   v = Math.cos(t * f * Math.PI * 2 + ph) * a; break;
      case 'smooth': {
        const s1 = Math.sin(t * f * Math.PI * 2 + ph) * 0.5;
        const s2 = Math.sin(t * f * 0.5 * Math.PI * 2 + ph + 1) * 0.3;
        const s3 = Math.sin(t * f * 2 * Math.PI * 2 + ph + 2) * 0.2;
        v = (s1 + s2 + s3) * a;
        break;
      }
      case 'drift': {
        v = (Math.sin(t * f * Math.PI * 2 + ph) * 0.3 +
             Math.sin(t * f * 0.3 * Math.PI * 2 + ph + 1) * 0.7) * a;
        break;
      }
      case 'spike': {
        // Random trigger spikes
        v = Math.sin(t * f * Math.PI * 2) * 0.1 * a;
        const spikephase = fract(t * f);
        if (spikephase < 0.05) v += a * (1 - spikephase / 0.05);
        break;
      }
      case 'combined': {
        v = (Math.sin(t * f * Math.PI * 2 + ph) * 0.4 +
             Math.cos(t * f * 1.618 * Math.PI * 2 + ph) * 0.3 +
             Math.sin(t * f * 0.5 * Math.PI * 2 + ph + 0.5) * 0.3) * a;
        break;
      }
    }
    return Math.max(-1, Math.min(1, v + n));
  }

  function fract(v) { return v - Math.floor(v); }

  const HISTORY = 300;
  const histories = CHANNELS.map(() => new Float32Array(HISTORY));
  let histIdx = 0;
  let lastScopeT = 0;

  function drawScope(ts) {
    const t = ts / 1000;
    const dt = Math.min(t - lastScopeT, 0.05);
    lastScopeT = t;

    // Resize canvas
    const W = canvas.parentElement.clientWidth;
    if (canvas.width !== W) { canvas.width = W; }
    const H = canvas.height;
    const w = canvas.width;

    // Update lag filters + histories
    CHANNELS.forEach((ch, i) => {
      const raw = getSignal(ch, i, t, 0, w);
      ch.lagRef.target = raw;
      const smoothed = ch.lagRef.step(dt);
      histories[i][histIdx % HISTORY] = smoothed;
    });
    histIdx++;

    // Draw
    ctx.fillStyle = 'rgba(2,4,8,0.85)';
    ctx.fillRect(0, 0, w, H);

    // Grid lines
    ctx.strokeStyle = 'rgba(26,35,50,0.8)';
    ctx.lineWidth = 1;
    const rows = 6;
    for (let r = 0; r <= rows; r++) {
      const y = (r / rows) * H;
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke();
    }
    for (let c = 0; c <= 10; c++) {
      const x = (c / 10) * w;
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
    }

    // Channel waveforms
    const rowH = H / CHANNELS.length;
    CHANNELS.forEach((ch, i) => {
      const cy = (i + 0.5) * rowH;
      const halfH = rowH * 0.42;

      // Channel background
      ctx.fillStyle = `rgba(${hexToRgb(ch.color)},0.04)`;
      ctx.fillRect(0, i * rowH, w, rowH);

      // Channel label
      ctx.fillStyle = ch.color;
      ctx.font = '10px Courier New';
      ctx.fillText(ch.name, 8, i * rowH + 16);

      // Current value
      const curVal = histories[i][(histIdx - 1 + HISTORY) % HISTORY];
      ctx.fillStyle = 'rgba(255,255,255,0.5)';
      ctx.font = '9px Courier New';
      ctx.fillText(curVal.toFixed(3), w - 52, i * rowH + 16);

      // Waveform
      ctx.beginPath();
      ctx.strokeStyle = ch.color;
      ctx.lineWidth = 1.5;
      ctx.shadowColor = ch.color;
      ctx.shadowBlur = 4;

      for (let px = 0; px < w; px++) {
        const idx = (histIdx - HISTORY + Math.floor(px * HISTORY / w) + HISTORY * 2) % HISTORY;
        const val = histories[i][idx];
        const x = px;
        const y = cy - val * halfH;
        px === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();
      ctx.shadowBlur = 0;

      // Zero line
      ctx.strokeStyle = `rgba(${hexToRgb(ch.color)},0.2)`;
      ctx.lineWidth = 0.5;
      ctx.setLineDash([4, 4]);
      ctx.beginPath(); ctx.moveTo(0, cy); ctx.lineTo(w, cy); ctx.stroke();
      ctx.setLineDash([]);

      // Row divider
      if (i < CHANNELS.length - 1) {
        ctx.strokeStyle = 'rgba(0,151,157,0.15)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(0, (i+1) * rowH);
        ctx.lineTo(w, (i+1) * rowH);
        ctx.stroke();
      }
    });

    requestAnimationFrame(drawScope);
  }

  function hexToRgb(hex) {
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return `${r},${g},${b}`;
  }

  requestAnimationFrame(drawScope);
})();

// ═══════════════════════════════════════════════════════════
// SECTION 3 — SIGNAL ROUTING MAP (Canvas 2D)
// ═══════════════════════════════════════════════════════════
(function initRouting() {
  const canvas = document.getElementById('routeCanvas');
  const ctx = canvas.getContext('2d');
  let t = 0;

  const NODES = [
    // Row 0 — Physical hardware
    { id: 'arduino', label: 'Arduino', sublabel: 'Microcontroller', x: 0.08, y: 0.12, color: '#00979D', icon: '⚙' },
    { id: 'rpi',     label: 'Raspberry Pi', sublabel: 'SBC', x: 0.08, y: 0.40, color: '#C51A4A', icon: '🍓' },
    { id: 'midi',    label: 'MIDI Controller', sublabel: 'Hardware', x: 0.08, y: 0.68, color: '#9B59B6', icon: '🎹' },
    // Row 1 — Interface
    { id: 'serial',  label: 'USB Serial', sublabel: '115200 baud', x: 0.28, y: 0.12, color: '#F39C12', icon: '⟷' },
    { id: 'python',  label: 'Python', sublabel: 'Serial Bridge', x: 0.28, y: 0.40, color: '#3776AB', icon: '🐍' },
    { id: 'usbmidi', label: 'USB MIDI', sublabel: 'Protocol', x: 0.28, y: 0.68, color: '#9B59B6', icon: '⟷' },
    // Row 2 — Routing
    { id: 'osc',     label: 'OSC', sublabel: 'UDP/TCP', x: 0.50, y: 0.25, color: '#00979D', icon: '◎' },
    { id: 'midiR',   label: 'MIDI Router', sublabel: 'IAC Driver', x: 0.50, y: 0.68, color: '#9B59B6', icon: '⟳' },
    // Row 3 — Destinations
    { id: 'td',      label: 'TouchDesigner', sublabel: 'Visual Engine', x: 0.75, y: 0.15, color: '#00979D', icon: '◈' },
    { id: 'daw',     label: 'Ableton Live', sublabel: 'DAW', x: 0.75, y: 0.50, color: '#FF7720', icon: '♪' },
    { id: 'max',     label: 'Max/MSP', sublabel: 'Patching', x: 0.75, y: 0.80, color: '#696969', icon: '◇' },
    // Row 4 — Output
    { id: 'proj',    label: 'Projection', sublabel: 'Visual Output', x: 0.93, y: 0.20, color: '#00979D', icon: '▣' },
    { id: 'audio',   label: 'Audio Output', sublabel: 'Speakers', x: 0.93, y: 0.55, color: '#FF3D00', icon: '♫' },
    { id: 'dmxOut',  label: 'DMX Lights', sublabel: 'Lighting', x: 0.93, y: 0.85, color: '#F7C948', icon: '💡' },
  ];

  const EDGES = [
    { from: 'arduino', to: 'serial',  label: 'Serial' },
    { from: 'serial',  to: 'python',  label: 'pyserial' },
    { from: 'python',  to: 'osc',     label: 'python-osc' },
    { from: 'rpi',     to: 'python',  label: 'GPIO' },
    { from: 'midi',    to: 'usbmidi', label: 'USB' },
    { from: 'usbmidi', to: 'midiR',   label: 'MIDI' },
    { from: 'osc',     to: 'td',      label: 'OSC In' },
    { from: 'osc',     to: 'max',     label: 'OSC In' },
    { from: 'midiR',   to: 'daw',     label: 'MIDI Ch' },
    { from: 'midiR',   to: 'max',     label: 'MIDI In' },
    { from: 'td',      to: 'proj',    label: 'HDMI' },
    { from: 'td',      to: 'dmxOut',  label: 'ArtNet' },
    { from: 'daw',     to: 'audio',   label: 'Audio' },
    { from: 'max',     to: 'audio',   label: 'DAC' },
  ];

  // Particle systems per edge
  const particles = EDGES.map(() => []);
  function spawnParticle(edgeIdx) {
    particles[edgeIdx].push({ t: 0, speed: 0.3 + Math.random() * 0.4 });
  }

  let lastT = 0;
  function getNodePos(id, W, H) {
    const n = NODES.find(n => n.id === id);
    return { x: n.x * W, y: n.y * H };
  }

  function drawRoute(ts) {
    const now = ts / 1000;
    const dt = Math.min(now - lastT, 0.05);
    lastT = now;

    lagRouteDensity.target = 0.6 + 0.4 * Math.sin(now * 0.5);
    lagRouteDensity.step(dt);
    lagSignalNoise.target = 0.1 + 0.05 * Math.sin(now * 1.7);
    lagSignalNoise.step(dt);
    lagSerialBaud.target = 0.5 + 0.5 * Math.sin(now * 0.8 + 1);
    lagSerialBaud.step(dt);

    const W = canvas.parentElement.clientWidth;
    if (canvas.width !== W) canvas.width = W;
    const H = canvas.height;
    const w = canvas.width;

    ctx.clearRect(0, 0, w, H);
    ctx.fillStyle = 'rgba(2,4,8,0.95)';
    ctx.fillRect(0, 0, w, H);

    // Grid
    ctx.strokeStyle = 'rgba(26,35,50,0.5)';
    ctx.lineWidth = 1;
    for (let gx = 0; gx < w; gx += 40) {
      ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke();
    }
    for (let gy = 0; gy < H; gy += 40) {
      ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(w, gy); ctx.stroke();
    }

    // Spawn particles
    if (Math.random() < 0.35) {
      const idx = Math.floor(Math.random() * EDGES.length);
      spawnParticle(idx);
    }

    // Draw edges
    EDGES.forEach((e, ei) => {
      const a = getNodePos(e.from, w, H);
      const b = getNodePos(e.to, w, H);
      const fromNode = NODES.find(n => n.id === e.from);
      const toNode = NODES.find(n => n.id === e.to);
      const c1 = fromNode.color;
      const c2 = toNode.color;

      // Bezier control point
      const cx = (a.x + b.x) / 2 + (Math.random() < 0.5 ? 0 : 20);
      const cy = (a.y + b.y) / 2;

      // Edge line
      const grad = ctx.createLinearGradient(a.x, a.y, b.x, b.y);
      grad.addColorStop(0, hexAlpha(c1, 0.25));
      grad.addColorStop(1, hexAlpha(c2, 0.25));
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.quadraticCurveTo(cx, cy, b.x, b.y);
      ctx.strokeStyle = grad;
      ctx.lineWidth = 1.5;
      ctx.setLineDash([6, 4]);
      ctx.stroke();
      ctx.setLineDash([]);

      // Edge label
      ctx.fillStyle = 'rgba(90,112,144,0.8)';
      ctx.font = '9px Courier New';
      ctx.fillText(e.label, (a.x + b.x) / 2, (a.y + b.y) / 2 - 6);

      // Particles
      particles[ei] = particles[ei].filter(p => p.t < 1);
      particles[ei].forEach(p => {
        p.t += dt * p.speed;
        const qt = p.t;
        const px = (1-qt)*(1-qt)*a.x + 2*(1-qt)*qt*cx + qt*qt*b.x;
        const py = (1-qt)*(1-qt)*a.y + 2*(1-qt)*qt*cy + qt*qt*b.y;
        const alpha = Math.sin(p.t * Math.PI);
        ctx.beginPath();
        ctx.arc(px, py, 3, 0, Math.PI * 2);
        ctx.fillStyle = hexAlpha(c1, alpha * 0.9);
        ctx.shadowColor = c1;
        ctx.shadowBlur = 8;
        ctx.fill();
        ctx.shadowBlur = 0;
      });
    });

    // Draw nodes
    NODES.forEach(n => {
      const nx = n.x * w, ny = n.y * H;
      const R = 22;
      // Glow
      const grd = ctx.createRadialGradient(nx, ny, 0, nx, ny, R * 2);
      grd.addColorStop(0, hexAlpha(n.color, 0.3));
      grd.addColorStop(1, hexAlpha(n.color, 0));
      ctx.beginPath();
      ctx.arc(nx, ny, R * 2, 0, Math.PI * 2);
      ctx.fillStyle = grd;
      ctx.fill();
      // Circle
      ctx.beginPath();
      ctx.arc(nx, ny, R, 0, Math.PI * 2);
      ctx.fillStyle = '#0a1520';
      ctx.fill();
      ctx.strokeStyle = n.color;
      ctx.lineWidth = 2;
      ctx.stroke();
      // Label
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 9px Courier New';
      ctx.textAlign = 'center';
      ctx.fillText(n.label, nx, ny + R + 12);
      ctx.fillStyle = 'rgba(200,216,232,0.5)';
      ctx.font = '8px Courier New';
      ctx.fillText(n.sublabel, nx, ny + R + 22);
      ctx.textAlign = 'left';
    });

    requestAnimationFrame(drawRoute);
  }

  function hexAlpha(hex, a) {
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return `rgba(${r},${g},${b},${a})`;
  }

  requestAnimationFrame(drawRoute);
})();

