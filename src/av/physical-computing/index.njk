// SECTION 4 — INSTALLATION ARCHETYPES
// ═══════════════════════════════════════════════════════════
(function initInstallations() {
  const archetypes = [
    {
      tag: 'Sound-Reactive',
      title: 'Audio-Driven',
      icon: '🔊',
      desc: 'Microphone or line-in captures amplitude/frequency. FFT analysis drives generative visuals in real time.',
      chain: ['Microphone', 'ADC', 'FFT Analysis', 'TouchDesigner', 'Projection'],
      colors: ['#FF3D00','#FF6B35','#FF3D00','#00979D','#00979D'],
    },
    {
      tag: 'Motion-Reactive',
      title: 'Presence-Driven',
      icon: '👤',
      desc: 'Depth camera or PIR sensor detects human presence and motion. Body position drives spatial visual response.',
      chain: ['Depth Camera', 'Skeleton Track', 'OSC Bridge', 'TouchDesigner', 'LED Array'],
      colors: ['#9B59B6','#9B59B6','#00979D','#00979D','#F7C948'],
    },
    {
      tag: 'Touch-Reactive',
      title: 'Tactile-Driven',
      icon: '✋',
      desc: 'Capacitive or pressure sensors on physical surfaces. Touch events trigger and modulate audio/visual responses.',
      chain: ['Touch Surface', 'Arduino', 'Serial → OSC', 'Max/MSP', 'Speakers'],
      colors: ['#00979D','#00979D','#F39C12','#696969','#FF3D00'],
    },
    {
      tag: 'Environmental',
      title: 'Climate-Driven',
      icon: '🌡',
      desc: 'Temperature, humidity, light, and air quality sensors feed slow, meditative drift in ambient audiovisual systems.',
      chain: ['DHT22 Sensor', 'Raspberry Pi', 'MQTT → OSC', 'Ableton', 'Ambience'],
      colors: ['#2ECC71','#C51A4A','#F39C12','#FF7720','#F7C948'],
    },
  ];

  const grid = document.getElementById('installGrid');
  let activeIdx = 0;

  archetypes.forEach((a, i) => {
    const card = document.createElement('div');
    card.className = 'install-card' + (i === 0 ? ' active' : '');
    card.innerHTML = `
      <div class="install-icon">${a.icon}</div>
      <div class="install-card-tag">[${a.tag}]</div>
      <div class="install-card-title">${a.title}</div>
      <div class="install-card-desc">${a.desc}</div>
    `;
    card.addEventListener('click', () => {
      document.querySelectorAll('.install-card').forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      activeIdx = i;
      lagInstallMode.target = i / (archetypes.length - 1);
      lagInstallAnim.target = 1;
    });
    grid.appendChild(card);
  });

  const canvas = document.getElementById('installCanvas');
  const ctx = canvas.getContext('2d');
  let lastT = 0;
  let flowAnim = 0;

  function drawInstall(ts) {
    const now = ts / 1000;
    const dt = Math.min(now - lastT, 0.05);
    lastT = now;

    lagInstallMode.step(dt);
    lagInstallAnim.target = 0;
    lagInstallAnim.step(dt);
    lagActuatorPower.target = 0.5 + 0.5 * Math.sin(now * 0.7);
    lagActuatorPower.step(dt);
    lagProtocolFlow.target = 0.5 + 0.5 * Math.sin(now * 1.1);
    lagProtocolFlow.step(dt);

    const W = canvas.parentElement.clientWidth;
    if (canvas.width !== W) canvas.width = W;
    const H = canvas.height;
    const w = canvas.width;

    ctx.clearRect(0, 0, w, H);
    ctx.fillStyle = 'rgba(2,4,8,0.95)';
    ctx.fillRect(0, 0, w, H);

    const arch = archetypes[activeIdx];
    const N = arch.chain.length;
    const step = w / (N + 1);
    const cy = H / 2;
    flowAnim = (flowAnim + dt * 0.8) % 1;

    // Connection lines with flowing particles
    for (let i = 0; i < N - 1; i++) {
      const x1 = step * (i + 1);
      const x2 = step * (i + 2);
      const c1 = arch.colors[i];
      const c2 = arch.colors[i + 1];

      // Line
      const grad = ctx.createLinearGradient(x1, cy, x2, cy);
      grad.addColorStop(0, hexAlpha2(c1, 0.5));
      grad.addColorStop(1, hexAlpha2(c2, 0.5));
      ctx.beginPath();
      ctx.moveTo(x1 + 28, cy);
      ctx.lineTo(x2 - 28, cy);
      ctx.strokeStyle = grad;
      ctx.lineWidth = 2;
      ctx.stroke();

      // Arrow
      const ax = x2 - 28;
      ctx.beginPath();
      ctx.moveTo(ax, cy - 5); ctx.lineTo(ax + 8, cy); ctx.lineTo(ax, cy + 5);
      ctx.strokeStyle = c2;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // Particle on this segment
      const pPos = (flowAnim + i * 0.2) % 1;
      const px = x1 + 28 + (x2 - 28 - x1 - 28) * pPos;
      ctx.beginPath();
      ctx.arc(px, cy, 4, 0, Math.PI * 2);
      ctx.fillStyle = arch.colors[i];
      ctx.shadowColor = arch.colors[i];
      ctx.shadowBlur = 10;
      ctx.fill();
      ctx.shadowBlur = 0;
    }

    // Nodes
    arch.chain.forEach((label, i) => {
      const nx = step * (i + 1);
      const R = 26;
      const col = arch.colors[i];

      // Glow
      const grd = ctx.createRadialGradient(nx, cy, 0, nx, cy, R * 2);
      grd.addColorStop(0, hexAlpha2(col, 0.3));
      grd.addColorStop(1, hexAlpha2(col, 0));
      ctx.beginPath(); ctx.arc(nx, cy, R * 2, 0, Math.PI * 2);
      ctx.fillStyle = grd; ctx.fill();

      // Circle
      ctx.beginPath(); ctx.arc(nx, cy, R, 0, Math.PI * 2);
      ctx.fillStyle = '#0a1520'; ctx.fill();
      ctx.strokeStyle = col; ctx.lineWidth = 2.5; ctx.stroke();

      // Label
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 10px Courier New';
      ctx.textAlign = 'center';
      ctx.fillText(label, nx, cy + R + 16);
      ctx.textAlign = 'left';
    });

    // Title
    ctx.fillStyle = arch.colors[0];
    ctx.font = 'bold 13px Courier New';
    ctx.fillText(`[${arch.tag}] Signal Flow`, 16, 22);

    requestAnimationFrame(drawInstall);
  }

  function hexAlpha2(hex, a) {
    if (!hex || hex.length < 7) return `rgba(0,151,157,${a})`;
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return `rgba(${r},${g},${b},${a})`;
  }

  requestAnimationFrame(drawInstall);
})();

