/* ════════════════════════════════════════════════════
   SECTION 9 — GLOSSARY
   ════════════════════════════════════════════════════ */
(function initGlossary(){
  const terms=[
    {term:'dBFS',def:'Decibels relative to Full Scale — digital audio level measurement where 0dBFS is the maximum representable value; all practical levels are negative.'},
    {term:'Dynamic Range',def:'The ratio between the loudest and quietest representable signal. 24-bit audio offers ~144dB theoretical dynamic range vs 96dB for 16-bit.'},
    {term:'Sample Rate',def:'Number of audio samples per second. 44.1kHz (CD), 48kHz (broadcast/video), 96kHz, and 192kHz are standard; higher rates reduce aliasing and enable pitch-shifting.'},
    {term:'Bit Depth',def:'Number of bits per audio sample, determining dynamic range and quantization noise floor. Professional production uses 24-bit or 32-bit floating point.'},
    {term:'Nyquist Theorem',def:'A signal must be sampled at more than twice its highest frequency component to be accurately reconstructed. At 48kHz, the maximum representable frequency is 24kHz.'},
    {term:'Parametric EQ',def:'Filter with adjustable center frequency, gain, and Q (bandwidth). Allows surgical precision compared to fixed graphic equalizers.'},
    {term:'Compressor',def:'Dynamic processor reducing gain when signal exceeds a threshold, controlling transients and evening out performance dynamics.'},
    {term:'Signal-to-Noise Ratio',def:'Ratio of desired signal level to background noise floor. Higher SNR indicates cleaner signal; professional audio targets >90dB SNR.'},
    {term:'Chroma Subsampling',def:'4:4:4 carries full color resolution per pixel; 4:2:2 halves horizontal color; 4:2:0 (used in most consumer video) quarters the color data.'},
    {term:'Color Space',def:'The range of colors representable by a system. BT.709 covers sRGB for HD; BT.2020 covers 75% of visible spectrum for HDR/UHD.'},
    {term:'Log Encoding',def:'Camera-native encoding that preserves detail in highlights and shadows using a logarithmic transfer function (S-Log3, LOG-C, BRAW) for post grading.'},
    {term:'LUT (Look-Up Table)',def:'Mathematical transformation applied to video to convert between color spaces or apply a creative look. Technical LUTs convert log footage to display-referred output.'},
    {term:'SDI',def:'Serial Digital Interface — the professional video standard for uncompressed digital video over 75-ohm coaxial cable at rates from 270Mbps to 12Gbps.'},
    {term:'VU Meter',def:'Volume Unit meter measuring average audio level, traditionally with 300ms ballistic response. Designed to correlate with perceived loudness of audio signals.'},
    {term:'Phantom Power',def:'48V DC supplied down balanced XLR cables to power condenser microphones without an external power supply.'},
    {term:'Gain Staging',def:'Setting appropriate signal levels at each stage of the signal chain to maximize dynamic range and minimize noise and distortion.'},
    {term:'Reference Level',def:'Standard operating level for professional equipment. Broadcast standard is -18dBFS for sine wave; cinema is -20dBFS; music production varies.'},
    {term:'Latency',def:'Delay from input to output through a processing system. Digital audio introduces processing latency; compensation ensures all signals remain aligned.'},
    {term:'AV Sync',def:'Alignment between audio and video signals such that lip movement matches corresponding speech. ITU recommends ±40ms tolerance window.'},
    {term:'Waveform Monitor',def:'Oscilloscope display showing video signal luminance over time — a line scan revealing exposure levels, legal video range, and timing.'},
    {term:'Vectorscope',def:'Polar plot displaying chroma (color saturation and hue) in a circular display, allowing comparison against reference color targets for broadcast compliance.'},
    {term:'Headroom',def:'The margin between the operating level and the maximum level before clipping — preserved to accommodate unexpected peaks without distortion.'}
  ];

  const grid=document.getElementById('gloss-grid');
  terms.forEach(t=>{
    const d=document.createElement('div'); d.className='gloss-item';
    d.innerHTML=`<div class="gloss-term">${t.term}</div><div class="gloss-def">${t.def}</div>`;
    grid.appendChild(d);
  });
})();

/* ════════════════════════════════════════════════════
   INTERSECTION OBSERVER
   ════════════════════════════════════════════════════ */
const observer=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target);}});
},{threshold:0.08});
document.querySelectorAll('.hidden').forEach(el=>observer.observe(el));
</script>
