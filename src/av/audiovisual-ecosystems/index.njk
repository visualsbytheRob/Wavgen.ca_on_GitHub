<script>
'use strict';

class LagFilter {
  constructor(init, tau) { this.value = init; this.tau = tau; }
  update(target, dt) {
    const k = 1 - Math.exp(-dt / this.tau);
    this.value += k * (target - this.value);
    return this.value;
  }
}

// ── LagFilter instances (17) ─────────────────────────────────
const lagHeroMX    = new LagFilter(0.5, 0.3);
const lagHeroMY    = new LagFilter(0.5, 0.3);
const lagWaveFreq  = new LagFilter(440, 0.5);
const lagWaveAmp   = new LagFilter(0.7, 0.3);
const lagAudioLv   = new LagFilter(0.8, 0.15);
const lagVideoLv   = new LagFilter(0.8, 0.2);
const lagSyncOff   = new LagFilter(0, 0.3);
const lagColorTemp = new LagFilter(6500, 0.35);
const lagSaturation= new LagFilter(1.0, 0.3);
const lagGamma     = new LagFilter(2.2, 0.3);
const lagEQ_Lo     = new LagFilter(0, 0.2);
const lagEQ_Mid    = new LagFilter(0, 0.2);
const lagEQ_Hi     = new LagFilter(0, 0.2);
const lagCompRatio = new LagFilter(2.0, 0.4);
const lagPA        = new LagFilter(0.7, 0.3);
const lagReverb    = new LagFilter(0.3, 0.4);
const lagTilt      = new LagFilter(-10, 0.35);

function lerp(a,b,t){return a+(b-a)*t;}
function clamp(v,lo,hi){return Math.max(lo,Math.min(hi,v));}
function rand(lo,hi){return lo+Math.random()*(hi-lo);}
function noise21(x,y){const n=Math.sin(x*127.1+y*311.7)*43758.5453;return n-Math.floor(n);}
function fbm(x,y,oct=3){let v=0,a=0.5,f=1;for(let i=0;i<oct;i++){v+=a*(noise21(x*f,y*f)*2-1);a*=0.5;f*=2.1;}return v;}

/* ════════════════════════════════════════════════════
   SECTION 1 — HERO: OSCILLOSCOPE
   ════════════════════════════════════════════════════ */
(function initHero(){
  const canvas=document.getElementById('hero-canvas');
  const ctx=canvas.getContext('2d');
  let W,H; let heroMX=0.5, heroMY=0.5;
  function resize(){W=canvas.parentElement.clientWidth;H=canvas.parentElement.clientHeight;canvas.width=W;canvas.height=H;}
  resize(); window.addEventListener('resize',resize);
  const hero=document.getElementById('hero');
  hero.addEventListener('mousemove',e=>{const r=canvas.getBoundingClientRect();heroMX=(e.clientX-r.left)/r.width;heroMY=(e.clientY-r.top)/r.height;});

  // multiple waveform channels
  const CHANNELS=[
    {freq:220,col:'#00FF88',amp:0.7,phase:0},
    {freq:440,col:'#FFB300',amp:0.5,phase:Math.PI/3},
    {freq:880,col:'#40FF99',amp:0.3,phase:Math.PI/2},
    {freq:1760,col:'rgba(0,255,136,0.3)',amp:0.2,phase:Math.PI/6}
  ];

  let frame=0, lastT=performance.now();
  function drawHero(ts){
    const dt=clamp((ts-lastT)/1000,0,0.05); lastT=ts; frame++;
    const t=ts/1000;
    const smx=lagHeroMX.update(heroMX,dt);
    const smy=lagHeroMY.update(heroMY,dt);

    // phosphor persistence
    ctx.fillStyle='rgba(2,6,2,0.1)'; ctx.fillRect(0,0,W,H);

    // oscilloscope grid
    ctx.strokeStyle='rgba(0,255,136,0.06)'; ctx.lineWidth=1;
    for(let gx=0;gx<W;gx+=W/10){ctx.beginPath();ctx.moveTo(gx,0);ctx.lineTo(gx,H);ctx.stroke();}
    for(let gy=0;gy<H;gy+=H/8){ctx.beginPath();ctx.moveTo(0,gy);ctx.lineTo(W,gy);ctx.stroke();}
    // center crosshair
    ctx.strokeStyle='rgba(0,255,136,0.15)';
    ctx.beginPath();ctx.moveTo(0,H/2);ctx.lineTo(W,H/2);ctx.stroke();
    ctx.beginPath();ctx.moveTo(W/2,0);ctx.lineTo(W/2,H);ctx.stroke();

    // freq driven by cursor X
    const baseFreq=100+smx*1000;
    lagWaveFreq.update(baseFreq,dt);
    lagWaveAmp.update(0.3+(1-smy)*0.5,dt);

    // draw waveform channels
    CHANNELS.forEach((ch,ci)=>{
      const f=ch.freq/440*lagWaveFreq.value/440;
      const amp=(ch.amp*lagWaveAmp.value)*H*0.35;
      const yOff=H/2 + (ci-1.5)*H*0.06;
      ctx.strokeStyle=ch.col; ctx.lineWidth=ci===0?2:1;
      ctx.beginPath();
      for(let x=0;x<W;x++){
        const phase=x/W*Math.PI*2*f*4+t*f*6.28+ch.phase;
        const y=yOff-Math.sin(phase)*amp*(1+0.2*Math.sin(t*0.7+ci));
        x===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
      }
      ctx.stroke();
    });

    // XY Lissajous (top-right corner)
    const lx=W-120, ly=60, lr=50;
    ctx.strokeStyle='rgba(0,255,136,0.15)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.arc(lx,ly,lr,0,Math.PI*2); ctx.stroke();
    ctx.strokeStyle='rgba(0,255,136,0.5)'; ctx.lineWidth=1;
    ctx.beginPath();
    for(let i=0;i<200;i++){
      const tt=i/200*Math.PI*2*3+t*0.3;
      const px=lx+Math.sin(tt*2)*lr;
      const py=ly+Math.sin(tt*3+t)*lr;
      i===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
    }
    ctx.stroke();

    // HUD updates
    document.getElementById('hud-freq').textContent=Math.round(lagWaveFreq.value)+'Hz';
    document.getElementById('hud-level').textContent=(-12+Math.round(lagWaveAmp.value*8))+'dBFS';

    requestAnimationFrame(drawHero);
  }
  requestAnimationFrame(drawHero);
})();

/* ════════════════════════════════════════════════════
   SECTION 2 — SIGNAL CHAIN
   ════════════════════════════════════════════════════ */
(function initChain(){
  const audioStages=['MIC','PREAMP','ADC','DAW','EQ/DYN','LIMITER','DAC','AMP','SPEAKER'];
  const videoStages=['SENSOR','ISP','LOG ENCODE','COLOR GRADE','LUT','CODEC','ROUTER','DISPLAY'];
  const aColors=['#00FF88','#40FF99','#FFB300','#00D4D4','#40A0FF','#FF3040','#FFCC00','#FF9040','#F0FFF4'];
  const vColors=['#FFB300','#FF9040','#FF3040','#CC00FF','#00D4D4','#40A0FF','#60FFFF','#F0FFF4'];

  function buildChain(stageArr, colors, containerId){
    const container=document.getElementById(containerId);
    stageArr.forEach((s,i)=>{
      const box=document.createElement('div'); box.className='chain-box';
      box.style.borderColor=colors[i]+'44'; box.style.color=colors[i];
      box.textContent=s;
      box.addEventListener('mouseenter',()=>{box.style.borderColor=colors[i];box.style.background=colors[i]+'22';});
      box.addEventListener('mouseleave',()=>{box.style.borderColor=colors[i]+'44';box.style.background='';});
      container.appendChild(box);
      if(i<stageArr.length-1){
        const arr=document.createElement('div'); arr.className='chain-arrow'; arr.textContent='→';
        container.appendChild(arr);
      }
    });
  }
  buildChain(audioStages,aColors,'audio-chain');
  buildChain(videoStages,vColors,'video-chain');

  // animated chain canvas
  const canvas=document.getElementById('chain-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  const packets=[];
  let lastC=performance.now();

  function animChain(ts){
    const dt=clamp((ts-lastC)/1000,0,0.05); lastC=ts;
    ctx.fillStyle='rgba(2,6,2,0.2)'; ctx.fillRect(0,0,W,H);
    // two signal lines
    const y1=H*0.35, y2=H*0.65;
    ctx.strokeStyle='rgba(0,255,136,0.15)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(0,y1); ctx.lineTo(W,y1); ctx.stroke();
    ctx.strokeStyle='rgba(255,179,0,0.15)';
    ctx.beginPath(); ctx.moveTo(0,y2); ctx.lineTo(W,y2); ctx.stroke();
    // spawn
    if(Math.random()<0.15){
      packets.push({t:0,speed:0.003+Math.random()*0.007,y:Math.random()<0.5?y1:y2,col:Math.random()<0.5?'#00FF88':'#FFB300',size:rand(2,5)});
    }
    for(let i=packets.length-1;i>=0;i--){
      const p=packets[i]; p.t+=p.speed;
      if(p.t>1){packets.splice(i,1);continue;}
      const px=p.t*W;
      ctx.beginPath(); ctx.arc(px,p.y,p.size,0,Math.PI*2);
      ctx.fillStyle=p.col; ctx.shadowColor=p.col; ctx.shadowBlur=6;
      ctx.fill(); ctx.shadowBlur=0;
    }
    // labels
    ctx.fillStyle='rgba(0,255,136,0.6)'; ctx.font='9px Courier New'; ctx.fillText('AUDIO',4,y1-6);
    ctx.fillStyle='rgba(255,179,0,0.6)'; ctx.fillText('VIDEO',4,y2-6);
    requestAnimationFrame(animChain);
  }
  requestAnimationFrame(animChain);
})();

/* ════════════════════════════════════════════════════
   SECTION 3 — MIXER / VU METERS
   ════════════════════════════════════════════════════ */
(function initMixer(){
  const CH_NAMES=['KICK','SNARE','HAT','BASS','GTR L','GTR R','KEYS','VOX','FX','BUS'];
  const ch_levels=CH_NAMES.map(()=>0.5+Math.random()*0.4);
  const ch_pans=CH_NAMES.map(()=>Math.random()*2-1);
  const ch_filters=CH_NAMES.map(v=>new LagFilter(v,0.15));

  const wrap=document.getElementById('mixer-wrap');
  CH_NAMES.forEach((name,i)=>{
    const div=document.createElement('div'); div.className='mixer-ch';
    div.innerHTML=`
      <div class="mixer-label">${name}</div>
      <div class="fader-track" style="position:relative;">
        <div class="fader-knob" id="fk-${i}" style="bottom:${ch_levels[i]*110}px;"></div>
      </div>
      <div class="meter-track">
        <div class="meter-fill" id="mf-${i}" style="background:#00FF88;height:0;"></div>
      </div>
      <div class="mixer-val" id="mv-${i}">0dB</div>
    `;
    wrap.appendChild(div);
    // simple fader drag
    const fk=div.querySelector('.fader-knob');
    const ft=div.querySelector('.fader-track');
    let dragging=false;
    fk.addEventListener('mousedown',e=>{dragging=true;e.preventDefault();});
    document.addEventListener('mousemove',e=>{
      if(!dragging)return;
      const r=ft.getBoundingClientRect();
      const rel=1-clamp((e.clientY-r.top)/r.height,0,1);
      ch_levels[i]=rel;
    });
    document.addEventListener('mouseup',()=>{dragging=false;});
  });

  // VU meter canvas
  const canvas=document.getElementById('vu-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  let lastMix=performance.now();
  const peakHolds=CH_NAMES.map(()=>0);

  function animMixer(ts){
    const dt=clamp((ts-lastMix)/1000,0,0.05); lastMix=ts;
    const t=ts/1000;
    ctx.fillStyle='rgba(2,6,2,0.4)'; ctx.fillRect(0,0,W,H);

    const chW=W/CH_NAMES.length;
    CH_NAMES.forEach((name,i)=>{
      const level=ch_levels[i];
      const filt=ch_filters[i].update(level,dt);
      // simulate audio signal
      const noise=noise21(i*5.1+t*3,i*2.3)*0.15;
      const sig=clamp(filt+noise,0,1);
      peakHolds[i]=Math.max(peakHolds[i]*0.998,sig);

      const cx=i*chW+chW*0.1;
      const cw=chW*0.8;
      const barH=(H-30)*sig;
      // color: green→yellow→red
      const col=sig<0.6?'#00FF88':sig<0.85?'#FFB300':'#FF3040';
      ctx.fillStyle=col;
      ctx.fillRect(cx,H-30-barH,cw,barH);
      // peak
      const peakY=H-30-(H-30)*peakHolds[i];
      ctx.fillStyle='#FFFFFF'; ctx.fillRect(cx,peakY,cw,2);
      // dBFS label
      const dBFS=Math.round(20*Math.log10(Math.max(sig,0.001)));
      ctx.fillStyle='rgba(192,232,200,0.5)'; ctx.font='8px Courier New';
      ctx.textAlign='center'; ctx.fillText(name,cx+cw/2,H-16);
      ctx.fillText(dBFS+'dB',cx+cw/2,H-6); ctx.textAlign='left';
      // update DOM
      const fkEl=document.getElementById(`fk-${i}`);
      const mfEl=document.getElementById(`mf-${i}`);
      const mvEl=document.getElementById(`mv-${i}`);
      if(fkEl)fkEl.style.bottom=(level*110)+'px';
      if(mfEl){mfEl.style.height=(sig*100)+'%';mfEl.style.background=col;}
      if(mvEl)mvEl.textContent=dBFS+'dB';
    });

    // stereo bus meter
    const busLevel=ch_levels.reduce((a,b)=>a+b,0)/CH_NAMES.length;
    const busH=(H-30)*clamp(busLevel+noise21(t*5,9)*0.1,0,1);
    ctx.fillStyle='rgba(0,255,136,0.2)'; ctx.fillRect(W-4,H-30-busH,4,busH);

    requestAnimationFrame(animMixer);
  }
  requestAnimationFrame(animMixer);
})();

/* ════════════════════════════════════════════════════
   SECTION 4 — PARAMETRIC EQ
   ════════════════════════════════════════════════════ */
(function initEQ(){
  let eqVals={lo:0,lm:0,mid:0,hm:0,hi:0};
  ['lo','lm','mid','hm','hi'].forEach(band=>{
    document.getElementById(`sl-eq${band}`).addEventListener('input',e=>{
      eqVals[band]=parseInt(e.target.value);
      document.getElementById(`vl-eq${band}`).textContent=(eqVals[band]>=0?'+':'')+eqVals[band]+'dB';
    });
  });

  const eqC=document.getElementById('eq-canvas');
  const specC=document.getElementById('spectrum-canvas');
  const eCtx=eqC.getContext('2d');
  const sCtx=specC.getContext('2d');
  const EW=eqC.width, EH=eqC.height;
  const SW=specC.width, SH=specC.height;

  const FREQS=[60,80,100,150,200,250,400,500,1000,2000,4000,6000,8000,12000,16000,20000];
  const CENTER_FREQS=[80,250,1000,4000,12000];

  function getGain(freq){
    let g=0;
    // shelf at 80Hz
    const dlo=Math.log2(freq/80); g+=eqVals.lo*Math.exp(-dlo*dlo*2);
    const dlm=Math.log2(freq/250); g+=eqVals.lm*Math.exp(-dlm*dlm*3);
    const dm=Math.log2(freq/1000); g+=eqVals.mid*Math.exp(-dm*dm*2.5);
    const dhm=Math.log2(freq/4000); g+=eqVals.hm*Math.exp(-dhm*dhm*3);
    const dhi=Math.log2(freq/12000); g+=eqVals.hi*Math.exp(-dhi*dhi*2);
    return g;
  }

  // EQ curve
  const SPEC_HISTORY=new Float32Array(FREQS.length*4).fill(0);
  let lastEQ=performance.now();

  function animEQ(ts){
    const dt=clamp((ts-lastEQ)/1000,0,0.05); lastEQ=ts;
    const t=ts/1000;
    const slo=lagEQ_Lo.update(eqVals.lo,dt);
    const smid=lagEQ_Mid.update(eqVals.mid,dt);
    const shi=lagEQ_Hi.update(eqVals.hi,dt);

    // EQ curve canvas
    eCtx.fillStyle='rgba(2,6,2,0.3)'; eCtx.fillRect(0,0,EW,EH);
    eCtx.strokeStyle='rgba(0,255,136,0.08)'; eCtx.lineWidth=1;
    // grid
    [0.25,0.5,0.75].forEach(y=>{eCtx.beginPath();eCtx.moveTo(0,y*EH);eCtx.lineTo(EW,y*EH);eCtx.stroke();});
    [0.1,0.3,0.5,0.7,0.9].forEach(x=>{eCtx.beginPath();eCtx.moveTo(x*EW,0);eCtx.lineTo(x*EW,EH);eCtx.stroke();});
    // 0dB line
    eCtx.strokeStyle='rgba(0,255,136,0.2)'; eCtx.lineWidth=1;
    eCtx.beginPath();eCtx.moveTo(0,EH/2);eCtx.lineTo(EW,EH/2);eCtx.stroke();
    // curve
    eCtx.strokeStyle='#00FF88'; eCtx.lineWidth=2;
    eCtx.beginPath();
    const minF=20,maxF=20000;
    for(let x=0;x<EW;x++){
      const logF=Math.pow(10,Math.log10(minF)+(Math.log10(maxF)-Math.log10(minF))*(x/EW));
      const gain=getGain(logF);
      const y=EH/2-gain*(EH/30);
      x===0?eCtx.moveTo(x,y):eCtx.lineTo(x,y);
    }
    eCtx.stroke();
    // labels
    ['20','100','1k','10k','20k'].forEach((lbl,i)=>{
      const logPos=i/4;
      eCtx.fillStyle='rgba(42,74,48,0.8)'; eCtx.font='8px Courier New';
      eCtx.fillText(lbl,Math.round(logPos*EW)+2,EH-4);
    });
    ['+12','+6','0','-6','-12'].forEach((lbl,i)=>{
      eCtx.fillStyle='rgba(42,74,48,0.8)'; eCtx.font='8px Courier New';
      eCtx.fillText(lbl,2,(i/4)*EH+4);
    });

    // spectrum analyzer
    sCtx.fillStyle='rgba(2,6,2,0.2)'; sCtx.fillRect(0,0,SW,SH);
    sCtx.strokeStyle='rgba(0,255,136,0.06)'; sCtx.lineWidth=1;
    [0.25,0.5,0.75].forEach(y=>{sCtx.beginPath();sCtx.moveTo(0,y*SH);sCtx.lineTo(SW,y*SH);sCtx.stroke();});

    const N_BARS=64;
    for(let i=0;i<N_BARS;i++){
      const logF=Math.pow(10,Math.log10(20)+(Math.log10(20000)-Math.log10(20))*(i/N_BARS));
      const baseLevel=0.4+noise21(i*0.3,t*0.5)*0.3+noise21(i*0.7,t*0.3)*0.15;
      const eqG=getGain(logF)/12;
      const level=clamp(baseLevel+eqG,0,1);
      const bx=i/N_BARS*SW, bw=SW/N_BARS-1;
      const bh=level*(SH-10);
      const col=level<0.6?'#00FF88':level<0.85?'#FFB300':'#FF3040';
      sCtx.fillStyle=col;
      sCtx.fillRect(bx,SH-bh,bw,bh);
    }

    requestAnimationFrame(animEQ);
  }
  requestAnimationFrame(animEQ);
})();

/* ════════════════════════════════════════════════════
   SECTION 5 — VIDEO SIGNAL
   ════════════════════════════════════════════════════ */
(function initVideo(){
  const canvas=document.getElementById('video-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  let ctTemp=6500, satTarget=1.0, gammaTarget=2.2;

  document.getElementById('sl-colortemp').addEventListener('input',e=>{
    ctTemp=parseInt(e.target.value);
    document.getElementById('vl-colortemp').textContent=ctTemp+'K';
  });
  document.getElementById('sl-sat').addEventListener('input',e=>{
    satTarget=e.target.value/100;
    document.getElementById('vl-sat').textContent=satTarget.toFixed(2);
  });
  document.getElementById('sl-gamma').addEventListener('input',e=>{
    gammaTarget=e.target.value/10;
    document.getElementById('vl-gamma').textContent=gammaTarget.toFixed(1);
  });

  let lastV=performance.now();
  function animVideo(ts){
    const dt=clamp((ts-lastV)/1000,0,0.05); lastV=ts;
    const t=ts/1000;
    const ct=lagColorTemp.update(ctTemp,dt);
    const sat=lagSaturation.update(satTarget,dt);
    const gam=lagGamma.update(gammaTarget,dt);

    ctx.fillStyle='#040A04'; ctx.fillRect(0,0,W,H);

    // waveform monitor (left half)
    const wmW=W/2-20, wmH=H-20, wmX=10, wmY=10;
    ctx.fillStyle='#020602'; ctx.fillRect(wmX,wmY,wmW,wmH);
    ctx.strokeStyle='rgba(0,255,136,0.1)'; ctx.lineWidth=1;
    [0.25,0.5,0.75,1.0].forEach(y=>{
      const py=wmY+wmH*(1-y);
      ctx.beginPath(); ctx.moveTo(wmX,py); ctx.lineTo(wmX+wmW,py); ctx.stroke();
      ctx.fillStyle='rgba(0,255,136,0.3)'; ctx.font='8px Courier New';
      ctx.fillText(Math.round(y*100)+'%',wmX+2,py-2);
    });

    // draw waveform trace
    ctx.strokeStyle='rgba(0,255,136,0.7)'; ctx.lineWidth=1;
    ctx.beginPath();
    for(let x=0;x<wmW;x++){
      const luma=0.5+fbm(x/wmW*5+t*0.1,0)*0.35;
      const py=wmY+wmH*(1-Math.pow(luma,1/gam));
      x===0?ctx.moveTo(wmX+x,py):ctx.lineTo(wmX+x,py);
    }
    ctx.stroke();
    ctx.fillStyle='rgba(0,255,136,0.6)'; ctx.font='9px Courier New'; ctx.textAlign='center';
    ctx.fillText('WAVEFORM MONITOR',wmX+wmW/2,wmY+wmH+16); ctx.textAlign='left';

    // vectorscope (right half) — color wheel
    const vsR=Math.min(wmH,W/2-40)*0.42;
    const vsCX=W/2+20+vsR+10, vsCY=wmY+wmH/2;
    ctx.fillStyle='#020602';
    ctx.beginPath(); ctx.arc(vsCX,vsCY,vsR+5,0,Math.PI*2); ctx.fill();
    // color targets
    const colorTargets=[
      {name:'R',a:-60/180*Math.PI,r:vsR*0.88,col:'#FF3040'},
      {name:'G',a:180/180*Math.PI,r:vsR*0.88,col:'#00FF88'},
      {name:'B',a:60/180*Math.PI,r:vsR*0.88,col:'#40A0FF'},
      {name:'Cy',a:(-60+180)/180*Math.PI,r:vsR*0.88,col:'#00D4D4'},
      {name:'Mg',a:(60+180)/180*Math.PI,r:vsR*0.88,col:'#CC00FF'},
      {name:'Ye',a:0,r:vsR*0.88,col:'#FFB300'}
    ];
    colorTargets.forEach(t2=>{
      const tx=vsCX+Math.cos(t2.a)*t2.r, ty=vsCY+Math.sin(t2.a)*t2.r;
      ctx.strokeStyle=t2.col; ctx.lineWidth=1.5;
      ctx.strokeRect(tx-5,ty-5,10,10);
      ctx.fillStyle=t2.col; ctx.font='8px Courier New'; ctx.textAlign='center';
      ctx.fillText(t2.name,tx,ty-8);
    });

    // scatter dots
    for(let i=0;i<60;i++){
      const ang=noise21(i*3.1+t*0.1,i*1.7)*Math.PI*2;
      const r2=noise21(i*5.3,i*2.9+t*0.05)*vsR*sat*0.85;
      ctx.beginPath(); ctx.arc(vsCX+Math.cos(ang)*r2,vsCY+Math.sin(ang)*r2,2,0,Math.PI*2);
      // color-temp tint
      const warm=clamp((ct-5000)/5000,0,1);
      ctx.fillStyle=`rgba(${Math.round(lerp(150,255,warm))},${Math.round(lerp(255,200,warm))},${Math.round(lerp(255,150,warm))},0.6)`;
      ctx.fill();
    }
    ctx.textAlign='center'; ctx.fillStyle='rgba(0,255,136,0.6)'; ctx.font='9px Courier New';
    ctx.fillText('VECTORSCOPE',vsCX,vsCY+vsR+16); ctx.textAlign='left';

    // info strip
    ctx.fillStyle='rgba(0,255,136,0.5)'; ctx.font='10px Courier New';
    ctx.fillText(`COLOR TEMP: ${Math.round(ct)}K  SAT: ${sat.toFixed(2)}  γ: ${gam.toFixed(1)}`,10,H-4);

    requestAnimationFrame(animVideo);
  }
  requestAnimationFrame(animVideo);
})();

/* ════════════════════════════════════════════════════
   SECTION 6 — A/V SYNC
   ════════════════════════════════════════════════════ */
(function initAVSync(){
  const canvas=document.getElementById('sync-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  let offsetTarget=0;

  document.getElementById('sl-offset').addEventListener('input',e=>{
    offsetTarget=parseInt(e.target.value);
    document.getElementById('vl-offset').textContent=offsetTarget+'ms';
  });

  const AUDIO_HIST=new Float32Array(W).fill(0);
  const VIDEO_HIST=new Float32Array(W).fill(0);
  let lastSync=performance.now();

  function animSync(ts){
    const dt=clamp((ts-lastSync)/1000,0,0.05); lastSync=ts;
    const t=ts/1000;
    const offset=lagSyncOff.update(offsetTarget,dt)*0.001;

    ctx.fillStyle='rgba(2,6,2,0.2)'; ctx.fillRect(0,0,W,H);

    // zero line
    ctx.strokeStyle='rgba(0,255,136,0.08)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(0,H/2); ctx.lineTo(W,H/2); ctx.stroke();

    // generate signals
    const audioVal=Math.sign(Math.sin(t*6.28*2))*(0.7+noise21(t*3,1)*0.2);
    const videoVal=Math.sign(Math.sin((t+offset)*6.28*2))*(0.7+noise21(t*3,2)*0.2);
    AUDIO_HIST.copyWithin(0,1); AUDIO_HIST[W-1]=audioVal;
    VIDEO_HIST.copyWithin(0,1); VIDEO_HIST[W-1]=videoVal;

    // draw audio
    ctx.strokeStyle='#00FF88'; ctx.lineWidth=1.5;
    ctx.beginPath();
    AUDIO_HIST.forEach((v,x)=>{ const y=H/2-v*(H*0.35); x===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
    ctx.stroke();
    // draw video
    ctx.strokeStyle='#FFB300'; ctx.lineWidth=1.5;
    ctx.beginPath();
    VIDEO_HIST.forEach((v,x)=>{ const y=H/2-v*(H*0.28); x===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
    ctx.stroke();

    // sync indicator
    const absOff=Math.abs(offsetTarget);
    const syncCol=absOff<45?'#00FF88':absOff<125?'#FFB300':'#FF3040';
    ctx.fillStyle=syncCol; ctx.font='11px Courier New';
    ctx.fillText(`OFFSET: ${offsetTarget}ms — ${absOff<45?'SYNC OK':absOff<125?'MARGINAL':'OUT OF SYNC'}`,12,20);

    requestAnimationFrame(animSync);
  }
  requestAnimationFrame(animSync);
})();

/* ════════════════════════════════════════════════════
   SECTION 7 — PA / ROOM ACOUSTICS
   ════════════════════════════════════════════════════ */
(function initPA(){
  const roomC=document.getElementById('room-canvas');
  const splC=document.getElementById('spl-canvas');
  const rCtx=roomC.getContext('2d');
  const sCtx2=splC.getContext('2d');
  const W=roomC.width, H=roomC.height;
  let mx=W/2, my=H*0.1, tiltTarget=-10;

  document.getElementById('sl-tilt').addEventListener('input',e=>{
    tiltTarget=parseInt(e.target.value);
    document.getElementById('vl-tilt').textContent=tiltTarget+'°';
  });
  document.getElementById('sl-subdel').addEventListener('input',e=>{
    document.getElementById('vl-subdel').textContent=e.target.value+'ms';
  });
  roomC.addEventListener('mousemove',e=>{
    const r=roomC.getBoundingClientRect();
    mx=(e.clientX-r.left)/roomC.clientWidth*W;
    my=(e.clientY-r.top)/roomC.clientHeight*H;
  });

  let lastPA=performance.now();
  function animPA(ts){
    const dt=clamp((ts-lastPA)/1000,0,0.05); lastPA=ts;
    const t=ts/1000;
    const tilt=lagTilt.update(tiltTarget,dt)*Math.PI/180;

    // room canvas
    rCtx.fillStyle='rgba(2,6,2,0.3)'; rCtx.fillRect(0,0,W,H);
    // room outline
    rCtx.strokeStyle='rgba(0,255,136,0.2)'; rCtx.lineWidth=1.5;
    rCtx.strokeRect(20,20,W-40,H-40);
    // stage
    rCtx.fillStyle='rgba(0,255,136,0.15)'; rCtx.fillRect(20,20,W-40,40);
    rCtx.fillStyle='rgba(0,255,136,0.5)'; rCtx.font='9px Courier New'; rCtx.textAlign='center';
    rCtx.fillText('STAGE',W/2,38);

    // line array (cursor-positioned)
    const arrayX=mx, arrayY=my;
    const ARRAY_H=80, N_BOXES=6;
    const boxH=ARRAY_H/N_BOXES;
    for(let i=0;i<N_BOXES;i++){
      const ay=arrayY+i*boxH-ARRAY_H/2;
      rCtx.fillStyle='rgba(0,212,212,0.3)'; rCtx.fillRect(arrayX-12,ay,24,boxH-1);
      rCtx.strokeStyle='#00D4D4'; rCtx.lineWidth=1; rCtx.strokeRect(arrayX-12,ay,24,boxH-1);
    }

    // coverage beam
    const beamAngle=Math.PI/4+tilt;
    const beamSpread=Math.PI/5;
    rCtx.fillStyle='rgba(0,255,136,0.04)';
    rCtx.beginPath();
    rCtx.moveTo(arrayX,arrayY);
    for(let a=beamAngle-beamSpread;a<=beamAngle+beamSpread;a+=0.05){
      rCtx.lineTo(arrayX+Math.cos(a)*400,arrayY+Math.sin(a)*400);
    }
    rCtx.closePath(); rCtx.fill();
    // beam edge
    rCtx.strokeStyle='rgba(0,255,136,0.15)'; rCtx.lineWidth=1;
    rCtx.beginPath();
    rCtx.moveTo(arrayX,arrayY);
    rCtx.lineTo(arrayX+Math.cos(beamAngle-beamSpread)*400,arrayY+Math.sin(beamAngle-beamSpread)*400);
    rCtx.moveTo(arrayX,arrayY);
    rCtx.lineTo(arrayX+Math.cos(beamAngle+beamSpread)*400,arrayY+Math.sin(beamAngle+beamSpread)*400);
    rCtx.stroke();

    rCtx.textAlign='center';
    rCtx.fillStyle='#00D4D4'; rCtx.font='9px Courier New';
    rCtx.fillText('LINE ARRAY',arrayX,arrayY-ARRAY_H/2-8);

    // SPL coverage map
    const splW=W, splH=H;
    const img=sCtx2.createImageData(splW,splH);
    for(let y=0;y<splH;y+=2){
      for(let x=0;x<splW;x+=2){
        const dx=x-arrayX, dy=y-arrayY;
        const dist=Math.sqrt(dx*dx+dy*dy)+1;
        const ang=Math.atan2(dy,dx);
        const beamGain=Math.max(0,1-Math.abs(ang-beamAngle)/beamSpread);
        const spl=clamp(beamGain*0.8/dist*120,0,1);
        const col=spl>0.7?[255,Math.round(spl*100),0]:spl>0.4?[Math.round(spl*200),255,0]:[0,Math.round(spl*255),100];
        for(let dy2=0;dy2<2;dy2++) for(let dx2=0;dx2<2;dx2++){
          const ii=(y+dy2)*splW+(x+dx2); if(ii>=splW*splH)continue;
          img.data[ii*4]=col[0]; img.data[ii*4+1]=col[1]; img.data[ii*4+2]=col[2]; img.data[ii*4+3]=Math.round(spl*180);
        }
      }
    }
    sCtx2.fillStyle='#040A04'; sCtx2.fillRect(0,0,splW,splH);
    sCtx2.putImageData(img,0,0);
    sCtx2.strokeStyle='rgba(0,255,136,0.2)'; sCtx2.lineWidth=1;
    sCtx2.strokeRect(0,0,splW,splH);
    sCtx2.fillStyle='rgba(0,255,136,0.6)'; sCtx2.font='9px Courier New'; sCtx2.textAlign='center';
    sCtx2.fillText('SPL COVERAGE MAP',splW/2,14); sCtx2.textAlign='left';

    requestAnimationFrame(animPA);
  }
  requestAnimationFrame(animPA);
})();

