    {name:'Derivative (TouchDesigner)',title:'Software Platform',bio:'Toronto-based developers of TouchDesigner, the node-based environment enabling artists to build custom immersive media systems with integrated video, audio, and show control pipelines.',shape:'circle',color:'#FF00CC'},
    {name:'Universal Everything',title:'Moving Image Studio',bio:'Sheffield studio whose looping digital art works — designed for LED facades, museums, and broadcast — are optimized for the technical constraints of large-scale distributed display systems.',shape:'triangle',color:'#FF3040'}
  ];

  const grid=document.getElementById('artists-grid');
  const svgNS='http://www.w3.org/2000/svg';
  artists.forEach(a=>{
    const card=document.createElement('div'); card.className='artist-card';
    const svg=document.createElementNS(svgNS,'svg'); svg.setAttribute('class','artist-avatar'); svg.setAttribute('viewBox','0 0 52 52');
    const S={
      circle:()=>{const c=document.createElementNS(svgNS,'circle');c.setAttribute('cx','26');c.setAttribute('cy','26');c.setAttribute('r','22');c.setAttribute('fill','none');c.setAttribute('stroke',a.color);c.setAttribute('stroke-width','2');const c2=document.createElementNS(svgNS,'circle');c2.setAttribute('cx','26');c2.setAttribute('cy','26');c2.setAttribute('r','11');c2.setAttribute('fill',a.color);c2.setAttribute('opacity','0.3');svg.appendChild(c);svg.appendChild(c2);},
      hex:()=>{const pts=Array.from({length:6},(_,i)=>{const ang=i*Math.PI/3-Math.PI/6;return`${26+22*Math.cos(ang)},${26+22*Math.sin(ang)}`;}).join(' ');const p=document.createElementNS(svgNS,'polygon');p.setAttribute('points',pts);p.setAttribute('fill','none');p.setAttribute('stroke',a.color);p.setAttribute('stroke-width','2');svg.appendChild(p);},
      triangle:()=>{const p=document.createElementNS(svgNS,'polygon');p.setAttribute('points','26,4 48,46 4,46');p.setAttribute('fill','none');p.setAttribute('stroke',a.color);p.setAttribute('stroke-width','2');svg.appendChild(p);},
      diamond:()=>{const p=document.createElementNS(svgNS,'polygon');p.setAttribute('points','26,2 50,26 26,50 2,26');p.setAttribute('fill','none');p.setAttribute('stroke',a.color);p.setAttribute('stroke-width','2');svg.appendChild(p);},
      square:()=>{const r=document.createElementNS(svgNS,'rect');r.setAttribute('x','4');r.setAttribute('y','4');r.setAttribute('width','44');r.setAttribute('height','44');r.setAttribute('fill','none');r.setAttribute('stroke',a.color);r.setAttribute('stroke-width','2');svg.appendChild(r);}
    };
    (S[a.shape]||S.circle)();
    card.innerHTML=`<div class="ph"></div><div class="artist-name">${a.name}</div><div class="artist-title">${a.title}</div><div class="artist-bio">${a.bio}</div>`;
    card.querySelector('.ph').replaceWith(svg); grid.appendChild(card);
  });
})();

/* ════════════════════════════════════════════════════
   SECTION 9 — GLOSSARY
   ════════════════════════════════════════════════════ */
(function initGlossary(){
  const terms=[
    {term:'Media Server',def:'Hardware/software system for real-time video playback, generative rendering, and signal routing in live performance and installation contexts.'},
    {term:'SDI (Serial Digital Interface)',def:'SMPTE standard for digital video transmission over coaxial cable, supporting 270Mbps (SD) to 12Gbps (8K) with embedded audio and timecode.'},
    {term:'NDI (Network Device Interface)',def:'NewTek IP video protocol enabling production-quality video over standard GbE networks with automatic discovery, sub-millisecond latency, and up to 4K resolution.'},
    {term:'Dante',def:'Audinate\'s Layer 3 IP audio networking protocol delivering up to 1024 channels of audio over standard Ethernet with sub-millisecond latency and PTP synchronization.'},
    {term:'ArtNet',def:'Open Ethernet-based DMX/RDM protocol allowing up to 32768 universes of lighting control data over standard IP networks — the most widely deployed lighting control protocol.'},
    {term:'Genlock',def:'Synchronizing the frame start of video devices to a common reference signal (black burst, tri-level sync, or PTP) so all outputs begin frames simultaneously.'},
    {term:'PTP (IEEE 1588)',def:'Precision Time Protocol achieving nanosecond-accurate network synchronization between devices using hardware timestamping — enables frame-accurate distributed rendering.'},
    {term:'Timecode',def:'SMPTE linear timecode encoding hour, minute, second, and frame in audio or embedded video signals as the common reference for multi-channel synchronization.'},
    {term:'LED Processor',def:'Purpose-built hardware (Brompton, Novastar, Absen) that receives video from render nodes and drives LED cabinet data links with calibration, HDR mapping, and failover.'},
    {term:'Warp & Blend',def:'Geometric warp corrects for projector misalignment on non-flat surfaces; edge blend creates seamless overlap zones between adjacent projectors.'},
    {term:'Signal Matrix',def:'Hardware or software crosspoint that routes any video/audio input to any output, enabling flexible topology changes without physical rewiring.'},
    {term:'Tiled Display',def:'Multiple panels or projectors arranged as a unified canvas, requiring bezel compensation, warp alignment, and color uniformity correction software.'},
    {term:'Distributed Rendering',def:'Splitting a render workload across multiple compute nodes each driving a portion of the total output, synchronized via PTP and master-controller scene state.'},
    {term:'Frame Synchronizer',def:'Device that accepts asynchronous video signals and resynchronizes them to a common reference, enabling mixing of sources with different timebases.'},
    {term:'KVM over IP',def:'Keyboard, video, and mouse control over IP networks allowing centralized management of distributed render nodes without physical access to each machine.'},
    {term:'Multiviewer',def:'System compositing multiple video sources onto a single confidence monitor output, used in production for simultaneous monitoring of all channels.'},
    {term:'sACN (E1.31)',def:'Streaming Architecture for Control Networks — ANSI standard for DMX over IP that improves on ArtNet with built-in priority, multicast, and larger universe counts.'},
    {term:'OSC (Open Sound Control)',def:'Network-based messaging protocol designed for real-time show control, parameter automation, and inter-application communication in AV systems.'},
    {term:'Failover',def:'Automatic switching to a redundant source or compute node when the primary fails, maintaining continuous output in high-availability immersive systems.'},
    {term:'EDID (Extended Display Identification)',def:'Metadata standard allowing displays to communicate supported resolutions, refresh rates, and color formats to source devices for automatic configuration.'},
    {term:'Input Latency',def:'Total delay from signal capture to display output, encompassing capture, processing, encoding, network transmission, decoding, and display pipeline stages.'},
    {term:'Pixel Pitch',def:'Center-to-center distance between LED emitters on an LED panel, determining the minimum comfortable viewing distance — smaller pitch requires more emitters per area.'}
  ];

  const grid=document.getElementById('gloss-grid');
  terms.forEach(t=>{
    const d=document.createElement('div'); d.className='gloss-item';
    d.innerHTML=`<div class="gloss-term">${t.term}</div><div class="gloss-def">${t.def}</div>`;
    grid.appendChild(d);
  });
})();

/* ════════════════════════════════════════════════════
   INTERSECTION OBSERVER
   ════════════════════════════════════════════════════ */
const observer=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target);}});
},{threshold:0.08});
document.querySelectorAll('.hidden').forEach(el=>observer.observe(el));
</script>
