(function initNetwork() {
  const canvas=document.getElementById('network-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  let flowTarget=0.65;

  document.getElementById('sl-netflow').addEventListener('input',e=>{
    flowTarget=e.target.value/100;
    document.getElementById('vl-netflow').textContent=flowTarget.toFixed(2);
  });

  const networkNodes=[
    {id:'CORE-SW',x:0.5,y:0.12,col:'#00D4D4',proto:'10GbE Switching',detail:'Core network switch: 10GbE uplinks, IGMP snooping for multicast, 1μs switching latency'},
    {id:'RENDER-1',x:0.2,y:0.35,col:'#60FFFF',proto:'NDI · Spout',detail:'Render node: RTX 4090, 2× 10GbE NICs, 128GB RAM, NVLink bridge'},
    {id:'RENDER-2',x:0.38,y:0.35,col:'#60FFFF',proto:'NDI · Spout',detail:'Render node: RTX 4090, 2× 10GbE NICs, 128GB RAM'},
    {id:'RENDER-3',x:0.62,y:0.35,col:'#60FFFF',proto:'NDI · Spout',detail:'Render node: RTX 3090 Ti, 10GbE NIC, 64GB RAM'},
    {id:'RENDER-4',x:0.80,y:0.35,col:'#60FFFF',proto:'NDI · Spout',detail:'Render node: RTX 3090, 10GbE NIC, 64GB RAM'},
    {id:'AUDIO-SW',x:0.15,y:0.6,col:'#00FF88',proto:'AES67 · Dante',detail:'Dante/AES67 audio switch: PTP grandmaster, 48kHz 24-bit, 64× channels'},
    {id:'ARTNET-GW',x:0.85,y:0.6,col:'#FFCC00',proto:'ArtNet · sACN',detail:'ArtNet/sACN gateway: 64× DMX universes, show control bridge, MIDI/OSC converter'},
    {id:'NDI-ROUTER',x:0.5,y:0.6,col:'#FF9040',proto:'NDI 5 · SRT',detail:'NDI video router: 24× in, 24× out, 4K60 per stream, cloud relay support'},
    {id:'LED-PROC',x:0.25,y:0.85,col:'#F0F8F8',proto:'Dual 10GbE',detail:'LED processor: Brompton Tessera SX40, 40Mpx output, HDR, Genlock'},
    {id:'PROJ-SYS',x:0.5,y:0.85,col:'#F0F8F8',proto:'SDI · HDMI',detail:'Projector system: 4× Christie 3DLP, blend zones, warp correction, 30Klm total'},
    {id:'MON-SYS',x:0.75,y:0.85,col:'#F0F8F8',proto:'HDMI 2.1',detail:'Monitoring system: multiviewer, confidence monitors, director feed, recording'},
    {id:'NTP-PTP',x:0.5,y:0.0+0.05,col:'#FF3040',proto:'PTP / GPS',detail:'Grandmaster clock: GPS-disciplined PTP IEEE 1588, 10ns accuracy, SMPTE ST 2059'}
  ];
  const netEdges=[[0,1],[0,2],[0,3],[0,4],[0,6],[0,7],[0,11],[1,5],[2,7],[3,7],[4,6],[5,8],[7,8],[7,9],[6,10],[0,10],[9,8],[11,0]];

  let activeNetNode=-1;
  canvas.addEventListener('click',e=>{
    const r=canvas.getBoundingClientRect();
    const mx=(e.clientX-r.left)/canvas.clientWidth*W;
    const my=(e.clientY-r.top)/canvas.clientHeight*H;
    let found=-1;
    networkNodes.forEach((n,i)=>{
      const d=Math.sqrt((n.x*W-mx)**2+(n.y*H-my)**2);
      if(d<25)found=i;
    });
    activeNetNode=found;
    const detail=document.getElementById('node-detail');
    if(found>=0){
      const n=networkNodes[found];
      detail.innerHTML=`<span style="color:${n.col}">${n.id}</span> — ${n.proto}<br><span style="color:var(--muted)">${n.detail}</span>`;
    } else {
      detail.textContent='Click a node to inspect protocol details.';
    }
  });

  const netPackets=[];
  let lastNet=performance.now();

  function animNetwork(ts){
    const dt=clamp((ts-lastNet)/1000,0,0.05); lastNet=ts;
    const fSpd=lagNetFlow.update(flowTarget,dt);

    ctx.fillStyle='rgba(2,8,8,0.2)'; ctx.fillRect(0,0,W,H);

    netEdges.forEach(([a,b])=>{
      const na=networkNodes[a],nb=networkNodes[b];
      ctx.strokeStyle='rgba(0,212,212,0.08)'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.moveTo(na.x*W,na.y*H); ctx.lineTo(nb.x*W,nb.y*H); ctx.stroke();
