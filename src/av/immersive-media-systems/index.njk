<script>
'use strict';

class LagFilter {
  constructor(init, tau) { this.value = init; this.tau = tau; }
  update(target, dt) {
    const k = 1 - Math.exp(-dt / this.tau);
    this.value += k * (target - this.value);
    return this.value;
  }
}

// ── LagFilter instances (17) ──────────────────────────────────
const lagHeroMX   = new LagFilter(0.5, 0.3);
const lagHeroMY   = new LagFilter(0.5, 0.3);
const lagNetPulse = new LagFilter(0, 0.5);
const lagSyncOff  = new LagFilter(10, 0.4);
const lagSignalLv = new LagFilter(0.8, 0.2);
const lagCluster  = new LagFilter(0.7, 0.4);
const lagDataFlow = new LagFilter(0.6, 0.3);
const lagLatency  = new LagFilter(8, 0.4);
const lagSync     = new LagFilter(0.99, 0.3);
const lagGenlock  = new LagFilter(0, 0.2);
const lagNDI      = new LagFilter(0.8, 0.2);
const lagBezel    = new LagFilter(8, 0.3);
const lagBlend    = new LagFilter(40, 0.3);
const lagNodes    = new LagFilter(6, 0.5);
const lagLoad     = new LagFilter(0.7, 0.3);
const lagNetFlow  = new LagFilter(0.65, 0.3);
const lagDrift    = new LagFilter(10, 0.4);

function lerp(a,b,t){return a+(b-a)*t;}
function clamp(v,lo,hi){return Math.max(lo,Math.min(hi,v));}
function rand(lo,hi){return lo+Math.random()*(hi-lo);}
function noise21(x,y){const n=Math.sin(x*127.1+y*311.7)*43758.5453;return n-Math.floor(n);}
function fbm(x,y,oct=3){let v=0,a=0.5,f=1;for(let i=0;i<oct;i++){v+=a*(noise21(x*f,y*f)*2-1);a*=0.5;f*=2.1;}return v;}

/* ════════════════════════════════════════════════════
   SECTION 1 — HERO: NETWORK GRAPH
   ════════════════════════════════════════════════════ */
(function initHero() {
  const canvas=document.getElementById('hero-canvas');
  const ctx=canvas.getContext('2d');
  let W,H,heroMX=0.5,heroMY=0.5;
  function resize(){W=canvas.parentElement.clientWidth;H=canvas.parentElement.clientHeight;canvas.width=W;canvas.height=H;}
  resize(); window.addEventListener('resize',resize);
  const hero=document.getElementById('hero');
  hero.addEventListener('mousemove',e=>{const r=canvas.getBoundingClientRect();heroMX=(e.clientX-r.left)/r.width;heroMY=(e.clientY-r.top)/r.height;});

  // network topology nodes
  function buildNodes() {
    const types=['MASTER','RENDER','RENDER','RENDER','RENDER','RENDER','SWITCH','SWITCH','DISPLAY','DISPLAY','DISPLAY','DISPLAY','DISPLAY','DISPLAY','DISPLAY','DISPLAY','NTP','ROUTER','AUDIO','CONTROL','SENSOR','SENSOR'];
    const cols={'MASTER':'#00D4D4','RENDER':'#60FFFF','SWITCH':'#FF9040','DISPLAY':'#F0F8F8','NTP':'#FF3040','ROUTER':'#FFCC00','AUDIO':'#00FF88','CONTROL':'#CC00FF','SENSOR':'#8080FF'};
    return types.map((type,i)=>({
      type,col:cols[type],
      x:rand(0.08,0.92), y:rand(0.12,0.88),
      vx:(Math.random()-0.5)*0.0003, vy:(Math.random()-0.5)*0.0003,
      r:type==='MASTER'?10:type==='SWITCH'?8:type==='DISPLAY'?6:5,
      phase:Math.random()*Math.PI*2,
      id:i
    }));
  }
  const nodes=buildNodes();
  // edges
  const master=nodes.findIndex(n=>n.type==='MASTER');
  const switches=nodes.reduce((a,n,i)=>n.type==='SWITCH'?[...a,i]:a,[]);
  const edges=[];
  nodes.forEach((n,i)=>{
    if(i===master)return;
    if(n.type==='RENDER') edges.push([master,i]);
    else if(n.type==='DISPLAY') edges.push([switches[Math.floor(Math.random()*switches.length)],i]);
    else if(n.type==='SWITCH') edges.push([master,i]);
    else edges.push([master,i]);
  });

  // data packets on edges
  const packets=[];
  function spawnPacket(){
    if(packets.length>60)return;
    const edge=edges[Math.floor(Math.random()*edges.length)];
    packets.push({edge,t:0,speed:0.005+Math.random()*0.015,dir:Math.random()<0.5?1:-1});
  }

  let frame=0, lastT=performance.now();
  function drawHero(ts){
    const dt=clamp((ts-lastT)/1000,0,0.05); lastT=ts; frame++;
    const smx=lagHeroMX.update(heroMX,dt);
    const smy=lagHeroMY.update(heroMY,dt);

    ctx.fillStyle='rgba(2,8,8,0.12)'; ctx.fillRect(0,0,W,H);

    // update node positions (float)
    nodes.forEach(n=>{
      n.x+=n.vx; n.y+=n.vy;
      if(n.x<0.05||n.x>0.95)n.vx*=-1;
      if(n.y<0.08||n.y>0.92)n.vy*=-1;
      // mouse repulsion
      const dx=n.x-smx, dy=n.y-smy;
      const d=Math.sqrt(dx*dx+dy*dy)+0.01;
      if(d<0.15){n.x+=dx/d*0.0008;n.y+=dy/d*0.0008;}
    });

    // draw edges
    edges.forEach(([a,b])=>{
      const na=nodes[a],nb=nodes[b];
      ctx.strokeStyle='rgba(0,212,212,0.08)'; ctx.lineWidth=0.7;
      ctx.beginPath();
      ctx.moveTo(na.x*W,na.y*H);
      ctx.lineTo(nb.x*W,nb.y*H);
      ctx.stroke();
    });

    // spawn packets
    if(frame%3===0)spawnPacket();
    // update + draw packets
    for(let i=packets.length-1;i>=0;i--){
      const p=packets[i];
      p.t+=p.speed;
      if(p.t>1||p.t<0){packets.splice(i,1);continue;}
      const [a,b]=p.edge;
      const t2=p.dir>0?p.t:1-p.t;
      const px=lerp(nodes[a].x,nodes[b].x,t2)*W;
      const py=lerp(nodes[a].y,nodes[b].y,t2)*H;
      ctx.beginPath(); ctx.arc(px,py,2,0,Math.PI*2);
      ctx.fillStyle='rgba(0,212,212,0.7)'; ctx.fill();
    }

    // draw nodes
    nodes.forEach((n,i)=>{
      const nx=n.x*W, ny=n.y*H;
      const pulse=0.5+0.5*Math.sin(ts/1000*2+n.phase);
      ctx.beginPath(); ctx.arc(nx,ny,n.r+pulse*2,0,Math.PI*2);
      ctx.fillStyle=n.col+'22'; ctx.fill();
      ctx.beginPath(); ctx.arc(nx,ny,n.r,0,Math.PI*2);
      ctx.fillStyle=n.col; ctx.shadowColor=n.col; ctx.shadowBlur=8;
      ctx.fill(); ctx.shadowBlur=0;
      if(n.type==='MASTER'||n.type==='SWITCH'){
        ctx.fillStyle='rgba(240,248,248,0.6)'; ctx.font='8px Courier New';
        ctx.textAlign='center'; ctx.fillText(n.type,nx,ny+n.r+12); ctx.textAlign='left';
      }
    });

    document.getElementById('hud-nodes').textContent=nodes.length;
    document.getElementById('hud-sync').textContent='±'+lagDrift.update(10,dt).toFixed(1)+'μs';
    requestAnimationFrame(drawHero);
  }
  requestAnimationFrame(drawHero);
})();

/* ════════════════════════════════════════════════════
   SECTION 2 — SIGNAL FLOW
   ════════════════════════════════════════════════════ */
(function initSignal() {
  const canvas=document.getElementById('signal-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  let flowTarget=0.6;

  document.getElementById('sl-dataflow').addEventListener('input',e=>{
    flowTarget=e.target.value/100;
    document.getElementById('vl-dataflow').textContent=flowTarget.toFixed(2);
  });

  const INPUTS=['CAM 1','CAM 2','PC OUT','GENERATOR','PLAYBACK','SENSOR'];
  const OUTPUTS=['DISP A','DISP B','DISP C','RECORD','STREAM','MONITOR'];
  const N_IN=INPUTS.length, N_OUT=OUTPUTS.length;

  // routing matrix
  const routing=Array.from({length:N_IN},()=>Array.from({length:N_OUT},()=>Math.random()<0.3));
  routing[0][0]=routing[0][3]=routing[2][4]=routing[4][1]=routing[4][2]=true;

  // build matrix HTML
  const container=document.getElementById('matrix-container');
  const table=document.createElement('div');
  table.style.display='grid';
  table.style.gridTemplateColumns=`80px repeat(${N_OUT},1fr)`;
  table.style.gap='2px';
  // header
  table.innerHTML=`<div style="height:28px"></div>`;
  OUTPUTS.forEach(o=>{
    const d=document.createElement('div');
    d.style.cssText='font-size:0.55rem;color:var(--cyan);letter-spacing:0.1em;text-align:center;text-transform:uppercase;padding:4px 0;';
    d.textContent=o; table.appendChild(d);
  });
  INPUTS.forEach((inp,i)=>{
    const label=document.createElement('div');
    label.style.cssText='font-size:0.55rem;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;display:flex;align-items:center;padding:0 4px;';
    label.textContent=inp; table.appendChild(label);
    OUTPUTS.forEach((_,j)=>{
      const cell=document.createElement('div');
      cell.className='matrix-cell '+(routing[i][j]?'active':'off');
      cell.textContent=routing[i][j]?'●':'○';
      cell.addEventListener('click',()=>{routing[i][j]=!routing[i][j];cell.className='matrix-cell '+(routing[i][j]?'active':'off');cell.textContent=routing[i][j]?'●':'○';});
      table.appendChild(cell);
    });
  });
  container.appendChild(table);

  // animated signal flow canvas
  const inX=100, outX=W-80;
  const inYs=INPUTS.map((_,i)=>H*(0.15+i*0.13));
  const outYs=OUTPUTS.map((_,j)=>H*(0.15+j*0.13));

  const packets2=[];
  let lastSig=performance.now();
  function animSignal(ts){
    const dt=clamp((ts-lastSig)/1000,0,0.05); lastSig=ts;
    const fSpd=lagDataFlow.update(flowTarget,dt);

    ctx.fillStyle='rgba(2,8,8,0.25)'; ctx.fillRect(0,0,W,H);

    // draw input labels
    INPUTS.forEach((inp,i)=>{
      ctx.fillStyle='rgba(0,212,212,0.6)'; ctx.font='10px Courier New';
      ctx.textAlign='right'; ctx.fillText(inp,inX-8,inYs[i]+4);
      ctx.beginPath(); ctx.arc(inX,inYs[i],5,0,Math.PI*2); ctx.fillStyle='var(--cyan)'; ctx.fill();
    });
    OUTPUTS.forEach((out,j)=>{
      ctx.fillStyle='rgba(240,248,248,0.6)'; ctx.font='10px Courier New';
      ctx.textAlign='left'; ctx.fillText(out,outX+10,outYs[j]+4);
      ctx.beginPath(); ctx.arc(outX,outYs[j],5,0,Math.PI*2); ctx.fillStyle='var(--white)'; ctx.fill();
    });
    ctx.textAlign='left';

    // draw active routes
    routing.forEach((row,i)=>row.forEach((active,j)=>{
      if(!active)return;
      const cpX=(inX+outX)/2;
      ctx.strokeStyle='rgba(0,212,212,0.12)'; ctx.lineWidth=1;
      ctx.beginPath();
      ctx.moveTo(inX,inYs[i]);
      ctx.bezierCurveTo(cpX,inYs[i],cpX,outYs[j],outX,outYs[j]);
      ctx.stroke();
    }));

    // spawn packets on active routes
    if(Math.random()<fSpd*0.3){
      routing.forEach((row,i)=>row.forEach((active,j)=>{
        if(active&&Math.random()<0.04){
          packets2.push({i,j,t:0,speed:0.008+Math.random()*0.012*fSpd});
        }
      }));
    }

    // update + draw packets
    for(let p=packets2.length-1;p>=0;p--){
      const pk=packets2[p];
      pk.t+=pk.speed;
      if(pk.t>=1){packets2.splice(p,1);continue;}
      const cpX=(inX+outX)/2;
      // cubic bezier position
      const t=pk.t, mt=1-t;
      const x=mt*mt*mt*inX+3*mt*mt*t*cpX+3*mt*t*t*cpX+t*t*t*outX;
      const y=mt*mt*mt*inYs[pk.i]+3*mt*mt*t*inYs[pk.i]+3*mt*t*t*outYs[pk.j]+t*t*t*outYs[pk.j];
      ctx.beginPath(); ctx.arc(x,y,3,0,Math.PI*2);
      ctx.fillStyle='rgba(0,212,212,0.9)'; ctx.shadowColor='#00D4D4'; ctx.shadowBlur=6;
      ctx.fill(); ctx.shadowBlur=0;
    }

    requestAnimationFrame(animSignal);
  }
  requestAnimationFrame(animSignal);
})();

/* ════════════════════════════════════════════════════
   SECTION 3 — TILED DISPLAY WALL
   ════════════════════════════════════════════════════ */
(function initTile() {
  const canvas=document.getElementById('tile-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  let cols=4, rows=2, bezelTarget=8, blendTarget=40;

  document.querySelectorAll('.tile-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      document.querySelectorAll('.tile-btn').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      cols=parseInt(btn.dataset.cols); rows=parseInt(btn.dataset.rows);
    });
  });
  document.getElementById('sl-bezel').addEventListener('input',e=>{
    bezelTarget=parseInt(e.target.value);
    document.getElementById('vl-bezel').textContent=bezelTarget+'px';
  });
  document.getElementById('sl-blend').addEventListener('input',e=>{
    blendTarget=parseInt(e.target.value);
    document.getElementById('vl-blend').textContent=blendTarget+'px';
  });

  let lastTile=performance.now();
  function animTile(ts){
    const dt=clamp((ts-lastTile)/1000,0,0.05); lastTile=ts;
    const t=ts/1000;
    const bezel=lagBezel.update(bezelTarget,dt);
    const blend=lagBlend.update(blendTarget,dt);

    ctx.fillStyle='#020808'; ctx.fillRect(0,0,W,H);

    const margin=30;
    const wallW=W-margin*2, wallH=H-margin*2;
    const tileW=(wallW-(cols-1)*bezel)/cols;
    const tileH=(wallH-(rows-1)*bezel)/rows;

    // draw tiles
    for(let r=0;r<rows;r++){
      for(let c=0;c<cols;c++){
        const tx=margin+c*(tileW+bezel);
        const ty=margin+r*(tileH+bezel);
        // content: animated noise/gradient
        const img=ctx.createImageData(Math.round(tileW),Math.round(tileH));
        const tw=Math.round(tileW), th=Math.round(tileH);
        for(let y=0;y<th;y+=2){
          for(let x=0;x<tw;x+=2){
            // full-wall coordinates
            const wx=(tx+x-margin)/(wallW);
            const wy=(ty+y-margin)/(wallH);
            const n=fbm(wx*3+t*0.1,wy*3+t*0.08)*0.5+0.5;
            const n2=fbm(wx*6-t*0.06,wy*6+t*0.07)*0.3+0.5;
            // blend edge darkening
            const edgeX=Math.min(x,tw-x)/Math.max(blend,1);
            const edgeY=Math.min(y,th-y)/Math.max(blend,1);
            const edgeFactor=clamp(Math.min(edgeX,edgeY),0,1);
            const r2=Math.round(n*20*edgeFactor);
            const g2=Math.round(n2*180*edgeFactor+n*40*edgeFactor);
            const b2=Math.round(n*180*edgeFactor);
            for(let dy=0;dy<2;dy++) for(let dx=0;dx<2;dx++){
              const ii=(y+dy)*tw+(x+dx); if(ii>=tw*th)continue;
              img.data[ii*4]=r2; img.data[ii*4+1]=g2; img.data[ii*4+2]=b2; img.data[ii*4+3]=255;
            }
          }
        }
        ctx.putImageData(img,tx,ty);
        // tile border
        ctx.strokeStyle='rgba(0,212,212,0.3)'; ctx.lineWidth=1;
        ctx.strokeRect(tx,ty,tileW,tileH);
        // tile label
        ctx.fillStyle='rgba(0,212,212,0.5)'; ctx.font='9px Courier New';
        ctx.fillText(`[${c+1},${r+1}]`,tx+4,ty+12);
      }
    }
    // wall resolution label
    ctx.fillStyle='rgba(240,248,248,0.6)'; ctx.font='11px Courier New'; ctx.textAlign='center';
    ctx.fillText(`${cols}×${rows} DISPLAY WALL · ${cols*3840}×${rows*2160} TOTAL RESOLUTION`,W/2,H-8);
    ctx.textAlign='left';

    requestAnimationFrame(animTile);
  }
  requestAnimationFrame(animTile);
})();

/* ════════════════════════════════════════════════════
   SECTION 4 — RENDER CLUSTER
   ════════════════════════════════════════════════════ */
(function initCluster() {
  const canvas=document.getElementById('cluster-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  let nodeTarget=6, loadTarget=0.7, activeNode=-1;
  let nodeLoads=[];

  document.getElementById('sl-nodes').addEventListener('input',e=>{
    nodeTarget=parseInt(e.target.value);
    document.getElementById('vl-nodes').textContent=nodeTarget;
  });
  document.getElementById('sl-load').addEventListener('input',e=>{
    loadTarget=e.target.value/100;
    document.getElementById('vl-load').textContent=Math.round(e.target.value)+'%';
  });
  canvas.addEventListener('click',e=>{
    const r=canvas.getBoundingClientRect();
    const mx=(e.clientX-r.left)/canvas.clientWidth*W;
    const my=(e.clientY-r.top)/canvas.clientHeight*H;
    nodeLoads.forEach((n,i)=>{
      if(Math.abs(mx-n.x)<40&&Math.abs(my-n.y)<50){activeNode=i;}
    });
  });

  let lastCl=performance.now();
  function animCluster(ts){
    const dt=clamp((ts-lastCl)/1000,0,0.05); lastCl=ts;
    const t=ts/1000;
    const nNodes=Math.round(lagNodes.update(nodeTarget,dt));
    const baseLoad=lagLoad.update(loadTarget,dt);
    lagCluster.update(baseLoad,dt);

    ctx.fillStyle='rgba(2,8,8,0.25)'; ctx.fillRect(0,0,W,H);

    // master node
    const masterX=W/2, masterY=50;
    ctx.beginPath(); ctx.arc(masterX,masterY,20,0,Math.PI*2);
    ctx.fillStyle='rgba(0,212,212,0.2)'; ctx.fill();
    ctx.strokeStyle='#00D4D4'; ctx.lineWidth=2; ctx.stroke();
    ctx.fillStyle='#00D4D4'; ctx.font='9px Courier New'; ctx.textAlign='center';
    ctx.fillText('MASTER',masterX,masterY+4); ctx.textAlign='left';

    // render nodes
    nodeLoads=[];
    for(let i=0;i<nNodes;i++){
      const angle=(i/(nNodes))*Math.PI*2-Math.PI/2;
      const radius=120;
      const nx=masterX+Math.cos(angle)*radius*1.8;
      const ny=masterY+80+Math.sin(angle)*radius*0.6;
      const load=clamp(baseLoad+noise21(i*3.1,t*0.3)*0.25-0.12,0,1);
      const temp=50+load*40;
      nodeLoads.push({x:nx, y:ny, load, temp, idx:i});

      // edge to master
      ctx.strokeStyle=`rgba(0,212,212,${load*0.3})`; ctx.lineWidth=1+load*2;
      ctx.beginPath(); ctx.moveTo(masterX,masterY+20); ctx.lineTo(nx,ny-30); ctx.stroke();

      // GPU bar background
      const barW=70, barH=80;
      const bx=nx-barW/2, by=ny-20;
      ctx.fillStyle='#04060E'; ctx.fillRect(bx,by,barW,barH);
      ctx.strokeStyle=activeNode===i?'#00D4D4':rgba(0,212,212,0.2);
      ctx.lineWidth=activeNode===i?2:1;
      ctx.strokeRect(bx,by,barW,barH);

      // GPU load bar
      const col=load<0.7?'#00D4D4':load<0.9?'#FF9040':'#FF3040';
      ctx.fillStyle=col;
      ctx.fillRect(bx+2,by+barH-2-load*(barH-20),barW-4,load*(barH-20));

      // thermal indicator
      const thermColor=temp<70?'#00FF88':temp<85?'#FF9040':'#FF3040';
      ctx.fillStyle=thermColor; ctx.fillRect(bx,by+barH+2,barW,5);

      // labels
      ctx.fillStyle='rgba(240,248,248,0.7)'; ctx.font='8px Courier New'; ctx.textAlign='center';
      ctx.fillText(`N${i+1}`,nx,by-4);
      ctx.fillText(`${Math.round(load*100)}%`,nx,by+barH-4);
      ctx.fillText(`${Math.round(temp)}°C`,nx,by+barH+16);
      ctx.textAlign='left';
    }

    // network switch in middle
    ctx.beginPath(); ctx.arc(masterX,masterY+80,12,0,Math.PI*2);
    ctx.fillStyle='rgba(255,144,64,0.3)'; ctx.fill();
    ctx.strokeStyle='#FF9040'; ctx.stroke();
    ctx.fillStyle='#FF9040'; ctx.font='7px Courier New'; ctx.textAlign='center';
    ctx.fillText('SW',masterX,masterY+84); ctx.textAlign='left';

    // stats overlay
    const avgLoad=nodeLoads.reduce((a,n)=>a+n.load,0)/Math.max(nodeLoads.length,1);
    ctx.fillStyle='rgba(0,212,212,0.7)'; ctx.font='10px Courier New';
    ctx.fillText(`NODES: ${nNodes}  AVG GPU: ${Math.round(avgLoad*100)}%  OUTPUTS: ${nNodes*2}`,12,H-12);

    requestAnimationFrame(animCluster);
  }
  requestAnimationFrame(animCluster);
})();

function rgba(r,g,b,a){return `rgba(${r},${g},${b},${a})`;}

/* ════════════════════════════════════════════════════
   SECTION 5 — SYNC / GENLOCK
   ════════════════════════════════════════════════════ */
(function initSync() {
  const gc=document.getElementById('genlock-canvas');
  const fc=document.getElementById('frame-canvas');
  const gCtx=gc.getContext('2d'), fCtx=fc.getContext('2d');
  const W=gc.width, H=gc.height;
  let driftTarget=10;

  document.getElementById('sl-drift').addEventListener('input',e=>{
    driftTarget=parseInt(e.target.value);
    document.getElementById('vl-drift').textContent=driftTarget+'μs';
  });

  const CHANNELS=['CH1 MASTER','CH2 NODE-A','CH3 NODE-B','CH4 NODE-C','CH5 NODE-D'];
  const HISTORY=CHANNELS.map(()=>new Float32Array(W).fill(0));
  let lastSync=performance.now();

  function animSync(ts){
    const dt=clamp((ts-lastSync)/1000,0,0.05); lastSync=ts;
    const t=ts/1000;
    const drift=lagDrift.update(driftTarget,dt);

    // genlock canvas: phase comparison
    gCtx.fillStyle='rgba(2,8,8,0.25)'; gCtx.fillRect(0,0,W,H);
    gCtx.strokeStyle='rgba(0,212,212,0.08)'; gCtx.lineWidth=1;
    const freq=2; // Hz display
    const period=W/4;
    // master signal
    gCtx.strokeStyle='rgba(0,212,212,0.9)'; gCtx.lineWidth=2;
    gCtx.beginPath();
    for(let x=0;x<W;x++){
      const phase=(x/period+t*freq)*Math.PI*2;
      const y=H/2-Math.sign(Math.sin(phase))*(H*0.2);
      x===0?gCtx.moveTo(x,y):gCtx.lineTo(x,y);
    }
    gCtx.stroke();
    // synced signal with drift
    gCtx.strokeStyle='rgba(255,144,64,0.7)'; gCtx.lineWidth=1.5;
    const driftPhase=drift/1000000*freq*Math.PI*2;
    gCtx.beginPath();
    for(let x=0;x<W;x++){
      const phase=(x/period+t*freq)*Math.PI*2+driftPhase;
      const y=H*0.3+30-Math.sign(Math.sin(phase))*(H*0.15);
      x===0?gCtx.moveTo(x,y):gCtx.lineTo(x,y);
    }
    gCtx.stroke();

    // drift indicator
    gCtx.fillStyle='#FF9040'; gCtx.font='10px Courier New';
    gCtx.fillText(`DRIFT: ${drift.toFixed(0)}μs`,8,16);
    gCtx.fillStyle='#00D4D4'; gCtx.fillText('MASTER',8,32);
    gCtx.fillStyle='rgba(255,144,64,0.9)'; gCtx.fillText('SLAVE',8,48);

    // frame alignment canvas
    fCtx.fillStyle='rgba(2,8,8,0.25)'; fCtx.fillRect(0,0,W,H);
    const chH=(H-10)/CHANNELS.length-4;

    CHANNELS.forEach((ch,ci)=>{
      const cy=10+ci*(chH+4);
      const driftUs=ci===0?0:(noise21(ci*5.3,t*0.5)*2-1)*drift*0.5;
      const phaseOff=driftUs/1000000*0.2;

      HISTORY[ci].copyWithin(0,1);
      const period2=W*0.15;
      const phase=(t*6.28318/period2+phaseOff)%(Math.PI*2);
      HISTORY[ci][W-1]=Math.sign(Math.sin(phase*10))*0.8;

      fCtx.fillStyle=ci===0?'#00D4D4':'rgba(0,212,212,0.3)';
      fCtx.font='9px Courier New'; fCtx.fillText(ch,4,cy+10);

      fCtx.strokeStyle=ci===0?'#00D4D4':'rgba(0,212,212,0.5)'; fCtx.lineWidth=1.2;
      fCtx.beginPath();
      for(let x=60;x<W-4;x++){
        const v=HISTORY[ci][x];
        const y=cy+chH/2-v*(chH*0.4);
        x===60?fCtx.moveTo(x,y):fCtx.lineTo(x,y);
      }
      fCtx.stroke();

      if(ci>0){
        fCtx.fillStyle='rgba(255,144,64,0.7)'; fCtx.font='8px Courier New';
        fCtx.fillText(`±${Math.abs(driftUs).toFixed(0)}μs`,4,cy+chH-2);
      }
    });

    requestAnimationFrame(animSync);
  }
  requestAnimationFrame(animSync);
})();

