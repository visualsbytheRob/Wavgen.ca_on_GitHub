    // spawn + draw packets
    if(Math.random()<fSpd*0.4){
      const edge=netEdges[Math.floor(Math.random()*netEdges.length)];
      netPackets.push({edge,t:0,speed:0.006+Math.random()*0.012*fSpd,dir:Math.random()<0.5?1:-1});
    }
    for(let i=netPackets.length-1;i>=0;i--){
      const p=netPackets[i]; p.t+=p.speed;
      if(p.t>1||p.t<0){netPackets.splice(i,1);continue;}
      const [a,b]=p.edge;
      const t=p.dir>0?p.t:1-p.t;
      const px=lerp(networkNodes[a].x,networkNodes[b].x,t)*W;
      const py=lerp(networkNodes[a].y,networkNodes[b].y,t)*H;
      ctx.beginPath(); ctx.arc(px,py,2,0,Math.PI*2);
      ctx.fillStyle='rgba(0,212,212,0.8)'; ctx.fill();
    }

    // nodes
    networkNodes.forEach((n,i)=>{
      const nx=n.x*W, ny=n.y*H;
      const isActive=i===activeNetNode;
      ctx.beginPath(); ctx.arc(nx,ny,isActive?18:12,0,Math.PI*2);
      ctx.fillStyle=n.col+(isActive?'44':'22'); ctx.fill();
      ctx.strokeStyle=n.col; ctx.lineWidth=isActive?2:1; ctx.stroke();
      ctx.fillStyle=isActive?'#F0F8F8':n.col;
      ctx.font=isActive?'bold 8px Courier New':'7px Courier New';
      ctx.textAlign='center'; ctx.fillText(n.id,nx,ny+4); ctx.textAlign='left';
    });

    requestAnimationFrame(animNetwork);
  }
  requestAnimationFrame(animNetwork);
})();

