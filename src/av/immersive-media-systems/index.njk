(function initServers() {
  const canvas=document.getElementById('server-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;

  const stages=[
    {label:'CONTENT\nSOURCE',detail:'Video files, live camera, generative GPU',col:'#00D4D4'},
    {label:'MEDIA\nSERVER',detail:'d3/disguise, Green Hippo, Resolume',col:'#60FFFF'},
    {label:'SIGNAL\nROUTER',detail:'SDI matrix, NDI router, KVM',col:'#FF9040'},
    {label:'PROCESSOR',detail:'LED processor, warp/blend, keystone',col:'#00FF88'},
    {label:'OUTPUT\nDEVICE',detail:'LED wall, projector, display panel',col:'#F0F8F8'}
  ];

  let hoveredStage=-1;
  canvas.addEventListener('mousemove',e=>{
    const r=canvas.getBoundingClientRect();
    const mx=(e.clientX-r.left)/canvas.clientWidth*W;
    const stageW=W/stages.length;
    hoveredStage=Math.floor(mx/stageW);
    if(hoveredStage<0||hoveredStage>=stages.length)hoveredStage=-1;
  });
  canvas.addEventListener('mouseleave',()=>{hoveredStage=-1;});

  const SERVERS=[
    {name:'disguise (d3)',features:'Multi-output · Virtual production · Notch FX',platform:'Windows',color:'#00D4D4'},
    {name:'Green Hippo',features:'Hippotizer · SHAPE · MeshMapper',platform:'Windows',color:'#00FF88'},
    {name:'Resolume',features:'Avenue · Arena · Alley',platform:'Win/Mac',color:'#FF9040'},
    {name:'WATCHOUT',features:'Multi-display · Dataton · Sync',platform:'Windows',color:'#60FFFF'},
    {name:'Notch',features:'Real-time generative · VFX · LED',platform:'Windows',color:'#CC00FF'}
  ];

  const serverCards=document.getElementById('server-cards');
  SERVERS.forEach(s=>{
    const card=document.createElement('div');
    card.style.cssText=`background:var(--card-bg);border:1px solid ${s.color}44;border-radius:4px;padding:0.8rem;`;
    card.innerHTML=`
      <div style="font-size:0.7rem;color:${s.color};font-weight:700;letter-spacing:0.1em;margin-bottom:0.3rem;">${s.name}</div>
      <div style="font-size:0.6rem;color:var(--muted);line-height:1.6;">${s.features}</div>
      <div style="font-size:0.58rem;color:${s.color}88;margin-top:0.4rem;letter-spacing:0.1em;">${s.platform}</div>
    `;
    serverCards.appendChild(card);
  });

  // data packets along pipeline
  const pipePackets=[];
  let lastSrv=performance.now();

  function animServers(ts){
    const dt=clamp((ts-lastSrv)/1000,0,0.05); lastSrv=ts;
    const t=ts/1000;
    ctx.fillStyle='rgba(2,8,8,0.25)'; ctx.fillRect(0,0,W,H);

    const stageW=W/stages.length;
    const stageH=H*0.6;
    const stageY=(H-stageH)/2;

    stages.forEach((s,i)=>{
      const sx=i*stageW+stageW*0.1;
      const sw=stageW*0.8;
      const isHov=i===hoveredStage;
      ctx.fillStyle=isHov?s.col+'33':s.col+'11';
      ctx.fillRect(sx,stageY,sw,stageH);
      ctx.strokeStyle=isHov?s.col:s.col+'55'; ctx.lineWidth=isHov?2:1;
      ctx.strokeRect(sx,stageY,sw,stageH);
      // label
      ctx.fillStyle=isHov?s.col:'rgba(192,224,224,0.6)';
      ctx.font=isHov?'bold 11px Courier New':'10px Courier New';
      ctx.textAlign='center';
      s.label.split('\n').forEach((line,li)=>ctx.fillText(line,sx+sw/2,stageY+stageH/2-8+li*14));
      // detail on hover
      if(isHov){
        ctx.font='9px Courier New'; ctx.fillStyle='rgba(192,224,224,0.5)';
        ctx.fillText(s.detail,sx+sw/2,stageY+stageH-10);
      }
      ctx.textAlign='left';
      // connector arrows
      if(i<stages.length-1){
        ctx.strokeStyle='rgba(0,212,212,0.4)'; ctx.lineWidth=1.5;
        const ax=sx+sw, ay=stageY+stageH/2;
        const bx=ax+stageW*0.1;
        ctx.beginPath(); ctx.moveTo(ax,ay); ctx.lineTo(bx,ay); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(bx-5,ay-4); ctx.lineTo(bx,ay); ctx.lineTo(bx-5,ay+4); ctx.stroke();
      }
    });

    // spawn packets
    if(Math.random()<0.08){pipePackets.push({t:0,speed:0.004+Math.random()*0.008,y:stageY+stageH/2+rand(-15,15)});}
    for(let i=pipePackets.length-1;i>=0;i--){
      const p=pipePackets[i]; p.t+=p.speed;
      if(p.t>1){pipePackets.splice(i,1);continue;}
      const px=p.t*W;
      ctx.beginPath(); ctx.arc(px,p.y,3,0,Math.PI*2);
      ctx.fillStyle='rgba(0,212,212,0.8)'; ctx.shadowColor='#00D4D4'; ctx.shadowBlur=5;
      ctx.fill(); ctx.shadowBlur=0;
    }

    requestAnimationFrame(animServers);
  }
  requestAnimationFrame(animServers);
})();

