/* ═══════════════════════════════════════════════════════════
   SECTION 9 — GLOSSARY
   ═══════════════════════════════════════════════════════════ */
(function initGlossary() {
  const terms = [
    { term:'Forward Kinematics', def:'Computing the position of end-effectors by propagating joint angle values from root to leaves through the kinematic chain.' },
    { term:'Inverse Kinematics', def:'Determining joint angles required to place an end-effector at a specified position, solved iteratively (FABRIK, CCD) or analytically.' },
    { term:'FABRIK', def:'Forward And Backward Reaching IK — an efficient iterative solver alternating between forward and backward passes to converge on a joint configuration satisfying the end-effector target.' },
    { term:'BVH Format', def:'Biovision Hierarchy file format encoding skeleton hierarchy and per-frame channel data (position, rotation) in plain text, widely supported in DCC software.' },
    { term:'Motion Retargeting', def:'Adapting a motion capture recording from one skeleton proportions and structure to a different target skeleton while preserving the original motion intent.' },
    { term:'Optical Flow', def:'Per-pixel apparent motion field between video frames, computed using brightness constancy and spatial smoothness. Sparse variants track detected interest points only.' },
    { term:'IMU Sensor Fusion', def:'Combining accelerometer, gyroscope, and magnetometer data via Kalman or complementary filters to estimate orientation with reduced drift.' },
    { term:'Marker Occlusion', def:'Loss of marker visibility due to body self-occlusion or proximity to other markers, requiring gap-filling via interpolation or biomechanical models.' },
    { term:'Root Motion', def:'The global trajectory of the skeleton root joint, typically the pelvis, representing world-space displacement and requiring separate handling from joint-space data.' },
    { term:'Skeletal Hierarchy', def:'Tree structure defining parent-child relationships between joints, allowing transforms to propagate from root to leaves through matrix concatenation.' },
    { term:'Dynamic Time Warping', def:'Algorithm for computing similarity between temporal sequences allowing elastic alignment — used for comparing motion segments of different durations.' },
    { term:'Pose Graph', def:'Graph-based representation of skeletal configurations over time, enabling motion retrieval, interpolation, and blending between similar poses in a database.' },
    { term:'Keyframe Animation', def:'Interpolating between discrete keyframe poses using splines (Bezier, Catmull-Rom) to produce smooth continuous motion without data at every frame.' },
    { term:'Motion Blending', def:'Combining multiple animation clips or poses using weighted linear interpolation, enabling smooth transitions and procedural layering of animations.' },
    { term:'Ground Truth Labeling', def:'Manual annotation of joint positions or gesture labels used to train and evaluate pose estimation models and motion recognition classifiers.' },
    { term:'Temporal Filtering', def:'Smoothing joint trajectories over time using low-pass filters, Savitzky-Golay smoothing, or exponential moving averages to reduce sensor noise.' },
    { term:'Feature Point Detection', def:'Locating stable, repeatable image regions (Harris corners, Shi-Tomasi, FAST) that can be reliably tracked across frames for optical flow computation.' },
    { term:'C3D Format', def:'Binary file format for storing 3D trajectory data, force plate measurements, and EMG signals from motion capture and biomechanics labs.' },
    { term:'Depth Sensing', def:'Per-pixel distance measurement using structured light, time-of-flight, or stereo reconstruction enabling 3D joint position estimation without markers.' },
    { term:'Biomechanical Model', def:'Physics-based representation of the human body as rigid segments connected by joints, enabling constraint-based gap-filling and realistic motion synthesis.' },
    { term:'Latency Compensation', def:'Predictive algorithms that extrapolate joint positions forward in time to counteract sensor-to-display delay in real-time tracking applications.' },
    { term:'Marker Set', def:'The specific configuration of reflective markers placed on a subject for optical motion capture, standardized (Plug-in Gait, Full Body) for lab-to-lab reproducibility.' }
  ];

  const grid = document.getElementById('gloss-grid');
  terms.forEach(t => {
    const d = document.createElement('div');
    d.className = 'gloss-item';
    d.innerHTML = `<div class="gloss-term">${t.term}</div><div class="gloss-def">${t.def}</div>`;
    grid.appendChild(d);
  });
})();

/* ═══════════════════════════════════════════════════════════
   INTERSECTION OBSERVER
   ═══════════════════════════════════════════════════════════ */
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
}, { threshold: 0.08 });
document.querySelectorAll('.hidden').forEach(el => observer.observe(el));
</script>
