// ═══════════════════════════════════════════════════════════════════════════
// SECTION 9: Glossary
// ═══════════════════════════════════════════════════════════════════════════
(function initGlossary() {
  const terms = [
    { term: 'Homography', def: 'A 3×3 projective transformation matrix mapping points between two planar views — the mathematical core of all quad-based projection mapping.' },
    { term: 'Keystone Correction', def: 'Geometric correction of trapezoidal distortion caused by projecting at an oblique angle to a flat surface. Applied via corner pin or full homography warp.' },
    { term: 'Edge Blending', def: 'Luminance falloff at overlapping projector boundaries using gamma-corrected curves to produce seamless seamless single-image multi-projector displays.' },
    { term: 'Gray Code', def: 'A binary encoding scheme used in structured light calibration where adjacent codes differ by only one bit — enabling robust pixel-to-projector correspondence decoding.' },
    { term: 'Warp Mesh', def: 'A grid of control points defining non-linear geometric correction applied to projector output — used to compensate for surface curvature, irregular geometry, and lens distortion.' },
    { term: 'Structured Light', def: 'Calibration technique projecting known patterns (Gray code stripes) onto surfaces and capturing them with a camera to compute precise spatial correspondences.' },
    { term: 'DLP Projector', def: 'Digital Light Processing projector using a DMD chip (Digital Micromirror Device) to reflect modulated light — preferred for projection mapping due to high contrast and fast response.' },
    { term: 'HAP Codec', def: 'GPU-accelerated video codec delivering extremely high frame rate / resolution playback by offloading decompression to the GPU — widely used in Resolume and media server workflows.' },
    { term: 'NDI', def: 'Network Device Interface — low-latency IP video transport protocol enabling high-quality video sharing between production systems over standard gigabit Ethernet.' },
    { term: 'Syphon / Spout', def: 'Texture sharing frameworks (macOS/Windows) allowing real-time frame passing between GPU-accelerated applications without memory copies — connects TouchDesigner to mapping engines.' },
    { term: 'Blend Zone', def: 'The overlapping region between two adjacent projectors where gamma-corrected luminance falloff curves are applied from both projectors to produce seamless brightness.' },
    { term: 'PJLink', def: 'Open standard protocol for network control of projectors — enabling power, input selection, and status monitoring of multiple projectors from a central media server.' },
    { term: 'Black Level Offset', def: 'Minimum luminance compensation in edge blend zones to account for the additive light from overlapping projectors — raising the dark floor to match the non-blended areas.' },
    { term: 'OSC', def: 'Open Sound Control — a UDP-based message protocol for sending real-time control data between performance applications, used to route parameter streams from DAWs and controllers to visual engines.' },
    { term: 'MadMapper', def: 'macOS/Windows projection mapping software for surface assignment, quad/mesh warping, and projection calibration — widely used for architectural projection and LED mapping.' },
    { term: 'Resolume Arena', def: 'VJ and projection mapping software supporting multi-projector output, warp mesh geometry, edge blending, and generative visual layering with MIDI/OSC control.' },
    { term: 'Reprojection Error', def: 'Metric measuring calibration accuracy — the average pixel distance between projected calibration points and their camera-detected positions. Target: < 0.5 px for precision mapping.' },
    { term: 'Corner Pin', def: 'Four-point perspective warp applied by repositioning the corners of the output image — the simplest form of geometric correction for flat surface projection.' },
    { term: 'Bezier Surface', def: 'A smooth parametric surface defined by a grid of control points with continuous tangent continuity — used in MadMapper for curved surface projection mapping.' },
    { term: 'Delta E (ΔE)', def: 'Perceptual color difference metric in CIE Lab color space — used to quantify color matching accuracy between projectors. ΔE < 2.0 is generally considered visually imperceptible.' },
    { term: 'Throw Ratio', def: 'Ratio of projector throw distance to image width (e.g., 1.5:1 means 1.5m throw for 1m wide image) — critical parameter for architectural site surveys and projector placement planning.' },
    { term: 'Generative Mapping', def: 'Real-time synthesis of projection content using procedural algorithms, particle systems, or data sources — piped into mapping engines via Syphon/Spout from TouchDesigner, Processing, or VVVV.' }
  ];

  const grid = document.getElementById('glossary-grid');
  terms.forEach(t => {
    const item = document.createElement('div');
    item.className = 'gloss-item hidden';
    item.innerHTML = `<div class="gloss-term">${t.term}</div><div class="gloss-def">${t.def}</div>`;
    grid.appendChild(item);
    observer.observe(item);
  });
})();

// ─── Scroll IntersectionObserver re-scan ──────────────────────────────────
window.addEventListener('load', () => {
  document.querySelectorAll('.hidden').forEach(el => observer.observe(el));
});
</script>
