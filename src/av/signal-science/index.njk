<script>
/* ═══════════════════════════════════════════════════════
   CORE SYSTEMS — LagFilter, Timer, Phosphor
═══════════════════════════════════════════════════════ */
class LagFilter {
  constructor(v=0,tau=0.15){this.value=v;this.target=v;this.tau=tau;}
  update(dt){const a=1-Math.exp(-dt/Math.max(this.tau,0.001));this.value+=(this.target-this.value)*a;return this.value;}
  set(t){this.target=t;}
  snap(v){this.value=this.target=v;}
}

function phosphorDecay(ctx,W,H,alpha=0.06,bg='rgba(0,2,4,1)'){
  ctx.globalAlpha=alpha;
  ctx.fillStyle=bg;
  ctx.fillRect(0,0,W,H);
  ctx.globalAlpha=1;
}

function glow(ctx,color,blur){ctx.shadowBlur=blur||16;ctx.shadowColor=color||'#00e5ff';}
function noGlow(ctx){ctx.shadowBlur=0;}

// Resize canvas to match CSS display width
function fitCanvas(canvas){
  const w=canvas.clientWidth||canvas.offsetWidth||800;
  if(canvas.width!==w){canvas.width=w;}
  return {W:canvas.width,H:canvas.height};
}

// Master timer
let masterT=0, masterDt=0.016, masterLast=0, masterElapsed=0;

/* ═══════════════════════════════════════════════════════
   BPM ENGINE (96 BPM)
═══════════════════════════════════════════════════════ */
const BPM = 96;
let bpmPhase=0, bpmBeat=0;
const beatLag = new LagFilter(0,0.05);

/* ═══════════════════════════════════════════════════════
   SECTION 1 — HERO CANVAS: CONVERGING SIGNAL WAVES
═══════════════════════════════════════════════════════ */
(function initHero(){
  const canvas = document.getElementById('hero-canvas');
  const ctx = canvas.getContext('2d');
  let W, H;

  // Particle system for word emergence
  const WORD = 'SIGNAL';
  const particles = [];
  const maxParticles = 180;
  let wordRevealProgress = new LagFilter(0, 1.2);
  let morphProgress = new LagFilter(0, 0.8);
  let waveBlend = new LagFilter(0, 0.6); // 0=audio, 1=unified

  // Simulated audio-like oscillation
  const audioFreqs = [1.0, 2.3, 0.7, 3.1, 1.8];
  const audioAmps  = [0.9, 0.4, 0.6, 0.2, 0.5];

  function getWave(type, x, t) {
    // x in [0,1], returns y in [-1,1]
    switch(type) {
      case 'audio':
        return audioFreqs.reduce((s,f,i)=>s+audioAmps[i]*Math.sin((x*8+t*f*2)*Math.PI*2),0)/2.5;
      case 'video':
        // Square-ish scanline pulse
        return Math.sin((x*6+t*0.8)*Math.PI*2)>0.3?0.7:-0.4;
      case 'data':
        // Stepped/quantized
        return Math.round(Math.sin((x*5+t*1.3)*Math.PI*2)*3)/3;
      case 'light':
        // Smooth high-freq sinusoid
        return Math.sin((x*12+t*1.6)*Math.PI*2)*0.7;
      case 'unified':
        return Math.sin((x*4+t*0.5)*Math.PI*2)*0.8
             + Math.sin((x*7+t*0.9)*Math.PI*2)*0.3;
    }
    return 0;
  }

  function initParticles() {
    particles.length = 0;
    for(let i=0;i<maxParticles;i++){
      particles.push({
        x: Math.random()*1.0,
        y: 0.5+Math.random()*0.1-0.05,
        vx: (Math.random()-0.5)*0.002,
        vy: (Math.random()-0.5)*0.002,
        life: Math.random(),
        speed: 0.3+Math.random()*0.7,
        domain: Math.floor(Math.random()*5),
        size: 1+Math.random()*2.5,
      });
    }
  }
  initParticles();

  const domainColors = ['#00e5ff','#f59e0b','#7c3aed','#22c55e','#ef4444'];

  function drawWaveLine(type, t, yCenter, amplitude, color, alpha, lineW) {
    const segs = 200;
    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth = lineW;
    ctx.globalAlpha = alpha;
    glow(ctx, color, 10);
    for(let i=0;i<=segs;i++){
      const x = i/segs;
      const y = getWave(type, x, t);
      const px = x*W;
      const py = yCenter + y*amplitude;
      if(i===0) ctx.moveTo(px,py); else ctx.lineTo(px,py);
    }
    ctx.stroke();
    noGlow(ctx);
    ctx.globalAlpha = 1;
  }

  function loop(t) {
    requestAnimationFrame(loop);
    if(!masterLast){masterLast=t;}
    const dt = Math.min((t-masterLast)*0.001,0.05);
    masterLast=t; masterElapsed+=dt; masterT=t*0.001; masterDt=dt;

    // BPM
    bpmPhase += dt*(BPM/60);
    if(bpmPhase>=1){bpmPhase-=1;bpmBeat++;}
    beatLag.set(bpmPhase<0.1?1:0);
    beatLag.update(dt);

    const {W:w,H:h} = fitCanvas(canvas);
    W=w; H=h;

    // Phosphor decay
    phosphorDecay(ctx,W,H,0.055,'rgba(0,2,4,1)');

    const st = masterT;
    const blend = (Math.sin(st*0.4)+1)*0.5; // slow oscillation
    morphProgress.set(blend);
    morphProgress.update(dt);
    waveBlend.set(Math.sin(st*0.25)*0.5+0.5);
    waveBlend.update(dt);

    const yMid = H * 0.52;
    const amp  = H * 0.17;

    // Grid lines
    ctx.globalAlpha = 0.06;
    ctx.strokeStyle = '#00e5ff';
    ctx.lineWidth = 0.5;
    for(let gy=H*0.25;gy<H*0.85;gy+=H*0.1){
      ctx.beginPath(); ctx.moveTo(0,gy); ctx.lineTo(W,gy); ctx.stroke();
    }
    for(let gx=W*0.1;gx<W*0.95;gx+=W*0.1){
      ctx.beginPath(); ctx.moveTo(gx,0); ctx.lineTo(gx,H); ctx.stroke();
    }
    ctx.globalAlpha=1;

    // Left 30%: Audio wave (cyan)
    const leftW = W*0.3;
    ctx.save();
    ctx.beginPath();
    ctx.rect(0,0,leftW,H);
    ctx.clip();
    drawWaveLine('audio',st,yMid,amp,'#00e5ff',0.9,1.5);
    ctx.restore();

    // Right 30%: Unified wave (white→cyan gradient morph)
    const rightStart = W*0.7;
    ctx.save();
    ctx.beginPath();
    ctx.rect(rightStart,0,W-rightStart,H);
    ctx.clip();
    drawWaveLine('unified',st,yMid,amp*1.1,'#00e5ff',0.95,2.0);
    ctx.restore();

    // Center 40%: Morphing blend of all four waves
    const cStart=W*0.3, cEnd=W*0.7, cW=cEnd-cStart;
    const segs=120;
    for(let pass=0;pass<4;pass++){
      const types=['audio','video','data','light'];
      const colors=['#00e5ff','#f59e0b','#7c3aed','#22c55e'];
      const a = 0.15+pass*0.08;
      ctx.save();
      ctx.beginPath(); ctx.rect(cStart,0,cW,H); ctx.clip();
      ctx.beginPath();
      ctx.strokeStyle=colors[pass];
      ctx.lineWidth=1.2;
      ctx.globalAlpha=a;
      glow(ctx,colors[pass],8);
      for(let i=0;i<=segs;i++){
        const nx=i/segs; // 0..1 in center zone
        const absX=cStart+nx*cW;
        const xFull=absX/W;
        const rawY=getWave(types[pass],xFull,st);
        const unifY=getWave('unified',xFull,st);
        // Blend toward unified as we approach center, then back out
        const centerDist=Math.abs(nx-0.5)*2; // 0=center 1=edge
        const blendFactor=1-centerDist*centerDist;
        const y=rawY*(1-blendFactor)+unifY*blendFactor;
        const py=yMid+y*amp;
        if(i===0) ctx.moveTo(absX,py); else ctx.lineTo(absX,py);
      }
      ctx.stroke();
      noGlow(ctx);
      ctx.globalAlpha=1;
      ctx.restore();
    }

    // Main unified center line
    ctx.save();
    ctx.beginPath(); ctx.rect(cStart,0,cW,H); ctx.clip();
    drawWaveLine('unified',st,yMid,amp*1.1,'#00e5ff',0.7,2);
    ctx.restore();

    // Convergence point glow at center
    const cx=W*0.5, cy=yMid;
    const pulseR=8+beatLag.value*16;
    const grad=ctx.createRadialGradient(cx,cy,0,cx,cy,pulseR*3);
    grad.addColorStop(0,'rgba(0,229,255,0.5)');
    grad.addColorStop(0.4,'rgba(0,229,255,0.1)');
    grad.addColorStop(1,'rgba(0,229,255,0)');
    ctx.fillStyle=grad;
    ctx.beginPath();
    ctx.arc(cx,cy,pulseR*3,0,Math.PI*2);
    ctx.fill();

    // Domain labels (left and right)
    ctx.font='10px Courier New';
    ctx.letterSpacing='2px';
    const lblAlpha=0.5;
    const domLabels=[
      {x:W*0.05,y:H*0.15,c:'#00e5ff',t:'AUDIO'},
      {x:W*0.05,y:H*0.30,c:'#f59e0b',t:'VIDEO'},
      {x:W*0.88,y:H*0.18,c:'#22c55e',t:'DATA'},
      {x:W*0.88,y:H*0.30,c:'#7c3aed',t:'ART'},
      {x:W*0.47,y:H*0.12,c:'#ffffff',t:'SIGNAL'},
    ];
    domLabels.forEach(l=>{
      ctx.globalAlpha=lblAlpha;
      glow(ctx,l.c,8);
      ctx.fillStyle=l.c;
      ctx.fillText(l.t,l.x,l.y);
      noGlow(ctx);
      ctx.globalAlpha=1;
    });

    // Particles flowing along wave
    particles.forEach(p=>{
      p.x += p.vx*p.speed*(1+beatLag.value*2);
      p.life -= dt*0.06;
      if(p.life<0||p.x<0||p.x>1){
        p.x=Math.random(); p.y=0.5;
        p.vx=(Math.random()-0.5)*0.003+0.001;
        p.vy=(Math.random()-0.5)*0.001;
        p.life=0.5+Math.random()*0.5;
        p.domain=Math.floor(Math.random()*5);
      }
      const waveY=getWave('unified',p.x,st);
      const ty=yMid+waveY*amp;
      p.y+=(ty/H-p.y)*0.08;
      // Color shifts crossing center
      let col=domainColors[p.domain];
      if(p.x>0.42&&p.x<0.58) col='#ffffff';
      const alpha=Math.min(1,p.life*2)*0.8;
      ctx.globalAlpha=alpha;
      glow(ctx,col,6);
      ctx.fillStyle=col;
      ctx.beginPath();
      ctx.arc(p.x*W,p.y*H,p.size,0,Math.PI*2);
      ctx.fill();
      noGlow(ctx);
      ctx.globalAlpha=1;
    });

    // Update nav BPM display
    document.getElementById('nav-bpm').textContent=BPM+' BPM';
  }
  requestAnimationFrame(loop);
})();

/* ═══════════════════════════════════════════════════════
   SECTION 2 — UNIFIED SIGNAL GRAPH
═══════════════════════════════════════════════════════ */
(function initGraph(){
  const canvas = document.getElementById('graph-canvas');
  if(!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;

  const DOMAINS = [
    { name:'Music',  color:'#00e5ff', abbr:'MUS', nodes:['Oscillator','Filter','Envelope','Speaker']    },
    { name:'Video',  color:'#f59e0b', abbr:'VID', nodes:['Camera','Codec','Renderer','Display']         },
    { name:'Art',    color:'#7c3aed', abbr:'ART', nodes:['Algorithm','Pixel','Canvas','Output']         },
    { name:'AV',     color:'#22c55e', abbr:'AV',  nodes:['Sensor','Processor','Projector','Space']      },
    { name:'Data',   color:'#ef4444', abbr:'DAT', nodes:['Input','Transform','Model','Output']          },
  ];

  // Will be computed in resize
  let nodeObjs = [];
  let routes = []; // {from, to, particles, lag}
  let selectedNode = null;
  let infoEl = document.getElementById('graph-info');

  function buildNodePositions() {
    nodeObjs = [];
    const cx=W*0.5, cy=H*0.5;
    const clusterR = Math.min(W,H)*0.34;
    DOMAINS.forEach((d,di)=>{
      const angle = (di/5)*Math.PI*2 - Math.PI/2;
      const clusterX = cx + Math.cos(angle)*clusterR;
      const clusterY = cy + Math.sin(angle)*clusterR;
      const nodeR = Math.min(W,H)*0.08;
      d.nodes.forEach((name,ni)=>{
        const na = angle + (ni-1.5)*(Math.PI*0.28);
        const nr = nodeR;
        nodeObjs.push({
          id: di*4+ni,
          domainIdx: di,
          name,
          x: clusterX+Math.cos(na)*nr,
          y: clusterY+Math.sin(na)*nr,
          domain: d,
          glowLag: new LagFilter(0,0.12),
          pulseLag: new LagFilter(0,0.08),
        });
      });
    });
  }

  canvas.addEventListener('click',e=>{
    const rect=canvas.getBoundingClientRect();
    const mx=(e.clientX-rect.left)*(canvas.width/rect.width);
    const my=(e.clientY-rect.top)*(canvas.height/rect.height);
    const hit=nodeObjs.find(n=>Math.hypot(n.x-mx,n.y-my)<16);
    if(!hit) return;
    if(!selectedNode){
      selectedNode=hit;
      hit.pulseLag.set(1);
    } else {
      if(hit.domainIdx !== selectedNode.domainIdx){
        addRoute(selectedNode,hit);
      }
      selectedNode=null;
    }
  });

  function addRoute(a,b){
    const exists=routes.find(r=>(r.from.id===a.id&&r.to.id===b.id)||(r.from.id===b.id&&r.to.id===a.id));
    if(exists){routes=routes.filter(r=>r!==exists);updateInfo();return;}
    routes.push({from:a,to:b,particles:[],lag:new LagFilter(0,0.3)});
    routes[routes.length-1].lag.set(1);
    for(let i=0;i<8;i++) spawnParticle(routes[routes.length-1]);
    updateInfo();
  }

  function spawnParticle(route){
    route.particles.push({t:Math.random(),speed:0.15+Math.random()*0.15,size:2+Math.random()*2});
  }

  function updateInfo(){
    if(infoEl) infoEl.textContent = `Click any two nodes across domains to create a cross-domain signal path. — ${routes.length} active route${routes.length!==1?'s':''}`;
  }

  window.setGraphPreset=function(preset){
    routes=[];
    if(preset==='audio-visual'){
      [[0,5],[1,6],[2,9],[3,10]].forEach(([a,b])=>addRoute(nodeObjs[a],nodeObjs[b]));
    } else if(preset==='data-sound'){
      [[16,0],[17,1],[18,2],[19,3]].forEach(([a,b])=>addRoute(nodeObjs[a],nodeObjs[b]));
    } else if(preset==='all-domains'){
      [[0,8],[4,12],[8,16],[12,0]].forEach(([a,b])=>addRoute(nodeObjs[a],nodeObjs[b]));
      [[2,10],[6,14],[10,18]].forEach(([a,b])=>addRoute(nodeObjs[a],nodeObjs[b]));
    } else if(preset==='feedback'){
      [[1,5],[5,9],[9,13],[13,17],[17,1]].forEach(([a,b])=>addRoute(nodeObjs[a],nodeObjs[b]));
    }
    updateInfo();
  };
  window.clearGraphRoutes=function(){routes=[];updateInfo();};

  function drawBezier(ax,ay,bx,by,color,alpha,width){
    const mx=(ax+bx)*0.5, my=(ay+by)*0.5;
    const ctrl1x=mx+(ay-by)*0.3, ctrl1y=my+(bx-ax)*0.3;
    ctx.beginPath();
    ctx.strokeStyle=color;
    ctx.lineWidth=width;
    ctx.globalAlpha=alpha;
    ctx.moveTo(ax,ay);
    ctx.quadraticCurveTo(ctrl1x,ctrl1y,bx,by);
    ctx.stroke();
    ctx.globalAlpha=1;
  }

  function getPointOnBezier(ax,ay,bx,by,t){
    const mx=(ax+bx)*0.5,my=(ay+by)*0.5;
    const cx=mx+(ay-by)*0.3,cy=my+(bx-ax)*0.3;
    const u=1-t;
    return {
      x:u*u*ax+2*u*t*cx+t*t*bx,
      y:u*u*ay+2*u*t*cy+t*t*by
    };
  }

  function loop(){
    requestAnimationFrame(loop);
    const {W:w,H:h}=fitCanvas(canvas);
    if(W!==w||H!==h){W=w;H=h;buildNodePositions();}

    phosphorDecay(ctx,W,H,0.07,'rgba(0,2,4,1)');

    const t=masterT;

    // Draw cluster backgrounds
    const cx=W*0.5, cy=H*0.5;
    const clusterR=Math.min(W,H)*0.34;
    DOMAINS.forEach((d,di)=>{
      const angle=(di/5)*Math.PI*2-Math.PI/2;
      const clX=cx+Math.cos(angle)*clusterR;
      const clY=cy+Math.sin(angle)*clusterR;
      const r=Math.min(W,H)*0.15;
      const grad=ctx.createRadialGradient(clX,clY,0,clX,clY,r);
      grad.addColorStop(0,d.color+'18');
      grad.addColorStop(1,d.color+'00');
      ctx.fillStyle=grad;
      ctx.beginPath();
      ctx.arc(clX,clY,r,0,Math.PI*2);
      ctx.fill();
      // Domain label
      glow(ctx,d.color,8);
      ctx.fillStyle=d.color;
      ctx.font=`bold 11px Courier New`;
      ctx.globalAlpha=0.7;
      ctx.fillText(d.name,clX-20,clY-Math.min(W,H)*0.14);
      noGlow(ctx);
      ctx.globalAlpha=1;
    });

    // Draw routes (bezier)
    routes.forEach(r=>{
      r.lag.update(masterDt);
      const {from,to}=r;
      const blendColor=blendHex(from.domain.color,to.domain.color);
      glow(ctx,blendColor,6);
      drawBezier(from.x,from.y,to.x,to.y,blendColor,r.lag.value*0.5,1.5);
      noGlow(ctx);

      // Particles
      r.particles.forEach(p=>{
        p.t+=p.speed*masterDt;
        if(p.t>1){p.t=0;}
        const pt=getPointOnBezier(from.x,from.y,to.x,to.y,p.t);
        const col=p.t<0.5?from.domain.color:to.domain.color;
        ctx.globalAlpha=0.85;
        glow(ctx,col,8);
        ctx.fillStyle=col;
        ctx.beginPath();
        ctx.arc(pt.x,pt.y,p.size,0,Math.PI*2);
        ctx.fill();
        noGlow(ctx);
        ctx.globalAlpha=1;
      });

      // Keep particles populated
      if(r.particles.length<10&&Math.random()<0.02) spawnParticle(r);
    });

    // Draw nodes
    nodeObjs.forEach(n=>{
      n.glowLag.update(masterDt);
      n.pulseLag.set(0); n.pulseLag.update(masterDt);
      const isSelected=(selectedNode&&selectedNode.id===n.id);
      const hasRoute=routes.some(r=>r.from.id===n.id||r.to.id===n.id);
      const pulse=Math.sin(t*2+n.id*0.3)*0.5+0.5;
      const r=7+pulse*2+(isSelected?4:0)+(hasRoute?2:0);

      n.glowLag.set(isSelected?1:hasRoute?0.7:0.3);
      const glowAmt=8+n.glowLag.value*20;

      glow(ctx,n.domain.color,glowAmt);
      ctx.fillStyle=isSelected?'#ffffff':n.domain.color;
      ctx.globalAlpha=0.9;
      ctx.beginPath();
      ctx.arc(n.x,n.y,r,0,Math.PI*2);
      ctx.fill();
      noGlow(ctx);
      ctx.globalAlpha=1;

      // Node label
      ctx.font='9px Courier New';
      ctx.fillStyle=isSelected?'#ffffff':n.domain.color+'cc';
      ctx.globalAlpha=0.75;
      ctx.fillText(n.name,n.x+10,n.y+3);
      ctx.globalAlpha=1;
    });

    // Center convergence point
    const cPulse=Math.sin(t*1.2)*0.5+0.5;
    const cGrad=ctx.createRadialGradient(cx,cy,0,cx,cy,30+cPulse*10);
    cGrad.addColorStop(0,'rgba(0,229,255,0.3)');
    cGrad.addColorStop(1,'rgba(0,229,255,0)');
    ctx.fillStyle=cGrad;
    ctx.beginPath();ctx.arc(cx,cy,40,0,Math.PI*2);ctx.fill();
    glow(ctx,'#00e5ff',16);
    ctx.fillStyle='#00e5ff';
    ctx.globalAlpha=0.9;
    ctx.beginPath();ctx.arc(cx,cy,4+cPulse*3,0,Math.PI*2);ctx.fill();
    noGlow(ctx);ctx.globalAlpha=1;
  }
  buildNodePositions();
  requestAnimationFrame(loop);
})();

function blendHex(a,b){
  const ra=parseInt(a.slice(1,3),16),ga=parseInt(a.slice(3,5),16),ba=parseInt(a.slice(5,7),16);
  const rb=parseInt(b.slice(1,3),16),gb=parseInt(b.slice(3,5),16),bb=parseInt(b.slice(5,7),16);
  return `rgb(${Math.round((ra+rb)/2)},${Math.round((ga+gb)/2)},${Math.round((ba+bb)/2)})`;
}

/* ═══════════════════════════════════════════════════════
   SECTION 3 — CROSS-DOMAIN ROUTING MATRIX
═══════════════════════════════════════════════════════ */
(function initRouting(){
  const canvas=document.getElementById('routing-canvas');
  if(!canvas) return;
  const ctx=canvas.getContext('2d');
  let W,H;

  const SOURCES=['Audio','Video','Data','Sensor','Generated'];
  const DESTS=['Speaker','Display','Canvas','Projector','Network'];
  const SRC_COLORS=['#00e5ff','#f59e0b','#ef4444','#22c55e','#7c3aed'];
  const DST_COLORS=['#00e5ff','#f59e0b','#7c3aed','#22c55e','#ef4444'];

  // 5x5 route matrix
  const routes=Array.from({length:5},()=>Array(5).fill(false));
  const routeLags=Array.from({length:5},()=>Array.from({length:5},()=>new LagFilter(0,0.2)));
  const particles=[];

  function toggleRoute(r,c){
    routes[r][c]=!routes[r][c];
    routeLags[r][c].set(routes[r][c]?1:0);
    updateStats();
  }
  function updateStats(){
    let count=0;
    routes.forEach(r=>r.forEach(v=>{if(v)count++;}));
    const den=Math.round(count/25*100);
    const buses=new Set();
    routes.forEach((r,ri)=>r.forEach((v,ci)=>{if(v){buses.add(ri);buses.add(ci+5);}}));
    document.getElementById('route-count').textContent=count;
    document.getElementById('signal-density').textContent=den+'%';
    document.getElementById('active-buses').textContent=buses.size;
  }
  window.matrixClear=()=>{routes.forEach(r=>r.fill(false));routeLags.forEach(r=>r.forEach(l=>l.set(0)));updateStats();};
  window.matrixFull=()=>{routes.forEach(r=>r.fill(true));routeLags.forEach(r=>r.forEach(l=>l.set(1)));updateStats();};
  window.matrixDiag=()=>{
    matrixClear();
    for(let i=0;i<5;i++){routes[i][i]=true;routeLags[i][i].set(1);}
    updateStats();
  };

  canvas.addEventListener('click',e=>{
    const rect=canvas.getBoundingClientRect();
    const mx=(e.clientX-rect.left)*(canvas.width/rect.width);
    const my=(e.clientY-rect.top)*(canvas.height/rect.height);
    const {cellW,cellH,ox,oy}=getGrid();
    const col=Math.floor((mx-ox)/cellW);
    const row=Math.floor((my-oy)/cellH);
    if(col>=0&&col<5&&row>=0&&row<5) toggleRoute(row,col);
  });

  function getGrid(){
    const margin=60, headerH=36, headerW=80;
    const totalW=W-margin-headerW, totalH=H-margin-headerH;
    const cellW=totalW/5, cellH=totalH/5;
    return {cellW,cellH,ox:headerW,oy:headerH,margin,headerW,headerH};
  }

  function loop(){
    requestAnimationFrame(loop);
    const {W:w,H:h}=fitCanvas(canvas);
    W=w;H=h;
    phosphorDecay(ctx,W,H,0.07,'rgba(0,2,4,1)');
    const t=masterT;
    const {cellW,cellH,ox,oy}=getGrid();

    // Grid headers — sources (left)
    SOURCES.forEach((s,i)=>{
      const y=oy+i*cellH+cellH*0.5;
      ctx.font='10px Courier New';
      ctx.fillStyle=SRC_COLORS[i];
      ctx.globalAlpha=0.85;
      glow(ctx,SRC_COLORS[i],4);
      ctx.fillText(s,4,y+3);
      noGlow(ctx);
      ctx.globalAlpha=1;
    });

    // Destination headers (top)
    DESTS.forEach((d,i)=>{
      const x=ox+i*cellW+cellW*0.5;
      ctx.save();
      ctx.translate(x-3,oy-4);
      ctx.rotate(-Math.PI*0.35);
      ctx.font='10px Courier New';
      ctx.fillStyle=DST_COLORS[i];
      ctx.globalAlpha=0.85;
      glow(ctx,DST_COLORS[i],4);
      ctx.fillText(d,0,0);
      noGlow(ctx);
      ctx.globalAlpha=1;
      ctx.restore();
    });

    // Grid cells
    for(let r=0;r<5;r++){
      for(let c=0;c<5;c++){
        routeLags[r][c].update(masterDt);
        const v=routeLags[r][c].value;
        const x=ox+c*cellW, y=oy+r*cellH;
        const isOn=routes[r][c];

        // Cell background
        ctx.fillStyle=isOn?`rgba(0,229,255,${0.08+v*0.1})`:
                           `rgba(0,229,255,0.03)`;
        ctx.strokeStyle=`rgba(0,229,255,${0.15+v*0.3})`;
        ctx.lineWidth=isOn?1.5:0.5;
        ctx.beginPath();
        ctx.rect(x+2,y+2,cellW-4,cellH-4);
        ctx.fill();
        ctx.stroke();

        // Active indicator
        if(isOn){
          const cx2=x+cellW/2, cy2=y+cellH/2;
          const pulse=Math.sin(t*3+r+c)*0.3+0.7;
          const blendC=blendHex(SRC_COLORS[r],DST_COLORS[c]);
          glow(ctx,blendC,10*v);
          ctx.fillStyle=blendC;
          ctx.globalAlpha=v*pulse;
          ctx.beginPath();
          ctx.arc(cx2,cy2,5+pulse*3,0,Math.PI*2);
          ctx.fill();
          noGlow(ctx);
          ctx.globalAlpha=1;

          // Particle on active routes
          if(Math.random()<0.04){
            particles.push({
              r,c,
              px:ox+r===r?ox+c*cellW+Math.random()*cellW:0,
              py:oy+r*cellH+Math.random()*cellH,
              life:1,col:blendC,
              vx:(Math.random()-0.5)*2,
              vy:(Math.random()-0.5)*2,
            });
          }
        }
      }
    }

    // Particles
    for(let i=particles.length-1;i>=0;i--){
      const p=particles[i];
      p.px+=p.vx; p.py+=p.vy; p.life-=0.04;
      if(p.life<=0){particles.splice(i,1);continue;}
      ctx.globalAlpha=p.life*0.7;
      glow(ctx,p.col,5);
      ctx.fillStyle=p.col;
      ctx.beginPath();
      ctx.arc(p.px,p.py,2,0,Math.PI*2);
      ctx.fill();
      noGlow(ctx);
      ctx.globalAlpha=1;
    }

    // Row/col highlights
    ctx.strokeStyle='rgba(0,229,255,0.06)';
    ctx.lineWidth=0.5;
    for(let i=0;i<=5;i++){
      ctx.beginPath();
      ctx.moveTo(ox,oy+i*cellH);ctx.lineTo(ox+5*cellW,oy+i*cellH);ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(ox+i*cellW,oy);ctx.lineTo(ox+i*cellW,oy+5*cellH);ctx.stroke();
    }
  }
  requestAnimationFrame(loop);
})();

/* ═══════════════════════════════════════════════════════
   SECTION 4 — AUDIOVISUAL MODULATION LAB
═══════════════════════════════════════════════════════ */
(function initModLab(){
  const canvas=document.getElementById('modlab-canvas');
  if(!canvas) return;
  const ctx=canvas.getContext('2d');
  let W,H;

  const SOURCES=['Amplitude','LFO','MIDI CC'];
  const DESTS=['Hue Rotation','Scale Factor','Particle Count'];
  const SRC_COLORS=['#00e5ff','#22c55e','#f59e0b'];
  const DST_COLORS=['#7c3aed','#ef4444','#00e5ff'];

  // 3x3 matrix
  const modRoutes=Array.from({length:3},()=>Array(3).fill(false));
  const modLags=Array.from({length:3},()=>Array.from({length:3},()=>new LagFilter(0,0.25)));
  const modParticles=[];

  let lfoShape='sine';
  let lfoRate=new LagFilter(2.0,0.3);
  let lfoPhase=0;
  let midiCC=new LagFilter(64,0.15);
  let midiDrift=0;

  // Source signal values (live)
  const srcVals=[new LagFilter(0.5,0.08),new LagFilter(0.5,0.05),new LagFilter(0.5,0.1)];
  // Dest values driven by modulation
  const dstVals=[new LagFilter(0,0.2),new LagFilter(1,0.15),new LagFilter(0.5,0.18)];

  document.getElementById('lfo-rate').addEventListener('input',function(){
    const hz=parseFloat(this.value)/10;
    lfoRate.set(hz);
    document.getElementById('lfo-rate-val').textContent=hz.toFixed(1)+'Hz';
  });
  window.setLFOShape=function(shape,btn){
    lfoShape=shape;
    document.querySelectorAll('#modlab-controls .ctrl-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
  };

  canvas.addEventListener('click',e=>{
    const rect=canvas.getBoundingClientRect();
    const mx=(e.clientX-rect.left)*(canvas.width/rect.width);
    const my=(e.clientY-rect.top)*(canvas.height/rect.height);
    const {panelW,matX,matY,cellSz}=getLayout();
    const col=Math.floor((mx-matX)/cellSz);
    const row=Math.floor((my-matY)/cellSz);
    if(col>=0&&col<3&&row>=0&&row<3){
      modRoutes[row][col]=!modRoutes[row][col];
      modLags[row][col].set(modRoutes[row][col]?1:0);
    }
  });

  function getLayout(){
    const panelW=W*0.28;
    const matW=W*0.22;
    const matX=panelW+W*0.06;
    const matY=H*0.1;
    const cellSz=matW/3;
    return {panelW,matX,matY,cellSz,matW};
  }

  function getLFOValue(phase){
    switch(lfoShape){
      case 'sine':   return Math.sin(phase*Math.PI*2)*0.5+0.5;
      case 'square': return phase<0.5?1:0;
      case 'tri':    return phase<0.5?phase*2:2-phase*2;
      case 'saw':    return phase;
    }
    return 0.5;
  }

  function loop(){
    requestAnimationFrame(loop);
    const {W:w,H:h}=fitCanvas(canvas);
    W=w;H=h;
    phosphorDecay(ctx,W,H,0.07,'rgba(0,2,4,1)');
    const t=masterT;
    lfoRate.update(masterDt);
    lfoPhase=(lfoPhase+lfoRate.value*masterDt)%1;
    midiDrift+=masterDt*0.3;
    midiCC.set(Math.sin(midiDrift)*30+64+Math.sin(midiDrift*1.7)*20);
    midiCC.update(masterDt);

    // Source values
    srcVals[0].set((Math.sin(t*1.3)*0.5+0.5)); srcVals[0].update(masterDt); // amplitude
    srcVals[1].set(getLFOValue(lfoPhase));      srcVals[1].update(masterDt); // LFO
    srcVals[2].set(midiCC.value/127);           srcVals[2].update(masterDt); // MIDI

    // Compute dest values from routing
    dstVals.forEach((d,di)=>{
      let driven=false;
      let sum=0,cnt=0;
      modRoutes.forEach((row,si)=>{
        if(row[di]&&modLags[si][di].value>0.1){
          sum+=srcVals[si].value*modLags[si][di].value;
          cnt++;
        }
      });
      if(cnt>0){d.set(sum/cnt);driven=true;}
      else{d.set(0.5);}
      d.update(masterDt);
    });

    const {panelW,matX,matY,cellSz}=getLayout();
    const srcPanelX=16, dstPanelX=W-panelW-16;
    const rowH=H*0.22;

    // Draw SOURCE panel
    SOURCES.forEach((s,i)=>{
      const py=matY+i*rowH+(rowH-24)/2;
      const v=srcVals[i].value;
      ctx.fillStyle=SRC_COLORS[i];
      ctx.globalAlpha=0.12;
      ctx.fillRect(srcPanelX,matY+i*rowH,panelW,rowH-4);
      ctx.globalAlpha=1;

      // Waveform mini preview
      const waveX=srcPanelX+8, waveW=panelW-48, waveY=py+12;
      ctx.beginPath();
      ctx.strokeStyle=SRC_COLORS[i];
      ctx.lineWidth=1.5;
      glow(ctx,SRC_COLORS[i],6);
      for(let xi=0;xi<=60;xi++){
        const xf=xi/60;
        let yv;
        if(i===0) yv=Math.sin((xf*4+t)*Math.PI*2)*0.5+0.5;
        else if(i===1) yv=getLFOValue((xf+lfoPhase)%1);
        else yv=(midiCC.value/127);
        const px2=waveX+xf*waveW, py2=waveY-yv*14;
        xi===0?ctx.moveTo(px2,py2):ctx.lineTo(px2,py2);
      }
      ctx.stroke();
      noGlow(ctx);

      // Label + value
      ctx.font='10px Courier New';
      ctx.fillStyle=SRC_COLORS[i];
      ctx.globalAlpha=0.85;
      ctx.fillText(s,srcPanelX+8,matY+i*rowH+14);
      ctx.fillStyle='#d8f0f8';
      ctx.globalAlpha=0.7;
      ctx.fillText((v*100).toFixed(0)+'%',srcPanelX+panelW-36,py+12);
      ctx.globalAlpha=1;
    });

    // Draw DEST panel
    DESTS.forEach((d,i)=>{
      const py=matY+i*rowH+(rowH-24)/2;
      const v=dstVals[i].value;
      ctx.fillStyle=DST_COLORS[i];
      ctx.globalAlpha=0.10;
      ctx.fillRect(dstPanelX,matY+i*rowH,panelW,rowH-4);
      ctx.globalAlpha=1;

      ctx.font='10px Courier New';
      ctx.fillStyle=DST_COLORS[i];
      ctx.globalAlpha=0.85;
      ctx.fillText(d,dstPanelX+8,matY+i*rowH+14);
      ctx.globalAlpha=1;

      // Visual representation of dest
      if(i===0){ // Hue wheel
        const angle=v*Math.PI*2;
        const hue=Math.round(v*360);
        const wCx=dstPanelX+panelW-30, wCy=py+8;
        for(let a=0;a<60;a++){
          ctx.fillStyle=`hsl(${a*6},80%,60%)`;
          ctx.beginPath();
          ctx.arc(wCx,wCy,12,a/60*Math.PI*2,(a+1)/60*Math.PI*2);
          ctx.lineTo(wCx,wCy);
          ctx.fill();
        }
        glow(ctx,'#ffffff',8);
        ctx.strokeStyle='#ffffff';
        ctx.lineWidth=2;
        ctx.beginPath();
        ctx.moveTo(wCx,wCy);
        ctx.lineTo(wCx+Math.cos(angle)*14,wCy+Math.sin(angle)*14);
        ctx.stroke();
        noGlow(ctx);
      } else if(i===1){ // Scale bar
        const scaleV=0.2+v*1.5;
        const bx=dstPanelX+panelW-70,by=py;
        const bw=40*scaleV;
        glow(ctx,DST_COLORS[i],4);
        ctx.fillStyle=DST_COLORS[i];
        ctx.globalAlpha=0.7;
        ctx.fillRect(bx,by,Math.min(bw,60),18);
        noGlow(ctx);
        ctx.globalAlpha=1;
      } else { // Particle dots
        const count=Math.round(v*12);
        for(let p=0;p<count;p++){
          const px3=dstPanelX+panelW-70+p*5,py3=py+9;
          glow(ctx,DST_COLORS[i],6);
          ctx.fillStyle=DST_COLORS[i];
          ctx.globalAlpha=0.8;
          ctx.beginPath();
          ctx.arc(px3,py3,3,0,Math.PI*2);
          ctx.fill();
          noGlow(ctx);
          ctx.globalAlpha=1;
        }
      }
    });

    // Draw MOD MATRIX (center)
    for(let r=0;r<3;r++){
      for(let c=0;c<3;c++){
        modLags[r][c].update(masterDt);
        const v=modLags[r][c].value;
        const x=matX+c*cellSz, y=matY+r*rowH;
        const cx2=x+cellSz/2, cy2=y+rowH/2;

        // Cell
        ctx.fillStyle=`rgba(0,229,255,${0.04+v*0.1})`;
        ctx.strokeStyle=`rgba(0,229,255,${0.15+v*0.4})`;
        ctx.lineWidth=v>0.5?1.5:0.5;
        ctx.beginPath();
        ctx.rect(x+3,y+3,cellSz-6,rowH-6);
        ctx.fill();
        ctx.stroke();

        if(modRoutes[r][c]){
          const srcColor=SRC_COLORS[r], dstColor=DST_COLORS[c];
          const blend=blendHex(srcColor,dstColor);
          glow(ctx,blend,12*v);
          ctx.fillStyle=blend;
          ctx.globalAlpha=0.8*v;
          ctx.beginPath();
          ctx.arc(cx2,cy2,6+v*3,0,Math.PI*2);
          ctx.fill();
          noGlow(ctx);
          ctx.globalAlpha=1;

          // Bezier to source/dest
          const srcY=matY+r*rowH+rowH/2, srcX2=srcPanelX+panelW;
          const dstY=matY+c*rowH+rowH/2, dstX2=dstPanelX;
          ctx.strokeStyle=blendHex(srcColor,'#00e5ff');
          ctx.lineWidth=1;
          ctx.globalAlpha=0.3*v;
          ctx.setLineDash([4,4]);
          ctx.beginPath(); ctx.moveTo(srcX2,srcY); ctx.lineTo(cx2-cellSz/2,cy2); ctx.stroke();
          ctx.beginPath(); ctx.moveTo(cx2+cellSz/2,cy2); ctx.lineTo(dstX2,dstY); ctx.stroke();
          ctx.setLineDash([]);
          ctx.globalAlpha=1;

          // Flow particles
          if(Math.random()<0.05){
            modParticles.push({
              cx:cx2,cy:cy2,
              tx:dstX2,ty:dstY,
              t:0,life:1,
              speed:0.8+Math.random()*0.5,
              col:blend,
              size:1.5+Math.random()*1.5,
            });
          }
        }
      }
    }

    // Modulation particles
    for(let i=modParticles.length-1;i>=0;i--){
      const p=modParticles[i];
      p.t+=p.speed*masterDt; p.life-=0.03;
      if(p.t>1||p.life<=0){modParticles.splice(i,1);continue;}
      const px=p.cx+(p.tx-p.cx)*p.t;
      const py=p.cy+(p.ty-p.cy)*p.t+Math.sin(p.t*Math.PI)*-20;
      ctx.globalAlpha=p.life*0.7;
      glow(ctx,p.col,6);
      ctx.fillStyle=p.col;
      ctx.beginPath();ctx.arc(px,py,p.size,0,Math.PI*2);ctx.fill();
      noGlow(ctx);ctx.globalAlpha=1;
    }

    // Matrix header labels
    ctx.font='9px Courier New';
    SOURCES.forEach((s,i)=>{
      const y=matY+i*rowH+rowH/2+3;
      ctx.fillStyle=SRC_COLORS[i];ctx.globalAlpha=0.5;
      ctx.fillText(i+1,matX-14,y);ctx.globalAlpha=1;
    });
    DESTS.forEach((d,i)=>{
      ctx.fillStyle=DST_COLORS[i];ctx.globalAlpha=0.5;
      ctx.save();ctx.translate(matX+i*cellSz+cellSz/2,matY-8);ctx.rotate(-0.4);
      ctx.fillText(i+1,0,0);ctx.restore();ctx.globalAlpha=1;
    });
  }
  requestAnimationFrame(loop);
})();

/* ═══════════════════════════════════════════════════════
   SECTION 5 — SIGNAL TRANSFORMATION SYSTEMS
═══════════════════════════════════════════════════════ */
(function initTransform(){
  const canvas=document.getElementById('transform-canvas');
  if(!canvas) return;
  const ctx=canvas.getContext('2d');
  let W,H;
  let activeTransform=0;
  const paramA=new LagFilter(0.7,0.2);
  const paramB=new LagFilter(0.5,0.2);

  // ADSR state
  let adsrPhase=0;
  const ADSR={a:0.1,d:0.2,s:0.6,r:0.3};

  const transformDefs=[
    {
      name:'Amplification',
      labelA:'Gain',fmtA:v=>(v*4).toFixed(1)+'×',
      labelB:null,
      color:'#00e5ff',
      desc:'Output = Input × Gain — the most fundamental signal operation.',
    },
    {
      name:'Filtering',
      labelA:'Cutoff',fmtA:v=>Math.round(v*18000+200)+'Hz',
      labelB:null,
      color:'#f59e0b',
      desc:'Low-pass: passes frequencies below cutoff, attenuates above.',
    },
    {
      name:'Enveloping',
      labelA:'Attack',fmtA:v=>(v*2).toFixed(2)+'s',
      labelB:'Sustain',fmtB:v=>Math.round(v*100)+'%',
      color:'#22c55e',
      desc:'ADSR multiplies signal amplitude over time — shaping each note.',
    },
    {
      name:'Quantization',
      labelA:'Bit Depth',fmtA:v=>Math.round(v*14+2)+'bit',
      labelB:null,
      color:'#7c3aed',
      desc:'Reduces continuous signal to discrete steps. More bits = smoother.',
    },
    {
      name:'FM Modulation',
      labelA:'Mod Index',fmtA:v=>(v*8).toFixed(1),
      labelB:'Carrier Hz',fmtB:v=>Math.round(v*440+110)+'Hz',
      color:'#ef4444',
      desc:'FM: Carrier frequency is modulated by modulator signal × index.',
    },
    {
      name:'Fourier Transform',
      labelA:'Window',fmtA:v=>Math.round(v*500+100)+'pts',
      labelB:null,
      color:'#00e5ff',
      desc:'Decomposes any waveform into its constituent frequencies.',
    },
  ];

  document.getElementById('transform-param-a').addEventListener('input',function(){
    const v=parseFloat(this.value)/100;
    paramA.set(v);
    const td=transformDefs[activeTransform];
    document.getElementById('tc-val-a').textContent=td.fmtA(v);
  });
  document.getElementById('transform-param-b').addEventListener('input',function(){
    const v=parseFloat(this.value)/100;
    paramB.set(v);
    const td=transformDefs[activeTransform];
    if(td.fmtB) document.getElementById('tc-val-b').textContent=td.fmtB(v);
  });

  window.setTransform=function(idx,btn){
    activeTransform=idx;
    document.querySelectorAll('.transform-tab').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    const td=transformDefs[idx];
    document.getElementById('tc-label-a').textContent=td.labelA;
    document.getElementById('tc-val-a').textContent=td.fmtA(paramA.value);
    const gbB=document.getElementById('tc-group-b');
    if(td.labelB){
      gbB.style.display='flex';
      document.getElementById('tc-label-b').textContent=td.labelB;
    } else {
      gbB.style.display='none';
    }
  };

  function drawPanel(panel,xs,ys,xw,xh,title,color){
    ctx.fillStyle='rgba(0,229,255,0.04)';
    ctx.strokeStyle=`rgba(${hexToRGBStr(color)},0.3)`;
    ctx.lineWidth=1;
    ctx.fillRect(xs,ys,xw,xh);
    ctx.strokeRect(xs,ys,xw,xh);
    ctx.font='9px Courier New';
    ctx.fillStyle=color;ctx.globalAlpha=0.7;
    ctx.fillText(title,xs+8,ys+14);
    ctx.globalAlpha=1;
  }

  function hexToRGBStr(hex){
    const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
    return `${r},${g},${b}`;
  }

  function drawWaveInPanel(fn,xs,ys,xw,xh,color,segs=80){
    const midY=ys+xh/2;
    ctx.beginPath();
    ctx.strokeStyle=color;ctx.lineWidth=1.5;
    glow(ctx,color,8);
    for(let i=0;i<=segs;i++){
      const x=i/segs;
      const y=fn(x);
      const px=xs+8+x*(xw-16), py=midY-y*(xh*0.35);
      i===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
    }
    ctx.stroke();noGlow(ctx);
  }

  function loop(){
    requestAnimationFrame(loop);
    const {W:w,H:h}=fitCanvas(canvas);
    W=w;H=h;
    paramA.update(masterDt);
    paramB.update(masterDt);
    phosphorDecay(ctx,W,H,0.08,'rgba(0,2,4,1)');

    const t=masterT;
    adsrPhase=(adsrPhase+masterDt*0.5)%1.4;

    const td=transformDefs[activeTransform];
    const color=td.color;
    const pA=paramA.value, pB=paramB.value;

    // Three panels: INPUT | TRANSFORM | OUTPUT
    const pW=(W-32)/3-8, pH=H-60, pY=30;
    const p1x=16, p2x=p1x+pW+12, p3x=p2x+pW+12;

    drawPanel('INPUT',p1x,pY,pW,pH,'INPUT →',color);
    drawPanel('PROCESS',p2x,pY,pW,pH,td.name.toUpperCase(),'#405868');
    drawPanel('OUTPUT',p3x,pY,pW,pH,'→ OUTPUT',color);

    // Source signal: composite sine
    const srcFn=x=>Math.sin(x*Math.PI*6)*0.7+Math.sin(x*Math.PI*11)*0.3;

    // Draw input
    drawWaveInPanel(srcFn,p1x,pY,pW,pH,color+'aa');

    // Transform-specific output + process
    let outFn;
    switch(activeTransform){
      case 0: // Amplification
        outFn=x=>Math.min(1,Math.max(-1,srcFn(x)*(pA*4)));
        // Gain indicator
        const gainH=pB>0?(pA*4)*pH*0.35:0;
        ctx.fillStyle=color; ctx.globalAlpha=0.15;
        ctx.fillRect(p2x+pW*0.3,pY+pH/2-gainH,pW*0.4,gainH);
        ctx.globalAlpha=1;
        ctx.font='11px Courier New';ctx.fillStyle=color;ctx.globalAlpha=0.6;
        ctx.fillText('×'+(pA*4).toFixed(1),p2x+pW/2-12,pY+pH/2+20);
        ctx.globalAlpha=1;
        break;
      case 1: // Filtering
        const cutoff=pA*0.8+0.1;
        outFn=x=>{
          let sum=0;
          for(let h=1;h<=8;h++){
            const freq=h*0.5;
            const atten=freq<cutoff?1:Math.exp(-(freq-cutoff)*8);
            sum+=Math.sin(x*Math.PI*6*h)*0.7/h*atten;
          }
          return sum*0.7;
        };
        // Frequency response curve
        ctx.beginPath();ctx.strokeStyle=color;ctx.lineWidth=1.5;ctx.globalAlpha=0.5;
        glow(ctx,color,6);
        for(let i=0;i<=60;i++){
          const f=i/60;
          const resp=f<cutoff?1:Math.exp(-(f-cutoff)*8);
          const px=p2x+8+f*(pW-16), py=pY+pH*0.8-resp*pH*0.6;
          i===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
        }
        ctx.stroke();noGlow(ctx);ctx.globalAlpha=1;
        ctx.font='9px Courier New';ctx.fillStyle=color;ctx.globalAlpha=0.5;
        ctx.fillText('CUT: '+(cutoff*20).toFixed(1)+'kHz',p2x+8,pY+pH-12);
        ctx.globalAlpha=1;
        break;
      case 2: // Enveloping
        const attack=pA*0.5+0.05;
        ADSR.a=attack;
        const envFn=p=>{
          if(p<ADSR.a) return p/ADSR.a;
          const dp=p-ADSR.a;
          if(dp<ADSR.d) return 1-(1-ADSR.s)*(dp/ADSR.d);
          const sp=dp-ADSR.d;
          if(sp<0.4) return ADSR.s;
          const rp=sp-0.4;
          if(rp<ADSR.r) return ADSR.s*(1-rp/ADSR.r);
          return 0;
        };
        // Draw ADSR envelope
        const epx=adsrPhase%1.4;
        ctx.beginPath();ctx.strokeStyle=color;ctx.lineWidth=1.5;
        glow(ctx,color,8);
        for(let i=0;i<=80;i++){
          const xp=i/80*1.2;
          const ev=envFn(xp);
          const px=p2x+8+xp/1.2*(pW-16), py=pY+pH*0.8-ev*pH*0.6;
          i===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
        }
        ctx.stroke();noGlow(ctx);
        // Playhead
        const hx=p2x+8+(epx/1.4)*(pW-16);
        ctx.strokeStyle='#ffffff';ctx.lineWidth=1;ctx.globalAlpha=0.4;
        ctx.beginPath();ctx.moveTo(hx,pY+10);ctx.lineTo(hx,pY+pH-10);ctx.stroke();
        ctx.globalAlpha=1;
        const eph=envFn(Math.min(epx,1.2));
        outFn=x=>srcFn(x)*eph;
        break;
      case 3: // Quantization
        const bits=Math.round(pA*14+2);
        const steps=Math.pow(2,bits);
        outFn=x=>{const v=srcFn(x);return Math.round(v*steps/2)/(steps/2);};
        ctx.font='11px Courier New';ctx.fillStyle=color;ctx.globalAlpha=0.6;
        ctx.fillText(bits+' bit',p2x+pW/2-16,pY+pH/2+20);
        ctx.fillText(steps+' steps',p2x+pW/2-24,pY+pH/2+36);
        ctx.globalAlpha=1;
        break;
      case 4: // FM
        const mi=pA*8;
        const carrier=pB*440+110;
        const modFreq=carrier*0.5;
        outFn=x=>Math.sin(x*Math.PI*8+mi*Math.sin(x*Math.PI*8*modFreq/carrier));
        // FM spectrum
        ctx.beginPath();ctx.strokeStyle=color;ctx.lineWidth=1;ctx.globalAlpha=0.4;
        for(let i=0;i<=40;i++){
          const f=i/40;
          const h=Math.abs(Math.sin(f*Math.PI*(mi+1)));
          const spx=p2x+8+f*(pW-16), spy=pY+pH-12-h*pH*0.5;
          ctx.moveTo(spx,pY+pH-12);ctx.lineTo(spx,spy);
        }
        ctx.stroke();ctx.globalAlpha=1;
        break;
      case 5: // Fourier
        const bins=32;
        outFn=srcFn;
        // Spectrum bars
        ctx.globalAlpha=0.8;
        glow(ctx,color,8);
        for(let i=0;i<bins;i++){
          const freq=(i+1)*0.3;
          const amp2=Math.abs(Math.sin(freq*2.7))*0.8+Math.abs(Math.sin(freq*1.3))*0.4;
          const barH=amp2*pH*0.55;
          const bx=p2x+8+i*(pW-16)/bins;
          const bw=Math.max(2,(pW-16)/bins-2);
          const hue=Math.round(i/bins*120);
          ctx.fillStyle=`hsl(${hue+180},80%,60%)`;
          ctx.fillRect(bx,pY+pH-12-barH,bw,barH);
        }
        noGlow(ctx);ctx.globalAlpha=1;
        break;
    }
    if(!outFn) outFn=srcFn;

    // Draw output
    drawWaveInPanel(outFn,p3x,pY,pW,pH,color);

    // Transform description
    ctx.font='10px Courier New';
    ctx.fillStyle='#405868';
    ctx.globalAlpha=0.7;
    const words=td.desc.split(' ');
    let line='',lineY=pY+pH+22;
    words.forEach(w=>{
      if((line+w).length>65){ctx.fillText(line,p1x,lineY);lineY+=15;line=w+' ';}
      else line+=w+' ';
    });
    if(line) ctx.fillText(line,p1x,lineY);
    ctx.globalAlpha=1;
  }
  requestAnimationFrame(loop);
})();

/* ═══════════════════════════════════════════════════════
   SECTION 6 — REALTIME DATA VISUALIZATION TRIPTYCH
═══════════════════════════════════════════════════════ */
(function initDataViz(){
  const canvA=document.getElementById('viz-a-canvas');
  const canvB=document.getElementById('viz-b-canvas');
  const canvC=document.getElementById('viz-c-canvas');
  if(!canvA||!canvB||!canvC) return;
  const ctxA=canvA.getContext('2d');
  const ctxB=canvB.getContext('2d');
  const ctxC=canvC.getContext('2d');

  // Stream A: 32-band spectrum → flower petals
  const specBands=Array.from({length:32},(_,i)=>new LagFilter(Math.random()*0.5,0.12));

  // Stream B: Scan line state
  let scanLine=0;
  const scanData=[];

  // Stream C: parametric curve
  let vizCSeq='fibonacci';
  const vizCData=[];
  let vizCt=new LagFilter(0,1.5);
  let vizCidx=0;

  function genSequence(type,n){
    const arr=[];
    if(type==='fibonacci'){
      let a=1,b=1;
      for(let i=0;i<n;i++){arr.push(a);[a,b]=[b,a+b];}
    } else if(type==='random'){
      let v=0;
      for(let i=0;i<n;i++){v+=Math.random()*2-1;arr.push(v);}
    } else if(type==='primes'){
      let n2=2;
      while(arr.length<n){
        let prime=true;
        for(let d=2;d*d<=n2;d++) if(n2%d===0){prime=false;break;}
        if(prime) arr.push(n2);
        n2++;
      }
    }
    return arr;
  }

  window.setVizCSequence=function(type,btn){
    vizCSeq=type;
    vizCData.length=0;
    document.querySelectorAll('#s6-dataviz .ctrl-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
  };

  function loopA(){
    requestAnimationFrame(loopA);
    const {W,H}=fitCanvas(canvA);
    phosphorDecay(ctxA,W,H,0.07,'rgba(0,2,4,1)');
    const t=masterT;

    // Simulate spectrum
    specBands.forEach((b,i)=>{
      const freq=i/32;
      b.set(Math.abs(Math.sin(t*(1+i*0.3)+i)*0.7+Math.sin(t*1.7*freq)*0.3)*0.9);
      b.update(masterDt);
    });

    const cx=W/2,cy=H/2;
    const baseR=Math.min(W,H)*0.18;
    const maxR=Math.min(W,H)*0.44;

    // BPM pulse ring
    const pulse=beatLag.value;
    const grad=ctxA.createRadialGradient(cx,cy,0,cx,cy,baseR*(1+pulse*0.3));
    grad.addColorStop(0,'rgba(0,229,255,0.15)');
    grad.addColorStop(1,'rgba(0,229,255,0)');
    ctxA.fillStyle=grad;
    ctxA.beginPath();ctxA.arc(cx,cy,baseR*(1.5+pulse),0,Math.PI*2);ctxA.fill();

    // Petal flower
    for(let i=0;i<32;i++){
      const angle=(i/32)*Math.PI*2-Math.PI/2;
      const r=baseR+specBands[i].value*(maxR-baseR);
      const c=`hsl(${Math.round(i/32*180+160)},80%,60%)`;
      const x=cx+Math.cos(angle)*r, y=cy+Math.sin(angle)*r;
      glow(ctxA,c,8);
      ctxA.strokeStyle=c;ctxA.lineWidth=1.5;ctxA.globalAlpha=0.8;
      ctxA.beginPath();ctxA.moveTo(cx,cy);ctxA.lineTo(x,y);ctxA.stroke();
      ctxA.fillStyle=c;
      ctxA.beginPath();ctxA.arc(x,y,2.5,0,Math.PI*2);ctxA.fill();
      noGlow(ctxA);ctxA.globalAlpha=1;
    }
    // Center
    glow(ctxA,'#00e5ff',12);
    ctxA.fillStyle='#00e5ff';ctxA.globalAlpha=0.9;
    ctxA.beginPath();ctxA.arc(cx,cy,4+pulse*3,0,Math.PI*2);ctxA.fill();
    noGlow(ctxA);ctxA.globalAlpha=1;
  }

  function loopB(){
    requestAnimationFrame(loopB);
    const {W,H}=fitCanvas(canvB);
    phosphorDecay(ctxB,W,H,0.12,'rgba(0,2,4,1)');
    const t=masterT;

    // Scan line advances
    scanLine=(scanLine+masterDt*60)%H;
    const scanY=Math.floor(scanLine);

    // Simulate gradient image
    for(let x=0;x<W;x+=4){
      const brightness=Math.sin(x/W*Math.PI*4+t*0.3)*0.5+0.5;
      const v=Math.round(brightness*255);
      ctxB.fillStyle=`rgb(${v},${Math.round(v*0.4)},${Math.round(v*0.8)})`;
      ctxB.globalAlpha=0.06;
      ctxB.fillRect(x,0,4,H);
    }
    ctxB.globalAlpha=1;

    // Scan line
    glow(ctxB,'#f59e0b',10);
    ctxB.strokeStyle='#f59e0b';ctxB.lineWidth=1.5;ctxB.globalAlpha=0.8;
    ctxB.beginPath();ctxB.moveTo(0,scanY);ctxB.lineTo(W,scanY);ctxB.stroke();
    noGlow(ctxB);ctxB.globalAlpha=1;

    // Data stream text (simulated pixel values)
    if(Math.random()<0.08){
      const brightness=Math.round((Math.sin(masterT*0.7)*0.5+0.5)*255);
      scanData.unshift(brightness);
      if(scanData.length>12) scanData.pop();
    }
    ctxB.font='9px Courier New';
    ctxB.fillStyle='#f59e0b';ctxB.globalAlpha=0.6;
    scanData.forEach((v,i)=>{
      ctxB.fillText(v.toString().padStart(3,'0'),4,H-12-i*12);
    });
    ctxB.globalAlpha=1;

    // Scan indicator
    ctxB.font='9px Courier New';ctxB.fillStyle='#f59e0b';ctxB.globalAlpha=0.5;
    ctxB.fillText('SCAN Y:'+scanY,W-72,12);
    ctxB.globalAlpha=1;
  }

  function loopC(){
    requestAnimationFrame(loopC);
    const {W,H}=fitCanvas(canvC);
    phosphorDecay(ctxC,W,H,0.05,'rgba(0,2,4,1)');
    const t=masterT;

    if(vizCData.length<64) {
      const seq=genSequence(vizCSeq,64);
      vizCData.push(...seq.slice(vizCData.length,vizCData.length+2));
    }

    if(vizCData.length<4) return;
    // Normalize
    const maxV=Math.max(...vizCData.map(Math.abs))||1;
    const norm=vizCData.map(v=>v/maxV);

    vizCt.set(t*0.3);vizCt.update(masterDt);

    // Parametric curve: x=n[i], y=n[i+1]
    ctxC.beginPath();
    for(let i=0;i<norm.length-1;i++){
      const xi=norm[i], yi=norm[i+1];
      const px=W/2+xi*(W*0.42);
      const py=H/2-yi*(H*0.42);
      const frac=i/norm.length;
      const hue=Math.round(frac*240+160);
      ctxC.strokeStyle=`hsl(${hue},80%,60%)`;
      ctxC.lineWidth=1.5;ctxC.globalAlpha=0.7;
      glow(ctxC,`hsl(${hue},80%,60%)`,6);
      ctxC.beginPath();
      if(i===0) ctxC.moveTo(px,py);
      const nx=norm[i+1]||(norm[0]), ny=norm[i+2]||(norm[1]);
      const px2=W/2+nx*(W*0.42), py2=H/2-ny*(H*0.42);
      ctxC.moveTo(px,py);ctxC.lineTo(px2,py2);
      ctxC.stroke();
      noGlow(ctxC);ctxC.globalAlpha=1;
    }

    // Current value dot
    const ci=Math.floor(t*8)%Math.max(1,norm.length-1);
    const cx=W/2+norm[ci]*(W*0.42), cy=H/2-norm[(ci+1)%norm.length]*(H*0.42);
    glow(ctxC,'#7c3aed',12);
    ctxC.fillStyle='#7c3aed';ctxC.globalAlpha=0.9;
    ctxC.beginPath();ctxC.arc(cx,cy,5,0,Math.PI*2);ctxC.fill();
    noGlow(ctxC);ctxC.globalAlpha=1;

    ctxC.font='9px Courier New';ctxC.fillStyle='#7c3aed';ctxC.globalAlpha=0.5;
    ctxC.fillText(vizCSeq.toUpperCase(),6,14);
    ctxC.globalAlpha=1;
  }

  requestAnimationFrame(loopA);
  requestAnimationFrame(loopB);
  requestAnimationFrame(loopC);
})();
</script>
