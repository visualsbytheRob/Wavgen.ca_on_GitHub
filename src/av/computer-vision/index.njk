<script>
'use strict';

/* ═══════════════════════════════════════════════════════════
   LAGFILTER — exponential smoothing, mandatory ≥15 instances
   ═══════════════════════════════════════════════════════════ */
class LagFilter {
  constructor(init, tau) { this.value = init; this.tau = tau; }
  update(target, dt) {
    const k = 1 - Math.exp(-dt / this.tau);
    this.value += k * (target - this.value);
    return this.value;
  }
}

// ── LagFilter instances ──────────────────────────────────────
const lagHeroMX    = new LagFilter(0.5, 0.35);
const lagHeroMY    = new LagFilter(0.5, 0.35);
const lagHeroHeat  = new LagFilter(0.5, 0.8);
const lagBlur      = new LagFilter(3.0, 0.25);
const lagThresh    = new LagFilter(128, 0.25);
const lagCanny     = new LagFilter(50,  0.25);
const lagSkelX     = new LagFilter(0.5, 0.15);
const lagSkelY     = new LagFilter(0.5, 0.15);
const lagFlow      = new LagFilter(0.6, 0.3);
const lagFlowDecay = new LagFilter(0.05,0.3);
const lagVecScale  = new LagFilter(1.0, 0.3);
const lagSegAlpha  = new LagFilter(0.7, 0.25);
const lagClassConf = new LagFilter(0.8, 0.25);
const lagBBoxConf  = new LagFilter(0.5, 0.2);
const lagMOG       = new LagFilter(0.015, 0.3);
const lagVarThresh = new LagFilter(32, 0.3);
const lagHeatmap   = new LagFilter(0.5, 0.5);

/* ═══════════════════════════════════════════════════════════
   UTILITIES
   ═══════════════════════════════════════════════════════════ */
function noise21(x, y) {
  const n = Math.sin(x * 127.1 + y * 311.7) * 43758.5453;
  return n - Math.floor(n);
}
function fbm(x, y, oct = 4) {
  let v = 0, a = 0.5, f = 1;
  for (let i = 0; i < oct; i++) {
    v += a * (noise21(x * f, y * f) * 2 - 1);
    a *= 0.5; f *= 2.1;
  }
  return v;
}
function lerp(a, b, t) { return a + (b - a) * t; }
function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
function rand(lo, hi) { return lo + Math.random() * (hi - lo); }

/* ═══════════════════════════════════════════════════════════
   SECTION 1 — HERO (WebGL thermal + Canvas2D skeleton overlay)
   ═══════════════════════════════════════════════════════════ */
(function initHero() {
  const wgl = document.getElementById('hero-webgl');
  const gl = wgl.getContext('webgl');
  let heroW, heroH, uTime, uRes, uMouse, uHeat, prog;
  let heroMX = 0.5, heroMY = 0.5;

  function resizeHero() {
    heroW = wgl.parentElement.clientWidth;
    heroH = wgl.parentElement.clientHeight;
    wgl.width = heroW; wgl.height = heroH;
    if (gl) gl.viewport(0, 0, heroW, heroH);
  }
  resizeHero();
  window.addEventListener('resize', resizeHero);

  if (!gl) return;

  const vsSrc = `
    attribute vec2 a_pos;
    void main() { gl_Position = vec4(a_pos, 0., 1.); }
  `;
  const fsSrc = `
    precision highp float;
    uniform float u_time;
    uniform vec2  u_res;
    uniform vec2  u_mouse;
    uniform float u_heat;

    float hash(vec2 p) {
      float h = dot(p, vec2(127.1, 311.7));
      return fract(sin(h) * 43758.5453);
    }
    float noise(vec2 p) {
      vec2 i = floor(p), f = fract(p);
      vec2 u = f * f * (3.0 - 2.0 * f);
      float a = hash(i);
      float b = hash(i + vec2(1,0));
      float c = hash(i + vec2(0,1));
      float d = hash(i + vec2(1,1));
      return mix(mix(a,b,u.x), mix(c,d,u.x), u.y);
    }
    float fbm(vec2 p) {
      float v = 0., a = 0.5;
      for (int i=0; i<5; i++) {
        v += a * noise(p);
        p *= 2.1; a *= 0.5;
      }
      return v;
    }
    vec3 thermalColor(float t) {
      t = clamp(t, 0., 1.);
      if (t < 0.25) return mix(vec3(0.0,0.0,0.1), vec3(0.0,0.2,0.5), t*4.);
      if (t < 0.5)  return mix(vec3(0.0,0.2,0.5), vec3(0.0,0.9,0.8), (t-0.25)*4.);
      if (t < 0.75) return mix(vec3(0.0,0.9,0.8), vec3(1.0,0.5,0.0), (t-0.5)*4.);
      return mix(vec3(1.0,0.5,0.0), vec3(1.0,0.1,0.0), (t-0.75)*4.);
    }
    void main() {
      vec2 uv = gl_FragCoord.xy / u_res;
      vec2 p = uv * 3.0;
      float t = u_time * 0.25;
      vec2 q = vec2(fbm(p + t), fbm(p + vec2(3.7, 1.3) + t));
      vec2 r = vec2(fbm(p + 2.*q + vec2(1.7, 9.2) + t*0.5),
                    fbm(p + 2.*q + vec2(8.3, 2.8) + t*0.3));
      float n = fbm(p + 2.*r);
      // heat blob near mouse
      vec2 md = uv - u_mouse;
      float heat = u_heat * exp(-dot(md,md) * 8.0);
      n = clamp(n + heat, 0., 1.);
      // scan line
      float scan = 1.0 - 0.05 * mod(gl_FragCoord.y * 0.5, 2.0);
      vec3 col = thermalColor(n) * scan;
      // vignette
      float vig = 1.0 - 0.5 * length(uv - 0.5);
      col *= vig;
      gl_FragColor = vec4(col, 1.0);
    }
  `;

  function compileShader(gl, type, src) {
    const s = gl.createShader(type);
    gl.shaderSource(s, src); gl.compileShader(s);
    return s;
  }
  prog = gl.createProgram();
  gl.attachShader(prog, compileShader(gl, gl.VERTEX_SHADER, vsSrc));
  gl.attachShader(prog, compileShader(gl, gl.FRAGMENT_SHADER, fsSrc));
  gl.linkProgram(prog); gl.useProgram(prog);

  const buf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, buf);
  gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1,1,-1,-1,1,1,1]), gl.STATIC_DRAW);
  const aPos = gl.getAttribLocation(prog, 'a_pos');
  gl.enableVertexAttribArray(aPos);
  gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

  uTime  = gl.getUniformLocation(prog, 'u_time');
  uRes   = gl.getUniformLocation(prog, 'u_res');
  uMouse = gl.getUniformLocation(prog, 'u_mouse');
  uHeat  = gl.getUniformLocation(prog, 'u_heat');

  const hero = document.getElementById('hero');
  hero.addEventListener('mousemove', e => {
    const r = wgl.getBoundingClientRect();
    heroMX = (e.clientX - r.left) / r.width;
    heroMY = 1 - (e.clientY - r.top) / r.height;
  });

  // Canvas2D skeleton overlay
  const oc = document.getElementById('hero-canvas');
  oc.width = heroW; oc.height = heroH;
  const ctx2 = oc.getContext('2d');

  // 17-keypoint skeleton (COCO format normalized)
  const KP_BASE = [
    [0.50,0.12],[0.48,0.10],[0.52,0.10],[0.45,0.11],[0.55,0.11],
    [0.38,0.22],[0.62,0.22],[0.32,0.36],[0.68,0.36],[0.28,0.50],
    [0.72,0.50],[0.42,0.52],[0.58,0.52],[0.40,0.68],[0.60,0.68],
    [0.38,0.84],[0.62,0.84]
  ];
  const SKELETON = [
    [0,1],[0,2],[1,3],[2,4],[5,6],[5,7],[7,9],[6,8],[8,10],
    [5,11],[6,12],[11,12],[11,13],[13,15],[12,14],[14,16]
  ];
  const KP_NAMES = ['Nose','LEye','REye','LEar','REar','LShoulder','RShoulder',
    'LElbow','RElbow','LWrist','RWrist','LHip','RHip','LKnee','RKnee','LAnkle','RAnkle'];

  let frame = 0, lastFps = performance.now(), fpsCount = 0, displayFps = 60;
  let lastT = performance.now();
  let skelMX = 0.5, skelMY = 0.5;

  hero.addEventListener('mousemove', e => {
    const r = hero.getBoundingClientRect();
    skelMX = (e.clientX - r.left) / r.width;
    skelMY = (e.clientY - r.top) / r.height;
  });

  function drawHero(ts) {
    const dt = clamp((ts - lastT) / 1000, 0, 0.05); lastT = ts;
    frame++;
    fpsCount++;
    if (ts - lastFps > 500) {
      displayFps = Math.round(fpsCount / ((ts - lastFps) / 1000));
      fpsCount = 0; lastFps = ts;
    }

    const smx = lagHeroMX.update(heroMX, dt);
    const smy = lagHeroMY.update(heroMY, dt);
    lagHeatmap.update(0.7, dt);

    // WebGL render
    if (gl) {
      resizeHero();
      wgl.width = heroW; wgl.height = heroH;
      gl.viewport(0, 0, heroW, heroH);
      gl.uniform1f(uTime, ts / 1000);
      gl.uniform2f(uRes, heroW, heroH);
      gl.uniform2f(uMouse, smx, smy);
      gl.uniform1f(uHeat, lagHeatmap.value);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
    }

    // Canvas2D skeleton
    oc.width = heroW; oc.height = heroH;
    ctx2.clearRect(0, 0, heroW, heroH);

    const sx = lagSkelX.update(skelMX, dt);
    const sy = lagSkelY.update(skelMY, dt);
    const anim = ts / 1000;

    // compute keypoint positions (walk cycle animation)
    const kps = KP_BASE.map(([nx, ny], i) => {
      const ox = (nx - 0.5) + (sx - 0.5) * 0.15;
      const oy = ny;
      // add subtle sway
      const swayX = Math.sin(anim * 1.2 + i * 0.5) * 0.008;
      const swayY = Math.cos(anim * 0.9 + i * 0.3) * 0.004;
      return {
        x: (ox + 0.5 + swayX) * heroW,
        y: (oy + swayY) * heroH,
        conf: 0.85 + 0.14 * noise21(i * 3.1, anim * 0.5)
      };
    });

    // draw skeleton edges
    ctx2.strokeStyle = 'rgba(0, 229, 212, 0.6)';
    ctx2.lineWidth = 1.5;
    SKELETON.forEach(([a, b]) => {
      ctx2.beginPath();
      ctx2.moveTo(kps[a].x, kps[a].y);
      ctx2.lineTo(kps[b].x, kps[b].y);
      ctx2.stroke();
    });

    // draw keypoints
    kps.forEach((kp, i) => {
      const r2 = kp.conf * 5;
      ctx2.beginPath();
      ctx2.arc(kp.x, kp.y, r2, 0, Math.PI * 2);
      ctx2.fillStyle = i === 0 ? '#FF2020' : '#00E5D4';
      ctx2.shadowColor = i === 0 ? '#FF2020' : '#00E5D4';
      ctx2.shadowBlur = 8;
      ctx2.fill();
      ctx2.shadowBlur = 0;
    });

    // bounding box around full body
    const xs = kps.map(k => k.x), ys = kps.map(k => k.y);
    const bx = Math.min(...xs) - 12, by = Math.min(...ys) - 12;
    const bw = Math.max(...xs) - bx + 24, bh = Math.max(...ys) - by + 24;
    ctx2.strokeStyle = 'rgba(255, 32, 32, 0.4)';
    ctx2.lineWidth = 1;
    ctx2.setLineDash([4, 4]);
    ctx2.strokeRect(bx, by, bw, bh);
    ctx2.setLineDash([]);

    // corner brackets
    const cornerLen = 12;
    ctx2.strokeStyle = '#FF2020'; ctx2.lineWidth = 2;
    [[bx, by], [bx+bw, by], [bx, by+bh], [bx+bw, by+bh]].forEach(([cx, cy], i) => {
      const sx2 = (i % 2 === 0) ? 1 : -1;
      const sy2 = (i < 2) ? 1 : -1;
      ctx2.beginPath();
      ctx2.moveTo(cx + sx2 * cornerLen, cy);
      ctx2.lineTo(cx, cy); ctx2.lineTo(cx, cy + sy2 * cornerLen);
      ctx2.stroke();
    });

    // HUD
    document.getElementById('hud-frame').textContent = String(frame).padStart(4, '0');
    document.getElementById('hud-conf').textContent = (0.88 + 0.08 * Math.sin(anim)).toFixed(2);
    document.getElementById('hud-fps').textContent = displayFps;

    requestAnimationFrame(drawHero);
  }
  requestAnimationFrame(drawHero);
})();

/* ═══════════════════════════════════════════════════════════
   SECTION 2 — OPENCV PIPELINE
   ═══════════════════════════════════════════════════════════ */
(function initOpenCV() {
  const W = 140, H = 105;
  const canvases = ['cv-raw','cv-gray','cv-blur','cv-thresh','cv-canny','cv-contour']
    .map(id => ({ id, ctx: document.getElementById(id).getContext('2d') }));

  // generate a synthetic "scene" image
  const sceneData = new Float32Array(W * H);
  for (let y = 0; y < H; y++) {
    for (let x = 0; x < W; x++) {
      // simple shapes
      const cx = x / W, cy = y / H;
      let v = fbm(cx * 4, cy * 4) * 0.3;
      // circle
      if ((cx-0.3)**2 + (cy-0.35)**2 < 0.04) v += 0.5;
      // rectangle
      if (cx > 0.55 && cx < 0.85 && cy > 0.2 && cy < 0.6) v += 0.4;
      // triangle-ish
      if (cy > 0.65 && cx > 0.15 && cx < 0.5 && cy < cx * 1.5 + 0.2) v += 0.45;
      sceneData[y * W + x] = clamp(v, 0, 1);
    }
  }

  let blurTarget = 3.0, threshTarget = 128, cannyTarget = 50;

  document.getElementById('sl-blur').addEventListener('input', e => {
    blurTarget = 0.5 + e.target.value / 100 * 9.5;
    document.getElementById('vl-blur').textContent = blurTarget.toFixed(1);
  });
  document.getElementById('sl-thresh').addEventListener('input', e => {
    threshTarget = Math.round(e.target.value / 100 * 255);
    document.getElementById('vl-thresh').textContent = threshTarget;
  });
  document.getElementById('sl-canny').addEventListener('input', e => {
    cannyTarget = Math.round(e.target.value / 100 * 200);
    document.getElementById('vl-canny').textContent = cannyTarget;
  });

  function applyGaussianBlur(src, sigma) {
    const ksize = Math.max(1, Math.round(sigma * 2));
    const kernel = [];
    let sum = 0;
    for (let k = -ksize; k <= ksize; k++) {
      const v = Math.exp(-k * k / (2 * sigma * sigma));
      kernel.push(v); sum += v;
    }
    const norm = kernel.map(v => v / sum);
    const tmp = new Float32Array(W * H);
    // horizontal
    for (let y = 0; y < H; y++) {
      for (let x = 0; x < W; x++) {
        let acc = 0;
        for (let k = -ksize; k <= ksize; k++) {
          const xi = clamp(x + k, 0, W - 1);
          acc += src[y * W + xi] * norm[k + ksize];
        }
        tmp[y * W + x] = acc;
      }
    }
    const out = new Float32Array(W * H);
    // vertical
    for (let y = 0; y < H; y++) {
      for (let x = 0; x < W; x++) {
        let acc = 0;
        for (let k = -ksize; k <= ksize; k++) {
          const yi = clamp(y + k, 0, H - 1);
          acc += tmp[yi * W + x] * norm[k + ksize];
        }
        out[y * W + x] = acc;
      }
    }
    return out;
  }

  function putGray(ctx, data) {
    const img = ctx.createImageData(W, H);
    for (let i = 0; i < data.length; i++) {
      const v = Math.round(clamp(data[i], 0, 1) * 255);
      img.data[i*4] = v; img.data[i*4+1] = v; img.data[i*4+2] = v; img.data[i*4+3] = 255;
    }
    ctx.putImageData(img, 0, 0);
  }

  function putColor(ctx, data, colorFn) {
    const img = ctx.createImageData(W, H);
    for (let i = 0; i < data.length; i++) {
      const [r,g,b] = colorFn(data[i]);
      img.data[i*4] = r; img.data[i*4+1] = g; img.data[i*4+2] = b; img.data[i*4+3] = 255;
    }
    ctx.putImageData(img, 0, 0);
  }

  function renderCV(dt) {
    const blurVal = lagBlur.update(blurTarget, dt);
    const threshVal = lagThresh.update(threshTarget, dt) / 255;
    const cannyVal = lagCanny.update(cannyTarget, dt) / 200;

    // raw: false color thermal
    putColor(canvases[0].ctx, sceneData, v => {
      if (v < 0.25) return [0, 0, Math.round(v * 4 * 180)];
      if (v < 0.5)  return [0, Math.round((v-0.25)*4*200), Math.round(200 - (v-0.25)*4*200)];
      if (v < 0.75) return [Math.round((v-0.5)*4*255), Math.round(200 - (v-0.5)*4*200), 0];
      return [255, 0, 0];
    });

    // gray
    putGray(canvases[1].ctx, sceneData);

    // blur
    const blurred = applyGaussianBlur(sceneData, blurVal);
    putGray(canvases[2].ctx, blurred);

    // threshold
    const thresh = blurred.map(v => v > threshVal ? 1 : 0);
    putGray(canvases[3].ctx, thresh);

    // canny (simplified: gradient magnitude)
    const sobel = new Float32Array(W * H);
    for (let y = 1; y < H-1; y++) {
      for (let x = 1; x < W-1; x++) {
        const gx = blurred[(y)*W+(x+1)] - blurred[(y)*W+(x-1)];
        const gy = blurred[(y+1)*W+(x)] - blurred[(y-1)*W+(x)];
        const mag = Math.sqrt(gx*gx + gy*gy);
        sobel[y*W+x] = mag > cannyVal ? 1 : 0;
      }
    }
    putColor(canvases[4].ctx, sobel, v => [0, Math.round(v*229), Math.round(v*212)]);

    // contours: dilation of edges
    const dilated = new Float32Array(W * H);
    for (let y = 1; y < H-1; y++) {
      for (let x = 1; x < W-1; x++) {
        const v = sobel[y*W+x] + sobel[(y-1)*W+x] + sobel[(y+1)*W+x] +
                  sobel[y*W+(x-1)] + sobel[y*W+(x+1)];
        dilated[y*W+x] = v > 0 ? 1 : 0;
      }
    }
    putColor(canvases[5].ctx, dilated, v => [Math.round(v*255), Math.round(v*32), Math.round(v*32)]);
  }

  let lastCV = performance.now();
  function animCV(ts) {
    const dt = clamp((ts - lastCV) / 1000, 0, 0.05); lastCV = ts;
    renderCV(dt);
    requestAnimationFrame(animCV);
  }
  requestAnimationFrame(animCV);
})();

/* ═══════════════════════════════════════════════════════════
   SECTION 3 — POSE ESTIMATION
   ═══════════════════════════════════════════════════════════ */
(function initPose() {
  const canvas = document.getElementById('pose-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;

  const KEYPOINTS = [
    [0.50,0.10],[0.47,0.08],[0.53,0.08],[0.44,0.09],[0.56,0.09],
    [0.37,0.22],[0.63,0.22],[0.29,0.38],[0.71,0.38],[0.24,0.54],
    [0.76,0.54],[0.40,0.54],[0.60,0.54],[0.37,0.72],[0.63,0.72],
    [0.35,0.88],[0.65,0.88]
  ];
  const BONES = [
    [0,1],[0,2],[1,3],[2,4],[5,6],[5,7],[7,9],[6,8],[8,10],
    [5,11],[6,12],[11,12],[11,13],[13,15],[12,14],[14,16]
  ];
  const NAMES = ['Nose','L.Eye','R.Eye','L.Ear','R.Ear','L.Shldr','R.Shldr',
    'L.Elbow','R.Elbow','L.Wrist','R.Wrist','L.Hip','R.Hip',
    'L.Knee','R.Knee','L.Ankle','R.Ankle'];

  let mx = 0.5, my = 0.5;
  canvas.addEventListener('mousemove', e => {
    const r = canvas.getBoundingClientRect();
    mx = (e.clientX - r.left) / canvas.clientWidth;
    my = (e.clientY - r.top) / canvas.clientHeight;
  });

  // build joint list UI
  const jl = document.getElementById('joint-list');
  const confEls = NAMES.map((n, i) => {
    const d = document.createElement('div');
    d.className = 'joint-item';
    d.innerHTML = `${n} <span id="jc-${i}">0.94</span>`;
    jl.appendChild(d);
    return document.getElementById(`jc-${i}`);
  });

  let lastP = performance.now();
  function animPose(ts) {
    const dt = clamp((ts - lastP) / 1000, 0, 0.05); lastP = ts;
    const t = ts / 1000;
    const smx = lagSkelX.update(mx, dt);
    const smy = lagSkelY.update(my, dt);

    ctx.fillStyle = 'rgba(8,2,2,0.3)';
    ctx.fillRect(0, 0, W, H);

    // grid
    ctx.strokeStyle = 'rgba(255,32,32,0.06)';
    ctx.lineWidth = 1;
    for (let gx = 0; gx < W; gx += 40) {
      ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke();
    }
    for (let gy = 0; gy < H; gy += 40) {
      ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke();
    }

    const influence = 0.2;
    const kps = KEYPOINTS.map(([nx, ny], i) => {
      const ox = (nx - 0.5);
      const swayX = Math.sin(t * 1.1 + i * 0.6) * 0.015 + (smx - 0.5) * influence;
      const swayY = Math.cos(t * 0.8 + i * 0.4) * 0.008 + (smy - 0.5) * influence * 0.5;
      return {
        x: (ox + 0.5 + swayX) * W,
        y: (ny + swayY) * H,
        conf: clamp(0.80 + 0.18 * noise21(i * 2.3, t * 0.3), 0, 1)
      };
    });

    // bones
    BONES.forEach(([a, b]) => {
      const c = (kps[a].conf + kps[b].conf) / 2;
      ctx.strokeStyle = `rgba(0,229,212,${c * 0.7})`;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(kps[a].x, kps[a].y);
      ctx.lineTo(kps[b].x, kps[b].y);
      ctx.stroke();
    });

    // keypoints
    kps.forEach((kp, i) => {
      const isHead = i < 5;
      ctx.beginPath();
      ctx.arc(kp.x, kp.y, isHead ? 6 : 4, 0, Math.PI * 2);
      ctx.fillStyle = isHead ? '#FF2020' : '#00E5D4';
      ctx.shadowColor = isHead ? '#FF2020' : '#00E5D4';
      ctx.shadowBlur = 10;
      ctx.fill();
      ctx.shadowBlur = 0;

      // confidence ring
      ctx.strokeStyle = `rgba(255,255,255,${kp.conf * 0.4})`;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.arc(kp.x, kp.y, (isHead ? 6 : 4) + 3, 0, Math.PI * 2 * kp.conf);
      ctx.stroke();

      confEls[i].textContent = kp.conf.toFixed(2);
    });

    requestAnimationFrame(animPose);
  }
  requestAnimationFrame(animPose);
})();

/* ═══════════════════════════════════════════════════════════
   SECTION 4 — OPTICAL FLOW
   ═══════════════════════════════════════════════════════════ */
(function initFlow() {
  const canvas = document.getElementById('flow-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;

  let flowTarget = 0.6, decayTarget = 0.05, vecScaleTarget = 1.0;
  let ptCount = 200;
  let mx = W / 2, my = H / 2;

  document.getElementById('sl-flow').addEventListener('input', e => {
    flowTarget = e.target.value / 100;
    document.getElementById('vl-flow').textContent = flowTarget.toFixed(2);
  });
  document.getElementById('sl-particles').addEventListener('input', e => {
    ptCount = Math.round(10 + e.target.value / 100 * 390);
    document.getElementById('vl-particles').textContent = ptCount;
  });
  document.getElementById('sl-decay').addEventListener('input', e => {
    decayTarget = 0.01 + e.target.value / 100 * 0.14;
    document.getElementById('vl-decay').textContent = decayTarget.toFixed(2);
  });
  document.getElementById('sl-vecscale').addEventListener('input', e => {
    vecScaleTarget = e.target.value / 100 * 3.0;
    document.getElementById('vl-vecscale').textContent = vecScaleTarget.toFixed(1);
  });

  canvas.addEventListener('mousemove', e => {
    const r = canvas.getBoundingClientRect();
    mx = (e.clientX - r.left) / canvas.clientWidth * W;
    my = (e.clientY - r.top) / canvas.clientHeight * H;
  });

  // particles
  let pts = Array.from({ length: 500 }, () => ({
    x: rand(0, W), y: rand(0, H),
    vx: 0, vy: 0, age: rand(0, 100), life: rand(60, 180)
  }));

  let lastF = performance.now();
  function animFlow(ts) {
    const dt = clamp((ts - lastF) / 1000, 0, 0.05); lastF = ts;
    const t = ts / 1000;

    const fSpd = lagFlow.update(flowTarget, dt);
    const fDec = lagFlowDecay.update(decayTarget, dt);
    const fVec = lagVecScale.update(vecScaleTarget, dt);

    ctx.fillStyle = `rgba(8,2,2,${fDec + 0.02})`;
    ctx.fillRect(0, 0, W, H);

    // vector field (sparse grid overlay)
    const gs = 50;
    for (let gy = gs; gy < H; gy += gs) {
      for (let gx = gs; gx < W; gx += gs) {
        const nx = gx / W, ny = gy / H;
        // curl noise field
        const dx = (mx / W - nx);
        const dy = (my / H - ny);
        const dist = Math.sqrt(dx*dx + dy*dy) + 0.001;
        const curlX = -dy / (dist * 0.5 + 0.5) * fSpd * fVec * 0.5;
        const curlY = dx / (dist * 0.5 + 0.5) * fSpd * fVec * 0.5;
        const fbmOff = fbm(nx * 3 + t * 0.2, ny * 3 + t * 0.15) * 0.3;
        const vx = curlX + Math.cos(fbmOff * Math.PI * 2) * 0.1 * fVec;
        const vy = curlY + Math.sin(fbmOff * Math.PI * 2) * 0.1 * fVec;
        ctx.strokeStyle = 'rgba(0,229,212,0.15)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(gx, gy);
        ctx.lineTo(gx + vx * gs, gy + vy * gs);
        ctx.stroke();
        // arrowhead
        ctx.beginPath();
        ctx.arc(gx + vx * gs, gy + vy * gs, 2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(0,229,212,0.2)';
        ctx.fill();
      }
    }

    // particles
    while (pts.length < ptCount) {
      pts.push({ x: rand(0, W), y: rand(0, H), vx: 0, vy: 0, age: 0, life: rand(80, 200) });
    }
    pts.length = Math.min(pts.length, 500);

    pts.slice(0, ptCount).forEach(p => {
      p.age += 1;
      if (p.age > p.life) {
        p.x = rand(0, W); p.y = rand(0, H);
        p.vx = 0; p.vy = 0; p.age = 0; p.life = rand(80, 200);
      }
      const nx = p.x / W, ny = p.y / H;
      const dx = (mx / W - nx);
      const dy = (my / H - ny);
      const dist = Math.sqrt(dx*dx + dy*dy) + 0.001;
      const ax = -dy / (dist * 0.5 + 0.5) * fSpd * 1.5;
      const ay = dx / (dist * 0.5 + 0.5) * fSpd * 1.5;
      const no = fbm(nx * 2 + t * 0.2, ny * 2 + t * 0.15);
      p.vx += (ax + Math.cos(no * 6.28) * 0.2) * dt * 60;
      p.vy += (ay + Math.sin(no * 6.28) * 0.2) * dt * 60;
      p.vx *= 0.96; p.vy *= 0.96;

      const alpha = clamp((1 - p.age / p.life) * 0.9, 0, 1);
      const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
      const hue = clamp(speed * 15, 0, 1);
      ctx.strokeStyle = `rgba(${Math.round(lerp(0,255,hue))},${Math.round(lerp(229,32,hue))},${Math.round(lerp(212,32,hue))},${alpha})`;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(p.x - p.vx * 3, p.y - p.vy * 3);
      ctx.lineTo(p.x, p.y);
      ctx.stroke();
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0 || p.x > W || p.y < 0 || p.y > H) {
        p.x = rand(0, W); p.y = rand(0, H); p.vx = 0; p.vy = 0; p.age = 0;
      }
    });

    // cursor
    ctx.beginPath();
    ctx.arc(mx, my, 8, 0, Math.PI * 2);
    ctx.strokeStyle = 'rgba(255,32,32,0.6)';
    ctx.lineWidth = 1;
    ctx.stroke();

    requestAnimationFrame(animFlow);
  }
  requestAnimationFrame(animFlow);
})();

/* ═══════════════════════════════════════════════════════════
   SECTION 5 — SEMANTIC SEGMENTATION
   ═══════════════════════════════════════════════════════════ */
(function initSegmentation() {
  const canvas = document.getElementById('seg-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;

  const CLASSES = [
    { name: 'Person',   color: [255, 32,  32],  prob: 0.9 },
    { name: 'Road',     color: [80,  80,  200], prob: 0.85},
    { name: 'Sky',      color: [100, 180, 255], prob: 0.95},
    { name: 'Vehicle',  color: [255, 180, 0],   prob: 0.78},
    { name: 'Building', color: [150, 100, 50],  prob: 0.82},
    { name: 'Foliage',  color: [0,   180, 80],  prob: 0.88},
    { name: 'Sidewalk', color: [160, 160, 160], prob: 0.76},
    { name: 'Unknown',  color: [40,  20,  20],  prob: 0.5 }
  ];

  // build legend
  const leg = document.getElementById('seg-legend');
  CLASSES.forEach(c => {
    const d = document.createElement('div');
    d.className = 'seg-chip';
    d.innerHTML = `<div class="seg-swatch" style="background:rgb(${c.color.join(',')})"></div>${c.name}`;
    leg.appendChild(d);
  });

  // generate class map
  const classMap = new Uint8Array(W * H);
  for (let y = 0; y < H; y++) {
    for (let x = 0; x < W; x++) {
      const nx = x / W, ny = y / H;
      let cls = 7;
      if (ny < 0.35) cls = 2; // sky
      else if (ny > 0.35 && ny < 0.45) cls = 4; // building horizon
      else if (nx > 0.3 && nx < 0.7 && ny > 0.45 && ny < 0.85) cls = 1; // road
      else if (ny > 0.75) cls = 6; // sidewalk
      // person blob
      if ((nx - 0.5)**2 + (ny - 0.55)**2 < 0.012) cls = 0;
      // vehicle
      if (nx > 0.65 && nx < 0.85 && ny > 0.48 && ny < 0.72) cls = 3;
      // foliage
      if (nx < 0.2 && ny > 0.35 && ny < 0.65) cls = 5;
      // noise
      const n = noise21(x * 0.07 + 3.1, y * 0.07 + 1.7);
      if (n > 0.85) cls = Math.floor(n * 8) % 8;
      classMap[y * W + x] = cls;
    }
  }

  let alphaTarget = 0.7, confTarget = 0.8;
  let mx = W / 2, my = H / 2;

  document.getElementById('sl-segalpha').addEventListener('input', e => {
    alphaTarget = e.target.value / 100;
    document.getElementById('vl-segalpha').textContent = alphaTarget.toFixed(2);
  });
  document.getElementById('sl-classconf').addEventListener('input', e => {
    confTarget = e.target.value / 100;
    document.getElementById('vl-classconf').textContent = confTarget.toFixed(2);
  });
  canvas.addEventListener('mousemove', e => {
    const r = canvas.getBoundingClientRect();
    mx = (e.clientX - r.left) / canvas.clientWidth * W;
    my = (e.clientY - r.top) / canvas.clientHeight * H;
  });

  let lastS = performance.now();
  let imgCache = null;

  function renderSeg(ts) {
    const dt = clamp((ts - lastS) / 1000, 0, 0.05); lastS = ts;
    const alpha = lagSegAlpha.update(alphaTarget, dt);
    const conf = lagClassConf.update(confTarget, dt);

    if (!imgCache) {
      imgCache = ctx.createImageData(W, H);
      for (let i = 0; i < W * H; i++) {
        const c = CLASSES[classMap[i]].color;
        imgCache.data[i*4] = c[0];
        imgCache.data[i*4+1] = c[1];
        imgCache.data[i*4+2] = c[2];
        imgCache.data[i*4+3] = 255;
      }
    }

    // blend: dark base + colored segments
    ctx.fillStyle = '#080202';
    ctx.fillRect(0, 0, W, H);

    // draw with confidence-controlled alpha
    const img2 = ctx.createImageData(W, H);
    for (let i = 0; i < W * H; i++) {
      const c = CLASSES[classMap[i]];
      const cConf = c.prob * conf;
      const a = Math.round(alpha * cConf * 255);
      img2.data[i*4] = c.color[0];
      img2.data[i*4+1] = c.color[1];
      img2.data[i*4+2] = c.color[2];
      img2.data[i*4+3] = a;
    }
    ctx.putImageData(img2, 0, 0);

    // grid
    ctx.strokeStyle = 'rgba(0,229,212,0.06)';
    ctx.lineWidth = 1;
    for (let gx = 0; gx < W; gx += 40) {
      ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke();
    }
    for (let gy = 0; gy < H; gy += 40) {
      ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke();
    }

    // cursor crosshair + class label
    const px = Math.round(clamp(mx, 0, W-1));
    const py = Math.round(clamp(my, 0, H-1));
    const cls = CLASSES[classMap[py * W + px]];

    ctx.strokeStyle = 'rgba(255,32,32,0.8)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(mx - 15, my); ctx.lineTo(mx + 15, my); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(mx, my - 15); ctx.lineTo(mx, my + 15); ctx.stroke();
    ctx.beginPath(); ctx.arc(mx, my, 6, 0, Math.PI * 2); ctx.stroke();

    ctx.fillStyle = '#080202';
    ctx.fillRect(mx + 12, my - 20, 110, 32);
    ctx.strokeStyle = `rgb(${cls.color.join(',')})`;
    ctx.strokeRect(mx + 12, my - 20, 110, 32);
    ctx.fillStyle = `rgb(${cls.color.join(',')})`;
    ctx.font = '10px Courier New';
    ctx.fillText(cls.name.toUpperCase(), mx + 18, my - 6);
    ctx.fillStyle = '#6A4A4A';
    ctx.fillText(`conf: ${(cls.prob * conf).toFixed(2)}`, mx + 18, my + 7);

    requestAnimationFrame(renderSeg);
  }
  requestAnimationFrame(renderSeg);
})();

/* ═══════════════════════════════════════════════════════════
   SECTION 6 — OBJECT DETECTION
   ═══════════════════════════════════════════════════════════ */
(function initDetection() {
  const canvas = document.getElementById('detect-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;

  const CLASS_NAMES = ['Person','Car','Bicycle','Dog','Cat','Chair','Bottle','Laptop','Phone','Backpack'];
  const COLORS = ['#FF2020','#00E5D4','#FF8800','#8800FF','#00FF88','#FF00CC','#FFCC00','#00CCFF','#FF6644','#88FF00'];

  let iouTarget = 0.45, confThreshTarget = 0.5;
  let detections = [];

  function generateDetections(iou, confThresh) {
    const count = 4 + Math.floor(Math.random() * 5);
    const dets = [];
    for (let i = 0; i < count; i++) {
      const conf = 0.4 + Math.random() * 0.58;
      if (conf < confThresh) continue;
      const cls = Math.floor(Math.random() * CLASS_NAMES.length);
      const w = 80 + Math.random() * 200;
      const h = 80 + Math.random() * 150;
      const x = Math.random() * (W - w);
      const y = Math.random() * (H - h);
      dets.push({ cls, conf, x, y, w, h });
    }
    return dets;
  }

  document.getElementById('sl-iou').addEventListener('input', e => {
    iouTarget = e.target.value / 100;
    document.getElementById('vl-iou').textContent = iouTarget.toFixed(2);
  });
  document.getElementById('sl-confthresh').addEventListener('input', e => {
    confThreshTarget = e.target.value / 100;
    document.getElementById('vl-confthresh').textContent = confThreshTarget.toFixed(2);
    detections = generateDetections(iouTarget, confThreshTarget);
    updateTable();
  });
  canvas.addEventListener('click', () => {
    detections = generateDetections(iouTarget, confThreshTarget);
    updateTable();
  });

  detections = generateDetections(0.45, 0.5);

  function updateTable() {
    const tbody = document.getElementById('bbox-tbody');
    tbody.innerHTML = '';
    detections.forEach(d => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td style="color:${COLORS[d.cls]}">${CLASS_NAMES[d.cls]}</td>
        <td>${d.conf.toFixed(3)}</td>
        <td style="color:#6A4A4A">${Math.round(d.x)},${Math.round(d.y)},${Math.round(d.w)},${Math.round(d.h)}</td>
        <td><div class="conf-bar" style="width:${Math.round(d.conf*100)}px"></div></td>
      `;
      tbody.appendChild(tr);
    });
  }
  updateTable();

  // animated scan line
  let scanY = 0;
  let lastD = performance.now();

  function animDetect(ts) {
    const dt = clamp((ts - lastD) / 1000, 0, 0.05); lastD = ts;
    lagBBoxConf.update(confThreshTarget, dt);

    ctx.fillStyle = '#080202';
    ctx.fillRect(0, 0, W, H);

    // grid
    ctx.strokeStyle = 'rgba(255,32,32,0.04)';
    for (let gx = 0; gx < W; gx += 60) {
      ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke();
    }
    for (let gy = 0; gy < H; gy += 60) {
      ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke();
    }

    // draw detection boxes
    detections.forEach(d => {
      ctx.strokeStyle = COLORS[d.cls];
      ctx.lineWidth = 2;
      ctx.strokeRect(d.x, d.y, d.w, d.h);

      // corner brackets
      const cl = 14;
      [[d.x, d.y, 1, 1],[d.x+d.w, d.y, -1, 1],[d.x, d.y+d.h, 1, -1],[d.x+d.w, d.y+d.h, -1, -1]].forEach(([cx, cy, sx, sy]) => {
        ctx.beginPath();
        ctx.moveTo(cx + sx * cl, cy); ctx.lineTo(cx, cy); ctx.lineTo(cx, cy + sy * cl);
        ctx.strokeStyle = COLORS[d.cls]; ctx.lineWidth = 2; ctx.stroke();
      });

      // label
      ctx.fillStyle = COLORS[d.cls];
      ctx.font = 'bold 11px Courier New';
      const label = `${CLASS_NAMES[d.cls]} ${(d.conf * 100).toFixed(0)}%`;
      const tw = ctx.measureText(label).width + 8;
      ctx.fillRect(d.x, d.y - 18, tw, 16);
      ctx.fillStyle = '#080202';
      ctx.fillText(label, d.x + 4, d.y - 6);
    });

    // scan line
    scanY = (scanY + 2) % H;
    const gradient = ctx.createLinearGradient(0, scanY - 8, 0, scanY + 8);
    gradient.addColorStop(0, 'rgba(0,229,212,0)');
    gradient.addColorStop(0.5, 'rgba(0,229,212,0.15)');
    gradient.addColorStop(1, 'rgba(0,229,212,0)');
    ctx.fillStyle = gradient;
    ctx.fillRect(0, scanY - 8, W, 16);

    requestAnimationFrame(animDetect);
  }
  requestAnimationFrame(animDetect);
})();

/* ═══════════════════════════════════════════════════════════
   SECTION 7 — BACKGROUND SUBTRACTION (MOG2)
   ═══════════════════════════════════════════════════════════ */
(function initMOG() {
  const sceneC = document.getElementById('mog-scene');
  const maskC  = document.getElementById('mog-mask');
  const irC    = document.getElementById('mog-ir');
  const sCtx   = sceneC.getContext('2d');
  const mCtx   = maskC.getContext('2d');
  const iCtx   = irC.getContext('2d');
  const W = sceneC.width, H = sceneC.height;

  let mogTarget = 0.015, varTarget = 32;
  let mx = W / 2, my = H / 2;

  document.getElementById('sl-mog').addEventListener('input', e => {
    mogTarget = 0.001 + e.target.value / 100 * 0.099;
    document.getElementById('vl-mog').textContent = mogTarget.toFixed(3);
  });
  document.getElementById('sl-varthresh').addEventListener('input', e => {
    varTarget = Math.round(4 + e.target.value / 100 * 124);
    document.getElementById('vl-varthresh').textContent = varTarget;
  });
  sceneC.addEventListener('mousemove', e => {
    const r = sceneC.getBoundingClientRect();
    mx = (e.clientX - r.left) / sceneC.clientWidth * W;
    my = (e.clientY - r.top) / sceneC.clientHeight * H;
  });

  // background model (grayscale)
  const bgModel = new Float32Array(W * H);
  for (let i = 0; i < W * H; i++) {
    const x = i % W, y = Math.floor(i / W);
    bgModel[i] = 0.15 + fbm(x / W * 4, y / H * 4) * 0.15;
  }

  let lastM = performance.now();
  function animMOG(ts) {
    const dt = clamp((ts - lastM) / 1000, 0, 0.05); lastM = ts;
    const t = ts / 1000;
    const mogRate = lagMOG.update(mogTarget, dt);
    const varT = lagVarThresh.update(varTarget, dt);

    // foreground: moving blob (cursor)
    const scene = new Float32Array(W * H);
    for (let y = 0; y < H; y++) {
      for (let x = 0; x < W; x++) {
        const bg = bgModel[y * W + x];
        // person blob near cursor
        const dx = x - mx, dy = y - my;
        const d2 = dx*dx + dy*dy;
        const blob = Math.exp(-d2 / (800)) * 0.5;
        // noise perturbation
        const n = noise21(x * 0.05 + t * 0.3, y * 0.05 + t * 0.25) * 0.08;
        scene[y * W + x] = clamp(bg + blob + n, 0, 1);
      }
    }

    // update background model
    for (let i = 0; i < W * H; i++) {
      bgModel[i] += mogRate * (scene[i] - bgModel[i]);
    }

    const sImg = sCtx.createImageData(W, H);
    const mImg = mCtx.createImageData(W, H);
    const iImg = iCtx.createImageData(W, H);

    for (let i = 0; i < W * H; i++) {
      const s = scene[i], bg = bgModel[i];
      const diff = Math.abs(s - bg) * 255;
      const isFg = diff > varT / 4;

      // scene: false color
      const sv = Math.round(s * 255);
      sImg.data[i*4] = Math.min(255, sv * 1.2);
      sImg.data[i*4+1] = Math.round(sv * 0.6);
      sImg.data[i*4+2] = Math.round(sv * 0.6);
      sImg.data[i*4+3] = 255;

      // mask: white foreground
      const mv = isFg ? 255 : 0;
      mImg.data[i*4] = mv; mImg.data[i*4+1] = mv; mImg.data[i*4+2] = mv; mImg.data[i*4+3] = 255;

      // infrared composite
      if (isFg) {
        const heat = diff / (varT / 4) * 0.5;
        iImg.data[i*4] = Math.min(255, Math.round(heat * 255));
        iImg.data[i*4+1] = Math.round(clamp(heat - 0.5, 0, 1) * 229);
        iImg.data[i*4+2] = Math.round(clamp(heat - 0.8, 0, 1) * 212);
      } else {
        const v = Math.round(bgModel[i] * 40);
        iImg.data[i*4] = v; iImg.data[i*4+1] = v; iImg.data[i*4+2] = v + 20;
      }
      iImg.data[i*4+3] = 255;
    }

    sCtx.putImageData(sImg, 0, 0);
    mCtx.putImageData(mImg, 0, 0);
    iCtx.putImageData(iImg, 0, 0);

    requestAnimationFrame(animMOG);
  }
  requestAnimationFrame(animMOG);
})();

