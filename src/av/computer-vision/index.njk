/* ═══════════════════════════════════════════════════════════
   SECTION 9 — GLOSSARY
   ═══════════════════════════════════════════════════════════ */
(function initGlossary() {
  const terms = [
    { term: 'Optical Flow', def: 'The apparent motion of pixels between consecutive frames, computed using brightness constancy and spatial smoothness constraints.' },
    { term: 'Keypoint Detection', def: 'Locating distinctive, repeatable image features such as corners, blobs, or joints that are stable under transformations.' },
    { term: 'SIFT', def: 'Scale-Invariant Feature Transform — descriptors constructed from local gradient histograms that are invariant to scale, rotation, and illumination.' },
    { term: 'Pose Estimation', def: 'Predicting the 2D or 3D positions of body joints from an image, typically using heatmap regression or regression networks.' },
    { term: 'Semantic Segmentation', def: 'Assigning a class label to every pixel in an image, producing dense per-pixel predictions of scene content.' },
    { term: 'Instance Segmentation', def: 'Semantic segmentation extended to differentiate individual object instances of the same class, producing unique masks per object.' },
    { term: 'Bounding Box Regression', def: 'Predicting the (x, y, width, height) coordinates of object bounding boxes, typically alongside class confidence scores.' },
    { term: 'Non-Maximum Suppression', def: 'Post-processing step that eliminates overlapping bounding boxes by retaining only the highest-confidence prediction for each region.' },
    { term: 'IOU (Intersection over Union)', def: 'Ratio of overlapping area between predicted and ground-truth bounding boxes to their combined area; primary detection accuracy metric.' },
    { term: 'MOG2', def: 'Mixture of Gaussians background subtraction algorithm modeling each pixel as a mixture distribution and classifying deviations as foreground.' },
    { term: 'Homography', def: 'A projective transformation mapping points from one plane to another, used for image stitching, perspective correction, and AR registration.' },
    { term: 'SLAM', def: 'Simultaneous Localization and Mapping — estimating camera pose and building a 3D map of the environment concurrently from sensor data.' },
    { term: 'Depth Estimation', def: 'Recovering per-pixel depth from monocular or stereo images using geometric constraints, learning, or time-of-flight sensing.' },
    { term: 'Convolutional Neural Network', def: 'Deep learning architecture using spatial convolution filters to extract hierarchical visual features for recognition and detection tasks.' },
    { term: 'Feature Pyramid Network', def: 'Multi-scale feature representation that combines high-resolution, low-level features with low-resolution, high-level features for detection at multiple scales.' },
    { term: 'BlazePose', def: 'MediaPipe real-time pose estimation model predicting 33 body keypoints from a single RGB frame at 30+ FPS on mobile hardware.' },
    { term: 'Canny Edge Detection', def: 'Multi-stage algorithm applying Gaussian smoothing, gradient computation, non-maximum suppression, and hysteresis thresholding to extract edges.' },
    { term: 'Background Modeling', def: 'Statistical representation of scene appearance without foreground objects, used to detect and segment moving objects in video streams.' },
    { term: 'Contour Detection', def: 'Finding the boundaries of foreground objects in a binary image, representing shape as a sequence of connected edge points.' },
    { term: 'Morphological Operations', def: 'Pixel-neighborhood operations (erosion, dilation, opening, closing) that modify binary or grayscale images based on a structuring element shape.' },
    { term: 'Image Pyramid', def: 'A multi-resolution representation constructed by successively downsampling an image, enabling scale-space feature detection and coarse-to-fine matching.' },
    { term: 'Transfer Learning', def: 'Adapting a model pre-trained on a large dataset (ImageNet) for a new vision task by fine-tuning on domain-specific data with limited samples.' }
  ];

  const grid = document.getElementById('gloss-grid');
  terms.forEach(t => {
    const d = document.createElement('div');
    d.className = 'gloss-item';
    d.innerHTML = `<div class="gloss-term">${t.term}</div><div class="gloss-def">${t.def}</div>`;
    grid.appendChild(d);
  });
})();

/* ═══════════════════════════════════════════════════════════
   INTERSECTION OBSERVER — SCROLL REVEAL
   ═══════════════════════════════════════════════════════════ */
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      observer.unobserve(e.target);
    }
  });
}, { threshold: 0.08 });

document.querySelectorAll('.hidden').forEach(el => observer.observe(el));
</script>
