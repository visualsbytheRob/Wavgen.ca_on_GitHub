---
layout: base.njk
---
{#
world.njk
Layout for WAVGEN interactive world pages integrated under the site's sticky header.

- Extends base.njk so all worlds get the site nav, footer, GSAP, and global scripts.
- Wraps world content in .wavgen-world to provide a CSS scoping root.
- Injects a sticky breadcrumb bar (Row 2) below the site header.
- Repositions the world's own nav to act as a section jump nav (Row 3).
- Suppresses any world-injected top-level nav logo/brand that would duplicate site navigation.
- Keeps fixed-position particle/bg canvases visually below the site header.

Three-row sticky stack:
  Row 1 — Site header        64px  sticky top:0   z-30  (navigation.njk, base.njk)
  Row 2 — Breadcrumb         36px  sticky top:64  z-25  (.wg-breadcrumb, injected here)
  Row 3 — World jump nav     ~60px sticky top:100 z-20  (world's own <nav>, repositioned)

scroll-margin-top on [id] anchors: 160px  (64 + 36 + 60)
#}

{# ── Row 2: Breadcrumb — sticky below the 64px site header ──────────────── #}
<nav class="wg-breadcrumb" aria-label="breadcrumb">
  <a href="/">Home</a>
  <span aria-hidden="true">›</span>
  {% if domain %}
  <a href="/{{ domain }}/">{{ domain | capitalize }}</a>
  <span aria-hidden="true">›</span>
  {% endif %}
  <span>{{ title | replace(" — Visual Learning World", "") }}</span>
</nav>

{# World content is scoped under .wavgen-world so CSS overrides below beat the world's own
   inline <style> selectors (0,1,1 specificity beats bare element selectors 0,0,1). #}
<div class="wavgen-world" data-domain="{{ domain }}" data-standalone="false">
  {{ content | safe }}
</div>

{# Forward the world's own JS bundle (particle systems, animations, interactions).
   base.njk already loads GSAP + ScrollTrigger globally so worldJs can assume them. #}
{% if worldJs %}
<script src="{{ worldJs }}" defer></script>
{% endif %}

<style>
  /* ══════════════════════════════════════════════════════
     ROW 2 — BREADCRUMB (sticky below 64px site header)
  ══════════════════════════════════════════════════════ */
  .wg-breadcrumb {
    position: sticky;
    top: 64px;
    z-index: 25;
    background: #2c0077;           /* wavgen-dark-purple — matches site header */
    padding: 0 1.5rem;
    height: 36px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    white-space: nowrap;
    overflow: hidden;
  }
  .wg-breadcrumb a {
    color: #fbbf24;                /* wavgen-yellow */
    text-decoration: none;
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .wg-breadcrumb a:hover { color: #fde68a; }
  .wg-breadcrumb span[aria-hidden] {
    color: rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
  }
  .wg-breadcrumb > span:last-child {
    color: rgba(255, 255, 255, 0.75);
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ══════════════════════════════════════════════════════
     SUPPRESS old-style .wg-nav class (exact match only)
     NOTE: do NOT use [class*="wg-nav"] — that would also
     match .wg-jump-nav and hide the jump nav.
  ══════════════════════════════════════════════════════ */
  .wavgen-world .wg-nav { display: none !important; }

  /* ══════════════════════════════════════════════════════
     ROW 3 — WORLD JUMP NAV (sticky below header + breadcrumb)
     Overrides position:fixed or position:sticky top:0 set
     by each world's own <style> block.
  ══════════════════════════════════════════════════════ */
  .wavgen-world nav {
    position: sticky !important;
    top: 100px !important;         /* 64px header + 36px breadcrumb */
    z-index: 20 !important;        /* below site header z-30, above content */
    left: auto !important;         /* undo fixed-element left:0 */
    right: auto !important;        /* undo fixed-element right:0 */
    overflow-x: auto !important;
    scrollbar-width: none;
  }
  .wavgen-world nav::-webkit-scrollbar { display: none; }

  /* Hide world nav logo/brand — redundant with site header + breadcrumb ─── */
  .wavgen-world nav .nav-logo,
  .wavgen-world nav .nav-brand,
  .wavgen-world nav .nav-brand-group { display: none !important; }

  /* Ensure inner containers don't wrap and scroll horizontally ────────────── */
  .wavgen-world nav .nav-inner,
  .wavgen-world nav .nav-links {
    flex-wrap: nowrap !important;
    white-space: nowrap !important;
    overflow-x: auto !important;
    scrollbar-width: none;
  }
  .wavgen-world nav .nav-inner::-webkit-scrollbar,
  .wavgen-world nav .nav-links::-webkit-scrollbar { display: none; }

  /* ul.nav-links (ml, quantum use <ul>) ────────────────────────────────────── */
  .wavgen-world nav ul.nav-links {
    list-style: none;
    flex-wrap: nowrap !important;
    white-space: nowrap !important;
  }

  /* ── Remove padding-top that worlds added to compensate for fixed nav ───── */
  /* Only ml uses .world-main with padding-top; reset it now nav is in flow. */
  .wavgen-world .world-main { padding-top: 0 !important; }

  /* ══════════════════════════════════════════════════════
     SECTION ANCHOR SCROLL OFFSET
     Keeps section headings visible below the full nav stack
     when a jump-nav link is clicked.
     160px = 64px header + 36px breadcrumb + 60px jump nav
  ══════════════════════════════════════════════════════ */
  .wavgen-world [id] {
    scroll-margin-top: 160px;
  }

  /* ══════════════════════════════════════════════════════
     PREVENT OVERFLOW CLIPPING FROM BREAKING STICKY
  ══════════════════════════════════════════════════════ */
  .wavgen-world {
    overflow: visible !important;
  }

  /* ══════════════════════════════════════════════════════
     CANVAS CONSTRAINTS
  ══════════════════════════════════════════════════════ */

  /* Hero canvases: clip so they don't underrun the site header */
  .wavgen-world canvas[id*="hero"],
  .wavgen-world canvas[id*="Hero"],
  .wavgen-world .hero-canvas {
    max-height: calc(100vh - 64px);
  }

  /* Fixed particle/background canvases: push down below header */
  .wavgen-world #particle-canvas,
  .wavgen-world #bg-canvas,
  .wavgen-world canvas.bg-canvas {
    top: 64px !important;
    height: calc(100vh - 64px) !important;
  }
</style>
