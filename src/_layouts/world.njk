---
layout: base.njk
---

{# Breadcrumb row — sits directly below the 64px site header #}
<nav class="wg-breadcrumb" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span aria-hidden="true">›</span>
  {% if domain %}
  <a href="/{{ domain }}/">{{ domain | capitalize }}</a>
  <span aria-hidden="true">›</span>
  {% endif %}
  <span class="wg-breadcrumb-current">{{ title | replace(" — Visual Learning World", "") | replace(" — Interactive Visual Learning Guide", "") | replace(" — Visual Learning Guide", "") | replace(" — WAVGEN Music World", "") | replace(" — WAVGEN World", "") }}</span>
</nav>

{# World iframe — full viewport minus header (64px) + breadcrumb (36px) = 100px #}
<iframe
  src="/worlds/{{ worldFile }}"
  class="wg-world-frame"
  allowfullscreen
  title="{{ title }}"
></iframe>

<style>
.wg-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0 2rem;
  height: 36px;
  background: #2c0077;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  font-size: 0.75rem;
  white-space: nowrap;
  overflow: hidden;
}
.wg-breadcrumb a {
  color: rgba(255, 255, 255, 0.6);
  text-decoration: none;
  transition: color 0.15s;
}
.wg-breadcrumb a:hover { color: #FEDD00; }
.wg-breadcrumb span[aria-hidden] { color: rgba(255, 255, 255, 0.3); }
.wg-breadcrumb-current { color: rgba(255, 255, 255, 0.9); font-weight: 500; }

.wg-world-frame {
  display: block;
  width: 100%;
  height: calc(100vh - 100px);
  border: none;
  overflow: hidden;
}

/* Prevent outer-page scroll — the world handles its own scrolling inside the iframe */
html, body {
  overflow: hidden;
}
</style>
