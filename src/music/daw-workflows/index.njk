bind('timelineCPU',lagCPUThresh,'timelineCPUV','%');
bind('timelineBuffer',lagBufferSize,'timelineBufferV','');

/* ─── INTERSECTION OBSERVER ─── */
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')});
},{threshold:.10});
document.querySelectorAll('.hidden').forEach(el=>io.observe(el));

// Jump nav active state
(function() {
  const links = document.querySelectorAll('.jump-link');
  const sections = [...links].map(l => document.querySelector(l.getAttribute('href'))).filter(Boolean);
  const io2 = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        links.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + e.target.id));
      }
    });
  }, { rootMargin: '-40% 0px -40% 0px' });
  sections.forEach(s => io2.observe(s));
})();
