function makeAvatar(shape,color){
  const S=80;
  const shapes={
    circle:`<circle cx="40" cy="40" r="28" fill="${color}22" stroke="${color}" stroke-width="2"/>
      <circle cx="40" cy="40" r="14" fill="${color}44"/>`,
    hexagon:(()=>{const pts=Array.from({length:6},(_,i)=>{const a=i/6*Math.PI*2-Math.PI/6;return`${40+28*Math.cos(a)},${40+28*Math.sin(a)}`}).join(' ');return`<polygon points="${pts}" fill="${color}22" stroke="${color}" stroke-width="2"/><circle cx="40" cy="40" r="10" fill="${color}55"/>`;})(),
    star:(()=>{const pts=Array.from({length:10},(_,i)=>{const a=i/10*Math.PI*2-Math.PI/2;const r=i%2===0?28:14;return`${40+r*Math.cos(a)},${40+r*Math.sin(a)}`}).join(' ');return`<polygon points="${pts}" fill="${color}22" stroke="${color}" stroke-width="2"/>`;})(),
    diamond:`<polygon points="40,12 68,40 40,68 12,40" fill="${color}22" stroke="${color}" stroke-width="2"/>`,
    triangle:`<polygon points="40,12 68,68 12,68" fill="${color}22" stroke="${color}" stroke-width="2"/>`,
    pentagon:(()=>{const pts=Array.from({length:5},(_,i)=>{const a=i/5*Math.PI*2-Math.PI/2;return`${40+28*Math.cos(a)},${40+28*Math.sin(a)}`}).join(' ');return`<polygon points="${pts}" fill="${color}22" stroke="${color}" stroke-width="2"/>`;})(),
  };
  return `<svg viewBox="0 0 ${S} ${S}" xmlns="http://www.w3.org/2000/svg">${shapes[shape]||shapes.circle}</svg>`;
}
