const sessCanvas=document.getElementById('session-canvas');
const sessCtx=sessCanvas.getContext('2d');

const SESSION_GROUPS=[
  {name:'DRUMS',color:'#D4820A',tracks:8,icon:'◈'},
  {name:'BASS',color:'#2A7FD4',tracks:4,icon:'◉'},
  {name:'GUITARS',color:'#44CC88',tracks:6,icon:'◆'},
  {name:'KEYS',color:'#CC4488',tracks:4,icon:'◇'},
  {name:'VOCALS',color:'#F0A020',tracks:6,icon:'○'},
  {name:'FX/MISC',color:'#8888FF',tracks:4,icon:'◎'},
];

function buildSessLegend(){
  const cont=document.getElementById('sess-legend');
  SESSION_GROUPS.forEach(g=>{
    const div=document.createElement('div');
    div.style.cssText='display:flex;align-items:center;gap:.4rem;margin:.2rem 0';
    div.innerHTML=`<div style="width:10px;height:10px;background:${g.color};border-radius:2px"></div>
      <span style="font-size:.7rem;letter-spacing:.1em;color:${g.color}">${g.name}</span>
      <span style="font-size:.65rem;color:var(--dim)">${g.tracks} TRACKS</span>`;
    cont.appendChild(div);
  });
}
buildSessLegend();

function drawSession(t){
  const w=sessCanvas.width,h=sessCanvas.height;
  sessCtx.clearRect(0,0,w,h);
  sessCtx.fillStyle='rgba(2,4,8,.95)';
  sessCtx.fillRect(0,0,w,h);

  const trackCount=parseInt(document.getElementById('sessTrackCount')?.value||32);
  const groupDepth=parseInt(document.getElementById('sessGroupDepth')?.value||3);
  const vu=lagSessVU.value/100;

  const TRACK_H=Math.min(28,(h-40)/trackCount);
  const NAME_W=120;

  // Header
  sessCtx.fillStyle='rgba(42,127,212,.2)';
  sessCtx.fillRect(0,0,w,22);
  ['TRACK','TYPE','AUDIO CONTENT','VU'].forEach((lbl,li)=>{
    sessCtx.fillStyle='rgba(42,127,212,.7)';
    sessCtx.font='8px Courier New';
    sessCtx.letterSpacing='2px';
    const xs=[4,NAME_W+4,NAME_W+70,w-60];
    sessCtx.fillText(lbl,xs[li],14);
  });

  let trackIdx=0;
  SESSION_GROUPS.forEach((g,gi)=>{
    if(trackIdx>=trackCount)return;
    // Group header row
    const gy=24+trackIdx*TRACK_H;
    if(gy+TRACK_H>h)return;
    sessCtx.fillStyle=g.color+'22';
    sessCtx.fillRect(0,gy,w,TRACK_H);
    sessCtx.fillStyle=g.color;
    sessCtx.font='bold 9px Courier New';
    sessCtx.fillText(`▼ ${g.icon} ${g.name}`,4,gy+TRACK_H*.7);
    // Waveform for group
    sessCtx.beginPath();
    sessCtx.strokeStyle=g.color+'66';
    sessCtx.lineWidth=1;
    for(let px=NAME_W+65;px<w-80;px+=2){
      const x=px/(w-80);
      const wave=noise21(x*8+gi*.7,t*.3)*vu;
      const wY=gy+TRACK_H/2+wave*(TRACK_H*.4);
      px===NAME_W+65?sessCtx.moveTo(px,wY):sessCtx.lineTo(px,wY);
    }
    sessCtx.stroke();
    // VU bar
    const vuV=vu*(0.6+noise21(gi*.7,t*.5)*.4);
    const vuW=40;
    sessCtx.fillStyle='rgba(42,127,212,.2)';
    sessCtx.fillRect(w-65,gy+2,vuW,TRACK_H-4);
    sessCtx.fillStyle=vuV>.8?'#CC4488':vuV>.6?'#F0A020':g.color;
    sessCtx.fillRect(w-65,gy+2,vuW*vuV,TRACK_H-4);
    trackIdx++;

    // Sub-tracks
    for(let ti=0;ti<Math.min(g.tracks-1,groupDepth*2)&&trackIdx<trackCount;ti++){
      const ty=24+trackIdx*TRACK_H;
      if(ty+TRACK_H>h){trackIdx++;return;}
      sessCtx.fillStyle='rgba(2,4,8,.3)';
      sessCtx.fillRect(0,ty,w,TRACK_H);
      sessCtx.strokeStyle='rgba(42,127,212,.08)';
      sessCtx.lineWidth=.5;
      sessCtx.beginPath();sessCtx.moveTo(0,ty);sessCtx.lineTo(w,ty);sessCtx.stroke();
      // Track name
      sessCtx.fillStyle=g.color+'88';
      sessCtx.font='8px Courier New';
      sessCtx.fillText(`  └ ${g.name.slice(0,3)} ${ti+1}`,4,ty+TRACK_H*.7);
      // Clip blocks
      for(let ci=0;ci<6;ci++){
        const cx2=NAME_W+70+ci*(w-NAME_W-90)/6+2;
        const cw2=(w-NAME_W-90)/6-4;
        const hasClip=noise21(ci*.5+ti*.3+gi*.7,0)>.35;
        if(hasClip){
          sessCtx.fillStyle=g.color+'33';
          sessCtx.fillRect(cx2,ty+2,cw2,TRACK_H-4);
          sessCtx.strokeStyle=g.color+'44';
          sessCtx.lineWidth=.5;
          sessCtx.strokeRect(cx2,ty+2,cw2,TRACK_H-4);
          // Mini waveform
          sessCtx.beginPath();sessCtx.strokeStyle=g.color+'77';sessCtx.lineWidth=.8;
          for(let px=0;px<cw2;px+=2){
            const wv=noise21((cx2+px)*.02,ti*.7+t*.2);
            const wy=ty+TRACK_H/2+(wv-.5)*vu*(TRACK_H*.7);
            px===0?sessCtx.moveTo(cx2+px,wy):sessCtx.lineTo(cx2+px,wy);
          }
          sessCtx.stroke();
        }
      }
      // Sub VU
      const svu=vu*(0.3+noise21(ti*.4+gi*.6,t*.4+ti*.1)*.7);
      sessCtx.fillStyle='rgba(42,127,212,.15)';sessCtx.fillRect(w-65,ty+2,40,TRACK_H-4);
      sessCtx.fillStyle=svu>.8?'#CC4488':g.color+'88';
      sessCtx.fillRect(w-65,ty+2,40*svu,TRACK_H-4);
      trackIdx++;
    }
  });
}

/* ─── STEM EXPORT PIPELINE ─── */
const stemsCanvas=document.getElementById('stems-canvas');
const stemsCtx=stemsCanvas.getContext('2d');

const STEM_STAGES=[
  {name:'RAW TRACKS',color:'#3D9FFF',x:.08},
  {name:'COMP/EQ',color:'#2A7FD4',x:.23},
  {name:'GROUP BUS',color:'#D4820A',x:.38},
  {name:'STEM MIX',color:'#F0A020',x:.53},
  {name:'BOUNCE',color:'#44CC88',x:.68},
  {name:'PROCESS',color:'#CC4488',x:.83},
  {name:'DELIVERY',color:'#8888FF',x:.95},
];

function drawStems(t){
  const w=stemsCanvas.width,h=stemsCanvas.height;
  stemsCtx.clearRect(0,0,w,h);
  stemsCtx.fillStyle='rgba(2,4,8,.95)';
  stemsCtx.fillRect(0,0,w,h);

  const stemLayers=parseInt(document.getElementById('stemLayers')?.value||5);
  const progress=lagStemProgress.value/100;
  const parallel=parseInt(document.getElementById('stemParallel')?.value||4);
  const bitDepth=parseInt(document.getElementById('stemBitDepth')?.value||24);

  const laneH=(h-60)/stemLayers;
  const STEM_NAMES=['DRUMS','BASS','INSTRUMENTS','VOCALS','FX'];
  const STEM_COLS=['#D4820A','#2A7FD4','#44CC88','#F0A020','#CC4488'];

  for(let li=0;li<stemLayers;li++){
    const laneY=30+li*laneH;
    // Stage progress bars
    STEM_STAGES.forEach((stage,si)=>{
      const stx=stage.x*w;
      const sty=laneY+2;
      const sth=laneH-4;
      const stageProgress=clamp((progress*STEM_STAGES.length-si),0,1);
      stemsCtx.fillStyle='rgba(42,127,212,.1)';
      stemsCtx.fillRect(stx-18,sty,36,sth);
      if(stageProgress>0){
        const stageFill=Math.min(stageProgress,1);
        stemsCtx.fillStyle=STEM_COLS[li%STEM_COLS.length]+(Math.floor(stageFill*180).toString(16).padStart(2,'0'));
        stemsCtx.fillRect(stx-18,sty+sth*(1-stageFill),36,sth*stageFill);
      }
      stemsCtx.strokeStyle=stage.color+'55';stemsCtx.lineWidth=1;stemsCtx.strokeRect(stx-18,sty,36,sth);
      // Connection line
      if(si<STEM_STAGES.length-1){
        const nx=STEM_STAGES[si+1].x*w;
        stemsCtx.beginPath();stemsCtx.moveTo(stx+18,laneY+laneH/2);stemsCtx.lineTo(nx-18,laneY+laneH/2);
        stemsCtx.strokeStyle=STEM_COLS[li%STEM_COLS.length]+(stageProgress>=1?'88':'22');
        stemsCtx.lineWidth=1;stemsCtx.stroke();
      }
    });
    // Stem name
    stemsCtx.fillStyle=STEM_COLS[li%STEM_COLS.length];
    stemsCtx.font='8px Courier New';stemsCtx.letterSpacing='1px';
    stemsCtx.fillText(STEM_NAMES[li]||`STEM ${li+1}`,2,laneY+laneH/2+3);
  }

  // Stage labels at top
  STEM_STAGES.forEach(stage=>{
    stemsCtx.fillStyle='rgba(42,127,212,.5)';
    stemsCtx.font='7px Courier New';stemsCtx.letterSpacing='1px';stemsCtx.textAlign='center';
    stemsCtx.fillText(stage.name,stage.x*w,18);stemsCtx.textAlign='left';
  });

  // Progress bar
  const pbY=h-18;
  stemsCtx.fillStyle='rgba(42,127,212,.15)';stemsCtx.fillRect(0,pbY,w,12);
  stemsCtx.fillStyle='rgba(42,127,212,.6)';stemsCtx.fillRect(0,pbY,w*progress,12);
  stemsCtx.fillStyle='rgba(255,255,255,.5)';stemsCtx.font='8px Courier New';
  stemsCtx.fillText(`RENDER ${Math.round(progress*100)}%  |  ${bitDepth}-BIT  |  ${parallel} PARALLEL STREAMS`,4,pbY+9);
}

/* ─── PRODUCTION PIPELINE ─── */
const pipeCanvas=document.getElementById('pipeline-canvas');
const pipeCtx=pipeCanvas.getContext('2d');

const PHASES=[
  {name:'PRE-PRODUCTION',color:'#3D9FFF',pct:.15,tasks:['Arrangement','Demo','Reference']},
  {name:'TRACKING',color:'#D4820A',pct:.2,tasks:['Drums','Bass','Guitar','Vocals']},
  {name:'EDITING',color:'#44CC88',pct:.2,tasks:['Comping','Tuning','Timing']},
  {name:'MIXING',color:'#CC4488',pct:.25,tasks:['Balance','EQ','Dynamics','FX']},
  {name:'MASTERING',color:'#F0A020',pct:.2,tasks:['Limiting','LUFS','Formats']},
];

function drawPipeline(t){
  const w=pipeCanvas.width,h=pipeCanvas.height;
  pipeCtx.clearRect(0,0,w,h);
  pipeCtx.fillStyle='rgba(2,4,8,.95)';
  pipeCtx.fillRect(0,0,w,h);

  const progress=lagPipeProgress.value/100;
  const bpm=lagPipeBPM.value;
  const cpuLoad=lagPipeCPU.value/100;

  // CPU meter top-right
  const cpuX=w-180,cpuY=10;
  pipeCtx.fillStyle='rgba(42,127,212,.15)';pipeCtx.fillRect(cpuX,cpuY,160,18);
  pipeCtx.fillStyle=cpuLoad>.85?'#CC4488':cpuLoad>.7?'#F0A020':'#3D9FFF';
  pipeCtx.fillRect(cpuX,cpuY,160*cpuLoad,18);
  pipeCtx.fillStyle='#aaa';pipeCtx.font='9px Courier New';
  pipeCtx.fillText(`CPU ${Math.round(cpuLoad*100)}%  BPM ${Math.round(bpm)}`,cpuX+4,cpuY+13);

  // Phase bars
  let xCursor=0;
  const barY=40,barH=h-80;
  PHASES.forEach((ph,pi)=>{
    const pw2=ph.pct*w;
    const phProgress=clamp((progress*PHASES.length-pi)*1,0,1);
    // Background
    pipeCtx.fillStyle='rgba(42,127,212,.06)';
    pipeCtx.fillRect(xCursor+2,barY,pw2-4,barH);
    // Fill
    if(phProgress>0){
      const grad=pipeCtx.createLinearGradient(xCursor,0,xCursor+pw2,0);
      grad.addColorStop(0,ph.color+'44');
      grad.addColorStop(1,ph.color+'22');
      pipeCtx.fillStyle=grad;
      pipeCtx.fillRect(xCursor+2,barY,Math.max(0,(pw2-4)*phProgress),barH);
    }
    pipeCtx.strokeStyle=ph.color+(phProgress>=1?'AA':'44');
    pipeCtx.lineWidth=1;pipeCtx.strokeRect(xCursor+2,barY,pw2-4,barH);
    // Phase name
    pipeCtx.fillStyle=phProgress>=1?ph.color:ph.color+'66';
    pipeCtx.font=`bold 9px Courier New`;pipeCtx.letterSpacing='1px';pipeCtx.textAlign='center';
    pipeCtx.fillText(ph.name,xCursor+pw2/2,barY+16);
    // Tasks
    ph.tasks.forEach((task,ti)=>{
      const taskProgress=clamp((phProgress*ph.tasks.length-ti)*1,0,1);
      const ty=barY+28+ti*(barH-32)/ph.tasks.length;
      pipeCtx.fillStyle=taskProgress>0?ph.color+'55':'rgba(42,127,212,.1)';
      pipeCtx.fillRect(xCursor+pw2/2-30,ty,60,(barH-32)/ph.tasks.length-3);
      pipeCtx.fillStyle=taskProgress>0?ph.color:'#4A6880';
      pipeCtx.font='7px Courier New';pipeCtx.letterSpacing='1px';
      pipeCtx.fillText(task,xCursor+pw2/2,ty+(barH-32)/ph.tasks.length*.6);
    });
    pipeCtx.textAlign='left';
    // Phase divider
    if(pi<PHASES.length-1){
      pipeCtx.beginPath();pipeCtx.moveTo(xCursor+pw2,barY-5);pipeCtx.lineTo(xCursor+pw2,barY+barH+5);
      pipeCtx.strokeStyle='rgba(42,127,212,.25)';pipeCtx.lineWidth=1.5;pipeCtx.stroke();
      // Arrow
      pipeCtx.fillStyle='rgba(42,127,212,.5)';
      pipeCtx.beginPath();pipeCtx.moveTo(xCursor+pw2,barY+barH/2-5);
      pipeCtx.lineTo(xCursor+pw2+8,barY+barH/2);pipeCtx.lineTo(xCursor+pw2,barY+barH/2+5);
      pipeCtx.fill();
    }
    xCursor+=pw2;
  });

  // Progress line
  const progX=progress*w;
  pipeCtx.beginPath();pipeCtx.moveTo(progX,barY-8);pipeCtx.lineTo(progX,barY+barH+8);
  pipeCtx.strokeStyle='rgba(240,160,32,.7)';pipeCtx.lineWidth=2;pipeCtx.setLineDash([4,4]);pipeCtx.stroke();
  pipeCtx.setLineDash([]);
  pipeCtx.fillStyle='#F0A020';pipeCtx.font='9px Courier New';
  pipeCtx.fillText(`NOW`,progX+4,barY-2);
}

/* ─── PLUGIN CHAIN + AUTOMATION ─── */
const pluginCanvas=document.getElementById('plugin-canvas');
const pluginCtx=pluginCanvas.getContext('2d');
const autoCanvas=document.getElementById('auto-canvas');
const autoCtx=autoCanvas.getContext('2d');

const PLUGIN_CHAINS=[
  ['INPUT GAIN','HIGH-PASS','EQ 4-BAND','COMPRESSOR','SATURATION','LIMITER'],
  ['INPUT GAIN','DE-ESSER','EQ 4-BAND','MULTIBAND COMP','REVERB SEND','CLIPPER'],
  ['TRANSIENT','EQ 4-BAND','PARALLEL COMP','STEREO WIDTH','TAPE SAT','LIMITER'],
  ['INPUT GAIN','DYNAMIC EQ','COMPRESSOR','EXCITER','DELAY SEND','OUTPUT GAIN'],
];
const PLUGIN_COLORS=['#3D9FFF','#2A7FD4','#D4820A','#CC4488','#44CC88','#8888FF'];
let activePluginChain=0;

function buildPluginBtns(){
  const cont=document.getElementById('plugin-btns');
  ['VOCAL CHAIN','MASTER BUS','DRUM BUS','GUITAR'].forEach((name,i)=>{
    const b=document.createElement('button');
    b.className='btn'+(i===0?' active':'');b.textContent=name;b.style.fontSize='.6rem';
    b.onclick=()=>{activePluginChain=i;document.querySelectorAll('#plugin-btns .btn').forEach((bb,j)=>bb.classList.toggle('active',j===i));};
    cont.appendChild(b);
  });
}
buildPluginBtns();

function drawPlugin(t){
  const w=pluginCanvas.width,h=pluginCanvas.height;
  pluginCtx.clearRect(0,0,w,h);
  pluginCtx.fillStyle='rgba(2,4,8,.95)';
  pluginCtx.fillRect(0,0,w,h);

  const chain=PLUGIN_CHAINS[activePluginChain];
  const nodeW=(w-20)/chain.length;
  const cy=h/2;

  chain.forEach((plugin,pi)=>{
    const nx=10+pi*nodeW+nodeW/2;
    const col=PLUGIN_COLORS[pi%PLUGIN_COLORS.length];
    const active=noise21(pi*.5,t*.5)>.3;

    // Node box
    pluginCtx.fillStyle=active?col+'33':'rgba(42,127,212,.1)';
    pluginCtx.strokeStyle=active?col:col+'44';
    pluginCtx.lineWidth=1.5;
    pluginCtx.beginPath();pluginCtx.rect(nx-nodeW/2+4,cy-25,nodeW-8,50);
    pluginCtx.fill();pluginCtx.stroke();

    // Plugin name
    pluginCtx.fillStyle=active?col:'#4A6880';
    pluginCtx.font='7px Courier New';pluginCtx.textAlign='center';pluginCtx.letterSpacing='0px';
    const words=plugin.split(' ');
    words.forEach((w2,wi)=>pluginCtx.fillText(w2,nx,cy-10+wi*12));
    pluginCtx.textAlign='left';

    // Gain reduction bar
    const gr=active?noise21(pi*.3,t*.8)*.4:0;
    pluginCtx.fillStyle=col+'55';
    pluginCtx.fillRect(nx-10,cy+18,20,-gr*30);
    pluginCtx.strokeStyle=col+'44';pluginCtx.lineWidth=.5;pluginCtx.strokeRect(nx-10,cy-12,20,30);

    // Connection arrow
    if(pi<chain.length-1){
      const lx=nx+nodeW/2-4;
      pluginCtx.beginPath();pluginCtx.moveTo(lx,cy);pluginCtx.lineTo(lx+8,cy);
      pluginCtx.strokeStyle='rgba(42,127,212,.4)';pluginCtx.lineWidth=1.5;pluginCtx.stroke();
      // Packet
      lagPluginFlow.update(t*.3,.016);
      const pkt=((t*lagRouteSpeed.value*.01)%1);
      if(pi===Math.floor(pkt*(chain.length-1))){
        const pp=(pkt*(chain.length-1)-pi);
        const ppx=lx+pp*8;
        pluginCtx.beginPath();pluginCtx.arc(ppx,cy,3,0,Math.PI*2);
        pluginCtx.fillStyle=col;pluginCtx.fill();
      }
    }
  });

  // Signal level indicator at top
  const sigLev=.3+noise21(t*.4,0)*.6;
  pluginCtx.fillStyle='rgba(42,127,212,.15)';pluginCtx.fillRect(10,8,w-20,8);
  pluginCtx.fillStyle=sigLev>.8?'#CC4488':sigLev>.6?'#F0A020':'#3D9FFF';
  pluginCtx.fillRect(10,8,(w-20)*sigLev,8);
}

function drawAuto(t){
  const w=autoCanvas.width,h=autoCanvas.height;
  autoCtx.clearRect(0,0,w,h);
  autoCtx.fillStyle='rgba(2,4,8,.95)';
  autoCtx.fillRect(0,0,w,h);

  const density=(document.getElementById('autoDensity')?.value||50)/100;
  const PARAMS=[
    {name:'VOLUME',color:'#3D9FFF'},
    {name:'PAN',color:'#D4820A'},
    {name:'SEND A',color:'#44CC88'},
    {name:'REVERB WET',color:'#CC4488'},
  ];

  const laneH=h/PARAMS.length;
  PARAMS.forEach((p,pi)=>{
    const ly=pi*laneH;
    autoCtx.fillStyle='rgba(42,127,212,.05)';
    autoCtx.fillRect(0,ly,w,laneH);
    autoCtx.strokeStyle='rgba(42,127,212,.1)';autoCtx.lineWidth=.5;
    autoCtx.beginPath();autoCtx.moveTo(0,ly+laneH);autoCtx.lineTo(w,ly+laneH);autoCtx.stroke();

    // Automation lane label
    autoCtx.fillStyle=p.color;autoCtx.font='7px Courier New';autoCtx.letterSpacing='1px';
    autoCtx.fillText(p.name,2,ly+laneH*.6);

    // Automation curve
    autoCtx.beginPath();
    for(let px=30;px<w;px+=3){
      const x=(px-30)/(w-30);
      // Complex automation shape
      let v;
      if(density>.5){
        v=.5+fbm(x*8+pi*.7,t*.1)*.4*density;
      } else {
        v=.5+.3*Math.sin(x*Math.PI*4+pi*1.2+t*.3)*density;
      }
      v=clamp(v,0,1);
      const vy=ly+laneH*.15+v*laneH*.7;
      px===30?autoCtx.moveTo(px,vy):autoCtx.lineTo(px,vy);
    }
    autoCtx.strokeStyle=p.color+'AA';autoCtx.lineWidth=1.5;autoCtx.stroke();

    // Control points
    for(let ci=0;ci<5;ci++){
      const cx=30+(ci+.5)/(5)*(w-30);
      const cv=.5+fbm((ci+.5)/5*8+pi*.7,Math.round(t*.1)*.1)*.4*density;
      const cvy=ly+laneH*.15+clamp(cv,0,1)*laneH*.7;
      autoCtx.beginPath();autoCtx.arc(cx,cvy,3,0,Math.PI*2);
      autoCtx.fillStyle=p.color;autoCtx.fill();
    }
  });
}

/* ─── REALTIME WORKFLOW TIMELINE ─── */
const timelineCanvas=document.getElementById('timeline-canvas');
const timelineCtx=timelineCanvas.getContext('2d');
let timelineEvents=[];

const TL_EVENT_TYPES=[
  {type:'NOTE',color:'#3D9FFF',h:12},
  {type:'CLIP',color:'#2A7FD4',h:16},
  {type:'PLUGIN',color:'#D4820A',h:10},
  {type:'RENDER',color:'#44CC88',h:14},
  {type:'CPU SPIKE',color:'#CC4488',h:8},
  {type:'MIDI',color:'#F0A020',h:10},
];
const TL_TRACKS=8;
const TRACK_COLORS=['#3D9FFF','#D4820A','#44CC88','#CC4488','#F0A020','#8888FF','#88CCFF','#FFCC44'];

function spawnTimelineEvent(scrollPos){
  const type=TL_EVENT_TYPES[Math.floor(Math.random()*TL_EVENT_TYPES.length)];
  const track=Math.floor(Math.random()*TL_TRACKS);
  timelineEvents.push({
    x:scrollPos+1200,
    track,
    w:20+Math.random()*80,
    color:type.color,
    h:type.h,
    type:type.type,
    life:1,
  });
}

function drawTimeline(t){
  const w=timelineCanvas.width,h=timelineCanvas.height;
  timelineCtx.clearRect(0,0,w,h);
  timelineCtx.fillStyle='rgba(2,4,8,.95)';
  timelineCtx.fillRect(0,0,w,h);

  const spd=lagTimelineScroll.value;
  const density=lagTimelineDensity.value/100;
  const cpuThresh=lagCPUThresh.value/100;
  const bufferSize=lagBufferSize.value;

  const scroll=t*spd*.8;
  const HEADER_H=24;
  const TRACK_H=(h-HEADER_H-30)/TL_TRACKS;

  // Header bar
  timelineCtx.fillStyle='rgba(42,127,212,.15)';timelineCtx.fillRect(0,0,w,HEADER_H);
  for(let bar=0;bar<30;bar++){
    const bx=bar*w/30-(scroll%( w/30));
    const barNum=Math.floor(scroll/(w/30))+bar;
    timelineCtx.strokeStyle='rgba(42,127,212,.3)';timelineCtx.lineWidth=.5;
    timelineCtx.beginPath();timelineCtx.moveTo(bx,0);timelineCtx.lineTo(bx,h);timelineCtx.stroke();
    if(bar%4===0){
      timelineCtx.fillStyle='rgba(42,127,212,.5)';timelineCtx.font='8px Courier New';
      timelineCtx.fillText(`${barNum+1}`,bx+2,16);
    }
  }

  // Track lanes
  for(let ti=0;ti<TL_TRACKS;ti++){
    const ty=HEADER_H+ti*TRACK_H;
    timelineCtx.fillStyle=ti%2===0?'rgba(4,16,32,.5)':'rgba(2,4,8,.5)';
    timelineCtx.fillRect(0,ty,w,TRACK_H);
    // Track label
    timelineCtx.fillStyle=TRACK_COLORS[ti]+'88';
    timelineCtx.font='7px Courier New';
    timelineCtx.fillText(`TRK ${ti+1}`,2,ty+TRACK_H*.6);
  }

  // Spawn events
  if(Math.random()<density*.1)spawnTimelineEvent(scroll);
  timelineEvents=timelineEvents.filter(ev=>{
    const ex=ev.x-scroll;
    if(ex+ev.w<0||ex>w)return false;
    const ty=HEADER_H+ev.track*TRACK_H;
    const ey=ty+(TRACK_H-ev.h)/2;
    timelineCtx.fillStyle=ev.color+'44';
    timelineCtx.fillRect(ex,ey,ev.w,ev.h);
    timelineCtx.strokeStyle=ev.color+'AA';timelineCtx.lineWidth=.8;
    timelineCtx.strokeRect(ex,ey,ev.w,ev.h);
    return true;
  });

  // CPU meter bottom
  const cpuY=h-22;
  timelineCtx.fillStyle='rgba(42,127,212,.15)';timelineCtx.fillRect(0,cpuY,w,16);
  for(let px=0;px<w;px+=4){
    const x=px/w;
    const cpu=.2+fbm(x*10+scroll*.01,0)*.7;
    const isOver=cpu>cpuThresh;
    timelineCtx.fillStyle=isOver?'#CC4488AA':'#3D9FFF55';
    timelineCtx.fillRect(px,cpuY+16*(1-cpu),3,16*cpu);
  }
  timelineCtx.fillStyle='rgba(255,255,255,.4)';
  timelineCtx.beginPath();timelineCtx.moveTo(0,cpuY+16*(1-cpuThresh));timelineCtx.lineTo(w,cpuY+16*(1-cpuThresh));
  timelineCtx.strokeStyle='#CC488888';timelineCtx.lineWidth=1;timelineCtx.setLineDash([3,3]);timelineCtx.stroke();
  timelineCtx.setLineDash([]);
  timelineCtx.fillStyle='#aaa';timelineCtx.font='8px Courier New';
  timelineCtx.fillText(`CPU LOAD  |  BUFFER: ${Math.round(bufferSize)} smp  |  BPM: ${Math.round(lagPipeBPM.value)}`,4,cpuY+13);
}

