/* ─── GLOSSARY ─── */
const GLOSSARY=[
  {term:'Signal Routing',def:'The path audio takes from source through processing to destination. Defines the architecture of a mix.'},
  {term:'Aux Bus',def:'A secondary mix bus fed by send signals from channel strips. Used for parallel effects returns.'},
  {term:'Group Channel',def:'A submix bus combining multiple tracks for unified processing and fader control.'},
  {term:'Stem',def:'A premixed audio file representing one group of instruments — drums stem, vocals stem, etc.'},
  {term:'Pre-Fader Send',def:'A send that taps signal before the channel fader, unaffected by fader moves. Used for headphone mixes.'},
  {term:'Post-Fader Send',def:'Send tapped after the fader. Level tracks with the channel — standard for effects returns.'},
  {term:'Insert',def:'In-line processor placed directly in the signal path, affecting all signal passing through the channel.'},
  {term:'Sidechain',def:'A secondary input to a processor (typically compressor) used as detection signal without affecting main path.'},
  {term:'Latency Compensation',def:'DAW adjustment for plugin processing delay to keep all tracks in time alignment.'},
  {term:'Buffer Size',def:'Audio processing block size in samples. Lower = less latency, higher CPU demand.'},
  {term:'Sample Rate',def:'Number of audio samples per second. 44.1kHz, 48kHz, 96kHz. Higher = more bandwidth, more data.'},
  {term:'Automation',def:'Recorded parameter changes over time — volume, pan, plugin parameters — in a DAW session.'},
  {term:'Session Template',def:'Pre-configured DAW project with routing, channels, and plugins ready for a specific workflow.'},
  {term:'Bounce',def:'Rendering audio tracks or a mix down to a single audio file. Offline bounce is faster than real-time.'},
  {term:'Comping',def:'Assembling the best phrases from multiple takes into a single composite performance.'},
  {term:'Gain Staging',def:'Managing levels at each stage of the signal chain to optimize headroom and avoid distortion.'},
  {term:'Mono Compatibility',def:'Checking a stereo mix in mono to verify phase coherence and stereo-dependent effects collapse gracefully.'},
  {term:'LUFS',def:'Loudness Units relative to Full Scale. Standard for streaming normalization targets (-14 LUFS for Spotify).'},
  {term:'Plugin Scan',def:'DAW startup process that validates and registers available VST/AU/AAX plugins.'},
  {term:'Freeze Track',def:'Rendering a track with its plugins to audio temporarily to reduce CPU load. Plugins become inactive.'},
  {term:'VCA Group',def:'Voltage Controlled Amplifier group for gang-controlling multiple faders with a single master fader.'},
  {term:'Recall',def:'Restoring a mix session to a previous state. Hardware consoles required physical recall sheets; DAWs automate it.'},
];
const gGrid=document.getElementById('glossary-grid');
GLOSSARY.forEach(g=>{
  const el=document.createElement('div');el.className='g-term';
  el.innerHTML=`<h4>${g.term}</h4><p>${g.def}</p>`;
  gGrid.appendChild(el);
});

/* ─── SLIDER BINDINGS ─── */
function bind(id,lagFilter,display,suffix=''){
  const el=document.getElementById(id);const dv=document.getElementById(display);
  if(!el)return;
  el.addEventListener('input',()=>{lagFilter.update(parseFloat(el.value),.01);if(dv)dv.textContent=el.value+suffix;});
}
bind('routeDensity',lagRouteDensity,'routeDensityV','');
bind('routeBusLoad',lagRouteBus,'routeBusLoadV','');
bind('routeSpeed',lagRouteSpeed,'routeSpeedV','');
bind('routeGlow',new LagFilter(70,.3),'routeGlowV','');
bind('sessVU',lagSessVU,'sessVUV','');
bind('stemProgress',lagStemProgress,'stemProgressV','%');
bind('stemBitDepth',new LagFilter(24,.3),'stemBitDepthV','bit');
bind('stemLayers',new LagFilter(5,.3),'stemLayersV','');
bind('stemParallel',new LagFilter(4,.3),'stemParallelV','');
bind('sessTrackCount',new LagFilter(32,.3),'sessTrackCountV','');
bind('sessGroupDepth',new LagFilter(3,.3),'sessGroupDepthV','');
bind('pipeProgress',lagPipeProgress,'pipeProgressV','%');
bind('pipeBPM',lagPipeBPM,'pipeBPMV',' BPM');
bind('pipeCPU',lagPipeCPU,'pipeCPUV','%');
bind('autoDensity',new LagFilter(50,.3),'autoDensityV','');
bind('timelineSpeed',new LagFilter(50,.3),'timelineSpeedV','');
