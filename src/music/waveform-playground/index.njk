<script>
/* ═══════════════════════════════════════════════════════════
   AUDIO CONTEXT
═══════════════════════════════════════════════════════════ */
let audioCtx = null;
function getAC() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();
  return audioCtx;
}
function masterGainNode(ac, vol, attack, decay) {
  const g = ac.createGain();
  g.gain.setValueAtTime(0, ac.currentTime);
  g.gain.linearRampToValueAtTime(vol, ac.currentTime + attack);
  g.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + attack + decay);
  g.connect(ac.destination);
  return g;
}

/* ═══════════════════════════════════════════════════════════
   HERO CANVAS
═══════════════════════════════════════════════════════════ */
const heroCanvas = document.getElementById('hero-canvas');
const heroCtx    = heroCanvas.getContext('2d');
let heroWave     = 'sine';
let heroPhase    = 0;

function resizeHero() {
  heroCanvas.width  = window.innerWidth;
  heroCanvas.height = window.innerHeight;
}
resizeHero();
window.addEventListener('resize', resizeHero);

function sampleWave(type, phi) {
  const t = ((phi % (Math.PI*2)) + Math.PI*2) % (Math.PI*2);
  const n = t / (Math.PI*2);
  switch (type) {
    case 'sine':   return Math.sin(phi);
    case 'saw':    return 2*(n - Math.floor(n+0.5));
    case 'square': return Math.sin(phi) >= 0 ? 1 : -1;
    case 'noise':  return Math.sin(phi*7.1)*Math.sin(phi*3.3+1.2)*Math.sin(phi*1.7+2.4);
    default:       return Math.sin(phi);
  }
}

const HERO_WAVES  = ['sine','saw','square','noise'];
const HERO_FREQS  = [1.4, 1.1, 0.85, 0.6];
const HERO_OFFS   = [-0.28, -0.09, 0.09, 0.28];

function drawHero() {
  const w = heroCanvas.width, h = heroCanvas.height;
  heroCtx.fillStyle = 'rgba(5,5,8,0.07)';
  heroCtx.fillRect(0, 0, w, h);

  HERO_WAVES.forEach((type, i) => {
    const active = type === heroWave;
    heroCtx.beginPath();
    heroCtx.strokeStyle = active ? '#22c55e' : 'rgba(34,197,94,0.22)';
    heroCtx.lineWidth   = active ? 2 : 1;
    if (active) { heroCtx.shadowColor = '#22c55e'; heroCtx.shadowBlur = 8; }
    else        { heroCtx.shadowBlur  = 0; }

    const cy  = h * (0.5 + HERO_OFFS[i]);
    const amp = h * 0.075;
    const frq = HERO_FREQS[i];
    for (let x = 0; x <= w; x++) {
      const phi = heroPhase * frq + (x / w) * Math.PI * 8;
      const y   = cy + sampleWave(type, phi) * amp;
      x === 0 ? heroCtx.moveTo(x, y) : heroCtx.lineTo(x, y);
    }
    heroCtx.stroke();
  });
  heroCtx.shadowBlur = 0;
  heroPhase += 0.018;
  requestAnimationFrame(drawHero);
}
drawHero();

function setHeroWave(t) {
  heroWave = t;
  document.querySelectorAll('#hero-wave-btns .btn').forEach(b => b.classList.remove('active'));
  document.getElementById('hero-btn-' + t).classList.add('active');
}

/* ═══════════════════════════════════════════════════════════
   INTERSECTION OBSERVER — scroll animations + nav active
═══════════════════════════════════════════════════════════ */
const hiddenEls = document.querySelectorAll('.hidden');
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); }});
}, { threshold: 0.12 });
hiddenEls.forEach(el => revealObs.observe(el));

const sections  = document.querySelectorAll('section[id]');
const navLinks  = document.querySelectorAll('.nav-links a');
const navObs    = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      navLinks.forEach(a => a.classList.remove('active'));
      const link = document.querySelector('.nav-links a[href="#' + e.target.id + '"]');
      if (link) link.classList.add('active');
    }
  });
}, { threshold: 0.4 });
sections.forEach(s => navObs.observe(s));

/* ═══════════════════════════════════════════════════════════
   WAVEFORM LAB
═══════════════════════════════════════════════════════════ */
let wlMorph = 0, wlFreq = 220, wlAmp = 0.7;
let wlFrozen = false, wlPhase = 0, wlPlaying = false;
let wlOsc = null, wlGain = null;
const wlCanvas = document.getElementById('wl-canvas');
const wlCtx    = wlCanvas.getContext('2d');

const HARMONIC_DATA = {
  sine:     [1, 0,    0,    0,    0,    0,    0,    0   ],
  triangle: [1, 0,    0.111,0,    0.04, 0,    0.02, 0   ],
  saw:      [1, 0.5,  0.333,0.25, 0.2,  0.167,0.143,0.125],
  square:   [1, 0,    0.333,0,    0.2,  0,    0.143,0   ]
};
const WSHAPES = ['sine','triangle','saw','square'];

function morphHarmonics(m) {
  const lo = Math.floor(m), hi = Math.min(lo+1, 3), f = m - lo;
  const a = HARMONIC_DATA[WSHAPES[lo]], b = HARMONIC_DATA[WSHAPES[hi]];
  return a.map((v,i) => v*(1-f) + b[i]*f);
}

function morphWaveValue(m, phi) {
  const lo = Math.floor(m), hi = Math.min(lo+1, 3), f = m - lo;
  return sampleWave(WSHAPES[lo], phi)*(1-f) + sampleWave(WSHAPES[hi], phi)*f;
}

function drawWL() {
  if (wlFrozen) { requestAnimationFrame(drawWL); return; }
  const w = wlCanvas.width, h = wlCanvas.height;
  wlCtx.fillStyle = 'rgba(6,6,16,0.18)';
  wlCtx.fillRect(0, 0, w, h);

  // Center line
  wlCtx.beginPath();
  wlCtx.strokeStyle = 'rgba(255,255,255,0.04)';
  wlCtx.lineWidth = 1;
  wlCtx.moveTo(0, h/2); wlCtx.lineTo(w, h/2);
  wlCtx.stroke();

  wlCtx.beginPath();
  wlCtx.strokeStyle = '#22c55e';
  wlCtx.lineWidth = 2;
  wlCtx.shadowColor = '#22c55e'; wlCtx.shadowBlur = 6;
  const cycles = 3;
  for (let x = 0; x <= w; x++) {
    const phi = (x / w) * cycles * Math.PI * 2 + wlPhase;
    const y   = h/2 - morphWaveValue(wlMorph, phi) * (h * 0.42) * wlAmp;
    x === 0 ? wlCtx.moveTo(x, y) : wlCtx.lineTo(x, y);
  }
  wlCtx.stroke();
  wlCtx.shadowBlur = 0;
  wlPhase += 0.06;

  // Update harmonic bars
  const harms = morphHarmonics(wlMorph);
  harms.forEach((v, i) => {
    const bar = document.getElementById('hb-' + (i+1));
    if (bar) bar.style.height = Math.max(v * 100, 2) + '%';
  });

  requestAnimationFrame(drawWL);
}
drawWL();

function wlMorphChange(v) {
  wlMorph = parseFloat(v);
  const names = ['SINE','TRIANGLE','SAW','SQUARE'];
  const lo = Math.floor(wlMorph), hi = Math.min(lo+1,3), f = wlMorph-lo;
  const label = f < 0.05 ? names[lo] : f > 0.95 ? names[hi] : names[lo]+' → '+names[hi];
  document.getElementById('wl-morph-val').textContent = label;
  if (wlOsc) updateWLOsc();
}
function wlFreqChange(v) {
  wlFreq = parseFloat(v);
  document.getElementById('wl-freq-val').textContent = v + ' Hz';
  if (wlOsc) updateWLOsc();
}
function wlAmpChange(v) {
  wlAmp = parseFloat(v);
  document.getElementById('wl-amp-val').textContent = parseFloat(v).toFixed(2);
  if (wlGain) wlGain.gain.setTargetAtTime(wlAmp * 0.3, getAC().currentTime, 0.01);
}
function updateWLOsc() {
  if (!wlOsc) return;
  wlOsc.frequency.setTargetAtTime(wlFreq, getAC().currentTime, 0.01);
  const types = ['sine','triangle','sawtooth','square'];
  const lo = Math.floor(wlMorph);
  wlOsc.type = types[lo];
}
function wlTogglePlay() {
  const ac = getAC(), btn = document.getElementById('wl-play-btn');
  if (wlPlaying) {
    if (wlOsc) { wlOsc.stop(); wlOsc = null; }
    wlPlaying = false; btn.textContent = '▶ PLAY'; btn.classList.remove('active');
  } else {
    wlOsc  = ac.createOscillator();
    wlGain = ac.createGain();
    const types = ['sine','triangle','sawtooth','square'];
    wlOsc.type = types[Math.floor(wlMorph)];
    wlOsc.frequency.value = wlFreq;
    wlGain.gain.value = wlAmp * 0.3;
    wlOsc.connect(wlGain); wlGain.connect(ac.destination);
    wlOsc.start();
    wlPlaying = true; btn.textContent = '■ STOP'; btn.classList.add('active');
  }
}
function wlToggleFreeze() {
  wlFrozen = !wlFrozen;
  const btn = document.getElementById('wl-freeze-btn');
  btn.classList.toggle('active', wlFrozen);
  btn.textContent = wlFrozen ? 'UNFREEZE' : 'FREEZE';
}

/* ═══════════════════════════════════════════════════════════
   PWM CANVAS
═══════════════════════════════════════════════════════════ */
const pwmCanvas = document.getElementById('pwm-canvas');
const pwmCtx    = pwmCanvas.getContext('2d');
let pwmSweepId  = null, pwmSweepDir = 1, pwmOsc = null, pwmGainNode = null, pwmPlaying = false;

function drawPWM() {
  const w = pwmCanvas.width, h = pwmCanvas.height;
  const duty = parseFloat(document.getElementById('pwm-slider').value) / 100;
  document.getElementById('pwm-pct').textContent = Math.round(duty*100) + '%';
  pwmCtx.fillStyle = '#060610';
  pwmCtx.fillRect(0, 0, w, h);

  pwmCtx.strokeStyle = '#22c55e'; pwmCtx.lineWidth = 2;
  pwmCtx.shadowColor = '#22c55e'; pwmCtx.shadowBlur = 5;
  pwmCtx.beginPath();

  const cycles = 3, cw = w / cycles;
  const cy = h/2, amp = h * 0.36;

  pwmCtx.moveTo(0, cy - amp);
  for (let c = 0; c < cycles; c++) {
    const x0 = c * cw, xM = x0 + cw * duty, x1 = (c+1) * cw;
    pwmCtx.lineTo(xM, cy - amp);
    pwmCtx.lineTo(xM, cy + amp);
    pwmCtx.lineTo(x1 - 0.5, cy + amp);
    pwmCtx.lineTo(x1, cy - amp);
  }
  pwmCtx.stroke();
  pwmCtx.shadowBlur = 0;

  if (pwmOsc) {
    const ac = getAC();
    const period = 1 / 440;
    // Approximate PWM with detune: not ideal but audible difference
    pwmOsc.detune.setTargetAtTime((duty - 0.5) * 100, ac.currentTime, 0.05);
  }
}
drawPWM();

function pwmTogglePlay() {
  const ac = getAC(), btn = document.getElementById('pwm-play-btn');
  if (pwmPlaying) {
    if (pwmOsc) { pwmOsc.stop(); pwmOsc = null; }
    pwmPlaying = false; btn.textContent = '▶ PLAY PWM'; btn.classList.remove('active');
  } else {
    pwmOsc = ac.createOscillator(); pwmGainNode = ac.createGain();
    pwmOsc.type = 'square'; pwmOsc.frequency.value = 220;
    pwmGainNode.gain.value = 0.25;
    pwmOsc.connect(pwmGainNode); pwmGainNode.connect(ac.destination);
    pwmOsc.start();
    pwmPlaying = true; btn.textContent = '■ STOP PWM'; btn.classList.add('active');
  }
}
function startPWMSweep() {
  if (pwmSweepId) { clearInterval(pwmSweepId); pwmSweepId = null; return; }
  pwmSweepId = setInterval(() => {
    const sl = document.getElementById('pwm-slider');
    let v = parseFloat(sl.value) + pwmSweepDir * 1.2;
    if (v >= 90) { v = 90; pwmSweepDir = -1; }
    if (v <= 10) { v = 10; pwmSweepDir =  1; }
    sl.value = v;
    document.getElementById('pwm-val').textContent = Math.round(v) + '%';
    drawPWM();
  }, 50);
}

/* ═══════════════════════════════════════════════════════════
   BEATING LAB
═══════════════════════════════════════════════════════════ */
const beatCanvas = document.getElementById('beat-canvas');
const beatCtx    = beatCanvas.getContext('2d');
let beatFreqA = 440, beatDetuneCents = 0, beatPlaying = false;
let beatOscA = null, beatOscB = null, beatGain = null;
let beatPhase = 0;

function beatFreqB() { return beatFreqA * Math.pow(2, beatDetuneCents / 1200); }

function drawBeat() {
  const w = beatCanvas.width, h = beatCanvas.height;
  beatCtx.fillStyle = 'rgba(6,6,16,0.15)';
  beatCtx.fillRect(0, 0, w, h);

  const fA = beatFreqA, fB = beatFreqB(), beatF = Math.abs(fA - fB);
  const cycles = 4, cy = h/2, amp = h * 0.38;

  // Osc A (dim)
  beatCtx.beginPath(); beatCtx.strokeStyle = 'rgba(34,197,94,0.28)'; beatCtx.lineWidth = 1;
  for (let x = 0; x <= w; x++) {
    const phi = beatPhase * (fA/440) + (x/w) * cycles * Math.PI * 2;
    const y = cy*0.5 + Math.sin(phi) * amp * 0.35;
    x===0 ? beatCtx.moveTo(x,y) : beatCtx.lineTo(x,y);
  }
  beatCtx.stroke();

  // Osc B (dim)
  beatCtx.beginPath(); beatCtx.strokeStyle = 'rgba(245,158,11,0.28)'; beatCtx.lineWidth = 1;
  for (let x = 0; x <= w; x++) {
    const phi = beatPhase * (fB/440) + (x/w) * cycles * Math.PI * 2;
    const y = cy*1.5 + Math.sin(phi) * amp * 0.35;
    x===0 ? beatCtx.moveTo(x,y) : beatCtx.lineTo(x,y);
  }
  beatCtx.stroke();

  // Combined sum with amplitude envelope
  beatCtx.beginPath(); beatCtx.strokeStyle = '#22c55e'; beatCtx.lineWidth = 2;
  beatCtx.shadowColor = '#22c55e'; beatCtx.shadowBlur = 6;
  for (let x = 0; x <= w; x++) {
    const tNorm = x / w;
    const phiA = beatPhase*(fA/440) + tNorm*cycles*Math.PI*2;
    const phiB = beatPhase*(fB/440) + tNorm*cycles*Math.PI*2;
    const sum  = (Math.sin(phiA) + Math.sin(phiB)) * 0.5;
    const y    = cy + sum * amp;
    x===0 ? beatCtx.moveTo(x,y) : beatCtx.lineTo(x,y);
  }
  beatCtx.stroke(); beatCtx.shadowBlur = 0;

  beatPhase += 0.04;

  // Update beat display
  document.getElementById('beat-freq-display').textContent = beatF.toFixed(1);
  requestAnimationFrame(drawBeat);
}
drawBeat();

function beatFreqAChange(v) {
  beatFreqA = parseFloat(v);
  document.getElementById('beat-freqA-val').textContent = v + ' Hz';
  if (beatOscA) beatOscA.frequency.setTargetAtTime(beatFreqA, getAC().currentTime, 0.02);
  if (beatOscB) beatOscB.frequency.setTargetAtTime(beatFreqB(), getAC().currentTime, 0.02);
}
function beatDetuneChange(v) {
  beatDetuneCents = parseFloat(v);
  document.getElementById('beat-detune-val').textContent = (v >= 0 ? '+' : '') + parseFloat(v).toFixed(1) + ' ¢';
  if (beatOscB) beatOscB.frequency.setTargetAtTime(beatFreqB(), getAC().currentTime, 0.02);
}
function beatTogglePlay() {
  const ac = getAC(), btn = document.getElementById('beat-play-btn');
  if (beatPlaying) {
    if (beatOscA) { beatOscA.stop(); beatOscA = null; }
    if (beatOscB) { beatOscB.stop(); beatOscB = null; }
    beatPlaying = false; btn.textContent = '▶ PLAY BOTH'; btn.classList.remove('active');
  } else {
    beatGain = ac.createGain(); beatGain.gain.value = 0.18; beatGain.connect(ac.destination);
    beatOscA = ac.createOscillator(); beatOscA.frequency.value = beatFreqA; beatOscA.connect(beatGain); beatOscA.start();
    beatOscB = ac.createOscillator(); beatOscB.frequency.value = beatFreqB(); beatOscB.connect(beatGain); beatOscB.start();
    beatPlaying = true; btn.textContent = '■ STOP'; btn.classList.add('active');
  }
}

/* ═══════════════════════════════════════════════════════════
   LISSAJOUS
═══════════════════════════════════════════════════════════ */
const lissCanvas = document.getElementById('liss-canvas');
const lissCtx    = lissCanvas.getContext('2d');
let lissXF = 3, lissYF = 2, lissPhOff = Math.PI/2, lissT = 0;

function lissUpdate() {
  lissXF    = parseInt(document.getElementById('liss-xfreq').value);
  lissYF    = parseInt(document.getElementById('liss-yfreq').value);
  const deg = parseInt(document.getElementById('liss-phase').value);
  lissPhOff = deg * Math.PI / 180;
  document.getElementById('liss-xf-val').textContent  = lissXF;
  document.getElementById('liss-yf-val').textContent  = lissYF;
  document.getElementById('liss-ph-val').textContent  = deg + '°';
  document.getElementById('liss-xf-disp').textContent = lissXF;
  document.getElementById('liss-yf-disp').textContent = lissYF;
  document.getElementById('liss-ph-disp').textContent = deg + '°';
}

function setLiss(x, y, deg) {
  document.getElementById('liss-xfreq').value = x;
  document.getElementById('liss-yfreq').value = y;
  document.getElementById('liss-phase').value = deg;
  lissUpdate();
}

function drawLiss() {
  const w = lissCanvas.width, h = lissCanvas.height;
  lissCtx.fillStyle = 'rgba(6,6,16,0.045)';
  lissCtx.fillRect(0, 0, w, h);

  const steps = 800, pad = 20;
  lissCtx.beginPath();
  lissCtx.strokeStyle = '#22c55e'; lissCtx.lineWidth = 1.4;
  lissCtx.shadowColor = '#22c55e'; lissCtx.shadowBlur = 4;
  for (let i = 0; i <= steps; i++) {
    const t = lissT + (i / steps) * Math.PI * 2;
    const x = pad + (Math.sin(t * lissXF + lissPhOff) + 1) / 2 * (w - pad*2);
    const y = pad + (Math.sin(t * lissYF)              + 1) / 2 * (h - pad*2);
    i === 0 ? lissCtx.moveTo(x, y) : lissCtx.lineTo(x, y);
  }
  lissCtx.stroke(); lissCtx.shadowBlur = 0;
  lissT += 0.005;
  requestAnimationFrame(drawLiss);
}
drawLiss();

/* ═══════════════════════════════════════════════════════════
   FM SYNTHESIS — GRID + AUDIO
═══════════════════════════════════════════════════════════ */
const fmGC  = document.getElementById('fm-grid-canvas');
const fmCtx = fmGC.getContext('2d');

const FM_RATIOS  = [1, 1.5, 2, 2.5, 3, 3.5, 4, 6];
const FM_INDICES = [0, 1,   2, 3,   4,  5,  7, 10];
const PRESETS = [
  { row: 0, col: 3, label: 'DX7' },
  { row: 5, col: 5, label: 'Bell' },
  { row: 2, col: 6, label: 'Bass' },
  { row: 6, col: 2, label: 'Marimba' }
];

function fmCellColor(ratio, idx) {
  const isInt = Math.abs(ratio - Math.round(ratio)) < 0.05;
  const isNear = Math.abs(ratio - Math.round(ratio)) < 0.55;
  if (isInt)  return ['rgba(34,197,94,', '#22c55e'];
  if (isNear) return ['rgba(245,158,11,', '#f59e0b'];
  return         ['rgba(249,115,22,', '#f97316'];
}

function drawFMGrid() {
  const w = fmGC.width, h = fmGC.height;
  const cw = w / 8, ch = h / 8;
  fmCtx.clearRect(0, 0, w, h);

  for (let row = 0; row < 8; row++) {
    for (let col = 0; col < 8; col++) {
      const ratio = FM_RATIOS[7 - row];
      const idx   = FM_INDICES[col];
      const [colBase] = fmCellColor(ratio, idx);
      const alpha = 0.12 + (idx / 10) * 0.25 + (ratio <= 4 ? 0.05 : 0);
      fmCtx.fillStyle = colBase + alpha + ')';
      fmCtx.fillRect(col*cw + 1, row*ch + 1, cw-2, ch-2);
      fmCtx.strokeStyle = 'rgba(255,255,255,0.05)';
      fmCtx.strokeRect(col*cw + 1, row*ch + 1, cw-2, ch-2);

      // Axis labels
      if (col === 0) {
        fmCtx.fillStyle = 'rgba(34,197,94,0.7)';
        fmCtx.font = '10px monospace';
        fmCtx.fillText('1:' + ratio, col*cw + 4, row*ch + 14);
      }
      if (row === 7) {
        fmCtx.fillStyle = 'rgba(148,163,184,0.6)';
        fmCtx.font = '10px monospace';
        fmCtx.fillText(idx, col*cw + cw/2 - 4, row*ch + ch - 4);
      }
    }
  }

  // Named preset dots
  PRESETS.forEach(p => {
    const cx = p.col * cw + cw/2, cy = p.row * ch + ch/2;
    fmCtx.beginPath();
    fmCtx.arc(cx, cy, 4, 0, Math.PI*2);
    fmCtx.fillStyle = '#fff';
    fmCtx.fill();
    fmCtx.fillStyle = 'rgba(255,255,255,0.85)';
    fmCtx.font = 'bold 9px monospace';
    fmCtx.fillText(p.label, cx + 6, cy + 3);
  });
}
drawFMGrid();

function fmGridClick(e) {
  const rect = fmGC.getBoundingClientRect();
  const x = (e.clientX - rect.left) * (fmGC.width  / rect.width);
  const y = (e.clientY - rect.top)  * (fmGC.height / rect.height);
  const col = Math.min(7, Math.floor(x / (fmGC.width  / 8)));
  const row = Math.min(7, Math.floor(y / (fmGC.height / 8)));
  const ratio = FM_RATIOS[7 - row];
  const idx   = FM_INDICES[col];
  playFM(220, ratio, idx, 1.8);
  document.getElementById('fm-last-played').textContent =
    'Playing: carrier 220 Hz · ratio 1:' + ratio + ' · index ' + idx;
  updateFMSpectrum(idx);

  // Flash cell
  const cw = fmGC.width/8, ch = fmGC.height/8;
  fmCtx.fillStyle = 'rgba(34,197,94,0.45)';
  fmCtx.fillRect(col*cw+1, row*ch+1, cw-2, ch-2);
  setTimeout(drawFMGrid, 300);
}

function playFM(carrierF, ratio, modIndex, dur) {
  const ac = getAC();
  const modF   = carrierF * ratio;
  const modDep = modIndex * carrierF;
  const mod    = ac.createOscillator();
  const modG   = ac.createGain();
  const car    = ac.createOscillator();
  const outG   = ac.createGain();
  mod.frequency.value = modF;
  modG.gain.value     = modDep;
  car.frequency.value = carrierF;
  outG.gain.setValueAtTime(0.28, ac.currentTime);
  outG.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + dur);
  mod.connect(modG); modG.connect(car.frequency);
  car.connect(outG); outG.connect(ac.destination);
  mod.start(); car.start();
  mod.stop(ac.currentTime + dur); car.stop(ac.currentTime + dur);
}

function playFMPreset(carrierF, ratio, idx, label) {
  playFM(carrierF, ratio, idx, 2.2);
  document.getElementById('fm-last-played').textContent = 'Playing: ' + label;
  updateFMSpectrum(idx);
}

function updateFMSpectrum(modIndex) {
  // Approximate Bessel function magnitudes for FM sidebands
  const J = [1];
  let prev1 = 1, prev2 = 0;
  for (let n = 1; n <= 15; n++) {
    const jn = (2*(n-1)/Math.max(modIndex,0.01)) * prev1 - prev2;
    J.push(Math.abs(jn));
    prev2 = prev1; prev1 = jn;
  }
  const mx = Math.max(...J, 0.001);
  for (let i = 0; i < 16; i++) {
    const bar = document.getElementById('fsb-' + i);
    if (bar) bar.style.height = Math.max((J[i]/mx)*95, 2) + '%';
  }
}

/* ═══════════════════════════════════════════════════════════
   PHYSICAL MODELING — PLUCKED STRING
═══════════════════════════════════════════════════════════ */
const strCanvas = document.getElementById('string-canvas');
const strCtx    = strCanvas.getContext('2d');
let strMaterial = 'nylon', strAmplitude = 0, strPhase2 = 0;
let strDecay = 0, strHarmonics = [1, 0.5, 0.25, 0.12], strBowing = false, strBowId = null;

const MAT = {
  nylon:   { decay: 0.015, cutoff: 1800, color: '#22c55e', q: 40 },
  steel:   { decay: 0.007, cutoff: 5000, color: '#7dd3fc', q: 80 },
  glass:   { decay: 0.012, cutoff: 7500, color: '#c4b5fd', q: 120 },
  crystal: { decay: 0.004, cutoff: 12000,color: '#fde68a', q: 160 }
};

function drawString() {
  const w = strCanvas.width, h = strCanvas.height;
  strCtx.fillStyle = '#060610';
  strCtx.fillRect(0, 0, w, h);

  // Bridge endpoints
  strCtx.beginPath();
  strCtx.strokeStyle = 'rgba(34,197,94,0.15)'; strCtx.lineWidth = 1;
  strCtx.moveTo(10, h/2); strCtx.lineTo(w-10, h/2);
  strCtx.stroke();

  if (strAmplitude > 0.001) {
    const m = MAT[strMaterial];
    strCtx.beginPath();
    strCtx.strokeStyle = m.color; strCtx.lineWidth = 2;
    strCtx.shadowColor = m.color; strCtx.shadowBlur = 10;
    for (let x = 10; x <= w-10; x++) {
      const t = (x - 10) / (w - 20);
      let y = h/2;
      strHarmonics.forEach((amp, i) => {
        y += Math.sin((i+1) * Math.PI * t) * Math.cos(strPhase2 * (i+1) * 2.5) * amp * strAmplitude * h * 0.35;
      });
      x === 10 ? strCtx.moveTo(x, y) : strCtx.lineTo(x, y);
    }
    strCtx.stroke(); strCtx.shadowBlur = 0;
    strAmplitude *= (1 - MAT[strMaterial].decay);
  }
  strPhase2 += 0.05;
  requestAnimationFrame(drawString);
}
drawString();

function pluckString(e) {
  const rect = strCanvas.getBoundingClientRect();
  const pos  = (e.clientX - rect.left) / rect.width;
  const m    = MAT[strMaterial];
  strAmplitude = 1.0;
  // Emphasize harmonics based on pluck position
  strHarmonics = [1, 0.5, 0.25, 0.12].map((v, i) =>
    v * Math.abs(Math.sin((i+1) * Math.PI * pos)));
  strHarmonics[0] = Math.max(strHarmonics[0], 0.3);

  // Audio
  const ac   = getAC();
  const tension = parseFloat(document.getElementById('string-tension').value);
  const baseF   = 110 * tension;
  const buf     = ac.createBuffer(1, Math.floor(ac.sampleRate * 0.05), ac.sampleRate);
  const data    = buf.getChannelData(0);
  for (let i = 0; i < data.length; i++) {
    data[i] = (Math.random()*2-1) * Math.exp(-i / (data.length*0.15));
  }
  const src = ac.createBufferSource();
  src.buffer = buf;
  const filt = ac.createBiquadFilter();
  filt.type = 'lowpass'; filt.frequency.value = m.cutoff; filt.Q.value = m.q;
  const env = ac.createGain();
  env.gain.setValueAtTime(0.5, ac.currentTime);
  env.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 2.5 / tension);
  src.connect(filt); filt.connect(env); env.connect(ac.destination);
  src.start();
}

function pluckStringAuto() {
  pluckString({ clientX: strCanvas.getBoundingClientRect().left + strCanvas.offsetWidth * 0.3,
                clientY: strCanvas.getBoundingClientRect().top });
}

function setStringMaterial(mat, btn) {
  strMaterial = mat;
  document.querySelectorAll('#string-material-btns .btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function toggleBow() {
  strBowing = !strBowing;
  const btn = document.getElementById('bow-btn');
  btn.classList.toggle('active', strBowing);
  btn.textContent = strBowing ? '■ STOP BOW' : 'BOW MODE';
  if (strBowing) {
    strBowId = setInterval(() => {
      strAmplitude = Math.min(strAmplitude + 0.02, 0.8);
    }, 50);
  } else {
    if (strBowId) clearInterval(strBowId);
  }
}

