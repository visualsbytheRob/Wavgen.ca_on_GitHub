<script>
/* ═══════════════════ WAVGEN CORE SYSTEMS ═══════════════════ */
class LagFilter {
  constructor(initial=0,tau=0.15){this.value=initial;this.target=initial;this.tau=tau;}
  update(dt){const a=1-Math.exp(-dt/Math.max(this.tau,0.001));this.value+=(this.target-this.value)*a;return this.value;}
  set(t){this.target=t;}
  snap(v){this.value=this.target=v;}
}

class BPMEngine {
  constructor(bpm=120){
    this.bpm=bpm;this._start=null;this._beat=0;this._running=false;
    this._subs=new Map();
  }
  start(){this._running=true;this._start=performance.now();this._beat=0;this._tick();}
  stop(){this._running=false;}
  _tick(){
    if(!this._running)return;
    const now=performance.now();
    const msPerBeat=60000/this.bpm;
    const expected=Math.floor((now-this._start)/msPerBeat);
    while(this._beat<=expected){this._fire(this._beat);this._beat++;}
    requestAnimationFrame(()=>this._tick());
  }
  _fire(n){
    const ph=n%16,isQ=ph%4===0,isD=ph===0;
    this._subs.forEach(fn=>fn({beat:n,phase:ph,isQ,isD,bpm:this.bpm}));
  }
  sub(id,fn){this._subs.set(id,fn);}
  setBPM(b){this.bpm=Math.max(60,Math.min(220,b));if(this._running){this.stop();this.start();}}
}

/* ═══════════════════ HERO WAREHOUSE CANVAS ═══════════════════ */
(function(){
  const canvas=document.getElementById('heroCanvas');
  const W=canvas.width=canvas.offsetWidth||1200;
  const H=canvas.height=440;
  const ctx=canvas.getContext('2d');

  const BPM=160;
  const engine=new BPMEngine(BPM);

  // State
  let beatFlash=new LagFilter(0,0.04);
  let crowdEnergy=new LagFilter(0.5,0.18);
  let laserAlpha=new LagFilter(0.7,0.12);
  let fogAlpha=new LagFilter(0.04,0.8);

  // Crowd dots
  const NDOTS=120;
  const dots=Array.from({length:NDOTS},()=>({
    x:W*0.15+Math.random()*W*0.7,
    y:H*0.65+Math.random()*H*0.28,
    r:1.2+Math.random()*1.8,
    phase:Math.random()*Math.PI*2,
    speed:0.8+Math.random()*0.8,
    amp:1+Math.random()*3
  }));

  // Lasers — emanate from center top
  const NLASERS=8;
  const lasers=Array.from({length:NLASERS},(_,i)=>({
    angle:(-0.5+i/(NLASERS-1))*Math.PI*0.9,
    phase:i*0.4,
    color:i%2===0?'#39ff14':'#f59e0b',
    speed:0.3+Math.random()*0.3
  }));

  // Fog blobs
  const NFOG=6;
  const fogs=Array.from({length:NFOG},()=>({
    x:Math.random()*W,y:H*0.5+Math.random()*H*0.3,
    r:80+Math.random()*120,vx:(Math.random()-0.5)*0.3,vy:-0.1-Math.random()*0.15,
    alpha:0.02+Math.random()*0.03
  }));

  // Speaker stacks (left + right)
  const speakers=[
    {x:W*0.03,y:H*0.3,w:44,h:160,ripples:[]},
    {x:W*0.97-44,y:H*0.3,w:44,h:160,ripples:[]}
  ];

  let strobeAlpha=new LagFilter(0,0.03);
  let lastTime=0;
  let beatCount=0;

  engine.sub('hero',({beat,phase,isQ})=>{
    crowdEnergy.set(0.85+Math.random()*0.15);
    strobeAlpha.set(isQ?0.6:0.2);
    if(isQ){
      speakers.forEach(s=>{
        if(s.ripples.length<5)s.ripples.push({r:20,a:0.8,speed:2.5+Math.random()});
      });
    }
    beatCount=beat;
    // Update BPM display
    document.getElementById('heroBpmDisplay').textContent=BPM+' BPM — Beat '+((beat%4)+1);
  });
  engine.start();

  function draw(ts){
    const dt=Math.min((ts-lastTime)/1000,0.05);lastTime=ts;

    beatFlash.update(dt);crowdEnergy.update(dt);
    laserAlpha.update(dt);fogAlpha.update(dt);
    strobeAlpha.update(dt);

    // Phosphor decay
    ctx.globalAlpha=0.09;
    ctx.fillStyle='#030200';
    ctx.fillRect(0,0,W,H);
    ctx.globalAlpha=1;

    // Ceiling & floor
    const ceilGrad=ctx.createLinearGradient(0,0,0,H*0.35);
    ceilGrad.addColorStop(0,'rgba(5,3,0,0.95)');
    ceilGrad.addColorStop(1,'rgba(3,3,3,0)');
    ctx.fillStyle=ceilGrad;ctx.fillRect(0,0,W,H*0.35);

    const floorGrad=ctx.createLinearGradient(0,H*0.7,0,H);
    floorGrad.addColorStop(0,'rgba(3,3,3,0)');
    floorGrad.addColorStop(1,'rgba(10,6,0,0.7)');
    ctx.fillStyle=floorGrad;ctx.fillRect(0,H*0.7,W,H*0.3);

    // Structural lines — warehouse beams
    ctx.strokeStyle='rgba(57,255,20,0.04)';
    ctx.lineWidth=1;
    for(let i=0;i<6;i++){
      const x=W*0.1+i*(W*0.16);
      ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(W/2,H*0.02);ctx.stroke();
    }

    // Speaker stacks
    speakers.forEach(s=>{
      ctx.fillStyle='#0a0800';
      ctx.strokeStyle='rgba(57,255,20,0.25)';
      ctx.lineWidth=1;
      ctx.fillRect(s.x,s.y,s.w,s.h);
      ctx.strokeRect(s.x,s.y,s.w,s.h);
      // Speaker cones
      for(let i=0;i<4;i++){
        const cy=s.y+20+i*38;
        ctx.beginPath();
        ctx.arc(s.x+s.w/2,cy,14,0,Math.PI*2);
        ctx.fillStyle='#050400';ctx.fill();
        ctx.strokeStyle='rgba(245,158,11,0.3)';ctx.stroke();
      }
      // Ripple rings from bass hits
      s.ripples.forEach(rp=>{
        rp.r+=rp.speed*(1+dt*60);rp.a-=0.025;
      });
      s.ripples=s.ripples.filter(r=>r.a>0);
      s.ripples.forEach(rp=>{
        ctx.beginPath();
        const cx=(s.x===W*0.03?s.x+s.w:s.x);
        ctx.arc(cx,s.y+s.h/2,rp.r,0,Math.PI*2);
        ctx.strokeStyle=`rgba(57,255,20,${rp.a*0.5})`;
        ctx.lineWidth=1.5;ctx.stroke();
      });
    });

    // Laser beams from ceiling
    const laserOriginX=W/2;
    const laserOriginY=H*0.02;
    lasers.forEach(laser=>{
      const sweep=Math.sin(ts*0.001*laser.speed+laser.phase)*0.25;
      const angle=laser.angle+sweep;
      const len=H*1.5;
      const tx=laserOriginX+Math.sin(angle)*len;
      const ty=laserOriginY+Math.cos(angle)*len;
      const grad=ctx.createLinearGradient(laserOriginX,laserOriginY,tx,ty);
      const isGreen=laser.color==='#39ff14';
      grad.addColorStop(0,isGreen?`rgba(57,255,20,${0.7*laserAlpha.value})`:`rgba(245,158,11,${0.6*laserAlpha.value})`);
      grad.addColorStop(0.4,isGreen?`rgba(57,255,20,${0.15*laserAlpha.value})`:`rgba(245,158,11,${0.12*laserAlpha.value})`);
      grad.addColorStop(1,'rgba(0,0,0,0)');
      ctx.beginPath();ctx.moveTo(laserOriginX,laserOriginY);ctx.lineTo(tx,ty);
      ctx.strokeStyle=grad;ctx.lineWidth=1.2;
      ctx.shadowBlur=6;ctx.shadowColor=laser.color;
      ctx.stroke();ctx.shadowBlur=0;
    });

    // Fog drifts
    fogs.forEach(fog=>{
      fog.x+=fog.vx;fog.y+=fog.vy;
      if(fog.y<-fog.r)fog.y=H+fog.r;
      if(fog.x<-fog.r)fog.x=W+fog.r;
      if(fog.x>W+fog.r)fog.x=-fog.r;
      const fg=ctx.createRadialGradient(fog.x,fog.y,0,fog.x,fog.y,fog.r);
      fg.addColorStop(0,`rgba(220,210,190,${fog.alpha})`);
      fg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=fg;ctx.beginPath();
      ctx.ellipse(fog.x,fog.y,fog.r,fog.r*0.5,0,0,Math.PI*2);
      ctx.fill();
    });

    // Crowd dots
    const ce=crowdEnergy.value;
    dots.forEach(d=>{
      const oy=Math.sin(ts*0.001*d.speed+d.phase)*d.amp*ce*3;
      const ox=Math.cos(ts*0.0007*d.speed+d.phase)*d.amp*ce*1.5;
      const glow=0.4+ce*0.5;
      ctx.beginPath();
      ctx.arc(d.x+ox,d.y+oy,d.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(245,158,11,${glow})`;
      ctx.shadowBlur=6*ce;ctx.shadowColor='#f59e0b';
      ctx.fill();ctx.shadowBlur=0;
    });
    crowdEnergy.set(crowdEnergy.value*0.98+0.25*0.02);

    // Strobe flash
    const sv=strobeAlpha.value;
    if(sv>0.02){
      ctx.fillStyle=`rgba(255,255,255,${sv*0.15})`;
      ctx.fillRect(0,0,W,H);
    }
    strobeAlpha.set(0);

    // Beat dot indicator (top right)
    const bph=beatCount%4;
    for(let i=0;i<4;i++){
      ctx.beginPath();
      ctx.arc(W-30-(3-i)*20,20,5,0,Math.PI*2);
      ctx.fillStyle=i<=bph?'rgba(57,255,20,0.9)':'rgba(57,255,20,0.15)';
      ctx.shadowBlur=i===bph?10:0;ctx.shadowColor='#39ff14';
      ctx.fill();ctx.shadowBlur=0;
    }

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);

  window.addEventListener('resize',()=>{
    canvas.width=canvas.offsetWidth;
    canvas.height=440;
  });
})();
</script>
