<script>
/* ═══════════════════ SECTION 2 — TIMELINE DRAG ═══════════════════ */
(function(){
  const outer=document.getElementById('timelineOuter');
  let isDragging=false,startX=0,scrollLeft=0;
  outer.addEventListener('mousedown',e=>{isDragging=true;startX=e.pageX-outer.offsetLeft;scrollLeft=outer.scrollLeft;});
  outer.addEventListener('mouseleave',()=>isDragging=false);
  outer.addEventListener('mouseup',()=>isDragging=false);
  outer.addEventListener('mousemove',e=>{
    if(!isDragging)return;e.preventDefault();
    const x=e.pageX-outer.offsetLeft;
    outer.scrollLeft=scrollLeft-(x-startX)*1.2;
  });
  // Touch support
  outer.addEventListener('touchstart',e=>{startX=e.touches[0].pageX;scrollLeft=outer.scrollLeft;});
  outer.addEventListener('touchmove',e=>{
    const x=e.touches[0].pageX;
    outer.scrollLeft=scrollLeft-(x-startX);
  });
})();

/* ═══════════════════ SECTION 3 — SOUND SYSTEM CANVAS ═══════════════════ */
(function(){
  const canvas=document.getElementById('soundCanvas');
  const W=canvas.width=canvas.offsetWidth||600;
  const H=canvas.height=400;
  const ctx=canvas.getContext('2d');
  const infoTitle=document.getElementById('soundInfoTitle');
  const infoDesc=document.getElementById('soundInfoDesc');

  const components=[
    {id:'tt',label:'Turntables',x:W*0.15,y:H*0.08,w:110,h:44,color:'#39ff14',
     spec:'Technics SL-1200 MK2. Direct drive. 33⅓ RPM. The DJ's primary instrument — pitch control enables BPM matching. Two decks for continuous mixing.',
     out:[1]},
    {id:'mix',label:'Mixer',x:W*0.44,y:H*0.08,w:80,h:44,color:'#39ff14',
     spec:'Rotary mixer (Urei 1620 / Rane TTM). EQ per channel: -∞ to +6dB. Crossfader. Gain staging critical — every dB of distortion compounds downstream.',
     out:[2]},
    {id:'xover',label:'Crossover',x:W*0.44,y:H*0.28,w:80,h:44,color:'#f59e0b',
     spec:'Active crossover splits signal by frequency: Sub (<80Hz) → sub amp, Mid (80–800Hz) → mid amp, High (800Hz+) → horn amp. Prevents woofers from attempting treble.',
     out:[3,4,5]},
    {id:'sub',label:'Sub Amp\n18"',x:W*0.1,y:H*0.58,w:90,h:50,color:'#ff6b00',
     spec:'18" subwoofer. Response: 20–80Hz. Power: 1000–3000W. Sub-bass is felt rather than heard — bone conduction, chest pressure. The physical argument of a sound system.',
     out:[]},
    {id:'mid',label:'Mid Stack\n12"',x:W*0.44,y:H*0.58,w:90,h:50,color:'#f59e0b',
     spec:'12" woofers + horn compression driver. Range: 80–800Hz. The kick drum body, snare crack, vocal presence. Mid clarity separates a professional from a domestic rig.',
     out:[]},
    {id:'horn',label:'Horns\nHF',x:W*0.78,y:H*0.58,w:80,h:50,color:'#39ff14',
     spec:'Exponential horn + 1" compression driver. Range: 800Hz–20kHz. High sensitivity (105dB/1W/1m). Horns project. Hi-hats, cymbals, top-end air.',
     out:[]},
    {id:'amp1',label:'Amp',x:W*0.18,y:H*0.42,w:56,h:32,color:'#7a7060',
     spec:'Class D amplifier. Crown XTi / Lab.gruppen. Power: 2000W RMS. Sub amplification requires massive power reserves for transient response.',
     out:[3]},
    {id:'amp2',label:'Amp',x:W*0.46,y:H*0.42,w:56,h:32,color:'#7a7060',
     spec:'Class AB/D amplifier. Mid-range requires precise power delivery for voice coil dynamics. Usually 500–1000W per cabinet.',
     out:[4]},
    {id:'amp3',label:'Amp',x:W*0.74,y:H*0.42,w:56,h:32,color:'#7a7060',
     spec:'Class AB amplifier. Horn drivers require sensitive amplification — too much power and you blow the voice coil. Usually 200–500W.',
     out:[5]},
  ];
  // Fix crossover outputs to amp indices
  components[2].out=[6,7,8];
  components[6].out=[3];components[7].out=[4];components[8].out=[5];
  // Turntable → mixer
  components[0].out=[1];
  // Mixer → crossover
  components[1].out=[2];

  // Signal path edges
  const edges=[
    {from:0,to:1},{from:1,to:2},
    {from:2,to:6},{from:2,to:7},{from:2,to:8},
    {from:6,to:3},{from:7,to:4},{from:8,to:5}
  ];

  // Particles per edge
  const particles=edges.map(e=>Array.from({length:4},()=>({t:Math.random(),speed:0.004+Math.random()*0.003})));

  let hoveredIdx=-1;
  function getCenter(c){return{x:c.x+c.w/2,y:c.y+c.h/2};}

  canvas.addEventListener('mousemove',e=>{
    const rect=canvas.getBoundingClientRect();
    const mx=(e.clientX-rect.left)*(W/rect.width);
    const my=(e.clientY-rect.top)*(H/rect.height);
    hoveredIdx=-1;
    components.forEach((c,i)=>{
      if(mx>c.x&&mx<c.x+c.w&&my>c.y&&my<c.y+c.h)hoveredIdx=i;
    });
    canvas.style.cursor=hoveredIdx>=0?'pointer':'default';
  });
  canvas.addEventListener('click',()=>{
    if(hoveredIdx>=0){
      const c=components[hoveredIdx];
      infoTitle.textContent=c.label.replace('\n',' ');
      infoDesc.textContent=c.spec;
    }
  });

  let lastT=0;
  function drawSound(ts){
    const dt=Math.min((ts-lastT)/1000,0.05);lastT=ts;
    ctx.globalAlpha=0.12;ctx.fillStyle='#030300';ctx.fillRect(0,0,W,H);ctx.globalAlpha=1;

    // Draw edges + particles
    edges.forEach((e,ei)=>{
      const a=components[e.from],b=components[e.to];
      const ax=a.x+a.w/2,ay=a.y+a.h/2,bx=b.x+b.w/2,by=b.y+b.h/2;
      ctx.beginPath();ctx.moveTo(ax,ay);ctx.lineTo(bx,by);
      ctx.strokeStyle='rgba(57,255,20,0.12)';ctx.lineWidth=1;ctx.stroke();
      // Particles
      particles[ei].forEach(p=>{
        p.t+=p.speed;if(p.t>1)p.t-=1;
        const px=ax+(bx-ax)*p.t,py=ay+(by-ay)*p.t;
        ctx.beginPath();ctx.arc(px,py,2,0,Math.PI*2);
        ctx.fillStyle='rgba(57,255,20,0.85)';
        ctx.shadowBlur=6;ctx.shadowColor='#39ff14';
        ctx.fill();ctx.shadowBlur=0;
      });
    });

    // Draw components
    components.forEach((c,i)=>{
      const isHov=i===hoveredIdx;
      ctx.fillStyle=isHov?'rgba(57,255,20,0.15)':'rgba(10,8,0,0.9)';
      ctx.strokeStyle=isHov?c.color:c.color+'55';
      ctx.lineWidth=isHov?1.5:1;
      if(isHov){ctx.shadowBlur=12;ctx.shadowColor=c.color;}
      roundRect(ctx,c.x,c.y,c.w,c.h,5);ctx.fill();ctx.stroke();
      ctx.shadowBlur=0;
      ctx.fillStyle=c.color;
      ctx.font=`bold ${c.label.includes('\n')?'9':'10'}px Segoe UI`;
      ctx.textAlign='center';ctx.textBaseline='middle';
      const lines=c.label.split('\n');
      if(lines.length===2){
        ctx.fillText(lines[0],c.x+c.w/2,c.y+c.h/2-6);
        ctx.font='8px Segoe UI';ctx.fillStyle=c.color+'aa';
        ctx.fillText(lines[1],c.x+c.w/2,c.y+c.h/2+6);
      } else {
        ctx.fillText(c.label,c.x+c.w/2,c.y+c.h/2);
      }
    });

    // Sub-bass ripple rings at bottom
    const t=ts*0.001;
    for(let i=0;i<3;i++){
      const phase=(t*0.8+i*0.5)%1;
      const r=20+phase*60;const alpha=(1-phase)*0.3;
      const c=components[3];
      ctx.beginPath();ctx.arc(c.x+c.w/2,c.y+c.h,r,Math.PI,0);
      ctx.strokeStyle=`rgba(255,107,0,${alpha})`;ctx.lineWidth=1;ctx.stroke();
    }

    requestAnimationFrame(drawSound);
  }
  requestAnimationFrame(drawSound);

  function roundRect(ctx,x,y,w,h,r){
    ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.arcTo(x+w,y,x+w,y+r,r);
    ctx.lineTo(x+w,y+h-r);ctx.arcTo(x+w,y+h,x+w-r,y+h,r);
    ctx.lineTo(x+r,y+h);ctx.arcTo(x,y+h,x,y+h-r,r);
    ctx.lineTo(x,y+r);ctx.arcTo(x,y,x+r,y,r);ctx.closePath();
  }

  // Freq response canvas
  const frc=document.getElementById('freqResponseCanvas');
  frc.width=frc.offsetWidth||400;frc.height=90;
  const fctx=frc.getContext('2d');
  const fw=frc.width,fh=frc.height;
  let lastFT=0;
  function drawFreq(ts){
    const dt=Math.min((ts-lastFT)/1000,0.05);lastFT=ts;
    fctx.globalAlpha=0.1;fctx.fillStyle='#030300';fctx.fillRect(0,0,fw,fh);fctx.globalAlpha=1;
    fctx.beginPath();
    for(let i=0;i<fw;i++){
      const freq=20*Math.pow(1000,i/fw);
      const t=ts*0.001;
      let resp=0;
      if(freq<80){resp=0.9+0.08*Math.sin(t*2.1+freq*0.01);}
      else if(freq<500){resp=0.7+0.06*Math.sin(t*1.7+freq*0.005);}
      else if(freq<3000){resp=0.6+0.05*Math.sin(t*1.4);}
      else{resp=0.45+0.04*Math.sin(t*2.3);}
      const y=fh-(resp*fh*0.85);
      if(i===0)fctx.moveTo(i,y);else fctx.lineTo(i,y);
    }
    fctx.strokeStyle='rgba(57,255,20,0.7)';fctx.lineWidth=1.5;
    fctx.shadowBlur=4;fctx.shadowColor='#39ff14';fctx.stroke();fctx.shadowBlur=0;
    // Sub fill
    fctx.lineTo(fw*0.12,fh);fctx.lineTo(0,fh);fctx.closePath();
    fctx.fillStyle='rgba(255,107,0,0.08)';fctx.fill();
    requestAnimationFrame(drawFreq);
  }
  requestAnimationFrame(drawFreq);
})();
</script>
