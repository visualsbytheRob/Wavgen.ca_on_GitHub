<script>
/* ═══════════════════ SECTION 6 — FLYER GENERATOR ═══════════════════ */
(function(){
  const EVENTS=[
    {name:'JUNGLE MASSIVE',sub:'ALL NIGHT LONG',venue:'Arch 7, Hackney',phone:'0171 XXX XXXX'},
    {name:'ROAST',sub:'JUNGLE FEVER',venue:'The Dungeons, Waterloo',phone:'0181 XXX XXXX'},
    {name:'METALHEADZ',sub:'SUNDAY SESSIONS',venue:'Blue Note, Hoxton',phone:'0171 XXX XXXX'},
    {name:'SPEED',sub:'INTELLIGENT DNB',venue:'Mars Bar, London W1',phone:'0171 XXX XXXX'},
    {name:'SWERVE',sub:'BREAKBEAT SCIENCE',venue:'The Leisure Lounge',phone:'0181 XXX XXXX'},
    {name:'KOOL FM',sub:'LIVE BROADCAST',venue:'Undisclosed Location',phone:'TUNE 100.4 FM'},
    {name:'FREE PARTY',sub:'BRING SOUND SYSTEM',venue:'M25 Junction — TBA',phone:'FREE BEFORE 10PM'},
    {name:'DARKCORE',sub:'FOR THE HARDCORE',venue:'Roller Express, N18',phone:'0181 XXX XXXX'},
    {name:'MOVEMENT',sub:'LIQUID FUNCTION',venue:'Brixton Academy',phone:'0171 XXX XXXX'},
    {name:'JUNGLE MANIA',sub:'THE ORIGINAL',venue:'Wembley Arena',phone:'0181 900 0000'},
    {name:'PERCEPTION',sub:'STEPPERS NIGHT',venue:'The Forum, Kentish Town',phone:'0171 XXX XXXX'},
    {name:'TELEPATHY',sub:'RAVE ALL NIGHT',venue:'Nr. Hemel Hempstead',phone:'FREE PARTY'},
  ];
  const MONTHS=['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  const YEARS=['1992','1993','1994','1995','1996','1997'];

  function drawFlyer(canvas,evt,seed){
    const W=canvas.width=200,H=canvas.height=286;
    const ctx=canvas.getContext('2d');
    const rng=mulberry32(seed);

    ctx.fillStyle='#030303';ctx.fillRect(0,0,W,H);

    // Noise/grain texture
    for(let i=0;i<3000;i++){
      const x=rng()*W,y=rng()*H;
      const a=rng()*0.12;
      ctx.fillStyle=`rgba(255,255,255,${a})`;
      ctx.fillRect(x,y,1,1);
    }

    // Background shape / slash
    const shapeType=Math.floor(rng()*4);
    if(shapeType===0){
      ctx.fillStyle='rgba(57,255,20,0.06)';
      ctx.fillRect(0,0,W,H*0.55);
    } else if(shapeType===1){
      ctx.fillStyle='rgba(245,158,11,0.07)';
      ctx.beginPath();ctx.moveTo(0,H*0.2);ctx.lineTo(W,0);ctx.lineTo(W,H*0.6);ctx.lineTo(0,H*0.8);ctx.closePath();ctx.fill();
    } else if(shapeType===2){
      for(let i=0;i<5;i++){
        const ly=rng()*H;
        ctx.fillStyle=`rgba(57,255,20,0.04)`;
        ctx.fillRect(0,ly,W,2+rng()*4);
      }
    }

    // Border
    const borderColor=rng()<0.6?'rgba(57,255,20,0.6)':'rgba(245,158,11,0.5)';
    ctx.strokeStyle=borderColor;ctx.lineWidth=1.5;
    ctx.strokeRect(3,3,W-6,H-6);
    if(rng()<0.5){ctx.strokeRect(6,6,W-12,H-12);}

    // Main event name
    const accentGreen=rng()<0.65;
    const mainColor=accentGreen?'#39ff14':'#f59e0b';
    ctx.fillStyle=mainColor;
    ctx.shadowBlur=8;ctx.shadowColor=mainColor;
    const nameLen=evt.name.length;
    const fontSize=nameLen<=6?28:nameLen<=10?22:16;
    ctx.font=`900 ${fontSize}px 'Segoe UI',sans-serif`;
    ctx.textAlign='center';ctx.textBaseline='middle';
    // Word-wrap if needed
    const words=evt.name.split(' ');
    if(words.length>1&&nameLen>8){
      ctx.font=`900 ${fontSize-2}px 'Segoe UI',sans-serif`;
      ctx.fillText(words[0],W/2,H*0.22);
      ctx.fillText(words.slice(1).join(' '),W/2,H*0.33);
    } else {
      ctx.fillText(evt.name,W/2,H*0.27);
    }
    ctx.shadowBlur=0;

    // Subtitle
    ctx.fillStyle=accentGreen?'rgba(245,158,11,0.9)':'rgba(57,255,20,0.9)';
    ctx.font=`700 8px 'Segoe UI',sans-serif`;
    ctx.letterSpacing='0.1em';
    ctx.fillText(evt.sub,W/2,H*0.43);

    // Divider line
    ctx.strokeStyle=mainColor+'55';ctx.lineWidth=0.5;
    ctx.beginPath();ctx.moveTo(20,H*0.5);ctx.lineTo(W-20,H*0.5);ctx.stroke();

    // Date
    const mo=MONTHS[Math.floor(rng()*12)];
    const yr=YEARS[Math.floor(rng()*YEARS.length)];
    const day=Math.floor(rng()*28)+1;
    ctx.fillStyle='rgba(232,224,208,0.85)';
    ctx.font=`700 10px 'Segoe UI',sans-serif`;
    ctx.fillText(`${day} ${mo} ${yr}`,W/2,H*0.57);

    // Venue
    ctx.fillStyle='rgba(122,112,96,0.9)';
    ctx.font=`600 7px 'Segoe UI',sans-serif`;
    ctx.fillText(evt.venue,W/2,H*0.65);

    // DJs
    const djs=['GOLDIE','FABIO','GROOVERIDER','BUKEM','DJ HYPE','KRUST','DJ RAP','RANDALL','FROST','BRYAN GEE'];
    const ndj=2+Math.floor(rng()*3);
    const djList=[];
    for(let i=0;i<ndj;i++)djList.push(djs[Math.floor(rng()*djs.length)]);
    ctx.fillStyle=mainColor+'cc';
    ctx.font=`700 7px 'Segoe UI',sans-serif`;
    ctx.fillText(djList.join(' · '),W/2,H*0.74);

    // Bottom info
    ctx.fillStyle='rgba(122,112,96,0.7)';
    ctx.font=`600 6.5px 'Segoe UI',sans-serif`;
    ctx.fillText(evt.phone,W/2,H*0.84);
    ctx.font=`700 6px 'Segoe UI',sans-serif`;
    ctx.fillStyle='rgba(57,255,20,0.5)';
    ctx.fillText('FREE BEFORE 10PM · STRICTLY 18+',W/2,H*0.91);

    // Tiny decorative dots
    for(let i=0;i<8;i++){
      const dx=20+i*(W-40)/7,dy=H*0.96;
      ctx.beginPath();ctx.arc(dx,dy,1,0,Math.PI*2);
      ctx.fillStyle=i%2===0?mainColor+'88':'rgba(122,112,96,0.5)';ctx.fill();
    }
  }

  function mulberry32(a){
    return function(){a|=0;a=a+0x6D2B79F5|0;let t=Math.imul(a^a>>>15,1|a);t=t+Math.imul(t^t>>>7,61|t)^t;return((t^t>>>14)>>>0)/4294967296;};
  }

  function buildGrid(){
    const grid=document.getElementById('flyerGrid');
    grid.innerHTML='';
    EVENTS.forEach((evt,i)=>{
      const seed=Math.floor(Math.random()*999999)+i*1000;
      const item=document.createElement('div');
      item.className='flyer-item';
      const c=document.createElement('canvas');
      item.appendChild(c);
      drawFlyer(c,evt,seed);
      item.addEventListener('click',()=>{
        const modal=document.getElementById('flyerModal');
        const wrap=document.getElementById('flyerModalCanvasWrap');
        wrap.innerHTML='';
        const bigC=document.createElement('canvas');
        wrap.appendChild(bigC);
        bigC.style.width='100%';bigC.style.height='100%';
        drawFlyer(bigC,evt,seed);
        modal.classList.add('open');
      });
      grid.appendChild(item);
    });
  }
  buildGrid();
  document.getElementById('regenFlyers').addEventListener('click',buildGrid);
  document.getElementById('flyerModalClose').addEventListener('click',()=>{
    document.getElementById('flyerModal').classList.remove('open');
  });
  document.getElementById('flyerModal').addEventListener('click',e=>{
    if(e.target===e.currentTarget)e.currentTarget.classList.remove('open');
  });
})();

/* ═══════════════════ SECTION 7 — CROWD BOIDS ═══════════════════ */
(function(){
  const canvas=document.getElementById('crowdCanvas');
  canvas.width=canvas.offsetWidth||700;canvas.height=420;
  const W=canvas.width,H=canvas.height;
  const ctx=canvas.getContext('2d');

  let crowdBpm=160,state='pre-drop',cohesion=0.4,targetN=80;
  const energyLag=new LagFilter(0.5,0.3);
  const speedLag=new LagFilter(1,0.15);

  const bpmSlider=document.getElementById('crowdBpm');
  const densitySlider=document.getElementById('crowdDensity');
  const cohesionSlider=document.getElementById('crowdCohesion');
  bpmSlider.addEventListener('input',()=>{crowdBpm=parseInt(bpmSlider.value);document.getElementById('crowdBpmVal').textContent=crowdBpm;});
  densitySlider.addEventListener('input',()=>{targetN=parseInt(densitySlider.value);document.getElementById('crowdDensityVal').textContent=targetN;});
  cohesionSlider.addEventListener('input',()=>{cohesion=parseInt(cohesionSlider.value)/100;document.getElementById('crowdCohesionVal').textContent=cohesionSlider.value;});

  const stateDisplay=document.getElementById('crowdStateDisplay');
  const energyBar=document.getElementById('energyBar');
  const energyLabel=document.getElementById('energyLabel');

  ['preDropBtn','dropBtn','breakdownBtn'].forEach((id,i)=>{
    document.getElementById(id).addEventListener('click',()=>{
      state=['pre-drop','drop','breakdown'][i];
      stateDisplay.textContent=state.toUpperCase();
      energyLag.set(i===1?1:i===2?0.1:0.5);
      document.querySelectorAll('.drop-btn').forEach(b=>b.classList.remove('active'));
      document.getElementById(id).classList.add('active');
    });
  });

  // Boids
  let boids=[];
  function initBoids(n){
    boids=Array.from({length:n},()=>({
      x:W*0.2+Math.random()*W*0.6,y:H*0.2+Math.random()*H*0.6,
      vx:(Math.random()-0.5)*2,vy:(Math.random()-0.5)*2,
      trail:[],hue:Math.random()*30
    }));
  }
  initBoids(80);

  // Speaker positions (4 corners)
  const spkPositions=[
    {x:W*0.05,y:H*0.05},{x:W*0.95,y:H*0.05},
    {x:W*0.05,y:H*0.95},{x:W*0.95,y:H*0.95}
  ];

  // Laser sweep
  let laserAngleLag=new LagFilter(0,0.2);
  let beatPhase=0,beatInterval=60/160;

  let lastT=0;
  function draw(ts){
    const dt=Math.min((ts-lastT)/1000,0.05);lastT=ts;
    beatInterval=60/crowdBpm;
    beatPhase+=dt/beatInterval;if(beatPhase>1)beatPhase-=1;

    energyLag.update(dt);speedLag.update(dt);
    const energy=energyLag.value;
    const maxSpeed=(0.5+energy*3.5)*(0.5+crowdBpm/180);
    speedLag.set(maxSpeed);speedLag.update(dt);

    // Manage boid count
    while(boids.length<targetN)boids.push({x:W*0.5+Math.random()*50,y:H*0.5+Math.random()*50,vx:(Math.random()-0.5)*2,vy:(Math.random()-0.5)*2,trail:[],hue:Math.random()*30});
    while(boids.length>targetN)boids.pop();

    // Phosphor decay
    ctx.globalAlpha=state==='drop'?0.06:0.12;
    ctx.fillStyle='#030300';ctx.fillRect(0,0,W,H);ctx.globalAlpha=1;

    // Floor grid
    ctx.strokeStyle='rgba(57,255,20,0.04)';ctx.lineWidth=0.5;
    for(let x=0;x<W;x+=40){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
    for(let y=0;y<H;y+=40){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}

    // Laser sweeps (top-down)
    const lAngle=Math.sin(ts*0.001*1.8)*0.6;
    laserAngleLag.set(lAngle);laserAngleLag.update(dt);
    const lx=W/2,ly=0;
    for(let i=0;i<4;i++){
      const a=laserAngleLag.value+(i-1.5)*0.3;
      const tx=lx+Math.sin(a)*H*1.5,ty=ly+Math.cos(a)*H*1.5;
      const grad=ctx.createLinearGradient(lx,ly,tx,ty);
      const lc=i%2===0?'rgba(57,255,20,':'rgba(245,158,11,';
      grad.addColorStop(0,lc+'0.25)');grad.addColorStop(0.5,lc+'0.08)');grad.addColorStop(1,lc+'0)');
      ctx.beginPath();ctx.moveTo(lx,ly);ctx.lineTo(tx,ty);
      ctx.strokeStyle=grad;ctx.lineWidth=1;ctx.stroke();
    }

    // Speaker stack markers
    spkPositions.forEach(sp=>{
      ctx.beginPath();ctx.arc(sp.x,sp.y,14,0,Math.PI*2);
      ctx.fillStyle='rgba(57,255,20,0.06)';ctx.fill();
      ctx.strokeStyle='rgba(57,255,20,0.3)';ctx.lineWidth=1;ctx.stroke();
      // Pulse ring on beat
      const pulse=Math.pow(1-beatPhase,3)*0.5;
      ctx.beginPath();ctx.arc(sp.x,sp.y,14+pulse*30,0,Math.PI*2);
      ctx.strokeStyle=`rgba(57,255,20,${pulse*0.4})`;ctx.lineWidth=1;ctx.stroke();
    });

    // Update and draw boids
    const SEP_R=22,COH_R=60,ALI_R=40;
    boids.forEach((b,i)=>{
      let sx=0,sy=0,cx=0,cy=0,ax=0,ay=0,n_sep=0,n_coh=0,n_ali=0;
      boids.forEach((other,j)=>{
        if(i===j)return;
        const dx=other.x-b.x,dy=other.y-b.y;
        const dist=Math.sqrt(dx*dx+dy*dy);
        if(dist<SEP_R&&dist>0){sx-=dx/dist;sy-=dy/dist;n_sep++;}
        if(dist<COH_R){cx+=other.x;cy+=other.y;n_coh++;}
        if(dist<ALI_R){ax+=other.vx;ay+=other.vy;n_ali++;}
      });
      // Separation
      if(n_sep>0){b.vx+=sx*0.05;b.vy+=sy*0.05;}
      // Cohesion
      if(n_coh>0){b.vx+=(cx/n_coh-b.x)*cohesion*0.004;b.vy+=(cy/n_coh-b.y)*cohesion*0.004;}
      // Alignment
      if(n_ali>0){b.vx+=(ax/n_ali-b.vx)*0.05;b.vy+=(ay/n_ali-b.vy)*0.05;}
      // Attraction to speakers in drop
      if(state==='drop'){
        const nearest=spkPositions.reduce((a,sp)=>{
          const d=Math.hypot(sp.x-b.x,sp.y-b.y);return d<a.d?{d,sp}:a;
        },{d:Infinity,sp:null});
        if(nearest.sp){
          b.vx+=(nearest.sp.x-b.x)*0.001;b.vy+=(nearest.sp.y-b.y)*0.001;
        }
      }
      // Bounds
      if(b.x<20)b.vx+=0.3;if(b.x>W-20)b.vx-=0.3;
      if(b.y<20)b.vy+=0.3;if(b.y>H-20)b.vy-=0.3;
      // Speed limit
      const spd=Math.sqrt(b.vx*b.vx+b.vy*b.vy);
      const ms=speedLag.value;
      if(spd>ms){b.vx=(b.vx/spd)*ms;b.vy=(b.vy/spd)*ms;}
      b.x+=b.vx;b.y+=b.vy;

      // Trail
      b.trail.push({x:b.x,y:b.y});
      if(b.trail.length>6)b.trail.shift();

      // Draw trail
      if(state==='drop'&&b.trail.length>1){
        ctx.beginPath();
        b.trail.forEach((tp,ti)=>{
          if(ti===0)ctx.moveTo(tp.x,tp.y);else ctx.lineTo(tp.x,tp.y);
        });
        ctx.strokeStyle=`rgba(245,158,11,${0.08+energy*0.15})`;ctx.lineWidth=1;ctx.stroke();
      }

      // Draw dot
      const dotColor=state==='drop'?'rgba(245,158,11,0.9)':state==='breakdown'?'rgba(122,112,96,0.5)':'rgba(57,255,20,0.7)';
      ctx.beginPath();ctx.arc(b.x,b.y,1.5+energy,0,Math.PI*2);
      ctx.fillStyle=dotColor;
      if(state==='drop'){ctx.shadowBlur=4+energy*4;ctx.shadowColor='#f59e0b';}
      ctx.fill();ctx.shadowBlur=0;
    });

    const pct=Math.round(energy*100);
    energyBar.style.width=pct+'%';
    energyLabel.textContent='Energy: '+pct+'%';
    if(state!=='drop')energyLag.set(energyLag.value*0.998+0.5*0.002);
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();
</script>
<!-- ═══════════════════════════════ SECTION 8 — ARTISTS ════════════════════ -->
<section id="artists">
<div class="hidden stagger-1"><div class="section-label">Key Figures</div>
<h2>Artists of the Continuum</h2>
<p>The DJs, producers, and selectors who built jungle and drum &amp; bass from South and East London's Black British communities.</p></div>
<div class="artist-grid">
<div class="artist-card hidden stagger-1">
<div class="artist-name">Fabio &amp; Grooverider</div>
<div class="artist-role">DJ Duo</div>
<div class="artist-era">1988 – present</div>
<div class="artist-city">South London</div>
<div class="artist-bio">The founding DJs of jungle and drum &amp; bass. Their Sunday night at Rage (Heaven) was the crucible where hardcore became jungle. BBC Radio 1 show 1997–2015. Grooverider championed darkside; Fabio pushed liquid.</div>
</div>
<div class="artist-card hidden stagger-2">
<div class="artist-name">Goldie</div>
<div class="artist-role">Producer / Label Owner</div>
<div class="artist-era">1992 – present</div>
<div class="artist-city">South London / Wolverhampton</div>
<div class="artist-bio">Metalheadz founder. 'Timeless' (1995) was the first DnB album to claim serious artistic ambition. 'Inner City Life' remains the most emotionally powerful record in the canon. Time-stretching as compositional tool.</div>
</div>
<div class="artist-card hidden stagger-3">
<div class="artist-name">LTJ Bukem</div>
<div class="artist-role">Producer / DJ</div>
<div class="artist-era">1992 – present</div>
<div class="artist-city">Hertfordshire</div>
<div class="artist-bio">Architect of atmospheric, jazz-influenced drum &amp; bass. Good Looking Records defined the liquid strand. 'Horizons' is the template for sophisticated DnB. Speed parties at Mars Bar were the alternative to rave's harder edge.</div>
</div>
<div class="artist-card hidden stagger-4">
<div class="artist-name">DJ Krust</div>
<div class="artist-role">Producer / DJ</div>
<div class="artist-era">1992 – present</div>
<div class="artist-city">Bristol</div>
<div class="artist-bio">Full Cycle / Reprazent. Bristol's DnB sound was distinct from London — darker, more political, influenced by trip-hop and reggae. 'Warhead' is a founding document of techstep. The Bristol scene ran parallel to London.</div>
</div>
<div class="artist-card hidden stagger-1">
<div class="artist-name">DJ Hype</div>
<div class="artist-role">MC / DJ</div>
<div class="artist-era">1991 – present</div>
<div class="artist-city">East London</div>
<div class="artist-bio">The MC's MC. Hype's style — rapid-fire rhymes over jungle riddims — brought the vocal tradition of Jamaican sound system culture into DnB. Ganja Records. His sets define jump-up jungle's maximum energy approach.</div>
</div>
<div class="artist-card hidden stagger-2">
<div class="artist-name">Cleveland Watkiss</div>
<div class="artist-role">Vocalist / Jazz Singer</div>
<div class="artist-era">1990 – present</div>
<div class="artist-city">Hackney, London</div>
<div class="artist-bio">The jazz vocalist who bridged DnB and jazz. His work with Goldie and on Bukem's Good Looking productions showed DnB could carry sophisticated harmonic content. The human voice over Amen breaks as emotional anchor.</div>
</div>
<div class="artist-card hidden stagger-3">
<div class="artist-name">DJ Rap</div>
<div class="artist-role">DJ / Producer</div>
<div class="artist-era">1992 – present</div>
<div class="artist-city">Singapore / UK</div>
<div class="artist-bio">One of the most technically precise DJs in jungle and DnB. 'Intelligent Woman' showed the genre's reach. Won the DMC world championship. Her production work on Proper Talent pushed DnB's technical production standards.</div>
</div>
<div class="artist-card hidden stagger-4">
<div class="artist-name">Jumping Jack Frost</div>
<div class="artist-role">DJ / Producer</div>
<div class="artist-era">1989 – present</div>
<div class="artist-city">London</div>
<div class="artist-bio">One of the original jungle pirates. V Recordings co-founder. Frost's mixing precision and record collection depth made him the DJ's DJ. His Rage residency alongside Grooverider placed him at the origin point of the entire culture.</div>
</div>
</div>
</section>
<!-- ═══════════════════════════════ SECTION 9 — GLOSSARY ═══════════════════ -->
<section id="glossary">
<div class="hidden stagger-1"><div class="section-label">Vocabulary</div>
<h2>Rave Culture Glossary</h2>
<p>22 terms from the Amen Break to 160BPM. The language of a culture that changed music.</p></div>
<div class="glossary-grid hidden stagger-2">
<div class="gloss-item">
<div class="gloss-term">160BPM</div>
<div class="gloss-def">The tempo at which jungle operates — Amen breaks stretched and chopped to 155–165 BPM. At this speed the breakbeat pattern creates a forward momentum unlike any 4/4 tempo.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Amen Break</div>
<div class="gloss-def">A 6-second drum solo from 'Amen, Brother' by The Winstons (1969). The most sampled recording in music history. The rhythmic DNA of jungle and drum &amp; bass.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Breakbeat</div>
<div class="gloss-def">A drum loop isolated from its rhythmic 'break' section — the moment in a funk or soul recording where the drummer plays without melody. The compositional raw material of jungle.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Clash</div>
<div class="gloss-def">A sound system battle — two rigs competing for crowd response. Borrowed from Jamaican sound system tradition. The selector chooses dubplates; the crowd chooses the winner.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Darkside</div>
<div class="gloss-def">The dark, menacing variant of early jungle (1993–94). Horror samples, sub-bass pressure, minor keys. Goldie's 'Terminator' is the founding text. Precursor to Metalheadz techstep.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Dubplate</div>
<div class="gloss-def">An exclusive lacquer-cut acetate of an unreleased track, pressed for a specific DJ. In sound system culture, owning the dubplate — the only copy — is the currency of status.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Free Party</div>
<div class="gloss-def">An illegal, non-commercial rave organised outside the club system. UK's Criminal Justice Act (1994) was written specifically to criminalise them by targeting 'repetitive beats'.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Hardcore Continuum</div>
<div class="gloss-def">Simon Reynolds's theory: a single evolutionary chain from UK rave (1989) through ardkore, jungle, DnB, garage, grime, to dubstep. The same cultural engine, constantly mutating.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Jump-Up</div>
<div class="gloss-def">An energetic, crowd-focused DnB subgenre. Heavy drops, wobbling subs, simple but effective. Commercial face of DnB. DJ Hazard, Dillinja, Shy FX. Maximum dancefloor pressure.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Jungle Techno</div>
<div class="gloss-def">Early name for jungle when it was still emerging from hardcore rave. The combination of breakbeats (from hip-hop/jungle) with techno's electronic texture. Became simply 'jungle' by 1993.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Liquid Funk</div>
<div class="gloss-def">A soulful, melodic DnB subgenre developed by LTJ Bukem. Lush pads, emotional basslines, jazz harmonics. Hospital Records continued the tradition. The cerebral alternative to jump-up.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Neurofunk</div>
<div class="gloss-def">Dark, technically complex DnB subgenre. Ed Rush &amp; Optical, Photek, Trace. Intricate Reese bass sound design, clinical production, sci-fi atmospherics. The most technically demanding DnB to produce.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Pirate Radio</div>
<div class="gloss-def">Unlicensed FM broadcasts from tower blocks. Kool FM, Rush FM, Rinse FM. The distribution infrastructure for underground music before the internet. A DJ slot on pirate radio built careers.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Ragga Jungle</div>
<div class="gloss-def">Jungle with Jamaican dancehall vocal samples. Connects electronic music to Caribbean diasporic identity. Shy FX's 'Original Nuttah' is canonical. Bass culture and rave culture in synthesis.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Reese Bass</div>
<div class="gloss-def">Deep, modulated bass created by Kevin Saunderson in 1988. Two detuned oscillators. The defining bass sound of jungle and DnB — warm, buzzing, harmonically rich under the breakbeat.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Riddim</div>
<div class="gloss-def">Jamaican term for rhythm or backing track. In sound system culture, the riddim is shared — multiple vocalists might toast (rap) over the same riddim. Carried into jungle via ragga vocal tradition.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Rollers</div>
<div class="gloss-def">DnB tracks with continuous, rolling rhythmic momentum — no traditional drop or breakdown. The energy stays constant through rhythmic density rather than structural contrast.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Selector</div>
<div class="gloss-def">The DJ role in sound system culture — the person who selects and plays the records. Distinct from the MC who toasts over them. 'The selector plays riddims; the crowd responds.'</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Sound System</div>
<div class="gloss-def">A mobile speaker rig operated by a collective. Bass bins (18"), mid stacks (12"), horns. The social instrument of reggae and rave culture — music as physical experience, community as technology.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Steppers</div>
<div class="gloss-def">A DnB sub-style with a 4/4 kick pattern underlying the Amen break — a conscious reference to roots reggae's 'steppers' rhythm. Bass weight and dancefloor function over technical complexity.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">Time Stretch</div>
<div class="gloss-def">Digital audio processing that changes tempo without affecting pitch — or vice versa. In jungle, time-stretch artifacts (smearing, granulation) were embraced as aesthetic elements: the sound of technology at its limits.</div>
</div>
<div class="gloss-item">
<div class="gloss-term">VIP</div>
<div class="gloss-def">'Version in Progress' — a remix of a track created by the original artist, typically with a darker or more dancefloor-focused arrangement. Exclusive to DJs initially. 'The VIP was the dubplate you could play twice.'</div>
</div>
</div>
</section>
<script>
/* ═══════════════════ INTERSECTION OBSERVER — SECTION REVEALS ═══════════════════ */
(function(){
  const observer=new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
      if(entry.isIntersecting){
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  },{threshold:0.08,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.hidden').forEach(el=>observer.observe(el));
})();

/* ═══════════════════ NAV ACTIVE STATE ═══════════════════ */
(function(){
  const sections=document.querySelectorAll('section[id]');
  const navLinks=document.querySelectorAll('nav a');
  function updateNav(){
    let current='hero';
    sections.forEach(s=>{
      const rect=s.getBoundingClientRect();
      if(rect.top<=100)current=s.id;
    });
    navLinks.forEach(a=>{
      a.classList.toggle('active',a.getAttribute('href')==='#'+current);
    });
  }
  window.addEventListener('scroll',updateNav,{passive:true});
  updateNav();
})();
</script>
