<script>
  // ─── UTILITY ─────────────────────────────────────────────────────────────────
  function rnd(min, max) { return Math.random() * (max - min) + min; }
  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
  function gaussian(mean, std) {
    let u = 0, v = 0;
    while (u === 0) u = Math.random();
    while (v === 0) v = Math.random();
    return mean + std * Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);
  }

  // ─── PARTICLE SYSTEM ─────────────────────────────────────────────────────────
  class ParticleSystem {
    constructor(canvas, count = 800, colorMode = "cyan") {
      this.canvas = canvas;
      this.ctx = canvas.getContext("2d");
      this.count = count;
      this.colorMode = colorMode;
      this.frozen = false;
      this.particles = [];
      this.init();
    }

    init() {
      this.particles = [];
      const w = this.canvas.width, h = this.canvas.height;
      for (let i = 0; i < this.count; i++) {
        this.particles.push({
          x: rnd(0, w), y: rnd(0, h),
          vx: rnd(-0.4, 0.4), vy: rnd(-0.4, 0.4),
          size: rnd(0.5, 2.5),
          opacity: rnd(0.3, 0.9),
          hue: rnd(0, 1)
        });
      }
    }

    getColor(p) {
      const t = p.hue;
      if (this.colorMode === "cyan") {
        return t < 0.7
          ? `rgba(6,182,212,${p.opacity})`
          : `rgba(168,85,247,${p.opacity})`;
      } else if (this.colorMode === "piano") {
        return t < 0.6
          ? `rgba(168,85,247,${p.opacity})`
          : `rgba(6,182,212,${p.opacity})`;
      } else if (this.colorMode === "rain") {
        return t < 0.5
          ? `rgba(59,130,246,${p.opacity})`
          : `rgba(6,182,212,${p.opacity * 0.7})`;
      } else if (this.colorMode === "snare") {
        return t < 0.5
          ? `rgba(245,158,11,${p.opacity})`
          : `rgba(239,68,68,${p.opacity * 0.7})`;
      } else {
        return `rgba(34,197,94,${p.opacity})`;
      }
    }

    getGlowColor(p) {
      if (this.colorMode === "piano") return "rgba(168,85,247,0.4)";
      if (this.colorMode === "rain")  return "rgba(59,130,246,0.4)";
      if (this.colorMode === "snare") return "rgba(245,158,11,0.4)";
      return "rgba(6,182,212,0.4)";
    }

    applyScatter(cx, cy, radius, force) {
      for (const p of this.particles) {
        const dx = p.x - cx, dy = p.y - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < radius && dist > 0) {
          const f = (force / dist) * (1 - dist / radius);
          p.vx += (dx / dist) * f;
          p.vy += (dy / dist) * f;
        }
      }
    }

    scatterAll() {
      for (const p of this.particles) {
        p.vx += rnd(-3, 3);
        p.vy += rnd(-3, 3);
      }
    }

    draw(densityScale = 1, sizeScale = 1, pitchRandom = 0) {
      if (this.frozen) return;
      const ctx = this.ctx;
      const w = this.canvas.width, h = this.canvas.height;
      ctx.fillStyle = "rgba(5,5,8,0.04)";
      ctx.fillRect(0, 0, w, h);

      const active = Math.floor(this.count * clamp(densityScale, 0.05, 1));
      for (let i = 0; i < active; i++) {
        const p = this.particles[i];
        // random walk
        p.vx += rnd(-0.02, 0.02);
        p.vy += rnd(-0.02, 0.02);
        p.vx *= 0.98;
        p.vy *= 0.98;
        p.x += p.vx;
        p.y += p.vy;
        // wrap
        if (p.x < 0) p.x = w;
        if (p.x > w) p.x = 0;
        if (p.y < 0) p.y = h;
        if (p.y > h) p.y = 0;
        // pitch random shifts hue
        if (pitchRandom > 0) p.hue = clamp(p.hue + rnd(-0.002, 0.002) * pitchRandom, 0, 1);
        const s = p.size * sizeScale;
        ctx.save();
        ctx.globalAlpha = p.opacity;
        ctx.shadowBlur = 6;
        ctx.shadowColor = this.getGlowColor(p);
        ctx.fillStyle = this.getColor(p);
        ctx.beginPath();
        ctx.arc(p.x, p.y, s, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }
    }
  }

  // ─── HERO CANVAS ─────────────────────────────────────────────────────────────
  const heroCanvas = document.getElementById("hero-canvas");
  let heroPS = new ParticleSystem(heroCanvas, 900, "cyan");
  let heroColorMode = "cyan";

  function resizeHeroCanvas() {
    heroCanvas.width = window.innerWidth;
    heroCanvas.height = window.innerHeight;
    heroPS.init();
  }
  resizeHeroCanvas();
  window.addEventListener("resize", resizeHeroCanvas);

  let heroGrainCount = 847, heroGrainSize = 120, heroDensity = 12;
  function animateHero() {
    heroPS.colorMode = heroColorMode;
    heroPS.count = heroGrainCount;
    heroPS.draw(heroDensity / 30, heroGrainSize / 500, 3);
    // drift stats
    heroGrainCount = Math.floor(800 + Math.sin(Date.now() * 0.001) * 80);
    heroGrainSize  = Math.floor(100 + Math.sin(Date.now() * 0.0007) * 40);
    heroDensity    = Math.floor(12  + Math.sin(Date.now() * 0.0013) * 5);
    document.getElementById("hero-grain-count").textContent = heroGrainCount;
    document.getElementById("hero-grain-size").textContent  = heroGrainSize + "ms";
    document.getElementById("hero-density").textContent     = heroDensity + "/sec";
    requestAnimationFrame(animateHero);
  }
  animateHero();

  function setHeroSource(src, btn) {
    heroColorMode = src;
    document.querySelectorAll("[id^=src-]").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
  }

  // ─── GRAIN CLOUD CANVAS ──────────────────────────────────────────────────────
  const grainCanvas = document.getElementById("grain-canvas");
  let grainPS = new ParticleSystem(grainCanvas, 600, "cyan");

  grainCanvas.addEventListener("click", e => {
    const r = grainCanvas.getBoundingClientRect();
    const sx = (e.clientX - r.left) * (grainCanvas.width / r.width);
    const sy = (e.clientY - r.top)  * (grainCanvas.height / r.height);
    grainPS.applyScatter(sx, sy, 120, 8);
  });

  let grainFrozen = false;
  function toggleGrainFreeze(btn) {
    grainFrozen = !grainFrozen;
    grainPS.frozen = grainFrozen;
    btn.classList.toggle("active", grainFrozen);
    btn.textContent = grainFrozen ? "UNFREEZE" : "FREEZE";
  }
  function scatterGrainCloud() { grainPS.scatterAll(); }
  function resetGrainCloud()   { grainPS.frozen = false; grainFrozen = false; document.getElementById("btn-freeze").classList.remove("active"); document.getElementById("btn-freeze").textContent = "FREEZE"; grainPS.init(); }
  function setGrainSource(src, btn) {
    grainPS.colorMode = src;
    document.querySelectorAll("[id^=gsrc-]").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
  }

  function animateGrain() {
    const gs   = parseFloat(document.getElementById("sl-grain-size").value);
    const gd   = parseFloat(document.getElementById("sl-grain-density").value);
    const pr   = parseFloat(document.getElementById("sl-pitch-random").value);
    grainPS.draw(gd / 30, gs / 300, pr);
    requestAnimationFrame(animateGrain);
  }
  animateGrain();

  // Slider bindings
  function bindSlider(sliderId, valId, fmt) {
    const sl = document.getElementById(sliderId);
    const vl = document.getElementById(valId);
    if (!sl || !vl) return;
    sl.addEventListener("input", () => { vl.textContent = fmt(sl.value); });
  }
  bindSlider("sl-grain-size",    "v-grain-size",    v => Math.round(v) + "ms");
  bindSlider("sl-grain-density", "v-grain-density", v => Math.round(v) + "/s");
  bindSlider("sl-pitch-random",  "v-pitch-random",  v => parseFloat(v).toFixed(1) + "st");
  bindSlider("sl-pos-scatter",   "v-pos-scatter",   v => parseFloat(v).toFixed(2));
  bindSlider("sl-stretch",       "v-stretch",       v => parseFloat(v).toFixed(2) + "×");
  bindSlider("sl-x-size",        "v-x-size",        v => Math.round(v) + "ms");
  bindSlider("sl-x-pitch",       "v-x-pitch",       v => parseFloat(v).toFixed(1) + "st");
  bindSlider("sl-x-density",     "v-x-density",     v => Math.round(v) + "/s");
  bindSlider("sl-x-pan",         "v-x-pan",         v => parseFloat(v).toFixed(2));


  // ─── PARAM CANVAS (2D ZONE MAP) ──────────────────────────────────────────────
  const paramCanvas = document.getElementById("param-canvas");
  const paramCtx    = paramCanvas.getContext("2d");
  let paramDot = { x: paramCanvas.width * 0.15, y: paramCanvas.height * 0.6 };
  let paramMouse = null;
  const ZONES = [
    { x: 0.8, y: 0.75, color: "rgba(6,182,212,0.18)",   name: "SMOOTH CLOUD" },
    { x: 0.15, y: 0.25, color: "rgba(168,85,247,0.18)", name: "CRYSTALLINE SHIMMER" },
    { x: 0.8, y: 0.25, color: "rgba(245,158,11,0.18)",  name: "STUTTER FRAGMENTS" },
    { x: 0.15, y: 0.75, color: "rgba(34,197,94,0.18)",  name: "DENSE TEXTURE" }
  ];

  function getZoneName(nx, ny) {
    let best = ZONES[0], bestDist = Infinity;
    for (const z of ZONES) {
      const d = Math.hypot(nx - z.x, ny - z.y);
      if (d < bestDist) { bestDist = d; best = z; }
    }
    return best.name;
  }

  function drawParamCanvas(mx, my) {
    const w = paramCanvas.width, h = paramCanvas.height;
    paramCtx.clearRect(0, 0, w, h);
    paramCtx.fillStyle = "#050508";
    paramCtx.fillRect(0, 0, w, h);

    // Zone radial gradients
    for (const z of ZONES) {
      const cx = z.x * w, cy = z.y * h;
      const g = paramCtx.createRadialGradient(cx, cy, 0, cx, cy, w * 0.45);
      g.addColorStop(0, z.color);
      g.addColorStop(1, "transparent");
      paramCtx.fillStyle = g;
      paramCtx.fillRect(0, 0, w, h);
    }

    // Zone labels
    paramCtx.font = "11px monospace";
    paramCtx.letterSpacing = "0.1em";
    const labelPos = [
      { x: 0.58, y: 0.88, t: "SMOOTH CLOUD",        col: "rgba(6,182,212,0.6)" },
      { x: 0.04, y: 0.1,  t: "CRYSTALLINE SHIMMER", col: "rgba(168,85,247,0.6)" },
      { x: 0.58, y: 0.1,  t: "STUTTER FRAGMENTS",   col: "rgba(245,158,11,0.6)" },
      { x: 0.04, y: 0.88, t: "DENSE TEXTURE",       col: "rgba(34,197,94,0.6)" }
    ];
    for (const lp of labelPos) {
      paramCtx.fillStyle = lp.col;
      paramCtx.fillText(lp.t, lp.x * w, lp.y * h);
    }

    // Grid lines
    paramCtx.strokeStyle = "rgba(255,255,255,0.04)";
    paramCtx.lineWidth = 1;
    for (let i = 1; i < 4; i++) {
      paramCtx.beginPath(); paramCtx.moveTo(w * i / 4, 0); paramCtx.lineTo(w * i / 4, h); paramCtx.stroke();
      paramCtx.beginPath(); paramCtx.moveTo(0, h * i / 4); paramCtx.lineTo(w, h * i / 4); paramCtx.stroke();
    }

    // Mouse crosshair
    if (mx !== null) {
      paramCtx.strokeStyle = "rgba(255,255,255,0.2)";
      paramCtx.lineWidth = 1;
      paramCtx.setLineDash([4, 4]);
      paramCtx.beginPath(); paramCtx.moveTo(mx, 0); paramCtx.lineTo(mx, h); paramCtx.stroke();
      paramCtx.beginPath(); paramCtx.moveTo(0, my); paramCtx.lineTo(w, my); paramCtx.stroke();
      paramCtx.setLineDash([]);
    }

    // Persistent dot
    paramCtx.save();
    paramCtx.shadowBlur = 16;
    paramCtx.shadowColor = "#06b6d4";
    paramCtx.fillStyle = "#06b6d4";
    paramCtx.beginPath();
    paramCtx.arc(paramDot.x, paramDot.y, 7, 0, Math.PI * 2);
    paramCtx.fill();
    paramCtx.restore();
  }

  paramCanvas.addEventListener("mousemove", e => {
    const r = paramCanvas.getBoundingClientRect();
    paramMouse = {
      x: (e.clientX - r.left) * (paramCanvas.width  / r.width),
      y: (e.clientY - r.top)  * (paramCanvas.height / r.height)
    };
    drawParamCanvas(paramMouse.x, paramMouse.y);
  });
  paramCanvas.addEventListener("mouseleave", () => { paramMouse = null; drawParamCanvas(null, null); });
  paramCanvas.addEventListener("click", e => {
    const r = paramCanvas.getBoundingClientRect();
    const x = (e.clientX - r.left) * (paramCanvas.width  / r.width);
    const y = (e.clientY - r.top)  * (paramCanvas.height / r.height);
    paramDot = { x, y };
    const nx = x / paramCanvas.width, ny = y / paramCanvas.height;
    const gs = Math.round(10 + nx * 1990);
    const gd = Math.round(1  + (1 - ny) * 29);
    const zone = getZoneName(nx, ny);
    document.getElementById("param-readout").innerHTML =
      `GRAIN SIZE: ${gs}ms &nbsp;|&nbsp; DENSITY: ${gd}/sec &nbsp;|&nbsp; ZONE: <span class="zone-badge" id="param-zone">${zone}</span>`;
    drawParamCanvas(x, y);
  });
  drawParamCanvas(null, null);

  // ─── TIME STRETCH CANVASES ────────────────────────────────────────────────────
  let stretchFactor = 1.0;
  let stretchMode = "a";

  function drawStretchCanvas(id, mode, factor) {
    const c = document.getElementById("stretch-canvas-" + id);
    if (!c) return;
    const ctx = c.getContext("2d");
    const w = c.width, h = c.height;
    ctx.clearRect(0, 0, w, h);
    ctx.fillStyle = id === "a" ? "rgba(6,182,212,0.04)" : id === "b" ? "rgba(168,85,247,0.04)" : "rgba(245,158,11,0.04)";
    ctx.fillRect(0, 0, w, h);

    const color = id === "a" ? "#06b6d4" : id === "b" ? "#a855f7" : "#f59e0b";
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5;
    ctx.shadowBlur = 4;
    ctx.shadowColor = color;
    ctx.beginPath();
    const segments = Math.floor(w / 2);
    for (let i = 0; i <= segments; i++) {
      const t = i / segments;
      const x = t * w;
      let y;
      if (id === "a") {
        // Granular: clean with subtle smear blobs
        const smear = Math.sin(t * Math.PI * 4 * factor) * 0.3;
        y = h / 2 + Math.sin(t * Math.PI * 8) * (h * 0.35) * (1 - Math.abs(smear) * 0.2);
      } else if (id === "b") {
        // Phase vocoder: metallic, some phase artifacts
        const phase = Math.sin(t * Math.PI * 12 / factor) * 0.15;
        y = h / 2 + Math.sin(t * Math.PI * 8 + phase * 10) * (h * 0.38);
      } else {
        // Simple speed: pitch shifts with time, artifacts
        const artifacts = (Math.random() - 0.5) * 8 * (factor > 1.5 ? factor - 1 : 0);
        y = h / 2 + Math.sin(t * Math.PI * 8 * (1 / factor)) * (h * 0.35) + artifacts;
      }
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();
  }

  function drawAllStretch() {
    const f = parseFloat(document.getElementById("sl-stretch")?.value || 1);
    drawStretchCanvas("a", "granular", f);
    drawStretchCanvas("b", "vocoder",  f);
    drawStretchCanvas("c", "speed",    f);
  }

  document.getElementById("sl-stretch")?.addEventListener("input", drawAllStretch);
  drawAllStretch();

  function setStretchMode(mode, btn) {
    stretchMode = mode;
    document.querySelectorAll("[id^=stretch-]").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
  }

  // ─── DISSOLUTION CANVAS ───────────────────────────────────────────────────────
  const dissolveCanvas = document.getElementById("dissolve-canvas");
  const dissolveCtx    = dissolveCanvas.getContext("2d");
  let dissolveProgress = 0;
  let dissolveRunning  = false;
  let dissolveSpeed    = 1;
  let dissolveDuration = 5 * 60; // seconds (simulated)
  let dissolveElapsed  = 0;
  let dissolveInterval = null;
  let dissolveParticles = [];

  const DISSOLVE_STATES = [
    { pct: 0,   msg: "The loop begins. Clean. Recognizable." },
    { pct: 0.2, msg: "First grain parameters shift. Pitch scatter: +2 semitones." },
    { pct: 0.4, msg: "Grain size randomizing. The source becomes uncertain." },
    { pct: 0.6, msg: "Density dropping. Silence enters the texture." },
    { pct: 0.8, msg: "Memory of the original fades. Only grain remains." },
    { pct: 1.0, msg: "The loop has dissolved. What remains is the room." }
  ];

  function getDissolveMsg(p) {
    let msg = DISSOLVE_STATES[0].msg;
    for (const s of DISSOLVE_STATES) {
      if (p >= s.pct) msg = s.msg;
    }
    return msg;
  }

  function drawDissolveFrame() {
    const w = dissolveCanvas.width, h = dissolveCanvas.height;
    const ctx = dissolveCtx;
    const p = dissolveProgress;
    ctx.clearRect(0, 0, w, h);
    ctx.fillStyle = "#050508";
    ctx.fillRect(0, 0, w, h);

    // Wave portion (fades with progress)
    const waveOpacity = Math.max(0, 1 - p * 1.4);
    if (waveOpacity > 0) {
      ctx.save();
      ctx.globalAlpha = waveOpacity;
      ctx.strokeStyle = "#06b6d4";
      ctx.lineWidth = 1.5;
      ctx.shadowBlur = 6;
      ctx.shadowColor = "rgba(6,182,212,0.5)";
      ctx.beginPath();
      for (let x = 0; x <= w; x++) {
        const t = x / w;
        const noise = p > 0.1 ? (Math.random() - 0.5) * p * 20 : 0;
        const y = h / 2 + Math.sin(t * Math.PI * 16) * (h * 0.3 * (1 - p * 0.5)) + noise;
        x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();
      ctx.restore();
    }

    // Scatter particles (increase with progress)
    const particleOpacity = Math.min(1, p * 2);
    if (particleOpacity > 0) {
      for (let i = 0; i < Math.floor(p * 300); i++) {
        const px = rnd(0, w), py = rnd(0, h);
        const sat = Math.max(0, 1 - p);
        const r = Math.floor(6  * sat + 148 * (1 - sat));
        const g = Math.floor(182 * sat + 163 * (1 - sat));
        const b = Math.floor(212 * sat + 175 * (1 - sat));
        ctx.save();
        ctx.globalAlpha = rnd(0.1, 0.5) * particleOpacity;
        ctx.fillStyle = `rgb(${r},${g},${b})`;
        ctx.shadowBlur = 4;
        ctx.shadowColor = `rgba(${r},${g},${b},0.5)`;
        ctx.beginPath();
        ctx.arc(px, py, rnd(0.5, 2), 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }
    }
  }
  drawDissolveFrame();

  function toggleDissolution(btn) {
    if (dissolveProgress >= 1) {
      dissolveProgress = 0;
      dissolveElapsed  = 0;
      document.getElementById("dissolve-progress").style.width = "0%";
      document.getElementById("dissolve-state").textContent = DISSOLVE_STATES[0].msg;
      document.getElementById("dissolve-time").textContent = "00:00";
      clearInterval(dissolveInterval);
      dissolveInterval = null;
      dissolveRunning = false;
      btn.textContent = "▶ BEGIN DISSOLUTION";
      drawDissolveFrame();
      return;
    }
    dissolveRunning = !dissolveRunning;
    btn.textContent = dissolveRunning ? "⏸ PAUSE" : "▶ RESUME";
    if (dissolveRunning) {
      dissolveInterval = setInterval(() => {
        if (!dissolveRunning) return;
        dissolveElapsed += dissolveSpeed;
        dissolveProgress = Math.min(1, dissolveElapsed / dissolveDuration);
        document.getElementById("dissolve-progress").style.width = (dissolveProgress * 100) + "%";
        document.getElementById("dissolve-state").textContent = getDissolveMsg(dissolveProgress);
        const mm = String(Math.floor(dissolveElapsed / 60)).padStart(2, "0");
        const ss = String(Math.floor(dissolveElapsed % 60)).padStart(2, "0");
        document.getElementById("dissolve-time").textContent = mm + ":" + ss;
        drawDissolveFrame();
        if (dissolveProgress >= 1) {
          clearInterval(dissolveInterval);
          dissolveRunning = false;
          btn.textContent = "↺ RESET";
        }
      }, 1000);
    } else {
      clearInterval(dissolveInterval);
    }
  }

  function setDuration(mins, btn) {
    dissolveDuration = mins * 60;
    document.querySelectorAll("[id^=dur-]").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
  }

  function setDissolveSpeed(spd, btn) {
    dissolveSpeed = spd;
    document.querySelectorAll("[id^=spd-]").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
  }


  // ─── XENAKIS CANVAS ───────────────────────────────────────────────────────────
  const xenCanvas = document.getElementById("xenakis-canvas");
  const xenCtx    = xenCanvas.getContext("2d");
  let xenState = {
    sizeDistribution: "linear", sizeMean: 200,
    pitchDistribution: "narrow", pitchCenter: 0,
    densityDistribution: "constant", densityRate: 12,
    panDistribution: "center", panSpread: 0.3
  };
  let xenPrev = null;

  function getXenRandomness() {
    let score = 0;
    if (xenState.sizeDistribution  === "gaussian")    score += 15;
    if (xenState.sizeDistribution  === "exponential") score += 25;
    if (xenState.pitchDistribution === "wide")        score += 20;
    if (xenState.pitchDistribution === "extreme")     score += 35;
    if (xenState.densityDistribution === "random")    score += 15;
    if (xenState.densityDistribution === "burst")     score += 25;
    if (xenState.panDistribution === "wide")          score += 10;
    if (xenState.panDistribution === "full")          score += 20;
    return Math.min(100, score);
  }

  function xenakisGenerate() {
    const w = xenCanvas.width, h = xenCanvas.height;
    const ctx = xenCtx;
    xenCtx.fillStyle = "#050508";
    xenCtx.fillRect(0, 0, w, h);

    const count = 400;
    const spreadX = xenState.sizeDistribution  === "exponential" ? 0.45 : xenState.sizeDistribution === "gaussian" ? 0.25 : 0.35;
    const spreadY = xenState.pitchDistribution === "extreme"     ? 0.48 : xenState.pitchDistribution === "wide"    ? 0.32 : 0.18;
    const cx = w / 2 + (xenState.panDistribution === "full" ? rnd(-w * 0.3, w * 0.3) : rnd(-w * 0.1, w * 0.1));
    const cy = h / 2;

    for (let i = 0; i < count; i++) {
      let px, py;
      if (xenState.sizeDistribution === "gaussian") {
        px = gaussian(cx, w * spreadX);
      } else if (xenState.sizeDistribution === "exponential") {
        px = cx + (Math.random() < 0.5 ? -1 : 1) * (-Math.log(Math.random())) * w * 0.18;
      } else {
        px = rnd(cx - w * spreadX, cx + w * spreadX);
      }
      py = gaussian(cy, h * spreadY);
      px = clamp(px, 4, w - 4);
      py = clamp(py, 4, h - 4);

      const t = i / count;
      const alpha = rnd(0.3, 0.8);
      const size  = rnd(0.8, 2.8);
      const useViolet = xenState.pitchDistribution !== "narrow" && Math.random() > 0.6;
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.shadowBlur = 6;
      ctx.shadowColor = useViolet ? "rgba(168,85,247,0.5)" : "rgba(6,182,212,0.5)";
      ctx.fillStyle = useViolet ? "#a855f7" : "#06b6d4";
      ctx.beginPath();
      ctx.arc(px, py, size, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    // Fade-in animation
    xenCanvas.style.transition = "opacity 0.5s";
    xenCanvas.style.opacity = "0";
    setTimeout(() => { xenCanvas.style.opacity = "1"; }, 50);

    // Update randomness meter
    const r = getXenRandomness();
    document.getElementById("randomness-val").textContent  = r + "%";
    document.getElementById("randomness-fill").style.width = r + "%";
  }

  function xenakisCompare() {
    // Flash effect — generate twice rapidly
    xenakisGenerate();
    setTimeout(xenakisGenerate, 600);
  }

  // Store previous generation for compare
  function setXDist(param, value, btn) {
    if (param === "size")    xenState.sizeDistribution = value;
    if (param === "pitch")   xenState.pitchDistribution = value;
    if (param === "density") xenState.densityDistribution = value;
    if (param === "pan")     xenState.panDistribution = value;

    // Deactivate siblings
    const prefix = "xd-" + param + "-";
    document.querySelectorAll(`[id^="${prefix}"]`).forEach(b => b.classList.remove("active"));
    btn.classList.add("active");

    // Update randomness meter
    const r = getXenRandomness();
    document.getElementById("randomness-val").textContent  = r + "%";
    document.getElementById("randomness-fill").style.width = r + "%";
  }

  // Initial xenakis render
  xenakisGenerate();

  // ─── INTERSECTION OBSERVER (scroll reveal) ────────────────────────────────────
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.remove("hidden");
        e.target.classList.add("visible");
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll(".hidden").forEach(el => observer.observe(el));

  // ─── NAV ACTIVE STATE ─────────────────────────────────────────────────────────
  const navLinks = document.querySelectorAll(".nav-links a");
  const sectionIds = ["grain-cloud","parameter-map","dissolution","xenakis","timeline","artists","glossary"];

  const navObserver = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const id = e.target.id;
        navLinks.forEach(a => {
          a.classList.toggle("active", a.getAttribute("href") === "#" + id);
        });
      }
    });
  }, { threshold: 0.3 });

  sectionIds.forEach(id => {
    const el = document.getElementById(id);
    if (el) navObserver.observe(el);
  });

  // ─── KEYBOARD ACCESSIBILITY ───────────────────────────────────────────────────
  document.querySelectorAll(".btn, .btn-cyan").forEach(btn => {
    btn.addEventListener("keydown", e => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        btn.click();
      }
    });
    if (!btn.hasAttribute("tabindex")) btn.setAttribute("tabindex", "0");
  });

  // ─── PARAM CANVAS ANIMATION LOOP ─────────────────────────────────────────────
  // Gentle pulse on the glow dot
  let paramPulse = 0;
  function animateParam() {
    paramPulse += 0.04;
    const w = paramCanvas.width, h = paramCanvas.height;
    // Only redraw the dot area to avoid redrawing full canvas on every frame
    drawParamCanvas(paramMouse ? paramMouse.x : null, paramMouse ? paramMouse.y : null);
    // Draw pulsing ring
    const pr = paramCtx;
    pr.save();
    pr.globalAlpha = 0.4 + 0.2 * Math.sin(paramPulse);
    pr.strokeStyle = "#06b6d4";
    pr.lineWidth = 1;
    pr.shadowBlur = 10;
    pr.shadowColor = "#06b6d4";
    pr.beginPath();
    pr.arc(paramDot.x, paramDot.y, 10 + 3 * Math.sin(paramPulse), 0, Math.PI * 2);
    pr.stroke();
    pr.restore();
    requestAnimationFrame(animateParam);
  }
  animateParam();

  </script>
