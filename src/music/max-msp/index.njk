    // Logic
    { name:'select',  cat:'logic', desc:'Route messages by value matching', detail:'Outputs a bang on matching outlet when input equals each argument.' },
    { name:'route',   cat:'logic', desc:'Route typed messages to outlets', detail:'Distributes lists based on first element to separate outlets.' },
    { name:'gate',    cat:'logic', desc:'Switch signal routing on/off', detail:'Routes input to one of N outputs based on gate number. 0 closes all gates.' },
    { name:'switch~', cat:'logic', desc:'Audio-rate signal switcher', detail:'Switches between audio signal sources at block rate without clicks.' },
    // Jitter
    { name:'jit.matrix',   cat:'jitter', desc:'N-dimensional matrix for video/data', detail:'Core Jitter data structure. Holds video frames, OpenGL textures, or control data.' },
    { name:'jit.pwindow',  cat:'jitter', desc:'Display a Jitter matrix in a window', detail:'Renders a matrix to screen. The primary video output object.' },
    { name:'jit.gl.render',cat:'jitter', desc:'OpenGL rendering context', detail:'Manages the OpenGL drawing context for all jit.gl.* objects.' },
    { name:'jit.noise',    cat:'jitter', desc:'Fill a matrix with noise', detail:'Generates random values into a Jitter matrix at video rate.' },
    { name:'jit.op',       cat:'jitter', desc:'Per-cell matrix math operations', detail:'Applies arithmetic operations cell-by-cell across matrices.' },
    { name:'jit.gl.slab',  cat:'jitter', desc:'GPU GLSL shader processing unit', detail:'Runs a GLSL fragment shader on a matrix. The core of GPU-based effects.' },
