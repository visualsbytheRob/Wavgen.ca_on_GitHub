// ═══════════════════════════════════════════════════════════
//  SECTION 9 — GLOSSARY
// ═══════════════════════════════════════════════════════════
(function initGlossary() {
  const terms = [
    { term:'Audio Rate', def:'Processing that occurs at the sample rate (44.1kHz+). Indicated by ~ suffix in MSP objects.' },
    { term:'Bang', def:'The simplest Max message — a trigger with no value. Indicated by a "B" button or the word "bang".' },
    { term:'Bpatcher', def:'Embeds a subpatcher inside a parent patch as a scrollable, resizable view.' },
    { term:'Buffer~', def:'A named chunk of memory for storing audio samples. Referenced by groove~, play~, and wave~.' },
    { term:'Cold Inlet', def:'An inlet that stores a value but does NOT trigger output. Contrast with Hot Inlet.' },
    { term:'Dac~', def:'Digital-to-Analog Converter — the MSP object that sends audio to the hardware output.' },
    { term:'Data Flow', def:"Max's core paradigm: messages travel from object to object through patch cables from outlet to inlet." },
    { term:'Gen~', def:'A sub-environment within Max that compiles patches to native audio-rate code for maximum efficiency.' },
    { term:'Hot Inlet', def:'The leftmost inlet of most objects. Receiving a message here triggers calculation and output.' },
    { term:'Inlet/Outlet', def:"Small squares on top (inlets) and bottom (outlets) of a Max object that connect the patch's data flow." },
    { term:'Jitter', def:'The matrix/video/3D extension of Max. Handles video, OpenGL, and multi-dimensional data (jit.*).' },
    { term:'Matrix~', def:'A signal routing matrix for audio. Routes N inputs to M outputs with individually scalable paths.' },
    { term:'Max for Live', def:'Max/MSP embedded inside Ableton Live. Lets you build custom devices as instruments and effects.' },
    { term:'Message', def:'Any data sent through patch cables: bangs, integers, floats, symbols, or lists.' },
    { term:'MSP', def:'Miller Smith Puckette — the DSP (audio-rate) layer of Max, added in v3. All MSP objects end in ~.' },
    { term:'Object', def:'A processing box in a Max patch. Receives messages from inlets and sends results to outlets.' },
    { term:'Patch', def:'A Max program — the visual network of connected objects and cables that defines a process.' },
    { term:'Patch Cable', def:'The line connecting an outlet of one object to an inlet of another, carrying messages or signals.' },
    { term:'Patcher', def:'Another word for a Max patch. Also refers to the window that contains your objects and cables.' },
    { term:'Poly~', def:'Loads multiple instances of a subpatcher for polyphonic voice management.' },
    { term:'Subpatcher', def:'A patch embedded inside a "p" object box — used for encapsulation and reuse of logic.' },
    { term:'Toggle', def:'A UI object that alternates between 0 and 1 on each click — like a software on/off switch.' },
  ];

  const grid = document.getElementById('glossary-grid');
  // Sort alphabetically
  terms.sort((a, b) => a.term.localeCompare(b.term));
  terms.forEach(t => {
    const div = document.createElement('div');
    div.className = 'gloss-item';
    div.innerHTML = `<div class="gloss-term">${t.term}</div><div class="gloss-def">${t.def}</div>`;
    grid.appendChild(div);
  });
})();

// ═══════════════════════════════════════════════════════════
//  INTERSECTION OBSERVER — SCROLL ANIMATIONS
// ═══════════════════════════════════════════════════════════
(function initScrollAnimations() {
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('hidden');
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.10 });

  document.querySelectorAll('.hidden').forEach(el => observer.observe(el));
})();

// ═══════════════════════════════════════════════════════════
//  NAV SCROLL SPY
// ═══════════════════════════════════════════════════════════
(function initScrollSpy() {
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(a => a.classList.remove('active'));
        const link = document.querySelector(`.nav-links a[href="#${entry.target.id}"]`);
        if (link) link.classList.add('active');
      }
    });
  }, { threshold: 0.3 });

  sections.forEach(s => observer.observe(s));
})();

</script>
