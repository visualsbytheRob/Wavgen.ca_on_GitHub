  const grid = document.getElementById('enc-grid');
  let activeCard = null;
  let currentCat = 'all', currentSearch = '';

  function renderGrid() {
    const q = currentSearch.toLowerCase();
    const filtered = objects.filter(o => {
      const catMatch = currentCat === 'all' || o.cat === currentCat;
      const searchMatch = !q || o.name.includes(q) || o.desc.toLowerCase().includes(q);
      return catMatch && searchMatch;
    });
    grid.innerHTML = '';
    filtered.forEach(obj => {
      const card = document.createElement('div');
      card.className = 'obj-card';
      card.innerHTML = `
        <div class="obj-name">${obj.name}</div>
        <span class="obj-badge badge-${obj.cat}">${obj.cat}</span>
        <div class="obj-desc">${obj.desc}</div>
        <div class="obj-expand">${obj.detail}</div>
