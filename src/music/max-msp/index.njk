<script>
'use strict';
// ═══════════════════════════════════════════════════════════
//  SHARED UTILITIES
// ═══════════════════════════════════════════════════════════

class LagFilter {
  constructor(tau) { this.tau = tau; this.value = null; }
  update(target, dt) {
    if (this.value === null) this.value = target;
    this.value += (1 - Math.exp(-dt / this.tau)) * (target - this.value);
    return this.value;
  }
}

// ── BPM Engine ──
class BPMEngine {
  constructor(bpm = 90) {
    this.bpm = bpm;
    this.listeners = [];
    this.beatNum = 0;
    this.lastBeat = performance.now();
    this._tick = this._tick.bind(this);
    this._raf = null;
    this.running = false;
  }
  start() { if (!this.running) { this.running = true; this._tick(); } }
  stop() { this.running = false; if (this._raf) cancelAnimationFrame(this._raf); }
  setBPM(b) { this.bpm = b; }
  on(fn) { this.listeners.push(fn); }
  _tick() {
    if (!this.running) return;
    const now = performance.now();
    const interval = 60000 / this.bpm;
    if (now - this.lastBeat >= interval) {
      this.lastBeat += interval;
      this.beatNum++;
      this.listeners.forEach(fn => fn(this.beatNum));
    }
    this._raf = requestAnimationFrame(this._tick);
  }
}
const bpmEngine = new BPMEngine(90);
bpmEngine.start();

// ── WebAudio context (lazy) ──
let audioCtx = null;
function getAudio() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  return audioCtx;
}

// ═══════════════════════════════════════════════════════════
//  SECTION 1 — HERO CANVAS
// ═══════════════════════════════════════════════════════════
(function initHero() {
  const canvas = document.getElementById('hero-canvas');
  const ctx = canvas.getContext('2d');
  let W, H;

  function resize() {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  // Node definitions
  const NODE_LABELS = ['cycle~','gain~','dac~','bang','number','metro','random','* 0.1','print','toggle','+ 1','noise~'];
  const NODE_COLORS = {
    'cycle~':'#f5c518','gain~':'#f5c518','dac~':'#f5c518','noise~':'#f5c518',
    'bang':'#00e5ff','toggle':'#00e5ff','metro':'#00e5ff',
    'number':'#9ca3af','random':'#9ca3af','print':'#9ca3af',
    '* 0.1':'#b46cff','+ 1':'#b46cff'
  };

  // Generate nodes
  const nodes = [];
  for (let i = 0; i < 9; i++) {
    const label = NODE_LABELS[i % NODE_LABELS.length];
    nodes.push({
      label,
      x: new LagFilter(0.4),
      y: new LagFilter(0.4),
      tx: 80 + Math.random() * (W > 800 ? 800 : W - 160),
      ty: 80 + Math.random() * 260,
      vx: (Math.random() - 0.5) * 0.3,
      vy: (Math.random() - 0.5) * 0.2,
      color: NODE_COLORS[label] || '#9ca3af',
      w: label.length * 8 + 24,
      h: 28,
      pulse: 0,
      pulseLag: new LagFilter(0.08),
    });
  }
  // Initialize lag values
  nodes.forEach(n => { n.x.value = n.tx; n.y.value = n.ty; });

  // Connections (outlet→inlet pairs by index)
  const connections = [
    [0,1],[1,2],[3,4],[4,5],[5,0],[6,7],[7,1],[8,0]
  ].filter(([a,b]) => a < nodes.length && b < nodes.length);

  // Signal pulses traveling along cables
  const pulses = [];
  function spawnPulse(connIdx) {
    pulses.push({ conn: connIdx, t: 0, speed: 0.008 + Math.random() * 0.006 });
  }
  bpmEngine.on(beat => {
    const c = beat % connections.length;
    spawnPulse(c);
    nodes[connections[c][0]].pulse = 1;
  });

  // Catenary curve helper
  function catenaryPoints(x1, y1, x2, y2, sag = 0.35, segs = 30) {
    const pts = [];
    const dx = x2 - x1, dy = y2 - y1;
    const mx = (x1 + x2) / 2, my = (y1 + y2) / 2;
    const len = Math.hypot(dx, dy);
    const ox = -dy / len * sag * len * 0.5;
    const oy = dx / len * sag * len * 0.5 + len * 0.2;
    const cx = mx + ox, cy = my + oy;
    for (let i = 0; i <= segs; i++) {
      const t = i / segs;
      const bx = (1-t)*(1-t)*x1 + 2*(1-t)*t*cx + t*t*x2;
      const by = (1-t)*(1-t)*y1 + 2*(1-t)*t*cy + t*t*y2;
      pts.push([bx, by]);
    }
    return pts;
  }

  let lastT = performance.now();

  function drawNode(n, rawX, rawY) {
    const x = rawX - n.w / 2, y = rawY - n.h / 2;
    const pulse = n.pulseLag.value || 0;
    ctx.strokeStyle = n.color;
    ctx.lineWidth = 1 + pulse * 1.5;
    ctx.shadowColor = n.color;
    ctx.shadowBlur = 6 + pulse * 14;
    ctx.fillStyle = `rgba(17,17,24,0.9)`;
    ctx.fillRect(x, y, n.w, n.h);
    ctx.strokeRect(x, y, n.w, n.h);
    ctx.shadowBlur = 0;
    ctx.fillStyle = n.color;
    ctx.font = `${10 + pulse * 1}px 'Courier New', monospace`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(n.label, rawX, rawY);

    // Inlet dot (top center)
    ctx.beginPath();
    ctx.arc(rawX, y, 3, 0, Math.PI * 2);
    ctx.fillStyle = '#444';
    ctx.fill();
    // Outlet dot (bottom center)
    ctx.beginPath();
    ctx.arc(rawX, y + n.h, 3, 0, Math.PI * 2);
    ctx.fillStyle = n.color;
    ctx.fill();
  }

  function frame(ts) {
    requestAnimationFrame(frame);
    const dt = Math.min((ts - lastT) / 1000, 0.05);
    lastT = ts;

    // Phosphor persistence
    ctx.fillStyle = 'rgba(10,10,15,0.06)';
    ctx.fillRect(0, 0, W, H);

    // Update node positions with gentle drift
    nodes.forEach(n => {
      n.tx += n.vx;
      n.ty += n.vy;
      if (n.tx < 60 || n.tx > W - 60) n.vx *= -1;
      if (n.ty < 60 || n.ty > H - 60) n.vy *= -1;
      const nx = n.x.update(n.tx, dt);
      const ny = n.y.update(n.ty, dt);
      n._rx = nx; n._ry = ny;
      n.pulse *= 0.92;
      n.pulseLag.update(n.pulse, dt);
    });

    // Draw cables
    connections.forEach(([a, b], ci) => {
      const na = nodes[a], nb = nodes[b];
      const x1 = na._rx, y1 = na._ry + na.h / 2;
      const x2 = nb._rx, y2 = nb._ry - nb.h / 2;
      const pts = catenaryPoints(x1, y1, x2, y2, 0.35, 28);
      ctx.beginPath();
      ctx.moveTo(pts[0][0], pts[0][1]);
      for (let i = 1; i < pts.length; i++) ctx.lineTo(pts[i][0], pts[i][1]);
      ctx.strokeStyle = 'rgba(245,197,24,0.25)';
      ctx.lineWidth = 1.5;
      ctx.shadowBlur = 0;
      ctx.stroke();
    });

    // Draw pulses
    for (let i = pulses.length - 1; i >= 0; i--) {
      const p = pulses[i];
      p.t += p.speed;
      if (p.t > 1) { pulses.splice(i, 1); continue; }
      const [a, b] = connections[p.conn];
      const na = nodes[a], nb = nodes[b];
      const x1 = na._rx, y1 = na._ry + na.h / 2;
      const x2 = nb._rx, y2 = nb._ry - nb.h / 2;
      const pts = catenaryPoints(x1, y1, x2, y2, 0.35, 28);
      const idx = Math.min(Math.floor(p.t * (pts.length - 1)), pts.length - 1);
      const [px, py] = pts[idx];
      ctx.beginPath();
      ctx.arc(px, py, 4, 0, Math.PI * 2);
      ctx.fillStyle = '#f5c518';
      ctx.shadowColor = '#f5c518';
      ctx.shadowBlur = 12;
      ctx.fill();
      ctx.shadowBlur = 0;
    }

    // Draw nodes
    nodes.forEach(n => drawNode(n, n._rx, n._ry));

    // Scan line overlay
    ctx.fillStyle = 'rgba(0,0,0,0.03)';
    for (let y = 0; y < H; y += 4) {
      ctx.fillRect(0, y, W, 1);
    }
  }
  requestAnimationFrame(frame);
})();

// ═══════════════════════════════════════════════════════════
//  SECTION 2 — VIRTUAL PATCHER
// ═══════════════════════════════════════════════════════════
(function initPatcher() {
  const canvas = document.getElementById('patcher-canvas');
  const ctx = canvas.getContext('2d');
  let W, H;

  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    W = canvas.width = canvas.offsetWidth || 600;
    H = canvas.height = canvas.offsetHeight || 480;
  }
  resize();
  window.addEventListener('resize', resize);

  let objects = [];
  let cables = [];
  let dragging = null, dragOffX = 0, dragOffY = 0;
  let connecting = null; // {obj, port:'out'}
  let audioEnabled = false;
  let audioNodes = {};
  let oscNode = null, gainNode = null;

  function makeObj(type, x, y) {
    const id = Date.now() + Math.random();
    const labels = {
      bang:'bang', toggle:'toggle', number:'number', metro:'metro 500',
      random:'random 100', 'cycle~':'cycle~ 440', 'gain~':'gain~',
      'dac~':'dac~', print:'print', plus:'+ 0', mult:'* 0.5'
    };
    const label = labels[type] || type;
    return {
      id, type, label, x, y,
      w: Math.max(label.length * 8 + 24, 60), h: 28,
      value: type === 'number' ? 0 : (type === 'toggle' ? 0 : null),
      valLag: new LagFilter(0.12),
      active: false
    };
  }

  function getOutletPos(obj) { return { x: obj.x + obj.w / 2, y: obj.y + obj.h }; }
  function getInletPos(obj) { return { x: obj.x + obj.w / 2, y: obj.y }; }

  function hitObj(mx, my) {
    for (let i = objects.length - 1; i >= 0; i--) {
      const o = objects[i];
      if (mx >= o.x && mx <= o.x + o.w && my >= o.y && my <= o.y + o.h) return o;
    }
    return null;
  }
  function hitOutlet(mx, my, obj) {
    const p = getOutletPos(obj);
    return Math.hypot(mx - p.x, my - p.y) < 8;
  }
  function hitInlet(mx, my, obj) {
    const p = getInletPos(obj);
    return Math.hypot(mx - p.x, my - p.y) < 8;
  }

  // Mouse events
  canvas.addEventListener('mousedown', e => {
    const r = canvas.getBoundingClientRect();
    const mx = e.clientX - r.left, my = e.clientY - r.top;
    const obj = hitObj(mx, my);
    if (obj) {
      if (hitOutlet(mx, my, obj)) {
        connecting = { obj, mx, my };
        return;
      }
      if (hitInlet(mx, my, obj) && connecting) {
        cables.push({ from: connecting.obj, to: obj });
        tryAudioConnect(connecting.obj, obj);
        connecting = null;
        document.getElementById('patch-status').textContent = 'Connected!';
        return;
      }
      // Double-click to bang
      if (obj.type === 'bang') { obj.active = true; setTimeout(() => obj.active = false, 80); }
      if (obj.type === 'toggle') { obj.value = obj.value ? 0 : 1; }
      dragging = obj;
      dragOffX = mx - obj.x;
      dragOffY = my - obj.y;
    } else {
      connecting = null;
    }
  });
  canvas.addEventListener('mousemove', e => {
    const r = canvas.getBoundingClientRect();
    const mx = e.clientX - r.left, my = e.clientY - r.top;
    if (dragging) { dragging.x = mx - dragOffX; dragging.y = my - dragOffY; }
    if (connecting) { connecting.mx = mx; connecting.my = my; }
  });
  canvas.addEventListener('mouseup', () => { dragging = null; });

  // Palette
  document.querySelectorAll('.palette-item').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.type;
      const x = 80 + Math.random() * (W - 200);
      const y = 60 + Math.random() * (H - 150);
      objects.push(makeObj(type, x, y));
      document.getElementById('patch-status').textContent = `Added: ${type}`;
    });
  });

  document.getElementById('btn-clear-patch').addEventListener('click', () => {
    objects = []; cables = [];
    if (oscNode) { try { oscNode.stop(); } catch(e){} oscNode = null; }
    if (gainNode) { gainNode.disconnect(); gainNode = null; }
    audioNodes = {};
    document.getElementById('patch-status').textContent = 'Patch cleared';
  });

  document.getElementById('btn-audio-toggle').addEventListener('click', function() {
    audioEnabled = !audioEnabled;
    this.textContent = `Audio: ${audioEnabled ? 'ON' : 'OFF'}`;
    if (audioEnabled) {
      getAudio().resume();
      document.getElementById('patch-status').textContent = 'Audio enabled';
    } else {
      if (oscNode) { try { oscNode.stop(); } catch(e){} oscNode = null; }
      if (gainNode) { gainNode.disconnect(); gainNode = null; }
      document.getElementById('patch-status').textContent = 'Audio disabled';
    }
  });

  function tryAudioConnect(from, to) {
    if (!audioEnabled) return;
    const ac = getAudio();
    if (from.type === 'cycle~' && to.type === 'gain~') {
      if (oscNode) { try { oscNode.stop(); } catch(e){} }
      oscNode = ac.createOscillator();
      oscNode.type = 'sine';
      oscNode.frequency.value = 440;
      gainNode = ac.createGain();
      gainNode.gain.value = 0.15;
      oscNode.connect(gainNode);
      gainNode.connect(ac.destination);
      oscNode.start();
      document.getElementById('patch-status').textContent = 'cycle~ → gain~ connected, audio active!';
    }
  }

  // Catenary helper for patcher
  function drawCable(ctx, x1, y1, x2, y2, color='rgba(245,197,24,0.7)') {
    const mx = (x1+x2)/2, my = (y1+y2)/2;
    const len = Math.hypot(x2-x1, y2-y1);
    const cy = my + len * 0.18;
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.quadraticCurveTo(mx, cy, x2, y2);
    ctx.strokeStyle = color;
    ctx.lineWidth = 2;
    ctx.stroke();
  }

  // Beat-driven number updates
  bpmEngine.on(() => {
    objects.forEach(o => {
      if (o.type === 'number') { o.value = (o.value || 0) + 1; }
      if (o.type === 'random') { o.value = Math.floor(Math.random() * 100); }
    });
  });

  let lastPT = performance.now();
  function patcherFrame(ts) {
    requestAnimationFrame(patcherFrame);
    const dt = Math.min((ts - lastPT) / 1000, 0.05);
    lastPT = ts;

    ctx.fillStyle = 'rgba(10,10,15,1)';
    ctx.fillRect(0, 0, W, H);

    // Grid dots
    ctx.fillStyle = 'rgba(30,30,46,0.5)';
    for (let gx = 20; gx < W; gx += 20)
      for (let gy = 20; gy < H; gy += 20)
        ctx.fillRect(gx, gy, 1, 1);

    // Draw cables
    cables.forEach(c => {
      const op = getOutletPos(c.from);
      const ip = getInletPos(c.to);
      drawCable(ctx, op.x, op.y, ip.x, ip.y);
    });

    // In-progress cable
    if (connecting) {
      const op = getOutletPos(connecting.obj);
      drawCable(ctx, op.x, op.y, connecting.mx, connecting.my, 'rgba(0,229,255,0.6)');
    }

    // Draw objects
    objects.forEach(o => {
      o.valLag.update(o.value || 0, dt);
      const isActive = o.active || (o.type === 'toggle' && o.value);
      ctx.fillStyle = isActive ? 'rgba(245,197,24,0.15)' : 'rgba(17,17,24,0.95)';
      ctx.strokeStyle = isActive ? '#f5c518' : '#1e1e2e';
      ctx.lineWidth = 1.5;
      ctx.fillRect(o.x, o.y, o.w, o.h);
      ctx.strokeRect(o.x, o.y, o.w, o.h);

      // Label / value
      ctx.fillStyle = isActive ? '#f5c518' : '#e2e2f0';
      ctx.font = '10px Courier New';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      let txt = o.label;
      if (o.type === 'number' || o.type === 'random') txt = String(Math.floor(o.valLag.value));
      if (o.type === 'toggle') txt = o.value ? '■' : '□';
      ctx.fillText(txt, o.x + o.w/2, o.y + o.h/2);

      // Inlet/Outlet ports
      const ip = getInletPos(o);
      const op2 = getOutletPos(o);
      ctx.beginPath(); ctx.arc(ip.x, ip.y, 3, 0, Math.PI*2);
      ctx.fillStyle = connecting ? '#00e5ff' : '#444'; ctx.fill();
      ctx.beginPath(); ctx.arc(op2.x, op2.y, 3, 0, Math.PI*2);
      ctx.fillStyle = '#f5c518'; ctx.fill();
    });
  }
  requestAnimationFrame(patcherFrame);
})();


// ═══════════════════════════════════════════════════════════
//  SECTION 3 — SIGNAL FLOW VISUALIZER
// ═══════════════════════════════════════════════════════════
(function initSignalFlow() {
  const canvas = document.getElementById('signal-canvas');
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
  resize(); window.addEventListener('resize', resize);

  let mode = 'audio'; // 'audio' | 'message'
  const speedLag = new LagFilter(0.3);
  let targetSpeed = 1;
  let speedVal = 1;

  document.getElementById('sf-audio-btn').addEventListener('click', function() {
    mode = 'audio';
    this.classList.add('active');
    document.getElementById('sf-msg-btn').classList.remove('active');
  });
  document.getElementById('sf-msg-btn').addEventListener('click', function() {
    mode = 'message';
    this.classList.add('active');
    document.getElementById('sf-audio-btn').classList.remove('active');
  });
  document.getElementById('sf-speed').addEventListener('input', function() {
    targetSpeed = parseFloat(this.value);
    document.getElementById('sf-speed-val').textContent = targetSpeed.toFixed(1) + '×';
  });

  // Graph nodes
  const graph = [
    { label:'input~', x:0.08, y:0.45 },
    { label:'filt~', x:0.25, y:0.35 },
    { label:'gain~', x:0.42, y:0.45 },
    { label:'dac~',  x:0.62, y:0.45 },
    { label:'scope~',x:0.80, y:0.30 },
    // Message path
    { label:'metro', x:0.08, y:0.72 },
    { label:'random',x:0.25, y:0.72 },
    { label:'scale', x:0.42, y:0.72 },
    { label:'number',x:0.62, y:0.72 },
    { label:'print', x:0.80, y:0.72 },
  ];
  const audioEdges = [[0,1],[1,2],[2,3],[2,4]];
  const msgEdges   = [[5,6],[6,7],[7,8],[8,9]];

  const audioParticles = [];
  const msgParticles = [];

  function spawnParticles() {
    const sv = speedLag.value || 1;
    // Audio: many fast particles (yellow)
    if (Math.random() < 0.4 * sv) {
      const ei = Math.floor(Math.random() * audioEdges.length);
      audioParticles.push({ edge: ei, t: 0, speed: (0.012 + Math.random() * 0.008) * sv });
    }
    // Message: fewer slower pulses (gray)
    if (Math.random() < 0.08 * sv) {
      const ei = Math.floor(Math.random() * msgEdges.length);
      msgParticles.push({ edge: ei, t: 0, speed: (0.004 + Math.random() * 0.003) * sv });
    }
  }

  let lastST = performance.now();
  function sfFrame(ts) {
    requestAnimationFrame(sfFrame);
    const dt = Math.min((ts - lastST) / 1000, 0.05);
    lastST = ts;
    speedVal = speedLag.update(targetSpeed, dt);

    ctx.fillStyle = 'rgba(10,10,15,0.08)';
    ctx.fillRect(0, 0, W, H);

    // Resolve node pixel coords
    const nodes = graph.map(n => ({ ...n, px: n.x * W, py: n.y * H }));

    // Draw mode label
    ctx.fillStyle = 'rgba(10,10,15,0.7)';
    ctx.fillRect(0, 0, W, H);

    const showAudio = mode === 'audio';
    const showMsg   = mode === 'message';
    const showBoth  = false;

    // Draw edges
    function drawEdges(edges, nodesRef, color) {
      edges.forEach(([a, b]) => {
        const na = nodesRef[a], nb = nodesRef[b];
        ctx.beginPath();
        ctx.moveTo(na.px, na.py);
        ctx.lineTo(nb.px, nb.py);
        ctx.strokeStyle = color;
        ctx.lineWidth = 1.5;
        ctx.stroke();
      });
    }
    function drawNodes(nodesRef, color, labelColor) {
      nodesRef.forEach(n => {
        ctx.fillStyle = 'rgba(17,17,24,0.95)';
        ctx.strokeStyle = color;
        ctx.lineWidth = 1.5;
        const bw = n.label.length * 7 + 20, bh = 24;
        ctx.fillRect(n.px - bw/2, n.py - bh/2, bw, bh);
        ctx.strokeRect(n.px - bw/2, n.py - bh/2, bw, bh);
        ctx.fillStyle = labelColor;
        ctx.font = '10px Courier New';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(n.label, n.px, n.py);
      });
    }

    if (mode === 'audio' || mode === 'message') {
      const an = nodes.slice(0, 5), mn = nodes.slice(5);
      drawEdges(audioEdges, nodes, mode === 'audio' ? 'rgba(245,197,24,0.6)' : 'rgba(245,197,24,0.12)');
      drawEdges(msgEdges.map(([a,b]) => [a,b]), nodes, mode === 'message' ? 'rgba(156,163,175,0.6)' : 'rgba(156,163,175,0.12)');
      drawNodes(an, mode === 'audio' ? '#f5c518' : '#333', mode === 'audio' ? '#f5c518' : '#444');
      drawNodes(mn, mode === 'message' ? '#9ca3af' : '#333', mode === 'message' ? '#9ca3af' : '#444');
    }

    // Section labels
    ctx.font = '9px Courier New'; ctx.textAlign = 'left';
    ctx.fillStyle = mode === 'audio' ? '#f5c518' : 'rgba(245,197,24,0.3)';
    ctx.fillText('◆ AUDIO RATE (44100Hz)', 16, 18);
    ctx.fillStyle = mode === 'message' ? '#9ca3af' : 'rgba(156,163,175,0.3)';
    ctx.fillText('● MESSAGE RATE (~1kHz)', 16, 32);

    // Spawn & draw particles
    spawnParticles();
    function drawParticles(particles, edges, color, r) {
      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.t += p.speed;
        if (p.t > 1) { particles.splice(i, 1); continue; }
        const [a, b] = edges[p.edge];
        const na = nodes[a], nb = nodes[b];
        const px = na.px + (nb.px - na.px) * p.t;
        const py = na.py + (nb.py - na.py) * p.t;
        ctx.beginPath();
        ctx.arc(px, py, r, 0, Math.PI * 2);
        ctx.fillStyle = color;
        ctx.shadowColor = color;
        ctx.shadowBlur = 8;
        ctx.fill();
        ctx.shadowBlur = 0;
      }
    }
    if (mode === 'audio') {
      drawParticles(audioParticles, audioEdges, '#f5c518', 3);
    } else {
      drawParticles(msgParticles, msgEdges, '#9ca3af', 4);
    }
  }
  requestAnimationFrame(sfFrame);
})();

