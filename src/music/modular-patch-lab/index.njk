<!-- PATCH SCHOOL -->
<section id="patch-school">
<div class="sec-title hidden">PATCH CABLE SCHOOL</div>
<div class="sec-sub hidden stagger-1">click output → input to wire a connection</div>
<div class="canvas-wrap hidden stagger-2">
<canvas height="320" id="patchCanvas" width="900"></canvas>
</div>
