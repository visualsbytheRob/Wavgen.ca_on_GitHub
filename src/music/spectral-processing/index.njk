function drawFreeze(t){
  const W=frzC.width,H=frzC.height;
  frzX.fillStyle='rgba(4,2,10,0.85)';
  frzX.fillRect(0,0,W,H);
  const frame=lagFrame.value;
  const blur=lagBlur.value;
  const pitch=lagFPitch.value;
  const BINS=128,PAD=20;
  const bw=(W-PAD*2)/BINS;

  if(!frozenFrame||!freezeActive){
    frozenFrame=[];
    for(let i=0;i<BINS;i++){
      const fi=i/BINS;
      frozenFrame[i]=Math.max(0,fbm(fi*4+frame*10,frame*5)-0.2)*1.2;
    }
  }

  // Time domain (top)
  frzX.strokeStyle='rgba(0,229,255,0.6)';
  frzX.lineWidth=1.5;
  frzX.beginPath();
  for(let x=0;x<W;x++){
    const xf=x/W;
    const wave=Math.sin(xf*40+t*3)*0.15*Math.exp(-Math.pow(xf-0.5,2)*4);
    const y=80+wave*60*(freezeActive?lagFreezeAnim.value:1);
    x===0?frzX.moveTo(x,y):frzX.lineTo(x,y);
  }
  frzX.stroke();

  frzX.fillStyle='#5A4890';frzX.font='9px Courier New';frzX.textAlign='left';
  frzX.fillText(freezeActive?'FROZEN FRAME':'LIVE SIGNAL',PAD,15);

  // Spectrum
  const specY=130,specH=H-specY-20;
  for(let i=0;i<BINS;i++){
    const bx=PAD+i*bw;
    let amp=frozenFrame[i]||0;
    if(!freezeActive){
      amp=Math.max(0,fbm(i*0.04+t*0.3,t*0.15)-0.2)*1.2;
    } else {
      amp=lerp(amp,amp*(0.9+noise21(i*0.1,t*0.3)*0.2),blur);
    }
    const bh=amp*specH;
    const col=freezeActive?`rgba(139,0,255,0.7)`:`rgba(0,229,255,0.6)`;
    frzX.fillStyle=col;
    frzX.fillRect(bx,specY+specH-bh,bw-1,bh);
  }

  // Frozen line indicator
  if(freezeActive){
    frzX.strokeStyle='rgba(0,229,255,0.5)';
    frzX.setLineDash([4,6]);
    frzX.beginPath();frzX.moveTo(0,specY-10);frzX.lineTo(W,specY-10);frzX.stroke();
    frzX.setLineDash([]);
    frzX.fillStyle='#00E5FF';frzX.font='9px Courier New';
    frzX.fillText('FROZEN →',PAD,specY-2);
  }
}

