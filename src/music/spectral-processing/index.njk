function drawFFT(t){
  const W=fftC.width,H=fftC.height;
  fftX.fillStyle='rgba(4,2,10,0.85)';
  fftX.fillRect(0,0,W,H);
  const fund=lagFund.value;
  const nHarm=Math.round(lagHarm.value);
  const SR=44100,BINS=512;
  const PAD=50;
  const plotW=W-PAD-10,plotH=H-40;

  // Grid
  fftX.strokeStyle='rgba(0,229,255,0.06)';
  fftX.lineWidth=1;
  for(let i=0;i<5;i++){
    const y=10+plotH*i/4;
    fftX.beginPath();fftX.moveTo(PAD,y);fftX.lineTo(W-10,y);fftX.stroke();
    fftX.fillStyle='#5A4890';fftX.font='8px Courier New';fftX.textAlign='right';
    fftX.fillText(`${(1-i/4).toFixed(2)}`,PAD-4,y+4);
  }

  // Freq axis labels
  const freqMarks=logMode?[100,200,500,1000,2000,5000,10000,20000]:[0,5000,10000,15000,20000];
  freqMarks.forEach(f=>{
    if(f>SR/2)return;
    let x;
    if(logMode){x=PAD+plotW*(Math.log10(f/20)/Math.log10(SR/2/20));}
    else{x=PAD+plotW*(f/(SR/2));}
    fftX.strokeStyle='rgba(0,229,255,0.1)';
    fftX.beginPath();fftX.moveTo(x,10);fftX.lineTo(x,10+plotH);fftX.stroke();
    fftX.fillStyle='#5A4890';fftX.font='8px Courier New';fftX.textAlign='center';
    fftX.fillText(f>=1000?`${f/1000}k`:f,x,H-4);
  });

  // Noise floor
  fftX.strokeStyle='rgba(139,0,255,0.3)';
  fftX.lineWidth=1;
  fftX.beginPath();
  for(let i=0;i<plotW;i++){
    const fi=i/plotW;
    const binFreq=logMode?20*Math.pow(SR/2/20,fi):(fi*SR/2);
    const noise=-80+noise21(i*0.02,t*0.1)*10;
    const y=10+plotH*(1-Math.max(0,(noise+80)/80));
    i===0?fftX.moveTo(PAD+i,y):fftX.lineTo(PAD+i,y);
  }
  fftX.stroke();

  // Harmonics
  for(let h=1;h<=nHarm;h++){
    const freq=fund*h;
    if(freq>SR/2)break;
    let x;
    if(logMode){x=PAD+plotW*(Math.log10(freq/20)/Math.log10(SR/2/20));}
    else{x=PAD+plotW*(freq/(SR/2));}
    const amp=Math.pow(1/h,0.7)*(0.9+noise21(h*3,t*0.3)*0.1);
    const dbAmp=20*Math.log10(amp);
    const normAmp=Math.max(0,(dbAmp+80)/80);
    const barH=plotH*normAmp;
    const grad=fftX.createLinearGradient(0,10+plotH-barH,0,10+plotH);
    grad.addColorStop(0,'rgba(0,229,255,0.9)');
    grad.addColorStop(0.5,'rgba(139,0,255,0.6)');
    grad.addColorStop(1,'rgba(139,0,255,0.1)');
    fftX.fillStyle=grad;
    fftX.fillRect(x-2,10+plotH-barH,4,barH);
    // Glow
    fftX.shadowBlur=12;fftX.shadowColor='#00E5FF';
    fftX.fillStyle='rgba(0,229,255,0.7)';
    fftX.fillRect(x-1,10+plotH-barH,2,barH);
    fftX.shadowBlur=0;
    // Freq label
    if(h<=8){
      fftX.fillStyle='#00E5FF';fftX.font='8px Courier New';fftX.textAlign='center';
      fftX.fillText(`H${h}`,x,10+plotH-barH-4);
    }
  }
}

