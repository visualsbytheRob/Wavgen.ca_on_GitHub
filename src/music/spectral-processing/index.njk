  const srcB=parseInt(document.getElementById('sl-srcb').value);
  const BINS=16;
  const PAD=30,specW=(W-PAD*4)/3,specH=H*0.55;
  const specY=H*0.1;

  function drawSpectrum(ctx,startX,spec,color,label){
    ctx.fillStyle='#5A4890';ctx.font='9px Courier New';ctx.textAlign='center';
    ctx.fillText(label,startX+specW/2,specY-8);
    for(let i=0;i<BINS;i++){
      const bx=startX+i*(specW/BINS);
      const bh=spec[i]*specH;
      const grad=ctx.createLinearGradient(0,specY+specH-bh,0,specY+specH);
      grad.addColorStop(0,color);grad.addColorStop(1,color.replace('0.8','0.1'));
      ctx.fillStyle=grad;ctx.fillRect(bx,specY+specH-bh,specW/BINS-2,bh);
    }
  }

  drawSpectrum(mrpX,PAD,SRC_SPECS[srcA],'rgba(224,160,0,0.8)',SRC_NAMES[srcA]);
  const morphed=SRC_SPECS[srcA].map((a,i)=>lerp(a,SRC_SPECS[srcB][i],morph));
  drawSpectrum(mrpX,PAD*2+specW,morphed,'rgba(0,229,255,0.8)','MORPHED');
  drawSpectrum(mrpX,PAD*3+specW*2,SRC_SPECS[srcB],'rgba(139,0,255,0.8)',SRC_NAMES[srcB]);

  // Morph indicator
  const miy=specY+specH+40;
  mrpX.fillStyle='rgba(0,229,255,0.1)';
  mrpX.fillRect(PAD,miy,W-PAD*2,12);
  mrpX.fillStyle='rgba(0,229,255,0.6)';
  mrpX.fillRect(PAD,miy,(W-PAD*2)*morph,12);
  mrpX.strokeStyle='rgba(0,229,255,0.4)';mrpX.lineWidth=1;
  mrpX.strokeRect(PAD,miy,W-PAD*2,12);
  mrpX.fillStyle='#00E5FF';mrpX.font='9px Courier New';
  mrpX.textAlign='center';mrpX.fillText(`MORPH: ${Math.round(morph*100)}%`,W/2,miy+30);
}

// MAIN LOOP
let lastT=0;
function frame(now){
  const dt=Math.min((now-lastT)/1000,0.05);lastT=now;
  const t=now/1000;
  lagHMX.update(mouseX,dt);lagHMY.update(mouseY,dt);
  lagFund.update(parseFloat(document.getElementById('sl-fund').value),dt);
  lagHarm.update(parseFloat(document.getElementById('sl-harm').value),dt);
  lagBlur.update(parseFloat(document.getElementById('sl-blur').value),dt);
  lagFrame.update(parseFloat(document.getElementById('sl-frame').value),dt);
  lagFPitch.update(parseFloat(document.getElementById('sl-fpitch').value),dt);
  lagTStretch.update(parseFloat(document.getElementById('sl-tstretch').value),dt);
  lagPShift.update(parseFloat(document.getElementById('sl-pshift').value),dt);
  lagIRLen.update(parseFloat(document.getElementById('sl-irlen').value),dt);
  lagWetDry.update(parseFloat(document.getElementById('sl-wetdry').value),dt);
  lagMorph.update(parseFloat(document.getElementById('sl-morph').value),dt);
  lagXSynth.update(parseFloat(document.getElementById('sl-xsynth').value),dt);
  lagFreezeAnim.update(freezeActive?0:1,dt);

  if(hgl&&hprog){hgl.viewport(0,0,hc.width,hc.height);hgl.useProgram(hprog);hgl.uniform2f(huniforms.res,hc.width,hc.height);hgl.uniform1f(huniforms.time,t);hgl.uniform2f(huniforms.mouse,lagHMX.value,1-lagHMY.value);hgl.drawArrays(hgl.TRIANGLE_STRIP,0,4);}
  drawFFT(t);
  drawFreeze(t);
  drawPV(t);
  drawConv(t);
  drawMorph(t);
  requestAnimationFrame(frame);
}
requestAnimationFrame(t=>{lastT=t;requestAnimationFrame(frame);});
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:0.1});
document.querySelectorAll('.hidden').forEach(el=>obs.observe(el));
</script>
