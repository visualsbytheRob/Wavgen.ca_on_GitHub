let tapePos=0;

function tapeTransfer(x,drive,bias,knee){
  // Soft saturation curve with bias offset
  const biasOff=bias*0.2;
  const driven=(x+biasOff)*drive;
  const k=knee;
  // Hyperbolic tangent saturation
  return Math.tanh(driven/k)*k;
}

function drawTape(t){
  const W=tpC.width,H=tpC.height;
  tpX.fillStyle='rgba(8,4,2,0.88)';tpX.fillRect(0,0,W,H);
  const speed=IPS_VALS[parseInt(document.getElementById('sl-speed').value)];
  const bias=parseFloat(document.getElementById('sl-bias').value);
  const inputDb=parseFloat(document.getElementById('sl-input').value);
  const inputGain=Math.pow(10,inputDb/20);
  const wf=lagWF.value;

  if(tapeRunning)tapePos+=0.005*speed/30;

  // Left reel
  const lrX=100,lrY=H/2-40;const lrR=60+tapePos*10%20;
  tpX.strokeStyle='rgba(139,69,19,0.6)';tpX.lineWidth=2;
  tpX.beginPath();tpX.arc(lrX,lrY,lrR,0,Math.PI*2);tpX.stroke();
  for(let s=0;s<8;s++){const a=s*Math.PI/4+tapePos*speed*0.2;tpX.beginPath();tpX.moveTo(lrX,lrY);tpX.lineTo(lrX+lrR*Math.cos(a)*0.7,lrY+lrR*Math.sin(a)*0.7);tpX.stroke();}

  // Right reel
  const rrX=W-100,rrY=H/2-40;const rrR=50-tapePos*10%15;
  tpX.strokeStyle='rgba(139,69,19,0.5)';tpX.lineWidth=2;
  tpX.beginPath();tpX.arc(rrX,rrY,rrR,0,Math.PI*2);tpX.stroke();
  for(let s=0;s<8;s++){const a=s*Math.PI/4-tapePos*speed*0.2;tpX.beginPath();tpX.moveTo(rrX,rrY);tpX.lineTo(rrX+rrR*Math.cos(a)*0.7,rrY+rrR*Math.sin(a)*0.7);tpX.stroke();}

  // Tape path
  const tapeY=H/2+20;
  tpX.strokeStyle='rgba(200,112,48,0.7)';tpX.lineWidth=4;
  tpX.beginPath();tpX.moveTo(lrX+lrR,tapeY);tpX.lineTo(rrX-rrR,tapeY);tpX.stroke();

  // Heads
  const heads=[{x:W*0.35,label:'ERASE',color:'#5A3A20'},{x:W*0.5,label:'RECORD',color:'#F0A020'},{x:W*0.65,label:'PLAY',color:'#8B4513'}];
  heads.forEach(h=>{
    tpX.fillStyle=h.color;
    tpX.fillRect(h.x-10,tapeY-25,20,30);
    tpX.fillStyle='#7A5A3A';tpX.font='8px Courier New';tpX.textAlign='center';
    tpX.fillText(h.label,h.x,tapeY+22);
  });

  // Input waveform + saturation
  const wavY=tapeY+70,wavH=50;
  tpX.fillStyle='#5A3A20';tpX.font='9px Courier New';tpX.textAlign='left';
  tpX.fillText('INPUT',8,wavY-8);
  tpX.fillText('SATURATED',8,wavY-8+wavH+28);
  tpX.strokeStyle='rgba(240,160,32,0.5)';tpX.lineWidth=1.5;tpX.beginPath();
  for(let x=0;x<W;x++){const xf=x/W;const wfMod=1+wf*Math.sin(xf*20+t*4)*0.03;const sample=Math.sin(xf*30*wfMod+t*3)*0.7*inputGain;x===0?tpX.moveTo(x,wavY+sample*wavH):tpX.lineTo(x,wavY+sample*wavH);}
  tpX.stroke();
  tpX.strokeStyle='rgba(200,112,48,0.8)';tpX.lineWidth=1.5;tpX.beginPath();
  for(let x=0;x<W;x++){const xf=x/W;const wfMod=1+wf*Math.sin(xf*20+t*4)*0.03;const sample=Math.sin(xf*30*wfMod+t*3)*0.7*inputGain;const saturated=tapeTransfer(sample,inputGain,bias*0.1,0.8);x===0?tpX.moveTo(x,wavY+wavH+28+saturated*wavH):tpX.lineTo(x,wavY+wavH+28+saturated*wavH);}
  tpX.stroke();

  // Status
  tpX.fillStyle=tapeRunning?'#F0A020':'#5A3A20';
  tpX.font='9px Courier New';tpX.textAlign='right';
  tpX.fillText(tapeRunning?`▶ ${speed} IPS`:'■ STOPPED',W-8,18);
}

