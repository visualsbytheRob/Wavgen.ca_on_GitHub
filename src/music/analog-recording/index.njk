const MIC_NAMES=['Condenser','Dynamic','Ribbon','Tube Cond'];
const PRE_NAMES=['Neve 1073','API 512','SSL G','UA 610'];
const COMP_NAMES=['LA-2A','1176','SSL G-Bus','Fairchild'];
const TAPE_NAMES=['ATR-102','Studer A80','Ampex 440','Otari MTR'];
document.getElementById('sl-mic').addEventListener('input',function(){document.getElementById('v-mic').textContent=MIC_NAMES[parseInt(this.value)];});
document.getElementById('sl-pre').addEventListener('input',function(){document.getElementById('v-pre').textContent=PRE_NAMES[parseInt(this.value)];});
