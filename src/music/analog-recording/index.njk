let chainPackets=[];

function drawChain(t){
  const W=chC.width,H=chC.height;
  chX.fillStyle='rgba(8,4,2,0.88)';chX.fillRect(0,0,W,H);
  const micIdx=parseInt(document.getElementById('sl-mic').value);
  const preIdx=parseInt(document.getElementById('sl-pre').value);
  const compIdx=parseInt(document.getElementById('sl-comp').value);
  const tapeIdx=parseInt(document.getElementById('sl-formula').value);
  const items=[
    {label:'MIC\n'+MIC_NAMES[micIdx],color:'#C87030',x:0.08},
    {label:'XFR\nTRANSF',color:'#8B4513',x:0.22},
    {label:'PRE\n'+PRE_NAMES[preIdx],color:'#F0A020',x:0.38},
    {label:'EQ\n3-BAND',color:'#D4820A',x:0.54},
    {label:'COMP\n'+COMP_NAMES[compIdx],color:'#FFB830',x:0.68},
    {label:'TAPE\n'+TAPE_NAMES[tapeIdx],color:'#C87030',x:0.85},
  ];
  const n=items.length;
  const W2=100,H2=50;
  items.forEach((item,i)=>{
    const x=item.x*W-W2/2,y=H*0.22;
    chX.fillStyle='#100806';
    chX.strokeStyle=item.color;chX.lineWidth=1.5;
    chX.fillRect(x,y,W2,H2);chX.strokeRect(x,y,W2,H2);
    chX.fillStyle=item.color;chX.font='8px Courier New';chX.textAlign='center';
    item.label.split('\n').forEach((l,li)=>chX.fillText(l,x+W2/2,y+H2/2+(li-0.5)*11));
    if(i<n-1){
      const nx=items[i+1].x*W-W2/2;
      chX.strokeStyle='rgba(240,160,32,0.3)';chX.lineWidth=1.5;
      chX.beginPath();chX.moveTo(x+W2,y+H2/2);chX.lineTo(nx,y+H2/2);chX.stroke();
    }
  });

  // Animated signal through chain
  chainPackets=chainPackets.filter(p=>p.t<1);
  chainPackets.forEach(p=>{
    p.t+=0.008;
    const px=items[0].x*W+p.t*(items[n-1].x*W-items[0].x*W);
    const py=H*0.22+H2/2;
    chX.beginPath();chX.arc(px,py,5,0,Math.PI*2);
    const warmth=p.t;const r=Math.round(lerp(200,240,warmth));const g=Math.round(lerp(112,160,warmth*0.5));
    chX.fillStyle=`rgb(${r},${g},48)`;chX.shadowBlur=10;chX.shadowColor='#F0A020';
    chX.fill();chX.shadowBlur=0;
  });

  // Waveform evolution
  const wBaseY=H*0.55;
  items.forEach((item,i)=>{
    const wx=item.x*W;
    const drive=0.5+i*0.12;
    chX.strokeStyle=`rgba(200,112,48,${0.4+i*0.08})`;chX.lineWidth=1.2;chX.beginPath();
    const ww=W2;
    for(let px=0;px<ww;px++){
      const xf=px/ww;
      const sample=Math.sin(xf*20+t*3)*0.4;
      const processed=tapeTransfer2(sample,drive);
      px===0?chX.moveTo(wx-W2/2+px,wBaseY+processed*H*0.12):chX.lineTo(wx-W2/2+px,wBaseY+processed*H*0.12);
    }
    chX.stroke();
    chX.fillStyle=item.color;chX.font='7px Courier New';chX.textAlign='center';
    chX.fillText('THD: '+(i*1.2+0.1).toFixed(1)+'%',wx,wBaseY+H*0.12+15);
  });
}

