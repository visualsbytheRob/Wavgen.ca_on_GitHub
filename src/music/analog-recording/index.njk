const SAT_NAMES=['Tape','Transformer','Tube','Transistor'];
document.getElementById('sl-sat-drive').addEventListener('input',function(){document.getElementById('v-sat-drive').textContent=Math.round(this.value*100)+'%';});
document.getElementById('sl-sat-char').addEventListener('input',function(){document.getElementById('v-sat-char').textContent=SAT_NAMES[parseInt(this.value)];});
document.getElementById('sl-odd-even').addEventListener('input',function(){document.getElementById('v-odd-even').textContent=Math.round(this.value*100)+'% ODD';});
document.getElementById('sl-knee').addEventListener('input',function(){document.getElementById('v-knee').textContent=parseFloat(this.value).toFixed(2);});

function satCurve(x,drive,oddEven,knee){
  const satChar=parseInt(document.getElementById('sl-sat-char').value);
  switch(satChar){
    case 0:return Math.tanh(x*(1+drive*3)/knee)*knee*(1-oddEven*0.2);// tape: mostly even
    case 1:{const g=1+drive*4;return x*g/(1+Math.abs(x*g))*(1+oddEven*0.1*Math.sin(x*8));}// transformer
    case 2:return Math.tanh(x*(1+drive*2)/knee)*knee*(1+oddEven*0.1*Math.sin(x*6));// tube
    case 3:{const g=1+drive*5;const h=x*g;return Math.max(-1,Math.min(1,h*(1-Math.pow(Math.abs(h),2)*0.3)));}// transistor: hard
  }
  return x;
}

function drawSaturation(t){
  const W=stC.width,H=stC.height;
  const drive=lagSatDrive.value;
  const oddEven=lagOddEven.value;
  const knee=lagKnee.value;

  // Transfer function
  stX.fillStyle='rgba(8,4,2,0.88)';stX.fillRect(0,0,W,H);
  const PAD=30;
  // Grid
  stX.strokeStyle='rgba(240,160,32,0.08)';stX.lineWidth=1;
  [0.25,0.5,0.75].forEach(f=>{
    const y=PAD+(H-PAD*2)*f;const x=PAD+(W-PAD*2)*f;
    stX.beginPath();stX.moveTo(PAD,y);stX.lineTo(W-PAD,y);stX.stroke();
    stX.beginPath();stX.moveTo(x,PAD);stX.lineTo(x,H-PAD);stX.stroke();
  });
  stX.strokeStyle='rgba(240,160,32,0.2)';stX.lineWidth=1;
  stX.beginPath();stX.moveTo(PAD,(H-PAD*2)/2+PAD);stX.lineTo(W-PAD,(H-PAD*2)/2+PAD);stX.stroke();
  stX.beginPath();stX.moveTo((W-PAD*2)/2+PAD,PAD);stX.lineTo((W-PAD*2)/2+PAD,H-PAD);stX.stroke();
  // Linear reference
  stX.strokeStyle='rgba(240,160,32,0.2)';stX.lineWidth=1;stX.setLineDash([4,6]);
  stX.beginPath();stX.moveTo(PAD,H-PAD);stX.lineTo(W-PAD,PAD);stX.stroke();stX.setLineDash([]);
  // Saturated curve
  stX.strokeStyle='rgba(200,112,48,0.9)';stX.lineWidth=2;stX.beginPath();
  for(let px=0;px<W-PAD*2;px++){
    const x=(px/(W-PAD*2))*2-1;
    const y=satCurve(x,drive,oddEven,knee);
    const cy=(H-PAD*2)/2+PAD-y*(H-PAD*2)/2;
    const cx=PAD+px;
    px===0?stX.moveTo(cx,cy):stX.lineTo(cx,cy);
  }
  stX.stroke();
  stX.fillStyle='#7A5A3A';stX.font='9px Courier New';stX.textAlign='left';
  stX.fillText('TRANSFER FUNCTION',PAD,H-8);

  // Spectrum
  const WS=ssC.width,HS=ssC.height;
  ssX.fillStyle='rgba(8,4,2,0.88)';ssX.fillRect(0,0,WS,HS);
  ssX.fillStyle='#7A5A3A';ssX.font='9px Courier New';ssX.textAlign='left';
  ssX.fillText('HARMONIC SPECTRUM',PAD,HS-8);
  // Fundamentals + harmonics
  const harmonic_amps=[1.0];
  for(let h=2;h<=12;h++){
    const isEven=h%2===0;
    const base=isEven?(drive*(1-oddEven)*0.8):( drive*oddEven*0.6);
    harmonic_amps.push(base/Math.pow(h-1,1.5)*0.8);
  }
  const barW=(WS-PAD*2)/12;
  harmonic_amps.forEach((amp,i)=>{
    const bx=PAD+i*barW+barW*0.1;
    const bh=amp*(HS-PAD*2-20);
    const isEven=(i+1)%2===0;
    const col=isEven?'#F0A020':'#8B4513';
    ssX.fillStyle=col+'88';
    ssX.strokeStyle=col;ssX.lineWidth=1;
    ssX.fillRect(bx,HS-PAD-bh,barW*0.8,bh);
    ssX.strokeRect(bx,HS-PAD-bh,barW*0.8,bh);
    ssX.fillStyle='#7A5A3A';ssX.font='8px Courier New';ssX.textAlign='center';
    ssX.fillText(`H${i+1}`,bx+barW*0.4,HS-PAD+12);
  });
}

