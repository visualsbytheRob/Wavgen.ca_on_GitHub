  const stages=['MIC\nINPUT','TRANSFORM-\nER','PREAMP',`EQ\n${consoleName==='SSL 4000'?'4-BAND':'3-BAND'}`,'DYNA-\nMICS','CHANNEL\nFADER','GROUP\nBUS','SUMMING\nBUS','STEREO\nOUT'];
  const COLS=['#C87030','#8B4513','#F0A020','#D4820A','#FFB830','#E8C080','#8B4513','#F0A020','#FFB830'];
  const n=stages.length;
  const PAD=30,stW=(W-PAD*2)/n;

  // Draw stages
  stages.forEach((stage,i)=>{
    const sx=PAD+i*stW,sy=H*0.15,sh=H*0.55,sw=stW-6;
