const stC=document.getElementById('sat-transfer-canvas');
const stX=stC.getContext('2d');
const ssC=document.getElementById('sat-spectrum-canvas');
const ssX=ssC.getContext('2d');
function resSAT(){stC.width=stC.offsetWidth;stC.height=280;ssC.width=ssC.offsetWidth;ssC.height=280;}resSAT();
