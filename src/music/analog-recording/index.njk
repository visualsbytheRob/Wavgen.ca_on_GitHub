    const lines=stage.split('\n');
    lines.forEach((l,li)=>cnX.fillText(l,sx+sw/2,sy+sh/2+(li-lines.length/2+0.5)*10));
    // Saturation glow
    if(saturation>0.1){
      cnX.strokeStyle=`rgba(240,160,32,${saturation*0.5})`;cnX.lineWidth=1;
      cnX.beginPath();cnX.arc(sx+sw/2,sy+sh/2,sw*0.4,0,Math.PI*2);cnX.stroke();
    }
    // Connection lines
    if(i<n-1){
      cnX.strokeStyle='rgba(240,160,32,0.2)';cnX.lineWidth=1.5;
      cnX.beginPath();cnX.moveTo(sx+sw,sy+sh/2);cnX.lineTo(sx+stW,sy+sh/2);cnX.stroke();
    }
  });

  // Signal packets
  cnPackets=cnPackets.filter(p=>p.t<1);
  cnPackets.forEach(p=>{
    p.t+=p.speed;
    const sx=PAD+p.t*(W-PAD*2);
    const sy=H*0.15+H*0.55/2;
    cnX.beginPath();cnX.arc(sx,sy,5,0,Math.PI*2);
    cnX.fillStyle='#F0A020';cnX.shadowBlur=12;cnX.shadowColor='#F0A020';
    cnX.fill();cnX.shadowBlur=0;
  });

  // Waveform comparison
  const cmpY=H*0.82;
  cnX.strokeStyle='rgba(240,160,32,0.4)';cnX.lineWidth=1;cnX.beginPath();
  for(let x=0;x<W;x++){const xf=x/W;const sample=Math.sin(xf*30+t*3)*0.4;cnX.lineTo(x,cmpY+sample*(H*0.08));}
  cnX.stroke();
  cnX.strokeStyle='rgba(200,112,48,0.7)';cnX.lineWidth=1;cnX.beginPath();
  for(let x=0;x<W;x++){const xf=x/W;const sample=Math.sin(xf*30+t*3)*0.4;const sat=tapeTransfer2(sample,1+busSat*2);cnX.lineTo(x,cmpY+sat*(H*0.1));}
  cnX.stroke();
