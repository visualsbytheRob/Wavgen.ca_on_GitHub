<!-- S8: GLOSSARY -->
<section class="hidden" id="s8">
<div class="section-label">08 · REFERENCE</div>
<div class="section-title">Analog Lexicon</div>
<div class="gloss-grid">
<div class="gloss-item"><div class="gloss-term">Magnetic Recording</div><div class="gloss-def">Storing audio as patterns of magnetic flux on oxide-coated tape. An electromagnetic write head aligns magnetic particles; a read head converts patterns back to electrical signal. The fundamental mechanism of all tape recording.</div></div>
<div class="gloss-item"><div class="gloss-term">Tape Saturation</div><div class="gloss-def">At high recording levels, tape oxide accepts less additional flux, producing even-order harmonic distortion. Intentional saturation adds warmth, compression, and perceived loudness — the primary sonic characteristic of tape recording.</div></div>
<div class="gloss-item"><div class="gloss-term">Wow and Flutter</div><div class="gloss-def">Speed variations in tape transport. Wow = slow periodic pitch variation (less than 6 Hz); Flutter = faster variation (6–100 Hz). Both contribute to the organic feel of tape at low levels. Defect at high levels.</div></div>
<div class="gloss-item"><div class="gloss-term">Bias</div><div class="gloss-def">High-frequency AC signal (40–150 kHz) added to the audio signal during recording. Bias improves linearity and reduces distortion. Different tape formulations require different bias levels — improper bias alters tone and distortion character.</div></div>
<div class="gloss-item"><div class="gloss-term">IPS (Inches Per Second)</div><div class="gloss-def">Tape speed: higher IPS means better high-frequency response, more tape consumption, lower relative noise floor. Professional multitrack standards: 15 ips (warm, slightly lower HF) and 30 ips (extended HF, lower noise).</div></div>
<div class="gloss-item"><div class="gloss-term">Console / Desk</div><div class="gloss-def">The mixing console through which signals are routed. Each classic large-format console (SSL 4000, Neve 8078, API 1604) has distinct sonic character from preamp, EQ circuitry, transformer types, and summing bus topology.</div></div>
<div class="gloss-item"><div class="gloss-term">Preamp</div><div class="gloss-def">Amplifies a microphone signal to line level. The preamp dominates the recording's sonic character. Neve 1073 (transformer warmth, harmonics), API 512 (punchy, fast), SSL G (clean, modern) — each colours differently.</div></div>
<div class="gloss-item"><div class="gloss-term">Print-Through</div><div class="gloss-def">Transfer of magnetic patterns from one tape layer to an adjacent layer on the reel. Creates ghost pre-echoes or post-echoes. A characteristic artifact of tape storage; more pronounced at higher recording levels and thinner tape stock.</div></div>
<div class="gloss-item"><div class="gloss-term">Oxide</div><div class="gloss-def">The magnetic coating on recording tape. Ferric oxide, chromium dioxide, and metal particle formulations each have different bias requirements, dynamic range, and sonic characteristics. High-output formulations (ATR, BASF 900, Quantegy GP9) allow higher recording levels.</div></div>
<div class="gloss-item"><div class="gloss-term">Head Gap</div><div class="gloss-def">The tiny gap in a recording or playback head. The gap width determines frequency response — smaller gaps extend high-frequency response. Record heads have wider gaps than playback heads for better recording linearity.</div></div>
<div class="gloss-item"><div class="gloss-term">Dolby / dbx Noise Reduction</div><div class="gloss-def">Compander systems encoding on record and decoding on playback. Dolby A, B, C, SR; dbx Type I, II. Reduce tape hiss at the expense of slight coloration. A recording made with NR must be decoded with the matching circuit.</div></div>
<div class="gloss-item"><div class="gloss-term">Summing Bus</div><div class="gloss-def">The circuit in a console where all track signals combine into a stereo mix. Analog summing adds subtle harmonic saturation and natural compression — the "glue" that distinguishes console-mixed records from purely in-the-box mixes.</div></div>
<div class="gloss-item"><div class="gloss-term">VU Meter</div><div class="gloss-def">Volume Unit meter — ballistic meter responding to average signal level. Standard metering in tape recording. 0 VU = +4 dBu in professional systems. The VU needle's characteristic sluggishness (300ms integration) tracks musical dynamics naturally.</div></div>
<div class="gloss-item"><div class="gloss-term">Transformer</div><div class="gloss-def">Magnetic coupling device transferring signal between impedances. Transformers add even-order harmonics, gentle high-frequency rolloff, and low-mid warmth. The transformer is the primary source of Neve's and API's distinctive sonic character.</div></div>
<div class="gloss-item"><div class="gloss-term">Even-Order Harmonics</div><div class="gloss-def">Harmonic partials at 2nd, 4th, 6th multiples of the fundamental. Perceived as warmth, richness, musical — in octave relationship to the fundamental. The dominant distortion type in Class-A amplifiers, triode vacuum tubes, and tape saturation.</div></div>
<div class="gloss-item"><div class="gloss-term">Odd-Order Harmonics</div><div class="gloss-def">Harmonic partials at 3rd, 5th, 7th multiples. Perceived as grit, aggression, harshness — not in octave relationship to the fundamental. Dominant in Class-B amplifiers, solid-state clipping, and driven transistor circuits.</div></div>
<div class="gloss-item"><div class="gloss-term">Noise Floor</div><div class="gloss-def">The inherent noise level of a recording system — tape hiss, circuit noise, electromagnetic interference. 2-inch tape at 30 ips measures approximately -72 dBFS. Noise reduction systems can improve this by 10-20 dB.</div></div>
<div class="gloss-item"><div class="gloss-term">Intermodulation Distortion (IMD)</div><div class="gloss-def">Nonlinear distortion generating sum and difference frequencies when two or more signals pass through a saturating circuit. Unlike harmonic distortion, IMD products are generally non-musical — an indicator of excessive drive levels.</div></div>
<div class="gloss-item"><div class="gloss-term">Overs and Headroom</div><div class="gloss-def">Analog recording has soft clipping headroom above 0 VU — signals can exceed nominal level before gross distortion. Typically 10-15 dB of usable headroom. Digital systems clip hard at 0 dBFS — a fundamental difference in dynamic character.</div></div>
<div class="gloss-item"><div class="gloss-term">Flux Density</div><div class="gloss-def">The intensity of magnetic flux per unit area on tape, expressed in nanowebers per metre (nWb/m). Higher flux = hotter recording level relative to tape saturation. Modern high-output tapes support higher flux densities before saturation.</div></div>
<div class="gloss-item"><div class="gloss-term">NAB / IEC EQ</div><div class="gloss-def">Standardised equalisation curves applied during tape recording and playback. NAB (American) and IEC (European) differ in low-frequency rolloff. Equipment must use matching EQ — using the wrong standard alters bass reproduction.</div></div>
<div class="gloss-item"><div class="gloss-term">Tape Compression</div><div class="gloss-def">Natural soft-knee compression behaviour as tape approaches saturation — input dynamics are gently compressed before saturation onset. Contributes to the glued, cohesive feel of tape recordings at moderate to high recording levels.</div></div>
</div>
</section>
<script>
const lerp=(a,b,t)=>a+(b-a)*t;
const clamp=(v,lo,hi)=>Math.max(lo,Math.min(hi,v));
const rand=(lo=0,hi=1)=>lo+Math.random()*(hi-lo);
function noise21(x,y){const ix=Math.floor(x),iy=Math.floor(y);const fx=x-ix,fy=y-iy;const ux=fx*fx*(3-2*fx),uy=fy*fy*(3-2*fy);const h=(a,b)=>{let n=(a*1619+b*31337)^(a*31337);n=(n>>8)^n;return(n&0xffff)/65535;};return lerp(lerp(h(ix,iy),h(ix+1,iy),ux),lerp(h(ix,iy+1),h(ix+1,iy+1),ux),uy);}
function fbm(x,y,oct=4){let v=0,a=0.5,f=1;for(let i=0;i<oct;i++){v+=a*noise21(x*f,y*f);a*=0.5;f*=2.1;}return v;}

class LagFilter{constructor(init,tau){this.value=init;this.tau=tau;}update(target,dt){const k=1-Math.exp(-dt/this.tau);this.value+=k*(target-this.value);return this.value;}}
const lagHMX=new LagFilter(0.5,0.9);
const lagHMY=new LagFilter(0.5,0.9);
const lagHGrain=new LagFilter(0,0.1);
const lagSpeed=new LagFilter(15,0.5);
const lagBias=new LagFilter(0,0.4);
const lagInput=new LagFilter(0,0.4);
const lagWF=new LagFilter(0.2,0.4);
const lagSatDrive=new LagFilter(0.3,0.3);
const lagOddEven=new LagFilter(0.3,0.3);
const lagKnee=new LagFilter(0.7,0.4);
const lagH2=new LagFilter(0.5,0.3);
const lagH3=new LagFilter(0.2,0.3);
const lagIMD=new LagFilter(0.1,0.3);
const lagBusSat=new LagFilter(0.3,0.3);
const lagConsoleGain=new LagFilter(0,0.4);
const lagHarmInput=new LagFilter(0,0.4);
const lagTapeAnim=new LagFilter(0,0.15);

let mouseX=0.5,mouseY=0.5;
document.addEventListener('mousemove',e=>{mouseX=e.clientX/window.innerWidth;mouseY=e.clientY/window.innerHeight;});

// HERO WebGL
const hc=document.getElementById('hero-canvas');
hc.width=window.innerWidth;hc.height=440;
window.addEventListener('resize',()=>{hc.width=window.innerWidth;hc.height=440;initHGL();});
const HVS=`attribute vec2 pos;void main(){gl_Position=vec4(pos,0,1);}`;
const HFS=`
precision highp float;
uniform vec2 u_res;uniform float u_time;uniform vec2 u_mouse;
float hash(vec2 p){p=fract(p*vec2(127.1,311.7));p+=dot(p,p+17.5);return fract(p.x*p.y);}
float noise(vec2 p){vec2 i=floor(p),f=fract(p);vec2 u=f*f*(3.-2.*f);return mix(mix(hash(i),hash(i+vec2(1,0)),u.x),mix(hash(i+vec2(0,1)),hash(i+vec2(1)),u.x),u.y);}
float fbm(vec2 p){float v=0.,a=.5;for(int i=0;i<5;i++){v+=a*noise(p);a*=.5;p=p*2.1+vec2(1.7,9.2);}return v;}
void main(){
  vec2 uv=gl_FragCoord.xy/u_res;
  vec2 st=uv*2.-1.;st.x*=u_res.x/u_res.y;
  float t=u_time;
  // Tape motion: horizontal oxide particles
  float tape=0.;
  for(int i=0;i<6;i++){
    float fi=float(i)/6.;
    float ty=-0.7+fi*0.28;
    float phase=fract(st.x*0.2+t*(0.3+fi*0.1));
    float particle=exp(-abs(st.y-ty)*30.)*exp(-abs(phase-0.5)*6.)*0.4;
    tape+=particle;
  }
  // Oxide noise field
  float ox=fbm(st*2.+t*0.04);
  float grain=noise(st*80.+t*0.5)*0.08;
  // Warm amber glow
  vec3 tapeOxide=vec3(0.55,0.28,0.08);
  vec3 warmAmber=vec3(0.94,0.63,0.13);
  vec3 consoleBlack=vec3(0.03,0.02,0.01);
  vec3 col=consoleBlack;
  col+=tapeOxide*tape*0.8;
  col+=mix(tapeOxide,warmAmber,ox)*ox*0.2;
  col+=vec3(grain);
  // VU glow from cursor
  vec2 ms=u_mouse*2.-1.;ms.x*=u_res.x/u_res.y;
  col+=warmAmber*exp(-length(st-ms)*5.)*0.3;
  // Saturation warmth over field
  col=col/(col+0.5)*1.5;// soft knee
  float vig=1.-length(uv-0.5)*1.4;
  col*=clamp(vig,0.,1.);
  gl_FragColor=vec4(col,1.);
}`;
let hgl,hprog,huniforms={};
function initHGL(){
  hgl=hc.getContext('webgl');if(!hgl)return;
  function mkS(t,src){const s=hgl.createShader(t);hgl.shaderSource(s,src);hgl.compileShader(s);return s;}
  if(hprog)hgl.deleteProgram(hprog);
  hprog=hgl.createProgram();
  hgl.attachShader(hprog,mkS(hgl.VERTEX_SHADER,HVS));
  hgl.attachShader(hprog,mkS(hgl.FRAGMENT_SHADER,HFS));
  hgl.linkProgram(hprog);hgl.useProgram(hprog);
  const buf=hgl.createBuffer();hgl.bindBuffer(hgl.ARRAY_BUFFER,buf);
  hgl.bufferData(hgl.ARRAY_BUFFER,new Float32Array([-1,-1,1,-1,-1,1,1,1]),hgl.STATIC_DRAW);
  const pl=hgl.getAttribLocation(hprog,'pos');hgl.enableVertexAttribArray(pl);hgl.vertexAttribPointer(pl,2,hgl.FLOAT,false,0,0);
  huniforms={res:hgl.getUniformLocation(hprog,'u_res'),time:hgl.getUniformLocation(hprog,'u_time'),mouse:hgl.getUniformLocation(hprog,'u_mouse')};
}
initHGL();

