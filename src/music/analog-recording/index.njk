function drawHarmonics(t){
  const W=hmC.width,H=hmC.height;
  hmX.fillStyle='rgba(8,4,2,0.88)';hmX.fillRect(0,0,W,H);
  const h2=lagH2.value;
  const h3=lagH3.value;
  const imd=lagIMD.value;
  const inputDb=parseFloat(document.getElementById('sl-harm-input').value);
  const inputGain=Math.pow(10,inputDb/20);
  const PAD=50;const plotW=W-PAD*2;const plotH=(H-40)/2;
  const plotY1=20,plotY2=plotH+30;

  // Waveform comparison (top)
  hmX.fillStyle='#5A3A20';hmX.font='9px Courier New';hmX.textAlign='left';
  hmX.fillText('WAVEFORM',PAD,plotY1-4);
  hmX.strokeStyle='rgba(240,160,32,0.4)';hmX.lineWidth=1.5;hmX.beginPath();
  for(let x=0;x<plotW;x++){const xf=x/plotW;const sample=Math.sin(xf*Math.PI*8)*inputGain*0.6;hmX.lineTo(PAD+x,plotY1+plotH/2-sample*plotH*0.4);}
  hmX.stroke();
  hmX.strokeStyle='rgba(200,112,48,0.8)';hmX.lineWidth=1.5;hmX.beginPath();
  for(let x=0;x<plotW;x++){const xf=x/plotW;const fund=Math.sin(xf*Math.PI*8)*inputGain*0.6;const h2sig=h2*fund*fund*0.5;const h3sig=h3*Math.pow(fund,3)*0.25;const imdSig=imd*Math.sin(xf*Math.PI*5.3)*fund*0.3;hmX.lineTo(PAD+x,plotY1+plotH/2-(fund+h2sig+h3sig+imdSig)*plotH*0.38);}
  hmX.stroke();

  // Harmonic bar chart (bottom)
  hmX.fillStyle='#5A3A20';hmX.font='9px Courier New';hmX.textAlign='left';
  hmX.fillText('HARMONIC CONTENT',PAD,plotY2-4);
  const nBars=12,barW=plotW/nBars;
  for(let b=0;b<nBars;b++){
    const isOdd=(b+1)%2!==0;
    let amp;
    if(b===0)amp=inputGain;
    else if(b===1)amp=h2*inputGain*0.7;
    else if(b===2)amp=h3*inputGain*0.5;
    else amp=(isOdd?h3:h2)*inputGain/Math.pow(b+1,2)*0.4+imd*0.1/b;
    amp=Math.min(1,amp);
    const bh=amp*(plotH-10);
    const bx=PAD+b*barW+barW*0.1;
    const col=isOdd?'#8B4513':'#F0A020';
    hmX.fillStyle=col+'55';hmX.strokeStyle=col;hmX.lineWidth=1;
    hmX.fillRect(bx,plotY2+plotH-10-bh,barW*0.8,bh);
    hmX.strokeRect(bx,plotY2+plotH-10-bh,barW*0.8,bh);
    hmX.fillStyle='#5A3A20';hmX.font='7px Courier New';hmX.textAlign='center';
    hmX.fillText(b===0?'F':`${b+1}H`,bx+barW*0.4,plotY2+plotH+8);
  }

  // DB scale
  for(let db=-60;db<=0;db+=20){
    const y=plotY2+plotH-10-Math.pow(10,db/20)*plotH;
    hmX.strokeStyle='rgba(240,160,32,0.1)';hmX.lineWidth=1;
    hmX.beginPath();hmX.moveTo(PAD,y);hmX.lineTo(W-PAD,y);hmX.stroke();
    hmX.fillStyle='#5A3A20';hmX.font='7px Courier New';hmX.textAlign='right';
    hmX.fillText(`${db}dB`,PAD-4,y+3);
  }
}

// MAIN LOOP
let lastT=0,cnPkT=0,chPkT=0;
function frame(now){
  const dt=Math.min((now-lastT)/1000,0.05);lastT=now;
  const t=now/1000;
  lagHMX.update(mouseX,dt);lagHMY.update(mouseY,dt);
  lagBias.update(parseFloat(document.getElementById('sl-bias').value),dt);
  lagInput.update(parseFloat(document.getElementById('sl-input').value),dt);
  lagWF.update(parseFloat(document.getElementById('sl-wf2').value),dt);
  lagSatDrive.update(parseFloat(document.getElementById('sl-sat-drive').value),dt);
  lagOddEven.update(parseFloat(document.getElementById('sl-odd-even').value),dt);
  lagKnee.update(parseFloat(document.getElementById('sl-knee').value),dt);
  lagH2.update(parseFloat(document.getElementById('sl-h2').value),dt);
  lagH3.update(parseFloat(document.getElementById('sl-h3').value),dt);
  lagIMD.update(parseFloat(document.getElementById('sl-imd').value),dt);
  lagBusSat.update(parseFloat(document.getElementById('sl-bus-sat').value),dt);
  lagConsoleGain.update(parseFloat(document.getElementById('sl-gain').value),dt);
  lagHarmInput.update(parseFloat(document.getElementById('sl-harm-input').value),dt);

  if(hgl&&hprog){hgl.viewport(0,0,hc.width,hc.height);hgl.useProgram(hprog);hgl.uniform2f(huniforms.res,hc.width,hc.height);hgl.uniform1f(huniforms.time,t);hgl.uniform2f(huniforms.mouse,lagHMX.value,1-lagHMY.value);hgl.drawArrays(hgl.TRIANGLE_STRIP,0,4);}
  drawTape(t);
  cnPkT+=dt;if(cnPkT>0.15){spawnCNPacket();cnPkT=0;}
  drawConsole(t);
  drawSaturation(t);
  chPkT+=dt;if(chPkT>0.2){chainPackets.push({t:0,speed:0.008});chPkT=0;}
  drawChain(t);
  drawHarmonics(t);
  requestAnimationFrame(frame);
}
requestAnimationFrame(t=>{lastT=t;requestAnimationFrame(frame);});
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:0.1});
document.querySelectorAll('.hidden').forEach(el=>obs.observe(el));
</script>
