<!-- HERO JS -->
<script>
(function(){
  const canvas = document.getElementById('hero-canvas');
  const wrap   = document.getElementById('hero-wrap');
  function resize(){
    canvas.width  = wrap.clientWidth;
    canvas.height = wrap.clientHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  const ctx = canvas.getContext('2d');

  class LagFilter {
    constructor(v=0, tau=0.15){ this.value=v; this.target=v; this.tau=tau; }
    set(t){ this.target=t; }
    update(dt){ const a=1-Math.exp(-dt/Math.max(this.tau,0.001)); this.value+=(this.target-this.value)*a; return this.value; }
  }

  // 5 waveform layers
  const layers = [
    { freq:0.5,  amp:0.18, speed:0.12, phase:0,    color:'rgba(37,99,235,0.7)',  ampLag:new LagFilter(0.18,1.5) },
    { freq:1.2,  amp:0.12, speed:0.19, phase:1.2,  color:'rgba(96,165,250,0.5)', ampLag:new LagFilter(0.12,2.0) },
    { freq:2.1,  amp:0.07, speed:0.28, phase:2.4,  color:'rgba(37,99,235,0.4)',  ampLag:new LagFilter(0.07,1.2) },
    { freq:3.4,  amp:0.05, speed:0.41, phase:0.8,  color:'rgba(96,165,250,0.3)', ampLag:new LagFilter(0.05,0.9) },
    { freq:0.8,  amp:0.22, speed:0.08, phase:3.1,  color:'rgba(245,158,11,0.25)',ampLag:new LagFilter(0.22,2.5) },
  ];

  // BPM: ambient 60BPM
  const BPM = 60;
  const beatInterval = 60 / BPM; // seconds
  let beatPhase = 0;
  let lastT = 0;
  let elapsed = 0;

  // Phosphor scanline pattern
  function buildScanPattern(){
    const pc = document.createElement('canvas');
    pc.width=1; pc.height=3;
    const px = pc.getContext('2d');
    px.fillStyle='rgba(0,0,0,0.04)';
    px.fillRect(0,0,1,1);
    return ctx.createPattern(pc,'repeat');
  }
  let scanPattern = null;

  function drawLayer(layer, W, H, t){
    const centerY = H * 0.5;
    const ampPx   = H * layer.ampLag.value;
    ctx.beginPath();
    const steps = Math.min(W, 600);
    for(let i=0; i<=steps; i++){
      const x = (i/steps)*W;
      const nx = i/steps; // 0..1
      // composite sine with harmonics
      const y = centerY +
        Math.sin(nx * Math.PI * 2 * layer.freq + layer.phase + t * layer.speed) * ampPx +
        Math.sin(nx * Math.PI * 4 * layer.freq + layer.phase*1.3 + t * layer.speed*1.7) * ampPx * 0.3 +
        Math.sin(nx * Math.PI * 1.5 * layer.freq + t * layer.speed*0.5) * ampPx * 0.15;
      if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
    }
    ctx.strokeStyle = layer.color;
    ctx.lineWidth = 1.2;
    // amber glow on high amplitude peaks
    const peakAmp = layer.ampLag.value;
    if(peakAmp > 0.14){
      ctx.shadowBlur = 18;
      ctx.shadowColor = 'rgba(245,158,11,0.6)';
    } else {
      ctx.shadowBlur = 10;
      ctx.shadowColor = 'rgba(37,99,235,0.7)';
    }
    ctx.stroke();
    ctx.shadowBlur = 0;
  }

  function draw(ts){
    const t = ts * 0.001;
    const dt = Math.min(t - lastT, 0.05);
    lastT = t;
    elapsed += dt;

    const W = canvas.width;
    const H = canvas.height;

    // Phosphor decay
    ctx.globalAlpha = 0.07;
    ctx.fillStyle = 'rgba(2,4,8,1)';
    ctx.fillRect(0,0,W,H);
    ctx.globalAlpha = 1.0;

    // Beat-driven amplitude modulation (60BPM)
    beatPhase = (elapsed % beatInterval) / beatInterval;
    const beatPulse = Math.pow(Math.sin(beatPhase * Math.PI), 3); // smooth beat

    // Update layers
    layers.forEach((layer, i) => {
      layer.phase += dt * 0.05; // slow phase drift
      const baseAmp = [0.18, 0.12, 0.07, 0.05, 0.22][i];
      layer.ampLag.set(baseAmp + beatPulse * [0.06, 0.04, 0.03, 0.02, 0.08][i]);
      layer.ampLag.update(dt);
      drawLayer(layer, W, H, elapsed);
    });

    // Scanlines
    if(!scanPattern) scanPattern = buildScanPattern();
    ctx.fillStyle = scanPattern;
    ctx.fillRect(0,0,W,H);

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();
</script>
