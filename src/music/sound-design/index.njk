<button class="btn btn-amber" data-imptype="hit" id="imp-type-hit">Hit</button>
<button class="btn btn-amber" data-imptype="whoosh" id="imp-type-wsh">Whoosh</button>
<button class="btn btn-amber" data-imptype="drone" id="imp-type-drn">Drone</button>
