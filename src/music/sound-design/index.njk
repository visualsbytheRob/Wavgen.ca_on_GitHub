</div>
<div class="layer-row">
<div class="layer-dot" style="background:#7c3aed;"></div>
<span class="layer-label">Sub-Bass</span>
<div class="layer-bar"><div class="layer-fill" id="lbar-sub" style="background:#7c3aed;width:0%;"></div></div>
</div>
<div class="layer-row">
<div class="layer-dot" style="background:#60a5fa;"></div>
<span class="layer-label">Mid</span>
<div class="layer-bar"><div class="layer-fill" id="lbar-mid" style="background:#60a5fa;width:0%;"></div></div>
</div>
