</div>
<div class="hidden stagger-4" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:0.75rem;">
<div class="slider-row"><span class="slider-label">Density</span><input id="env-density" max="100" min="1" type="range" value="40"/><span class="slider-val" id="env-density-v">40</span></div>
<div class="slider-row"><span class="slider-label">Intensity</span><input id="env-intensity" max="100" min="1" type="range" value="60"/><span class="slider-val" id="env-intensity-v">60</span></div>
<div class="slider-row"><span class="slider-label">Weather</span><input id="env-weather" max="100" min="0" type="range" value="0"/><span class="slider-val" id="env-weather-v">0</span></div>
</div>
</section>
<script>
// ─────────────────────────────────────────────
// SECTION 4: CINEMATIC IMPACT GENERATOR
// ─────────────────────────────────────────────
(function(){
  const canvas=document.getElementById('impact-canvas');
  const ctx=canvas.getContext('2d');
  function resize(){canvas.width=canvas.parentElement.clientWidth;canvas.height=400;}
  resize();new ResizeObserver(resize).observe(canvas.parentElement);

  let lastT=0,elapsed=0;
  let playhead=-1; // -1 = stopped, 0..1 = playing
  let playing=false;
  let impType='explosion';
  let reverbOn=false;

  const subdLag=new LagFilter(0.5,0.2);
  const sharpLag=new LagFilter(0.7,0.2);
  const tailLag=new LagFilter(0.6,0.2);

  const TYPES={
    explosion:{subW:0.35,spikeH:1.0,tailL:0.45,color:'#f59e0b',color2:'#2563eb'},
    hit:       {subW:0.2, spikeH:0.85,tailL:0.3, color:'#60a5fa',color2:'#f59e0b'},
    whoosh:    {subW:0.4, spikeH:0.45,tailL:0.2, color:'#34d399',color2:'#60a5fa'},
    drone:     {subW:0.7, spikeH:0.3, tailL:0.55,color:'#a78bfa',color2:'#2563eb'},
    swell:     {subW:0.5, spikeH:0.55,tailL:0.5, color:'#60a5fa',color2:'#a78bfa'},
  };

  document.getElementById('imp-play').addEventListener('click',function(){
    if(!playing){playing=true;playhead=0;this.textContent='◼ Stop';}
    else{playing=false;playhead=-1;this.textContent='▶ Play';}
  });
  document.getElementById('imp-reverb').addEventListener('click',function(){
    reverbOn=!reverbOn;this.textContent=reverbOn?'ON':'OFF';
    this.classList.toggle('active',reverbOn);
  });
  document.querySelectorAll('[data-imptype]').forEach(btn=>{
    btn.addEventListener('click',()=>{
      impType=btn.dataset.imptype;
      document.querySelectorAll('[data-imptype]').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  ['imp-subd','imp-sharp','imp-tail'].forEach((id,i)=>{
    const el=document.getElementById(id);
    const lags=[subdLag,sharpLag,tailLag];
    const labels=[['imp-subd-v',v=>(0.5+v*0.025).toFixed(1)+'s'],
                  ['imp-sharp-v',v=>v],['imp-tail-v',v=>(0.2+v*0.018).toFixed(1)+'s']];
    el.addEventListener('input',()=>{
      lags[i].set(+el.value/100);
      document.getElementById(labels[i][0]).textContent=labels[i][1](+el.value);
    });
  });

  function buildWaveform(W, type, subd, sharp, tail, rev){
    const T=TYPES[type];
    const pts=[];
    const subEnd=Math.floor(W*(T.subW*0.5+subd*0.3));
    const spikeX=Math.floor(subEnd+W*0.05);
    const tailEnd=Math.floor(spikeX+W*(T.tailL*0.4+tail*0.2));
    for(let i=0;i<W;i++){
      let y=0;
      if(i<subEnd){
        const nx=i/subEnd;
        y=Math.sin(nx*Math.PI)*nx*T.subW*(1+subd*0.5);
        if(type==='drone') y+=Math.sin(nx*Math.PI*8)*0.1;
        if(type==='swell') y=Math.pow(nx,0.5)*T.subW*0.8;
      } else if(i<=spikeX){
        const nx=(i-subEnd)/(spikeX-subEnd+1);
        y=T.spikeH*(1-nx)*sharp*1.5;
        if(type==='whoosh') y*=Math.sin(nx*Math.PI);
      } else if(i<=tailEnd){
        const nx=(i-spikeX)/(tailEnd-spikeX+1);
        y=T.spikeH*Math.exp(-nx*(5+sharp*3))*tail;
        if(rev) y+=T.spikeH*Math.exp(-nx*1.5)*0.3*Math.sin(nx*Math.PI*6)*tail;
        if(type==='drone') y*=(1+Math.sin(nx*Math.PI*12)*0.2);
      }
      pts.push(Math.min(1,Math.abs(y)));
    }
    return pts;
  }

  function draw(ts){
    const t=ts*0.001,dt=Math.min(t-lastT,0.05);lastT=t;elapsed+=dt;
    [subdLag,sharpLag,tailLag].forEach(l=>l.update(dt));
    const W=canvas.width,H=canvas.height;

    ctx.fillStyle='rgba(2,4,8,0.08)';ctx.fillRect(0,0,W,H);

    const T=TYPES[impType];
    const pts=buildWaveform(W,impType,subdLag.value,sharpLag.value,tailLag.value,reverbOn);
    const cy=H*0.5;

    // Draw waveform (top+bottom mirrored)
    ctx.beginPath();
    pts.forEach((y,i)=>{
      const py=cy-y*H*0.42;
      i===0?ctx.moveTo(i,py):ctx.lineTo(i,py);
    });
    ctx.strokeStyle=T.color;ctx.shadowBlur=12;ctx.shadowColor=T.color;
    ctx.lineWidth=2;ctx.stroke();ctx.shadowBlur=0;
    ctx.beginPath();
    pts.forEach((y,i)=>{
      const py=cy+y*H*0.42;
      i===0?ctx.moveTo(i,py):ctx.lineTo(i,py);
    });
    ctx.strokeStyle=T.color2;ctx.shadowBlur=8;ctx.shadowColor=T.color2;
    ctx.lineWidth=1.2;ctx.stroke();ctx.shadowBlur=0;

    // Center zero line
    ctx.strokeStyle='rgba(59,130,246,0.15)';ctx.lineWidth=0.5;
    ctx.beginPath();ctx.moveTo(0,cy);ctx.lineTo(W,cy);ctx.stroke();

    // Playhead
    if(playing){
      playhead+=dt*0.3;
      if(playhead>1){playing=false;playhead=-1;document.getElementById('imp-play').textContent='▶ Play';}
    }
    if(playhead>=0){
      const px=playhead*W;
      ctx.strokeStyle='rgba(245,158,11,0.9)';ctx.shadowBlur=16;ctx.shadowColor='#f59e0b';
      ctx.lineWidth=2;ctx.beginPath();ctx.moveTo(px,0);ctx.lineTo(px,H);ctx.stroke();ctx.shadowBlur=0;
      // Amplitude indicator at playhead
      const amp=pts[Math.floor(px)]||0;
      ctx.fillStyle='rgba(245,158,11,0.7)';ctx.beginPath();
      ctx.arc(px,cy-amp*H*0.42,5,0,Math.PI*2);ctx.fill();
    }

    // Section labels
    ctx.fillStyle='rgba(96,165,250,0.5)';ctx.font='10px Segoe UI';
    ctx.fillText('SUB RUMBLE',8,H*0.08);
    ctx.fillText('IMPACT',W*0.38,H*0.08);
    ctx.fillText('DECAY TAIL',W*0.58,H*0.08);

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();

// ─────────────────────────────────────────────
// SECTION 5: ENVIRONMENTAL TEXTURES
// ─────────────────────────────────────────────
(function(){
  const canvas=document.getElementById('env-canvas');
  const ctx=canvas.getContext('2d');
  function resize(){canvas.width=canvas.parentElement.clientWidth;canvas.height=350;}
  resize();new ResizeObserver(resize).observe(canvas.parentElement);

  let lastT=0,elapsed=0;
  let envMode='ocean';

  const densityLag=new LagFilter(0.4,0.3);
  const intensityLag=new LagFilter(0.6,0.3);
  const weatherLag=new LagFilter(0,0.4);

  // Per-environment LagFilters for smooth morphing
  const ENV_PARAMS={
    ocean:  {freqLag:new LagFilter(0.3,1.5), ampLag:new LagFilter(0.7,1.5), speedLag:new LagFilter(0.08,1.5), noiseLag:new LagFilter(0.05,1.5)},
    forest: {freqLag:new LagFilter(2.0,1.5), ampLag:new LagFilter(0.3,1.5), speedLag:new LagFilter(0.4,1.5),  noiseLag:new LagFilter(0.6,1.5)},
    urban:  {freqLag:new LagFilter(1.2,1.5), ampLag:new LagFilter(0.5,1.5), speedLag:new LagFilter(0.25,1.5), noiseLag:new LagFilter(0.4,1.5)},
    cave:   {freqLag:new LagFilter(0.5,1.5), ampLag:new LagFilter(0.4,1.5), speedLag:new LagFilter(0.12,1.5), noiseLag:new LagFilter(0.15,1.5)},
  };
  const ENV_TARGETS={
    ocean:  {freq:0.3,amp:0.7,speed:0.08,noise:0.05},
    forest: {freq:2.0,amp:0.3,speed:0.4, noise:0.6},
    urban:  {freq:1.2,amp:0.5,speed:0.25,noise:0.4},
    cave:   {freq:0.5,amp:0.4,speed:0.12,noise:0.15},
  };
  const ENV_COLORS={ocean:'#2563eb',forest:'#34d399',urban:'#f59e0b',cave:'#a78bfa'};
  const ENV_CAPTIONS={
    ocean:'Deep Ocean — slow rolling waves, deep undulation',
    forest:'Forest — irregular high-freq bursts over steady base',
    urban:'Urban Street — rhythmic patterns, random events',
    cave:'Cave/Tunnel — sparse low events, long decay tails'
  };

  // Current blended params
  const freq=new LagFilter(0.3,0.8),amp=new LagFilter(0.7,0.8);
  const speed=new LagFilter(0.08,0.8),noise=new LagFilter(0.05,0.8);
  const colorR=new LagFilter(37,0.8),colorG=new LagFilter(99,0.8),colorB=new LagFilter(235,0.8);
  function hexToRgb(h){const n=parseInt(h.slice(1),16);return[n>>16&255,(n>>8)&255,n&255];}

  document.querySelectorAll('[data-env]').forEach(btn=>{
    btn.addEventListener('click',()=>{
      envMode=btn.dataset.env;
      document.querySelectorAll('[data-env]').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      const t=ENV_TARGETS[envMode];
      freq.set(t.freq);amp.set(t.amp);speed.set(t.speed);noise.set(t.noise);
      const [r,g,b]=hexToRgb(ENV_COLORS[envMode]);colorR.set(r);colorG.set(g);colorB.set(b);
      document.getElementById('env-caption').textContent=ENV_CAPTIONS[envMode];
    });
  });
  document.getElementById('env-density').addEventListener('input',function(){
    densityLag.set(+this.value/100);document.getElementById('env-density-v').textContent=this.value;
  });
  document.getElementById('env-intensity').addEventListener('input',function(){
    intensityLag.set(+this.value/100);document.getElementById('env-intensity-v').textContent=this.value;
  });
  document.getElementById('env-weather').addEventListener('input',function(){
    weatherLag.set(+this.value/100);document.getElementById('env-weather-v').textContent=this.value;
  });

  // Layers for the 2D waveform field
  const LAYERS=5;

  function draw(ts){
    const t=ts*0.001,dt=Math.min(t-lastT,0.05);lastT=t;elapsed+=dt;
    [freq,amp,speed,noise,densityLag,intensityLag,weatherLag,colorR,colorG,colorB].forEach(l=>l.update(dt));

    const W=canvas.width,H=canvas.height;
    ctx.fillStyle='rgba(2,4,8,0.07)';ctx.fillRect(0,0,W,H);

    const cr=Math.round(colorR.value),cg=Math.round(colorG.value),cb=Math.round(colorB.value);
    const intens=intensityLag.value,dens=densityLag.value,wx=weatherLag.value;

    for(let li=0;li<LAYERS;li++){
      const layerPhase=li*(Math.PI*2/LAYERS);
      const layerFreq=freq.value*(0.6+li*0.3)*(1+dens*0.5);
      const layerAmp=amp.value*(1-li*0.12)*intens;
      const layerSpeed=speed.value*(1+li*0.4);
      const alpha=0.8-li*0.12;

      ctx.beginPath();
      const cy=H*(0.2+li*(0.6/LAYERS));
      for(let i=0;i<=W;i++){
        const nx=i/W;
        let y=Math.sin(nx*Math.PI*2*layerFreq+layerPhase+elapsed*layerSpeed)*layerAmp*H*0.1;
        y+=Math.sin(nx*Math.PI*4*layerFreq*1.3+elapsed*layerSpeed*0.7)*layerAmp*H*0.04;
        // Noise component (weather / environment specific)
        if(noise.value>0.1||wx>0){
          const noiseAmt=(noise.value+wx*0.4)*H*0.06;
          y+=Math.sin(nx*100+elapsed*3.7+li)*noiseAmt*(Math.random()*0.3+0.7);
        }
        // Cave: add echo/decay events
        if(envMode==='cave'&&Math.sin(nx*Math.PI*1.5+elapsed*0.2+li)>0.85){
          y+=Math.exp(-((nx*Math.PI*1.5+elapsed*0.2+li)%Math.PI)*2)*H*0.08;
        }
        const py=cy+y;
        i===0?ctx.moveTo(i,py):ctx.lineTo(i,py);
      }
      ctx.strokeStyle=`rgba(${cr},${cg},${cb},${alpha*0.8})`;
      ctx.shadowBlur=li===0?14:6;ctx.shadowColor=`rgba(${cr},${cg},${cb},0.5)`;
      ctx.lineWidth=li===0?1.8:1;ctx.stroke();ctx.shadowBlur=0;
    }

    // Weather noise overlay
    if(wx>0.05){
      for(let i=0;i<W;i+=Math.max(1,Math.floor(3/wx))){
        if(Math.random()<wx*0.3){
          const y=Math.random()*H;
          ctx.strokeStyle=`rgba(${cr},${cg},${cb},${wx*0.4})`;
          ctx.lineWidth=0.5;ctx.beginPath();
          ctx.moveTo(i,y);ctx.lineTo(i+1,y+Math.random()*4-2);ctx.stroke();
        }
      }
    }

    // Environment label
    ctx.fillStyle=`rgba(${cr},${cg},${cb},0.7)`;ctx.font='bold 11px Segoe UI';
    ctx.fillText(envMode.toUpperCase(),12,24);

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();
</script>
<!-- SECTION 6: PROCEDURAL SOUND DESIGN -->
