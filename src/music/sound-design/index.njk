<script>
// ─────────────────────────────────────────────
// SECTION 6: PROCEDURAL SOUND RECIPE BUILDER
// ─────────────────────────────────────────────
(function(){
  const TEXTURES=['Noise:White','Noise:Pink','Noise:Brown','Tone:Sine','Tone:Saw','Tone:Square','Grain:Sparse','Grain:Dense'];
  const PROCESSES=['Filter','Compress','Reverb','Pitch↑','Pitch↓','Distort','Fade','Delay'];
  const PRESETS={
    'Sci-Fi Laser':['Tone:Sine','Pitch↑','Distort','Filter'],
    'Monster Roar':['Noise:Brown','Grain:Dense','Reverb','Compress','Filter'],
    'Spaceship':   ['Tone:Saw','Noise:Pink','Filter','Compress','Reverb'],
    'Rain':        ['Noise:White','Noise:Pink','Filter','Delay'],
    'Fire':        ['Noise:Brown','Grain:Sparse','Reverb','Distort'],
    'Digital Glitch':['Noise:White','Tone:Square','Distort','Pitch↑','Filter'],
  };

  let chain=[];
  const MAX=6;

  function buildPalette(containerId, items){
    const el=document.getElementById(containerId);
    items.forEach(item=>{
      const chip=document.createElement('div');
      chip.className='recipe-chip';chip.textContent=item;
      chip.addEventListener('click',()=>addToChain(item));
      el.appendChild(chip);
    });
  }
  buildPalette('palette-texture',TEXTURES);
  buildPalette('palette-process',PROCESSES);

  const presetsRow=document.getElementById('presets-row');
  Object.keys(PRESETS).forEach(name=>{
    const btn=document.createElement('button');
    btn.className='btn btn-sm';btn.textContent=name;
    btn.addEventListener('click',()=>{chain=PRESETS[name].slice();renderChain();});
    presetsRow.appendChild(btn);
  });

  function addToChain(item){
    if(chain.length>=MAX) return;
    chain.push(item);renderChain();
  }
  function removeFromChain(idx){chain.splice(idx,1);renderChain();}

  function renderChain(){
    const chainEl=document.getElementById('recipe-chain');
    chainEl.innerHTML='';
    if(chain.length===0){
      chainEl.innerHTML='<span style="font-size:0.75rem;color:var(--dim);padding:0.3rem;">Click ingredients to build your chain…</span>';
    } else {
      chain.forEach((item,i)=>{
        const node=document.createElement('div');node.className='recipe-node';
        node.innerHTML=`${item} <span class="remove" data-i="${i}">✕</span>`;
        node.querySelector('.remove').addEventListener('click',()=>removeFromChain(i));
        chainEl.appendChild(node);
        if(i<chain.length-1){
          const arr=document.createElement('span');
          arr.style.cssText='color:var(--dim);font-size:0.8rem;';arr.textContent='→';
          chainEl.appendChild(arr);
        }
      });
    }
    document.getElementById('proc-notation').textContent=chain.length>0?chain.join(' → '):'(empty chain)';
    document.getElementById('proc-caption').textContent=chain.length>0?
      `Chain: ${chain.join(' → ')} · waveform transforms shown below`:'Signal chain waveform — build a recipe to see it evolve';
  }
  document.getElementById('proc-clear').addEventListener('click',()=>{chain=[];renderChain();});

  // Canvas
  const canvas=document.getElementById('proc-canvas');
  const ctx=canvas.getContext('2d');
  function resize(){canvas.width=canvas.parentElement.clientWidth;canvas.height=350;}
  resize();new ResizeObserver(resize).observe(canvas.parentElement);
  let lastT=0,elapsed=0;

  function applyProcess(pts,proc,t){
    return pts.map((y,i)=>{
      const nx=i/pts.length;
      switch(proc){
        case 'Filter':  return y*(0.3+Math.pow(1-nx,0.5)*0.7);
        case 'Compress':return Math.sign(y)*Math.pow(Math.abs(y),0.5)*0.8;
        case 'Reverb':  return y+pts[Math.max(0,i-Math.floor(pts.length*0.1))]*0.4;
        case 'Pitch↑':  return pts[Math.min(pts.length-1,Math.floor(i*1.5))]||y;
        case 'Pitch↓':  return pts[Math.floor(i*0.6)]||y;
        case 'Distort': return Math.tanh(y*4)*0.8;
        case 'Fade':    return y*(1-nx);
        case 'Delay':   return y*0.7+(pts[Math.max(0,i-Math.floor(pts.length*0.15))]||0)*0.5;
        default:        return y;
      }
    });
  }

  function genSource(type,W,t){
    const pts=[];
    for(let i=0;i<W;i++){
      const nx=i/W;let y=0;
      if(type.includes('Sine'))    y=Math.sin(nx*Math.PI*8+t*0.5);
      else if(type.includes('Saw')) y=(nx*6+t*0.3)%2-1;
      else if(type.includes('Square')) y=Math.sign(Math.sin(nx*Math.PI*8+t*0.5));
      else if(type.includes('White'))  y=(Math.random()*2-1);
      else if(type.includes('Pink'))   y=(Math.random()*2-1)*(1-nx*0.5);
      else if(type.includes('Brown'))  y=Math.sin(nx*Math.PI*2+t*0.1)*(1+Math.random()*0.3);
      else if(type.includes('Sparse')) y=Math.random()<0.03?Math.random()*2-1:0;
      else if(type.includes('Dense'))  y=Math.random()<0.2?Math.random()*2-1:0;
      pts.push(y);
    }
    return pts;
  }

  function draw(ts){
    const t=ts*0.001,dt=Math.min(t-lastT,0.05);lastT=t;elapsed+=dt;
    const W=canvas.width,H=canvas.height;
    ctx.fillStyle='rgba(2,4,8,0.09)';ctx.fillRect(0,0,W,H);

    if(chain.length===0){
      // idle: multi-layer ambient
      const cy=H*0.5;
      for(let li=0;li<4;li++){
        ctx.beginPath();
        for(let i=0;i<=W;i++){
          const nx=i/W;
          const y=cy+Math.sin(nx*Math.PI*(1+li*0.7)+elapsed*(0.1+li*0.08))*H*(0.05+li*0.03);
          i===0?ctx.moveTo(i,y):ctx.lineTo(i,y);
        }
        ctx.strokeStyle=`rgba(37,99,235,${0.5-li*0.1})`;ctx.lineWidth=1;ctx.stroke();
      }
      return requestAnimationFrame(draw);
    }

    // Find first source
    const sourceIdx=chain.findIndex(c=>!PROCESSES.includes(c));
    if(sourceIdx<0) return requestAnimationFrame(draw);

    let pts=genSource(chain[sourceIdx],W,elapsed);
    const colors=['#2563eb','#60a5fa','#f59e0b','#34d399','#a78bfa','#f87171'];

    // Draw stages
    const stageH=Math.floor(H/(chain.length+1));
    chain.forEach((step,si)=>{
      if(si>sourceIdx) pts=applyProcess(pts,step,elapsed);
      const cy=(si+0.5)*stageH+stageH*0.2;
      ctx.beginPath();
      pts.forEach((y,i)=>{
        const px=i;const py=cy+y*stageH*0.35;
        i===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
      });
      ctx.strokeStyle=colors[si%colors.length];
      ctx.shadowBlur=6;ctx.shadowColor=colors[si%colors.length];
      ctx.lineWidth=1.3;ctx.stroke();ctx.shadowBlur=0;
      ctx.fillStyle=colors[si%colors.length];ctx.font='10px Segoe UI';
      ctx.fillText(step,6,cy-stageH*0.38);
    });

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
  renderChain();
})();

// ─────────────────────────────────────────────
// SECTION 7: REACTIVE VISUALIZATION
// ─────────────────────────────────────────────
(function(){
  const canvas=document.getElementById('react-canvas');
  const ctx=canvas.getContext('2d');
  function resize(){canvas.width=canvas.parentElement.clientWidth;canvas.height=400;}
  resize();new ResizeObserver(resize).observe(canvas.parentElement);

  let lastT=0,elapsed=0,bpm=110,genre='ambient';
  const bassLag=new LagFilter(0,0.1),subLag=new LagFilter(0,0.15);
  const midLag=new LagFilter(0,0.08),highLag=new LagFilter(0,0.06);
  const bgColorLag=new LagFilter(0,0.2);
  const wobbleLag=new LagFilter(0,0.08);
  const ringLag=new LagFilter(0,0.1);
  const scanLag=new LagFilter(0,0.05);

  const GENRE_PROFILES={
    ambient:     {bassBase:0.2,subBase:0.15,midBase:0.25,highBase:0.1, beatStrength:0.3},
    cinematic:   {bassBase:0.5,subBase:0.4, midBase:0.4, highBase:0.3, beatStrength:0.7},
    experimental:{bassBase:0.3,subBase:0.2, midBase:0.5, highBase:0.6, beatStrength:0.5},
    industrial:  {bassBase:0.7,subBase:0.6, midBase:0.45,highBase:0.55,beatStrength:0.9},
  };

  document.getElementById('react-bpm').addEventListener('input',function(){
    bpm=+this.value;document.getElementById('react-bpm-v').textContent=bpm;
  });
  document.querySelectorAll('[data-genre]').forEach(btn=>{
    btn.addEventListener('click',()=>{
      genre=btn.dataset.genre;
      document.querySelectorAll('[data-genre]').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  // Particles
  const NPARTICLES=60;
  const particles=Array.from({length:NPARTICLES},()=>({
    angle:Math.random()*Math.PI*2,speed:0.01+Math.random()*0.02,r:0,size:2
  }));

  function simulate(t,dt){
    const beatSec=60/bpm;
    const beatPhase=(t%beatSec)/beatSec;
    const G=GENRE_PROFILES[genre];
    const beat=Math.pow(Math.max(0,Math.sin(beatPhase*Math.PI)),2)*G.beatStrength;
    const slowBeat=Math.pow(Math.max(0,Math.sin(beatPhase*Math.PI*0.5)),2)*G.beatStrength;

    bassLag.set(G.bassBase+beat*0.5+Math.sin(t*1.3)*0.1*G.bassBase);
    subLag.set(G.subBase+slowBeat*0.4+Math.sin(t*0.6)*0.1*G.subBase);
    midLag.set(G.midBase+Math.sin(t*2.1)*0.15*G.midBase+beat*0.2);
    highLag.set(G.highBase+Math.abs(Math.sin(t*4.7+Math.random()*0.2))*0.2+beat*0.1);
    [bassLag,subLag,midLag,highLag].forEach(l=>l.update(dt));
    bgColorLag.set(bassLag.value);bgColorLag.update(dt);
    wobbleLag.set(subLag.value);wobbleLag.update(dt);
    ringLag.set(midLag.value);ringLag.update(dt);
    scanLag.set(highLag.value);scanLag.update(dt);
  }

  function draw(ts){
    const t=ts*0.001,dt=Math.min(t-lastT,0.05);lastT=t;elapsed+=dt;
    simulate(elapsed,dt);
    const W=canvas.width,H=canvas.height;

    // Layer 1: Bass → bg color pulse (blue throb)
    const bgAlpha=0.06+bassLag.value*0.08;
    ctx.fillStyle=`rgba(2,4,8,${1-bgAlpha})`;ctx.fillRect(0,0,W,H);
    ctx.fillStyle=`rgba(37,99,235,${bgColorLag.value*0.15})`;ctx.fillRect(0,0,W,H);

    // Layer 2: Sub-bass → canvas wobble effect (horizontal wave distortion)
    const wobble=wobbleLag.value;
    if(wobble>0.05){
      ctx.strokeStyle=`rgba(124,58,237,${wobble*0.3})`;ctx.lineWidth=2;
      for(let y=0;y<H;y+=20){
        ctx.beginPath();
        ctx.moveTo(0,y+Math.sin(y*0.1+elapsed*2)*wobble*6);
        ctx.lineTo(W,y+Math.sin(y*0.1+elapsed*2+Math.PI)*wobble*6);
        ctx.stroke();
      }
    }

    // Layer 3: Mid → particle ring
    const cx=W*0.5,cy=H*0.5;
    const ringR=80+ringLag.value*120;
    particles.forEach((p,i)=>{
      p.angle+=p.speed*(1+ringLag.value*2)*dt;
      p.r=ringR+(Math.sin(p.angle*3+elapsed)*20*ringLag.value);
      p.size=2+ringLag.value*4;
      const px=cx+Math.cos(p.angle)*p.r+(Math.sin(elapsed*2+i)*wobbleLag.value*15);
      const py=cy+Math.sin(p.angle)*p.r*(0.5+subLag.value*0.3);
      ctx.beginPath();ctx.arc(px,py,p.size,0,Math.PI*2);
      ctx.fillStyle=`rgba(96,165,250,${0.3+ringLag.value*0.5})`;
      ctx.shadowBlur=8;ctx.shadowColor='#60a5fa';ctx.fill();ctx.shadowBlur=0;
    });

    // Ring outline
    ctx.beginPath();ctx.ellipse(cx,cy,ringR,ringR*(0.5+subLag.value*0.3),0,0,Math.PI*2);
    ctx.strokeStyle=`rgba(37,99,235,${0.2+bassLag.value*0.4})`;
    ctx.shadowBlur=bassLag.value*20;ctx.shadowColor='#2563eb';
    ctx.lineWidth=1;ctx.stroke();ctx.shadowBlur=0;

    // Layer 4: High → edge scanline intensity
    const scanInt=scanLag.value;
    if(scanInt>0.05){
      for(let y=0;y<H;y+=2){
        ctx.fillStyle=`rgba(245,158,11,${scanInt*0.06})`;
        ctx.fillRect(0,y,W,1);
        ctx.fillRect(0,y,Math.floor(scanInt*30),1);
        ctx.fillRect(W-Math.floor(scanInt*30),y,Math.floor(scanInt*30),1);
      }
    }

    // Update layer bars
    document.getElementById('lbar-bass').style.width=(bassLag.value*100)+'%';
    document.getElementById('lbar-sub').style.width=(subLag.value*100)+'%';
    document.getElementById('lbar-mid').style.width=(midLag.value*100)+'%';
    document.getElementById('lbar-high').style.width=(highLag.value*100)+'%';

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();
</script>
<!-- SECTION 8: ARTISTS -->
<section id="artists">
<div class="section-label">Section 08</div>
<h2 class="hidden stagger-1">Masters of the Craft</h2>
<p class="hidden stagger-2">Eight sound designers whose work defines cinema's invisible architecture — from Skywalker Sound to the editing rooms of David Fincher.</p>
<div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(240px,1fr));">
<div class="artist-card hidden stagger-1">
<div class="artist-name">Ben Burtt</div>
<div class="artist-film">Star Wars · WALL-E · Indiana Jones</div>
<div class="artist-tech">Field recording + synthesis fusion. Lightsaber from film projector motor + CRT TV interference. R2-D2 from baby vocals processed through hardware synthesizers.</div>
<div class="artist-oscar">Academy Award winner — Star Wars (1978), E.T. (1983)</div>
<div><span class="artist-tag">Recording + Synthesis</span></div>
</div>
<div class="artist-card hidden stagger-2">
<div class="artist-name">Walter Murch</div>
<div class="artist-film">Apocalypse Now · The Godfather · THX 1138</div>
<div class="artist-tech">Inventor of the "sound designer" title. Pioneered worldizing — re-recording sounds in real spaces to embed natural acoustic environments. Sound as expression of inner psychological states.</div>
<div class="artist-oscar">Academy Award winner — Apocalypse Now (1980)</div>
<div><span class="artist-tag">Worldizing · Theoretical</span></div>
</div>
<div class="artist-card hidden stagger-3">
<div class="artist-name">Gary Rydstrom</div>
<div class="artist-film">Jurassic Park · Saving Private Ryan · Terminator 2</div>
<div class="artist-tech">Transformation of natural recordings into impossible creatures. T-Rex roar built from elephant, tiger, crocodile, and whale sounds. Raptor vocals from baby voices + crocodile hiss.</div>
<div class="artist-oscar">7× Academy Award winner</div>
<div><span class="artist-tag">Transformation · Layering</span></div>
</div>
<div class="artist-card hidden stagger-4">
<div class="artist-name">Randy Thom</div>
<div class="artist-film">Cast Away · The Right Stuff · Forrest Gump</div>
<div class="artist-tech">Theorist and practitioner at Skywalker Sound. Argues sound design must begin at the screenplay stage. His essays on "designing a movie for sound" changed how the industry thinks about audio integration.</div>
<div class="artist-oscar">Academy Award winner · Skywalker Sound veteran</div>
<div><span class="artist-tag">Theory · Integration</span></div>
</div>
<div class="artist-card hidden stagger-1">
<div class="artist-name">Skywalker Sound</div>
<div class="artist-film">Industrial Light &amp; Sound · Marin County, CA</div>
<div class="artist-tech">George Lucas's post-production facility. The institutional center of American cinematic sound design since 1975. Home to Burtt, Rydstrom, Thom, and a generation of sound designers who defined the craft.</div>
<div class="artist-oscar">Dozens of Academy Awards collectively</div>
<div><span class="artist-tag">Institution · Legacy</span></div>
</div>
<div class="artist-card hidden stagger-2">
<div class="artist-name">Ren Klyce</div>
<div class="artist-film">Se7en · Fight Club · The Social Network · Gone Girl</div>
<div class="artist-tech">David Fincher's long-term collaborator. Synthesis as behavioral and psychological architecture. Sound design as a tool for building dread, unease, and tension beneath the surface of image.</div>
<div class="artist-oscar">Multiple BAFTA and Guild nominations</div>
<div><span class="artist-tag">Psychological · Synthesis</span></div>
</div>
<div class="artist-card hidden stagger-3">
<div class="artist-name">Frank Serafine</div>
<div class="artist-film">Tron · Star Trek: The Motion Picture · The Hunt for Red October</div>
<div class="artist-tech">Pioneer of electronic synthesis in film sound. Created the electronic soundscape of Tron (1982) using early synthesizers at a time when electronic sound in film was virtually unexplored.</div>
<div class="artist-oscar">Emmy Award winner · Electronic synthesis pioneer</div>
<div><span class="artist-tag">Electronic · Synthesis Pioneer</span></div>
</div>
<div class="artist-card hidden stagger-4">
<div class="artist-name">Richard King</div>
<div class="artist-film">The Dark Knight · Inception · Dunkirk · Interstellar</div>
<div class="artist-tech">Christopher Nolan's primary sound collaborator. Builds immersive practical sound environments using real objects rather than synthesis. Dunkirk's sound design notoriously avoided digital processing.</div>
<div class="artist-oscar">Academy Award winner — The Dark Knight (2009), Inception (2011)</div>
<div><span class="artist-tag">Practical · Immersive</span></div>
</div>
</div>
</section>
<!-- SECTION 9: GLOSSARY -->
<section id="glossary">
<div class="section-label">Section 09</div>
<h2 class="hidden stagger-1">Glossary</h2>
<p class="hidden stagger-2">22 essential terms spanning Foley, synthesis, signal processing, and the psychoacoustics of cinematic sound.</p>
<div class="glossary-grid hidden stagger-3">
<div class="term">
<div class="term-word">ADR</div>
<div class="term-def">Automated Dialogue Replacement. Re-recording dialogue in a studio to replace unusable production sound. Also called "looping." The post-production process of restoring or improving recorded speech to match picture.</div>
</div>
<div class="term">
<div class="term-word">Additive Synthesis</div>
<div class="term-def">Building complex timbres by summing sine waves at controlled frequencies and amplitudes. Theoretically any sound can be reproduced as a sum of sinusoids. The Hammond organ is the analog example; FM synthesis is a computational shortcut.</div>
</div>
<div class="term">
<div class="term-word">Ambience</div>
<div class="term-def">The continuous background sound of a scene or environment — crowd noise, wind, mechanical hum, room tone. Distinct from Foley and dialogue, ambience provides the acoustic world that contains all other sounds.</div>
</div>
<div class="term">
<div class="term-word">Atmos (Dolby)</div>
<div class="term-def">Dolby's object-based spatial audio format. Places sounds as 3D objects in space rather than channels, enabling reproduction at any speaker count. The standard for theatrical and streaming immersive audio since 2012.</div>
</div>
<div class="term">
<div class="term-word">Bus</div>
<div class="term-def">A shared signal routing path that combines multiple audio signals into a single output. In mixing, buses allow groups of sounds (all dialogue, all Foley) to be processed together. Essential in film mixing for stem management.</div>
</div>
<div class="term">
<div class="term-word">Convolution</div>
<div class="term-def">Applying the acoustic "fingerprint" (impulse response) of one space or object to another signal. A convolution reverb places any sound inside a real captured space. Also used for cabinet simulation and creative spectral processing.</div>
</div>
<div class="term">
<div class="term-word">Delay</div>
<div class="term-def">A time-based effect that produces one or more echoes of a signal. In sound design, delay creates space, depth, and rhythmic interest. Short delays (1–30ms) create thickening and widening; longer delays create distinct echoes.</div>
</div>
<div class="term">
<div class="term-word">Envelope (ADSR)</div>
<div class="term-def">A time-varying control signal with four stages: Attack (rise to peak), Decay (fall to sustain), Sustain (held level), Release (fade to silence). ADSR shapes amplitude, filter, or any parameter over the lifetime of a note or event.</div>
</div>
<div class="term">
<div class="term-word">Filter</div>
<div class="term-def">A processor that attenuates specific frequency ranges. Low-pass filters remove high frequencies; high-pass remove lows; band-pass isolate a frequency band. The foundational tool of subtractive synthesis and spectral shaping.</div>
</div>
<div class="term">
<div class="term-word">FM Synthesis</div>
<div class="term-def">Frequency Modulation synthesis. One oscillator (the modulator) modulates the frequency of another (the carrier). At high modulation depths, complex non-harmonic spectra emerge — producing metallic, bell, and percussive timbres. Yamaha DX7 is canonical.</div>
</div>
<div class="term">
<div class="term-word">Foley</div>
<div class="term-def">Recording and creating sound effects in synchrony with picture, named after Jack Foley. Includes footsteps, clothing movement, and prop handling. Performance-based, recorded to picture in a Foley stage. Distinct from field recording and synthesis.</div>
</div>
<div class="term">
<div class="term-word">Impulse Response</div>
<div class="term-def">The acoustic fingerprint of a space — recorded by playing a sine sweep or impulse and capturing the result. Used in convolution reverb to place sounds inside real spaces. Field recordists capture IRs to preserve locations acoustically.</div>
</div>
<div class="term">
<div class="term-word">Noise Floor</div>
<div class="term-def">The level of inherent electronic or environmental noise in a recording system. A lower noise floor allows quiet sounds to be captured without artifacts. Determined by microphone self-noise and preamp noise — critical specifications for field recording.</div>
</div>
<div class="term">
<div class="term-word">Oscillator</div>
<div class="term-def">The primary sound source in most synthesizers. Produces continuous periodic waveforms — sine, sawtooth, square, triangle, noise — whose fundamental frequency determines pitch. Voltage-controlled oscillators (VCO) form the basis of analog synthesis.</div>
</div>
<div class="term">
<div class="term-word">Reverb</div>
<div class="term-def">The persistence of sound in a space after the source stops — the sum of all reflections. Reverb places sounds in acoustic environments and is fundamental to cinematic sound design. Convolution reverb uses real measured spaces.</div>
</div>
<div class="term">
<div class="term-word">Sampling</div>
<div class="term-def">Recording a real sound and playing it back at different pitches and timings. The bridge between field recording and synthesis. Modern sample libraries combine thousands of recordings to recreate acoustic instruments and environments with synthesis control.</div>
</div>
<div class="term">
<div class="term-word">Sound Design</div>
<div class="term-def">The craft of creating, recording, and manipulating audio to serve a narrative, interactive, or aesthetic purpose. In film, sound design encompasses all non-musical sound — effects, ambience, Foley — and their integration with the image.</div>
</div>
<div class="term">
<div class="term-word">Stems</div>
<div class="term-def">Separate mixed tracks for each major element of a film's audio — dialogue stem, music stem, effects stem. Stems allow re-mixing for different formats (theatrical vs. streaming), languages, and territories without rebuilding the entire mix.</div>
</div>
<div class="term">
<div class="term-word">Subtractive Synthesis</div>
<div class="term-def">Starting with a harmonically rich waveform (sawtooth, pulse) and using filters to subtract frequencies. The dominant synthesis paradigm — Moog, Prophet-5, 303. Filter cutoff sweeps are its signature gesture.</div>
</div>
<div class="term">
<div class="term-word">Synthesis</div>
<div class="term-def">The electronic generation of sound from mathematical principles rather than physical acoustic sources. Encompasses subtractive, additive, FM, granular, physical modeling, and spectral methods. The core technology of sound design beyond recording.</div>
</div>
<div class="term">
<div class="term-word">Transient</div>
<div class="term-def">The initial high-energy, non-periodic portion of a sound — the attack before steady-state sustain begins. Transients carry sonic identity: we recognize instruments primarily by transient shape. Transient preservation or removal is a primary sound design tool.</div>
</div>
<div class="term">
<div class="term-word">Waveform</div>
<div class="term-def">The visual representation of a sound as amplitude over time. The shape of a waveform determines its harmonic content — sine is pure, sawtooth is rich in harmonics, noise is aperiodic. Reading waveforms is the fundamental literacy of sound design.</div>
</div>
</div>
</section>
