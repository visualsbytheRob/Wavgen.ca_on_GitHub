<script>
// ─────────────────────────────────────────────
// SHARED LagFilter (reused across all sections)
// ─────────────────────────────────────────────
class LagFilter {
  constructor(v=0,tau=0.15){this.value=v;this.target=v;this.tau=tau;}
  set(t){this.target=t;}
  update(dt){const a=1-Math.exp(-dt/Math.max(this.tau,0.001));this.value+=(this.target-this.value)*a;return this.value;}
  snap(v){this.value=this.target=v;}
}

// ─────────────────────────────────────────────
// SECTION 2: FOLEY LAB
// ─────────────────────────────────────────────
(function(){
  const canvas = document.getElementById('foley-canvas');
  const ctx    = canvas.getContext('2d');
  function resize(){canvas.width=canvas.parentElement.clientWidth;canvas.height=420;}
  resize(); new ResizeObserver(resize).observe(canvas.parentElement);

  let bpm=80, bpmLag=new LagFilter(80,0.5);
  let vols=[0.8,0.55,0.65,0.4].map(v=>new LagFilter(v,0.12));
  let muted=[false,false,false,false];
  let burstTimer=0;
  let recTrack=-1;
  let lastT=0, elapsed=0;

  // Wire sliders
  ['fvol0','fvol1','fvol2','fvol3'].forEach((id,i)=>{
    const el=document.getElementById(id);
    el.addEventListener('input',()=>{
      vols[i].set(+el.value/100);
      document.getElementById(id+'v').textContent=el.value;
    });
  });
  ['fmute0','fmute1','fmute2','fmute3'].forEach((id,i)=>{
    document.getElementById(id).addEventListener('click',function(){
      muted[i]=!muted[i];
      this.classList.toggle('active',muted[i]);
    });
  });
  const bpmEl=document.getElementById('foley-bpm');
  bpmEl.addEventListener('input',()=>{bpm=+bpmEl.value;document.getElementById('foley-bpm-val').textContent=bpm;});
  document.getElementById('foley-rec').addEventListener('click',()=>{burstTimer=0.4;recTrack=Math.floor(Math.random()*4);});

  const TRACK_COLORS=['#2563eb','#60a5fa','#f59e0b','#34d399'];
  const TRACK_NAMES=['Footsteps','Cloth','Contact','Atmosphere'];

  function genTrackWave(track, W, t, bpmNow, vol, burst){
    const pts=[];
    const beatSec=60/bpmNow;
    for(let i=0;i<W;i++){
      const x=i/W; // 0..1 across time window (2 seconds)
      const tOff=x*2;
      let y=0;
      if(track===0){ // Footsteps: rhythmic low-freq bursts
        const beatPhase=(tOff % beatSec)/beatSec;
        const pulse=Math.exp(-beatPhase*8)*Math.sin(beatPhase*Math.PI*20);
        y=pulse*vol*(1+(burst>0&&recTrack===0?1.5:0));
      } else if(track===1){ // Cloth: high-freq noise bursts
        const noiseBase=Math.sin(tOff*47.3+t*2.1)*Math.sin(tOff*81.7+t*1.3);
        const env=0.3+0.7*Math.abs(Math.sin(tOff*1.8+t*0.5));
        y=noiseBase*env*vol*0.6;
      } else if(track===2){ // Contact: transient spikes
        const beatPhase2=((tOff+0.3) % (beatSec*1.5))/(beatSec*1.5);
        y=Math.exp(-beatPhase2*20)*(1+Math.sin(beatPhase2*30)*0.3)*vol*1.2;
      } else { // Atmosphere: continuous low-level
        y=(Math.sin(tOff*2.1+t*0.3)*0.5+Math.sin(tOff*0.7+t*0.1)*0.3)*vol*0.5;
      }
      pts.push(y);
    }
    return pts;
  }

  function drawTrack(ctx,W,H,yOff,trackH,pts,color,name,mute){
    const cy=yOff+trackH*0.5;
    // Track background
    ctx.fillStyle='rgba(6,12,18,0.6)';
    ctx.fillRect(0,yOff,W,trackH);
    // Label
    ctx.fillStyle=mute?'#2a3a4a':color;
    ctx.font='10px Segoe UI';
    ctx.fillText(name,8,yOff+14);
    if(!mute){
      ctx.beginPath();
      pts.forEach((y,i)=>{
        const px=i;
        const py=cy-y*trackH*0.42;
        i===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
      });
      ctx.strokeStyle=color;
      ctx.shadowBlur=8;ctx.shadowColor=color;
      ctx.lineWidth=1.2;ctx.stroke();ctx.shadowBlur=0;
    } else {
      ctx.strokeStyle='rgba(42,58,74,0.5)';
      ctx.beginPath();ctx.moveTo(0,cy);ctx.lineTo(W,cy);ctx.stroke();
    }
    // Border
    ctx.strokeStyle='rgba(59,130,246,0.12)';
    ctx.lineWidth=0.5;ctx.beginPath();ctx.rect(0,yOff,W,trackH);ctx.stroke();
  }

  function draw(ts){
    const t=ts*0.001;
    const dt=Math.min(t-lastT,0.05);lastT=t;elapsed+=dt;
    burstTimer=Math.max(0,burstTimer-dt);
    const W=canvas.width,H=canvas.height;
    bpmLag.set(bpm);bpmLag.update(dt);
    vols.forEach(v=>v.update(dt));

    ctx.fillStyle='rgba(2,4,8,0.85)';ctx.fillRect(0,0,W,H);

    const masterH=80, trackH=Math.floor((H-masterH)/4);
    const bpmNow=bpmLag.value;

    // Draw 4 tracks
    const allPts=[];
    for(let i=0;i<4;i++){
      const vol=muted[i]?0:vols[i].value;
      const burst=burstTimer>0&&recTrack===i?burstTimer:0;
      const pts=genTrackWave(i,W,elapsed,bpmNow,vol,burst);
      allPts.push(pts);
      drawTrack(ctx,W,H,i*trackH,trackH,pts,TRACK_COLORS[i],TRACK_NAMES[i],muted[i]);
    }

    // Master composite
    const masterY=H-masterH;
    ctx.fillStyle='rgba(10,26,40,0.9)';ctx.fillRect(0,masterY,W,masterH);
    ctx.fillStyle='rgba(37,99,235,0.08)';ctx.fillRect(0,masterY,W,masterH);
    ctx.fillStyle='#60a5fa';ctx.font='10px Segoe UI';ctx.fillText('MASTER',8,masterY+14);
    const masterPts=allPts[0].map((_,i)=>allPts.reduce((s,p)=>s+p[i],0)/4);
    const masterCy=masterY+masterH*0.5;
    ctx.beginPath();
    masterPts.forEach((y,i)=>{
      const py=masterCy-y*masterH*0.38;
      i===0?ctx.moveTo(i,py):ctx.lineTo(i,py);
    });
    ctx.strokeStyle='#f59e0b';ctx.shadowBlur=14;ctx.shadowColor='#f59e0b';
    ctx.lineWidth=1.8;ctx.stroke();ctx.shadowBlur=0;

    // Record burst flash
    if(burstTimer>0){
      ctx.fillStyle=`rgba(245,158,11,${burstTimer*0.4})`;
      ctx.fillRect(0,recTrack*trackH,W,trackH);
    }

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();

// ─────────────────────────────────────────────
// SECTION 3: SYNTHESIS EXPLORER
// ─────────────────────────────────────────────
(function(){
  const canvas=document.getElementById('syn-canvas');
  const ctx=canvas.getContext('2d');
  function resize(){canvas.width=canvas.parentElement.clientWidth;canvas.height=400;}
  resize();new ResizeObserver(resize).observe(canvas.parentElement);

  let mode='sub'; // sub | add | fm
  let lastT=0,elapsed=0;

  // LagFilters for sub params
  const cutLag=new LagFilter(0.6,0.15),resLag=new LagFilter(0.3,0.15);
  const attLag=new LagFilter(0.1,0.15),decLag=new LagFilter(0.3,0.15);
  const susLag=new LagFilter(0.7,0.15),relLag=new LagFilter(0.5,0.15);
  // Additive harmonic amplitudes
  const harmAmps=[1,0.6,0.4,0.3,0.2,0.15,0.1,0.08].map(v=>new LagFilter(v,0.2));
  // FM params
  const fmRatioLag=new LagFilter(2,0.2),fmIdxLag=new LagFilter(4,0.2);
  const fmCFreqLag=new LagFilter(0.5,0.15),fmMAmpLag=new LagFilter(0.6,0.15);

  // Wire tabs
  document.querySelectorAll('.tab[data-syn]').forEach(btn=>{
    btn.addEventListener('click',()=>{
      mode=btn.dataset.syn;
      document.querySelectorAll('.tab[data-syn]').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('syn-sub-ctrl').style.display=mode==='sub'?'':'none';
      document.getElementById('syn-add-ctrl').style.display=mode==='add'?'':'none';
      document.getElementById('syn-fm-ctrl').style.display=mode==='fm'?'':'none';
      const caps={sub:'Subtractive: sawtooth → filter cutoff → ADSR envelope',
        add:'Additive: 8 harmonics summed → composite waveform',
        fm:'FM: carrier modulated by modulator → complex spectrum'};
      document.getElementById('syn-caption').textContent=caps[mode];
    });
  });

  // Wire sub sliders
  function wireSub(id,lag,fmt){
    const el=document.getElementById(id);
    el.addEventListener('input',()=>{lag.set(+el.value/100);document.getElementById(id+'-v').textContent=fmt(+el.value);});
  }
  wireSub('s-cutoff',cutLag,v=>v);
  wireSub('s-res',resLag,v=>v);
  wireSub('s-att',attLag,v=>v+'ms');
  wireSub('s-dec',decLag,v=>v+'ms');
  wireSub('s-sus',susLag,v=>v+'%');
  wireSub('s-rel',relLag,v=>v+'ms');

  // Build harmonic sliders
  const hgrid=document.getElementById('harmonics-grid');
  for(let i=0;i<8;i++){
    const div=document.createElement('div');
    div.style.cssText='display:flex;flex-direction:column;align-items:center;gap:0.3rem;';
    div.innerHTML=`<span style="font-size:0.65rem;color:var(--dim)">H${i+1}</span>
      <input type="range" id="harm${i}" min="0" max="100" value="${Math.round(harmAmps[i].value*100)}"
        style="writing-mode:vertical-lr;direction:rtl;width:20px;height:80px;cursor:pointer;">
      <span style="font-size:0.65rem;color:var(--accent3)" id="harmv${i}">${Math.round(harmAmps[i].value*100)}</span>`;
    hgrid.appendChild(div);
    document.getElementById('harm'+i).addEventListener('input',function(){
      harmAmps[i].set(+this.value/100);
      document.getElementById('harmv'+i).textContent=this.value;
    });
  }

  // Wire FM sliders
  document.getElementById('fm-ratio').addEventListener('input',function(){
    fmRatioLag.set(+this.value);
    document.getElementById('fm-ratio-v').textContent='1:'+this.value;
  });
  document.getElementById('fm-idx').addEventListener('input',function(){
    fmIdxLag.set(+this.value/10);
    document.getElementById('fm-idx-v').textContent=(+this.value/10).toFixed(1);
  });
  document.getElementById('fm-cfreq').addEventListener('input',function(){
    fmCFreqLag.set(+this.value/100);
    document.getElementById('fm-cfreq-v').textContent=this.value;
  });
  document.getElementById('fm-mamp').addEventListener('input',function(){
    fmMAmpLag.set(+this.value/100);
    document.getElementById('fm-mamp-v').textContent=this.value;
  });

  function drawSubtractive(W,H,t){
    const panelW=Math.floor(W/3);
    // Panel labels
    ['OSCILLATOR','FILTER','ENVELOPE'].forEach((label,i)=>{
      ctx.fillStyle='rgba(37,99,235,0.06)';ctx.fillRect(i*panelW,0,panelW,H);
      ctx.fillStyle='var(--accent3)';ctx.font='10px Segoe UI';
      ctx.fillText(label,i*panelW+10,20);
      // divider
      if(i>0){ctx.strokeStyle='rgba(59,130,246,0.15)';ctx.lineWidth=1;
        ctx.beginPath();ctx.moveTo(i*panelW,0);ctx.lineTo(i*panelW,H);ctx.stroke();}
    });

    const cy=H*0.5;
    // OSC: animated sawtooth
    ctx.beginPath();
    for(let i=0;i<=panelW;i++){
      const x=i;const nx=i/panelW;
      const cycles=4;const phase=(nx*cycles+t*0.8)%1;
      const y=cy-(phase*2-1)*H*0.35;
      i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
    }
    ctx.strokeStyle='#2563eb';ctx.shadowBlur=10;ctx.shadowColor='#2563eb';
    ctx.lineWidth=1.5;ctx.stroke();ctx.shadowBlur=0;

    // FILTER: show cutoff line + filtered waveform
    const cut=cutLag.value;const res=resLag.value;
    const cutY=cy-(cut*2-1)*H*0.3;
    ctx.strokeStyle='rgba(245,158,11,0.6)';ctx.lineWidth=1;
    ctx.setLineDash([4,4]);ctx.beginPath();
    ctx.moveTo(panelW,cutY);ctx.lineTo(panelW*2,cutY);ctx.stroke();ctx.setLineDash([]);
    ctx.fillStyle='rgba(245,158,11,0.5)';ctx.font='9px Segoe UI';
    ctx.fillText('cutoff',panelW+6,cutY-4);
    // Resonance bump
    ctx.beginPath();
    for(let i=0;i<=panelW;i++){
      const x=panelW+i;const nx=i/panelW;
      const freq=nx*cut+0.1;
      const bump=res*0.4*Math.exp(-Math.pow((nx-cut)*8,2));
      const y=cy-(freq+bump)*H*0.28;
      i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
    }
    ctx.strokeStyle='#60a5fa';ctx.shadowBlur=8;ctx.shadowColor='#60a5fa';
    ctx.lineWidth=1.3;ctx.stroke();ctx.shadowBlur=0;

    // ENVELOPE: ADSR shape
    const att=attLag.value,dec=decLag.value,sus=susLag.value,rel=relLag.value;
    const pw=panelW-20;const envX=panelW*2+10;const envY=H*0.85;
    const eH=H*0.6;
    const attEnd=envX+att*pw*0.3;
    const decEnd=attEnd+dec*pw*0.2;
    const susEnd=decEnd+pw*0.25;
    const relEnd=susEnd+rel*pw*0.25;
    ctx.beginPath();
    ctx.moveTo(envX,envY);
    ctx.lineTo(attEnd,envY-eH);
    ctx.lineTo(decEnd,envY-sus*eH);
    ctx.lineTo(susEnd,envY-sus*eH);
    ctx.lineTo(relEnd,envY);
    ctx.strokeStyle='#f59e0b';ctx.shadowBlur=12;ctx.shadowColor='#f59e0b';
    ctx.lineWidth=2;ctx.stroke();ctx.shadowBlur=0;
    // Fill
    ctx.beginPath();
    ctx.moveTo(envX,envY);ctx.lineTo(attEnd,envY-eH);ctx.lineTo(decEnd,envY-sus*eH);
    ctx.lineTo(susEnd,envY-sus*eH);ctx.lineTo(relEnd,envY);ctx.closePath();
    ctx.fillStyle='rgba(245,158,11,0.08)';ctx.fill();
    ['A','D','S','R'].forEach((label,i)=>{
      const xs=[envX+att*pw*0.15,attEnd+dec*pw*0.1,decEnd+pw*0.12,susEnd+rel*pw*0.12];
      ctx.fillStyle='rgba(245,158,11,0.6)';ctx.font='9px Segoe UI';ctx.fillText(label,xs[i],envY+14);
    });
  }

  function drawAdditive(W,H,t){
    harmAmps.forEach(h=>h.update(0.016));
    const N=8,barW=Math.floor(W/(N*2));
    const cy=H*0.55;
    // Draw harmonic bars
    for(let i=0;i<N;i++){
      const amp=harmAmps[i].value;
      const x=barW*(i*2+0.5);const barH=amp*H*0.35;
      const hue=200+i*15;
      ctx.fillStyle=`hsla(${hue},70%,55%,0.25)`;
      ctx.fillRect(x,cy-barH,barW,barH*2);
      ctx.strokeStyle=`hsla(${hue},80%,65%,0.9)`;
      ctx.shadowBlur=8;ctx.shadowColor=`hsl(${hue},80%,60%)`;
      ctx.lineWidth=1.2;ctx.strokeRect(x,cy-barH,barW,barH*2);ctx.shadowBlur=0;
      ctx.fillStyle='rgba(96,165,250,0.7)';ctx.font='9px Segoe UI';
      ctx.fillText('H'+(i+1),x+barW*0.2,cy+barH+14);
    }
    // Summed waveform at bottom
    const sumY=H*0.82;
    ctx.beginPath();
    for(let px=0;px<W;px++){
      const nx=px/W;let y=0;
      for(let i=0;i<N;i++) y+=harmAmps[i].value*Math.sin(nx*Math.PI*2*(i+1)+t*0.5*(i+1)*0.3);
      const py=sumY-y*H*0.06;
      px===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
    }
    ctx.strokeStyle='#f59e0b';ctx.shadowBlur=14;ctx.shadowColor='#f59e0b';
    ctx.lineWidth=1.8;ctx.stroke();ctx.shadowBlur=0;
    ctx.fillStyle='rgba(245,158,11,0.6)';ctx.font='10px Segoe UI';ctx.fillText('SUMMED OUTPUT',8,sumY-H*0.09);
  }

  function drawFM(W,H,t){
    fmRatioLag.update(0.016);fmIdxLag.update(0.016);
    fmCFreqLag.update(0.016);fmMAmpLag.update(0.016);
    const ratio=fmRatioLag.value,idx=fmIdxLag.value;
    const cfreq=fmCFreqLag.value*3+0.5;
    const mamp=fmMAmpLag.value;
    const cy=H*0.5;
    // Carrier
    ctx.beginPath();
    for(let i=0;i<=W;i++){
      const nx=i/W;
      const y=cy-Math.sin(nx*Math.PI*2*cfreq+t*0.4)*H*0.15;
      i===0?ctx.moveTo(i,y):ctx.lineTo(i,y);
    }
    ctx.strokeStyle='rgba(37,99,235,0.6)';ctx.lineWidth=1;ctx.stroke();
    // Modulator
    ctx.beginPath();
    for(let i=0;i<=W;i++){
      const nx=i/W;
      const y=cy-Math.sin(nx*Math.PI*2*cfreq*ratio+t*0.4*ratio)*H*0.1*mamp;
      i===0?ctx.moveTo(i,y):ctx.lineTo(i,y);
    }
    ctx.strokeStyle='rgba(245,158,11,0.5)';ctx.lineWidth=1;ctx.stroke();
    // FM Result
    ctx.beginPath();
    for(let i=0;i<=W;i++){
      const nx=i/W;
      const mod=Math.sin(nx*Math.PI*2*cfreq*ratio+t*0.4*ratio)*idx*mamp;
      const y=cy-Math.sin(nx*Math.PI*2*cfreq+mod+t*0.4)*H*0.3;
      i===0?ctx.moveTo(i,y):ctx.lineTo(i,y);
    }
    ctx.strokeStyle='#60a5fa';ctx.shadowBlur=14;ctx.shadowColor='#60a5fa';
    ctx.lineWidth=2;ctx.stroke();ctx.shadowBlur=0;
    // Labels
    [['CARRIER','rgba(37,99,235,0.8)',H*0.12],
     ['MODULATOR','rgba(245,158,11,0.8)',H*0.22],
     ['FM RESULT','rgba(96,165,250,0.9)',H*0.36]].forEach(([l,c,y])=>{
      ctx.fillStyle=c;ctx.font='10px Segoe UI';ctx.fillText(l,8,y);
    });
  }

  function draw(ts){
    const t=ts*0.001,dt=Math.min(t-lastT,0.05);lastT=t;elapsed+=dt;
    const W=canvas.width,H=canvas.height;
    [cutLag,resLag,attLag,decLag,susLag,relLag].forEach(l=>l.update(dt));

    ctx.fillStyle='rgba(2,4,8,0.88)';ctx.fillRect(0,0,W,H);
    if(mode==='sub') drawSubtractive(W,H,elapsed);
    else if(mode==='add') drawAdditive(W,H,elapsed);
    else drawFM(W,H,elapsed);
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();
</script>
<!-- SECTION 4: CINEMATIC IMPACT GENERATOR -->
<section id="impact">
