<!-- SECTION 9: GLOSSARY -->
<section id="glossary">
<div class="container">
<div class="section-label">Section 09</div>
<div class="section-title hidden stagger-1">Glossary</div>
<div class="section-sub hidden stagger-2">22 essential effects and signal processing terms</div>
<div class="glossary-grid hidden stagger-3">
<div class="gloss-item"><span class="gloss-term">All-Pass Filter</span><span class="gloss-def">Passes all frequencies but shifts phase; stacked stages create phasing effect</span></div>
<div class="gloss-item"><span class="gloss-term">Attack</span><span class="gloss-def">Time for a dynamics processor to respond to a signal exceeding threshold</span></div>
<div class="gloss-item"><span class="gloss-term">BPM Sync</span><span class="gloss-def">Locking modulation or delay time to the project tempo in musical divisions</span></div>
<div class="gloss-item"><span class="gloss-term">Chorus</span><span class="gloss-def">Multi-voice detuned delay (5–30ms) with LFO modulation adding width and shimmer</span></div>
<div class="gloss-item"><span class="gloss-term">Comb Filter</span><span class="gloss-def">Frequency response with evenly-spaced notches caused by mixing delayed signal with itself</span></div>
<div class="gloss-item"><span class="gloss-term">Compressor</span><span class="gloss-def">Reduces dynamic range when signal exceeds threshold, defined by ratio and knee</span></div>
<div class="gloss-item"><span class="gloss-term">Delay</span><span class="gloss-def">Repeating echo of the dry signal; time, feedback, and wet level define the character</span></div>
<div class="gloss-item"><span class="gloss-term">Drive</span><span class="gloss-def">Amount of gain pushing signal into a nonlinear element, producing harmonic distortion</span></div>
<div class="gloss-item"><span class="gloss-term">Dry/Wet</span><span class="gloss-def">Balance between unprocessed (dry) and processed (wet) signal paths at effect output</span></div>
<div class="gloss-item"><span class="gloss-term">Envelope</span><span class="gloss-def">Amplitude contour of a sound over time — Attack, Decay, Sustain, Release (ADSR)</span></div>
<div class="gloss-item"><span class="gloss-term">Feedback</span><span class="gloss-def">Routing effect output back to input; controls decay length and resonance in delays</span></div>
<div class="gloss-item"><span class="gloss-term">Flanger</span><span class="gloss-def">Very short LFO-modulated delay (0.5–10ms) with feedback creating swept comb filter</span></div>
<div class="gloss-item"><span class="gloss-term">Gate</span><span class="gloss-def">Attenuates signal below threshold; removes noise in quiet passages between notes</span></div>
<div class="gloss-item"><span class="gloss-term">LFO</span><span class="gloss-def">Low Frequency Oscillator (below 20Hz) used as modulation source for parameters</span></div>
<div class="gloss-item"><span class="gloss-term">Limiter</span><span class="gloss-def">High-ratio compressor (∞:1) preventing signal from exceeding a hard ceiling</span></div>
<div class="gloss-item"><span class="gloss-term">Modulation</span><span class="gloss-def">Periodic variation of a parameter over time, typically from LFO or envelope source</span></div>
<div class="gloss-item"><span class="gloss-term">Phaser</span><span class="gloss-def">All-pass filter stages whose phase shift is modulated by LFO, creating sweeping peaks</span></div>
<div class="gloss-item"><span class="gloss-term">Q Factor</span><span class="gloss-def">Filter bandwidth — high Q creates a narrow resonant peak; low Q a broad gentle slope</span></div>
<div class="gloss-item"><span class="gloss-term">Release</span><span class="gloss-def">Time for a dynamics processor to stop acting after signal drops below threshold</span></div>
<div class="gloss-item"><span class="gloss-term">Saturation</span><span class="gloss-def">Gentle asymmetric clipping adding warmth and even harmonics, emulating analog circuitry</span></div>
<div class="gloss-item"><span class="gloss-term">Sidechain</span><span class="gloss-def">Using a separate signal to trigger dynamics processing — classic in pumping EDM kicks</span></div>
<div class="gloss-item"><span class="gloss-term">Threshold</span><span class="gloss-def">Level at which a dynamics processor begins acting on the incoming signal</span></div>
</div>
</div>
</section>
<script>
'use strict';
// ─── LAG FILTER ───────────────────────────────────────────────────────────────
class LagFilter {
  constructor(tau) { this.tau = tau; this.value = null; }
  update(target, dt) {
    if (this.value === null) this.value = target;
    this.value += (1 - Math.exp(-dt / this.tau)) * (target - this.value);
    return this.value;
  }
}

// ─── WEBAUDIO CONTEXT ─────────────────────────────────────────────────────────
let audioCtx = null;
function getAudioCtx() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();
  return audioCtx;
}

// ─── UTILS ────────────────────────────────────────────────────────────────────
function lerp(a, b, t) { return a + (b - a) * t; }
function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
function logFreq(norm) { return Math.pow(10, lerp(Math.log10(20), Math.log10(20000), norm)); }
function dbToLinear(db) { return Math.pow(10, db / 20); }
function linearToDb(lin) { return lin > 0 ? 20 * Math.log10(lin) : -96; }

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 1 — HERO CANVAS
// ═══════════════════════════════════════════════════════════════════════════════
(function initHero() {
  const canvas = document.getElementById('hero-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, animId;
  let t = 0;

  const BLOCKS = [
    { label: 'FILTER',     color: '#06b6d4' },
    { label: 'DISTORTION', color: '#f97316' },
    { label: 'CHORUS',     color: '#8b5cf6' },
    { label: 'DELAY',      color: '#06b6d4' },
    { label: 'REVERB',     color: '#8b5cf6' }
  ];

  function resize() {
    W = canvas.offsetWidth;
    H = 440;
    canvas.width = W;
    canvas.height = H;
  }

  // Draw a waveform segment morphed by stage index
  function drawWaveSegment(ctx, xStart, xEnd, yCenter, amplitude, stage, phase, color, alpha) {
    ctx.save();
    ctx.globalAlpha = alpha;
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.8;
    ctx.shadowColor = color;
    ctx.shadowBlur = 8;
    ctx.beginPath();
    const N = Math.max(2, Math.round((xEnd - xStart) / 2));
    for (let i = 0; i <= N; i++) {
      const x = xStart + (xEnd - xStart) * (i / N);
      const prog = i / N;
      let y = 0;
      switch (stage) {
        case 0: // raw sine
          y = Math.sin(prog * Math.PI * 6 + phase) * amplitude;
          break;
        case 1: // filter — narrower, smoother
          y = Math.sin(prog * Math.PI * 3 + phase) * amplitude * 0.6;
          break;
        case 2: // distortion — clipped peaks
          y = Math.tanh(Math.sin(prog * Math.PI * 6 + phase) * 3) * amplitude * 0.9;
          // add harmonics
          y += Math.sin(prog * Math.PI * 18 + phase * 2) * amplitude * 0.15;
          break;
        case 3: // chorus — doubled with shimmer
          y = Math.sin(prog * Math.PI * 6 + phase) * amplitude * 0.75
            + Math.sin(prog * Math.PI * 6.4 + phase * 1.1 + 0.3) * amplitude * 0.35;
          break;
        case 4: // delay — trailing echoes
          y = Math.sin(prog * Math.PI * 6 + phase) * amplitude * 0.9
            + Math.sin((prog - 0.2) * Math.PI * 6 + phase) * amplitude * 0.4 * (prog > 0.2 ? 1 : 0)
            + Math.sin((prog - 0.4) * Math.PI * 6 + phase) * amplitude * 0.2 * (prog > 0.4 ? 1 : 0);
          break;
        case 5: // reverb — diffuse tail
          let rev = 0;
          for (let k = 0; k < 8; k++) {
            rev += Math.sin(prog * Math.PI * (6 + k * 0.7) + phase + k * 0.4) * amplitude * (0.8 / (k + 1));
          }
          y = rev * 0.35;
          break;
      }
      if (i === 0) ctx.moveTo(x, yCenter + y);
      else ctx.lineTo(x, yCenter + y);
    }
    ctx.stroke();
    ctx.restore();
  }

  function drawBlock(bx, by, bw, bh, label, color, glowIntensity) {
    ctx.save();
    // glow
    ctx.shadowColor = color;
    ctx.shadowBlur = 16 * glowIntensity;
    // border
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5;
    ctx.globalAlpha = 0.7 + glowIntensity * 0.3;
    ctx.strokeRect(bx, by, bw, bh);
    // fill
    ctx.globalAlpha = 0.08 + glowIntensity * 0.1;
    ctx.fillStyle = color;
    ctx.fillRect(bx, by, bw, bh);
    // label
    ctx.globalAlpha = 0.9;
    ctx.shadowBlur = 0;
    ctx.fillStyle = color;
    ctx.font = `bold 10px 'Courier New', monospace`;
    ctx.letterSpacing = '0.15em';
    ctx.textAlign = 'center';
    ctx.fillText(label, bx + bw / 2, by + bh / 2 + 4);
    ctx.restore();
  }

  function frame() {
    animId = requestAnimationFrame(frame);
    t += 0.016;

    // Phosphor decay
    ctx.fillStyle = 'rgba(10,10,15,0.05)';
    ctx.fillRect(0, 0, W, H);

    const yCenter = H * 0.5;
    const blockH = 60;
    const blockY = yCenter - blockH / 2;
    const margin = 32;
    const totalW = W - margin * 2;
    const blockW = totalW * 0.09;
    const segW = (totalW - BLOCKS.length * blockW) / (BLOCKS.length + 1);

    // Draw connecting signal lines + morphing waveforms
    for (let i = 0; i <= BLOCKS.length; i++) {
      const xStart = margin + i * (blockW + segW) - (i > 0 ? 0 : 0);
      const xSegStart = margin + i * (segW + blockW);
      const xSegEnd = xSegStart + segW;
      const col = i < BLOCKS.length ? BLOCKS[i].color : '#e2e2f0';
      const glowA = 0.7 + 0.3 * Math.sin(t * 2 + i);
      drawWaveSegment(ctx, xSegStart, xSegEnd, yCenter, 22, i, t * 3 - i * 0.8, col, glowA);

      // connecting line to block
      if (i < BLOCKS.length) {
        const bx = xSegEnd;
        ctx.save();
        ctx.strokeStyle = BLOCKS[i].color;
        ctx.lineWidth = 1;
        ctx.globalAlpha = 0.4;
        ctx.beginPath();
        ctx.moveTo(bx, yCenter);
        ctx.lineTo(bx + blockW, yCenter);
        ctx.stroke();
        ctx.restore();
      }
    }

    // Draw blocks
    for (let i = 0; i < BLOCKS.length; i++) {
      const xSeg0 = margin + i * (segW + blockW) + segW;
      const glow = 0.6 + 0.4 * Math.sin(t * 1.5 + i * 0.9);
      drawBlock(xSeg0, blockY, blockW, blockH, BLOCKS[i].label, BLOCKS[i].color, glow);
    }

    // Title
    ctx.save();
    ctx.textAlign = 'center';
    ctx.fillStyle = '#f97316';
    ctx.font = `bold clamp(28px,4vw,52px) 'Courier New', monospace`;
    ctx.shadowColor = '#f97316';
    ctx.shadowBlur = 20;
    ctx.fillText('EFFECTS WORLD', W / 2, H * 0.18);
    ctx.shadowBlur = 0;
    ctx.fillStyle = '#6b6b8a';
    ctx.font = `11px 'Courier New', monospace`;
    ctx.letterSpacing = '0.3em';
    ctx.fillText('filters · dynamics · modulation · time', W / 2, H * 0.18 + 28);
    ctx.restore();

    // Grid lines (subtle)
    ctx.save();
    ctx.strokeStyle = '#1e1e2e';
    ctx.lineWidth = 0.5;
    ctx.globalAlpha = 0.4;
    for (let y = 0; y < H; y += 40) {
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
    }
    ctx.restore();
  }

  function start() {
    resize();
    if (animId) cancelAnimationFrame(animId);
    frame();
  }

  window.addEventListener('resize', () => { resize(); });
  start();
})();


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 2 — FILTER LAB
// ═══════════════════════════════════════════════════════════════════════════════
(function initFilterLab() {
  let filterNode = null, oscNode = null, gainNode = null, analyserIn = null, analyserOut = null;
  let audioEnabled = false;
  const lagFreq = new LagFilter(0.08);
  const lagQ    = new LagFilter(0.08);
  const lagGain = new LagFilter(0.08);

  const freqCanvas  = document.getElementById('filter-freq-canvas');
  const oscCanvas   = document.getElementById('filter-osc-canvas');
  const fCtx = freqCanvas.getContext('2d');
  const oCtx = oscCanvas.getContext('2d');

  const selType  = document.getElementById('filter-type-sel');
  const slFreq   = document.getElementById('filter-freq');
  const slQ      = document.getElementById('filter-q');
  const slGain   = document.getElementById('filter-gain');
  const valFreq  = document.getElementById('filter-freq-val');
  const valQ     = document.getElementById('filter-q-val');
  const valGain  = document.getElementById('filter-gain-val');
  const enableBtn= document.getElementById('filter-enable-btn');

  let currentFreq = 1000, currentQ = 1, currentGain = 0;
  let prevT = performance.now();

  function enableAudio() {
    const ac = getAudioCtx();
    oscNode = ac.createOscillator();
    oscNode.type = 'sawtooth';
    oscNode.frequency.value = 220;

    filterNode = ac.createBiquadFilter();
    filterNode.type = selType.value;

    analyserIn = ac.createAnalyser();
    analyserIn.fftSize = 2048;
    analyserOut = ac.createAnalyser();
    analyserOut.fftSize = 2048;

    gainNode = ac.createGain();
    gainNode.gain.value = 0.12;

    oscNode.connect(analyserIn);
    analyserIn.connect(filterNode);
    filterNode.connect(analyserOut);
    analyserOut.connect(gainNode);
    gainNode.connect(ac.destination);
    oscNode.start();
    audioEnabled = true;
    enableBtn.textContent = 'Audio ON';
    enableBtn.classList.add('active');
  }

  enableBtn.addEventListener('click', () => {
    if (!audioEnabled) enableAudio();
    else {
      oscNode && oscNode.stop();
      gainNode && gainNode.disconnect();
      audioEnabled = false;
      enableBtn.textContent = 'Enable Audio';
      enableBtn.classList.remove('active');
    }
  });

  selType.addEventListener('change', () => { if (filterNode) filterNode.type = selType.value; });

  function getFilteredFreq() { return logFreq(parseFloat(slFreq.value)); }
  function getQ()    { return parseFloat(slQ.value); }
  function getGainV(){ return parseFloat(slGain.value); }

  slFreq.addEventListener('input',  () => { valFreq.textContent = getFilteredFreq().toFixed(0) + ' Hz'; });
  slQ.addEventListener('input',     () => { valQ.textContent = getQ().toFixed(1); });
  slGain.addEventListener('input',  () => { valGain.textContent = getGainV().toFixed(1); });

  window.filterPreset = function(name) {
    const presets = {
      'dark-pad':    { type:'lowpass',  freq:0.3,  q:1.5,  gain:0  },
      'bright-pluck':{ type:'highpass', freq:0.55, q:2,    gain:0  },
      'telephone':   { type:'bandpass', freq:0.5,  q:8,    gain:0  },
      'vowel':       { type:'peaking',  freq:0.48, q:6,    gain:10 },
      'bass':        { type:'lowpass',  freq:0.2,  q:4,    gain:0  }
    };
    const p = presets[name]; if (!p) return;
    selType.value = p.type; slFreq.value = p.freq; slQ.value = p.q; slGain.value = p.gain;
    valFreq.textContent = logFreq(p.freq).toFixed(0) + ' Hz';
    valQ.textContent = p.q.toFixed(1);
    valGain.textContent = p.gain.toFixed(1);
    if (filterNode) filterNode.type = p.type;
  };

  function drawFreqResponse() {
    const W = freqCanvas.offsetWidth || 600;
    const H = 180;
    freqCanvas.width = W; freqCanvas.height = H;

    const ac = getAudioCtx();
    const freq = currentFreq, q = currentQ, gainDb = currentGain;
    const type = selType.value;

    // Build offline frequency response
    const nFreqs = W;
    const freqs = new Float32Array(nFreqs);
    for (let i = 0; i < nFreqs; i++) freqs[i] = logFreq(i / nFreqs);
    const mag = new Float32Array(nFreqs);
    const phase = new Float32Array(nFreqs);

    // Temporary filter just for response calculation
    const tmp = ac.createBiquadFilter();
    tmp.type = type;
    tmp.frequency.value = freq;
    tmp.Q.value = q;
    tmp.gain.value = gainDb;
    tmp.getFrequencyResponse(freqs, mag, phase);

    fCtx.clearRect(0, 0, W, H);
    fCtx.fillStyle = '#0a0a0f';
    fCtx.fillRect(0, 0, W, H);

    // Grid lines
    fCtx.strokeStyle = '#1e1e2e';
    fCtx.lineWidth = 0.5;
    const dbRange = 40;
    for (let db = -dbRange; db <= dbRange; db += 10) {
      const y = H / 2 - (db / dbRange) * (H / 2 - 10);
      fCtx.beginPath(); fCtx.moveTo(0, y); fCtx.lineTo(W, y); fCtx.stroke();
      fCtx.fillStyle = '#6b6b8a';
      fCtx.font = '9px Courier New';
      fCtx.fillText(db + 'dB', 3, y - 2);
    }
    // 0dB center
    fCtx.strokeStyle = '#2e2e4e';
    fCtx.lineWidth = 1;
    fCtx.beginPath(); fCtx.moveTo(0, H/2); fCtx.lineTo(W, H/2); fCtx.stroke();

    // Response curve
    fCtx.beginPath();
    fCtx.strokeStyle = '#06b6d4';
    fCtx.lineWidth = 2;
    fCtx.shadowColor = '#06b6d4';
    fCtx.shadowBlur = 8;
    for (let i = 0; i < nFreqs; i++) {
      const db = 20 * Math.log10(Math.max(1e-6, mag[i]));
      const y = H / 2 - (db / dbRange) * (H / 2 - 10);
      const yc = clamp(y, 2, H - 2);
      if (i === 0) fCtx.moveTo(i, yc); else fCtx.lineTo(i, yc);
    }
    fCtx.stroke();

    // Cutoff marker
    const cx = Math.round(nFreqs * (Math.log10(freq) - Math.log10(20)) / (Math.log10(20000) - Math.log10(20)));
    fCtx.strokeStyle = 'rgba(249,115,22,0.5)';
    fCtx.lineWidth = 1;
    fCtx.shadowBlur = 0;
    fCtx.beginPath(); fCtx.moveTo(cx, 0); fCtx.lineTo(cx, H); fCtx.stroke();
    fCtx.fillStyle = '#f97316';
    fCtx.font = '9px Courier New';
    fCtx.fillText(freq.toFixed(0) + 'Hz', Math.min(cx + 3, W - 50), 12);
  }

  function drawOscilloscope() {
    const W = oscCanvas.offsetWidth || 600;
    const H = 120;
    oscCanvas.width = W; oscCanvas.height = H;
    oCtx.fillStyle = 'rgba(10,10,15,0.3)';
    oCtx.fillRect(0, 0, W, H);

    if (!analyserIn) {
      // Draw a placeholder sine wave
      const t = performance.now() / 1000;
      oCtx.strokeStyle = '#6b6b8a'; oCtx.lineWidth = 1;
      oCtx.beginPath();
      for (let x = 0; x < W; x++) {
        const y = H/2 + Math.sin(x/W * Math.PI * 8 + t * 2) * 20;
        x === 0 ? oCtx.moveTo(x, y) : oCtx.lineTo(x, y);
      }
      oCtx.stroke();
      return;
    }

    const bufLen = analyserIn.frequencyBinCount;
    const dataIn  = new Float32Array(bufLen);
    const dataOut = new Float32Array(bufLen);
    analyserIn.getFloatTimeDomainData(dataIn);
    analyserOut.getFloatTimeDomainData(dataOut);

    const halfW = W / 2;
    const step = Math.floor(bufLen / 256);

    // Input waveform (dim)
    oCtx.strokeStyle = '#1e1e2e'; oCtx.lineWidth = 1;
    oCtx.beginPath();
    for (let i = 0; i < 256; i++) {
      const x = (i / 256) * halfW;
      const y = H/2 - dataIn[i * step] * (H/2 - 6);
      i === 0 ? oCtx.moveTo(x, y) : oCtx.lineTo(x, y);
    }
    oCtx.stroke();

    // Input label
    oCtx.fillStyle = '#6b6b8a'; oCtx.font = '9px Courier New'; oCtx.textAlign = 'left';
    oCtx.fillText('INPUT', 4, 10);

    // Filtered waveform (bright)
    oCtx.strokeStyle = '#06b6d4'; oCtx.lineWidth = 1.5;
    oCtx.shadowColor = '#06b6d4'; oCtx.shadowBlur = 4;
    oCtx.beginPath();
    for (let i = 0; i < 256; i++) {
      const x = halfW + (i / 256) * halfW;
      const y = H/2 - dataOut[i * step] * (H/2 - 6);
      i === 0 ? oCtx.moveTo(x, y) : oCtx.lineTo(x, y);
    }
    oCtx.stroke();
    oCtx.shadowBlur = 0;
    oCtx.fillStyle = '#06b6d4'; oCtx.fillText('FILTERED', halfW + 4, 10);

    // Divider
    oCtx.strokeStyle = '#1e1e2e'; oCtx.lineWidth = 1; oCtx.beginPath();
    oCtx.moveTo(halfW, 0); oCtx.lineTo(halfW, H); oCtx.stroke();
  }

  let rafId;
  function loop() {
    rafId = requestAnimationFrame(loop);
    const now = performance.now();
    const dt = (now - prevT) / 1000;
    prevT = now;

    currentFreq = lagFreq.update(logFreq(parseFloat(slFreq.value)), dt);
    currentQ    = lagQ.update(parseFloat(slQ.value), dt);
    currentGain = lagGain.update(parseFloat(slGain.value), dt);

    if (filterNode) {
      filterNode.frequency.value = currentFreq;
      filterNode.Q.value = currentQ;
      filterNode.gain.value = currentGain;
    }
    drawFreqResponse();
    drawOscilloscope();
  }
  loop();
})();

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 3 — DYNAMICS CHAIN
// ═══════════════════════════════════════════════════════════════════════════════
(function initDynamics() {
  const gateCanvas = document.getElementById('gate-canvas');
  const compCanvas = document.getElementById('comp-canvas');
  const limCanvas  = document.getElementById('limiter-canvas');
  const gCtx = gateCanvas.getContext('2d');
  const cCtx = compCanvas.getContext('2d');
  const lCtx = limCanvas.getContext('2d');

  const gateLed  = document.getElementById('gate-led');
  const inFill   = document.getElementById('dyn-in-fill');
  const outFill  = document.getElementById('dyn-out-fill');
  const inVal    = document.getElementById('dyn-in-val');
  const outVal   = document.getElementById('dyn-out-val');
  const limGrFill= document.getElementById('lim-gr-fill');

  // LagFilters
  const lagGateGR = new LagFilter(0.06);
  const lagCompGR = new LagFilter(0.06);
  const lagLimGR  = new LagFilter(0.04);
  const lagIn     = new LagFilter(0.05);
  const lagOut    = new LagFilter(0.05);

  // Simulated signal — noise burst every 2s
  let sigPhase = 0, burstTimer = 0, burstOn = false;
  let rawLevel = 0; // 0..1 linear

  // Gate history ring buffer
  const gateHistory = new Array(100).fill(0);
  let gateHistIdx = 0;

  let prevT = performance.now();
  let t = 0;

  function simulateSignal(dt) {
    burstTimer += dt;
    if (burstTimer > 2.0) { burstTimer = 0; burstOn = true; }
    if (burstOn && burstTimer > 0.6) burstOn = false;
    // Amplitude envelope
    if (burstOn) {
      rawLevel = Math.min(1, rawLevel + dt * 8) * (0.7 + 0.3 * Math.random());
    } else {
      rawLevel = rawLevel * Math.exp(-dt * 10);
    }
    // Keep a small noise floor
    rawLevel = Math.max(rawLevel, 0.01 + Math.random() * 0.01);
  }

  function processGate(level) {
    const thresh = dbToLinear(parseFloat(document.getElementById('gate-thresh').value));
    const open = level > thresh;
    gateLed.className = 'state-led' + (open ? ' open' : '');
    const gr = open ? 0 : -60; // dB gain reduction
    return open ? level : level * 0.001;
  }

  function processCompressor(level) {
    const threshold = parseFloat(document.getElementById('comp-thresh').value);
    const ratio = parseFloat(document.getElementById('comp-ratio').value);
    const knee = parseFloat(document.getElementById('comp-knee').value);
    const levelDb = linearToDb(level);
    let outputDb = levelDb;
    const kneeStart = threshold - knee / 2;
    const kneeEnd   = threshold + knee / 2;
    if (levelDb > kneeEnd) {
      outputDb = threshold + (levelDb - threshold) / ratio;
    } else if (levelDb > kneeStart) {
      const kneePos = (levelDb - kneeStart) / knee;
      outputDb = levelDb + ((1/ratio - 1) * Math.pow(kneePos, 2) * knee / 2);
    }
    document.getElementById('comp-ratio-val').textContent = ratio.toFixed(1) + ':1';
    document.getElementById('comp-thresh-val').textContent = threshold.toFixed(0) + ' dB';
    document.getElementById('comp-knee-val').textContent   = knee.toFixed(0) + ' dB';
    return dbToLinear(outputDb);
  }

  function processLimiter(level) {
    const ceil = dbToLinear(parseFloat(document.getElementById('lim-ceil').value));
    document.getElementById('lim-ceil-val').textContent = parseFloat(document.getElementById('lim-ceil').value).toFixed(1) + ' dBFS';
    const gr = level > ceil ? (level - ceil) / level : 0;
    const smoothGR = lagLimGR.update(gr, 0.016);
    limGrFill.style.width = (smoothGR * 100) + '%';
    return Math.min(level, ceil);
  }

  function drawGate() {
    const W = gateCanvas.offsetWidth || 300;
    gateCanvas.width = W; gateCanvas.height = 80;
    gCtx.fillStyle = '#0a0a0f'; gCtx.fillRect(0, 0, W, 80);
    // Draw gain reduction history
    gCtx.strokeStyle = '#06b6d4'; gCtx.lineWidth = 1.5;
    gCtx.shadowColor = '#06b6d4'; gCtx.shadowBlur = 4;
    gCtx.beginPath();
    for (let i = 0; i < gateHistory.length; i++) {
      const x = (i / gateHistory.length) * W;
      const y = 70 - gateHistory[(gateHistIdx + i) % gateHistory.length] * 60;
      i === 0 ? gCtx.moveTo(x, y) : gCtx.lineTo(x, y);
    }
    gCtx.stroke(); gCtx.shadowBlur = 0;
    // Threshold line
    const tDb = parseFloat(document.getElementById('gate-thresh').value);
    document.getElementById('gate-thresh-val').textContent = tDb.toFixed(0) + ' dB';
    document.getElementById('gate-atk-val').textContent   = document.getElementById('gate-atk').value + ' ms';
    document.getElementById('gate-rel-val').textContent   = document.getElementById('gate-rel').value + ' ms';
    gCtx.strokeStyle = 'rgba(249,115,22,0.4)'; gCtx.lineWidth = 0.5;
    const ty = 70 - ((tDb + 60) / 60) * 60;
    gCtx.beginPath(); gCtx.moveTo(0, ty); gCtx.lineTo(W, ty); gCtx.stroke();
    gCtx.fillStyle = '#6b6b8a'; gCtx.font = '8px Courier New';
    gCtx.fillText('GATE OPEN', 3, 8);
  }

  function drawCompressor() {
    const W = compCanvas.offsetWidth || 300;
    compCanvas.width = W; compCanvas.height = 100;
    cCtx.fillStyle = '#0a0a0f'; cCtx.fillRect(0, 0, W, 100);

    const threshold = parseFloat(document.getElementById('comp-thresh').value);
    const ratio     = parseFloat(document.getElementById('comp-ratio').value);
    const knee      = parseFloat(document.getElementById('comp-knee').value);

    const pad = 16;
    const plotW = W - pad * 2, plotH = 100 - pad * 2;
    const dbMin = -60, dbMax = 0;

    // Grid
    cCtx.strokeStyle = '#1e1e2e'; cCtx.lineWidth = 0.5;
    for (let db = dbMin; db <= dbMax; db += 20) {
      const x = pad + ((db - dbMin) / (dbMax - dbMin)) * plotW;
      const y = pad + plotH - ((db - dbMin) / (dbMax - dbMin)) * plotH;
      cCtx.beginPath(); cCtx.moveTo(x, pad); cCtx.lineTo(x, pad + plotH); cCtx.stroke();
      cCtx.beginPath(); cCtx.moveTo(pad, y); cCtx.lineTo(pad + plotW, y); cCtx.stroke();
    }
    // 1:1 line
    cCtx.strokeStyle = '#2e2e4e'; cCtx.lineWidth = 1;
    cCtx.beginPath(); cCtx.moveTo(pad, pad + plotH); cCtx.lineTo(pad + plotW, pad); cCtx.stroke();

    // Compression curve
    cCtx.strokeStyle = '#f97316'; cCtx.lineWidth = 2;
    cCtx.shadowColor = '#f97316'; cCtx.shadowBlur = 6;
    cCtx.beginPath();
    const steps = 60;
    for (let i = 0; i <= steps; i++) {
      const inDb = dbMin + (i / steps) * (dbMax - dbMin);
      let outDb = inDb;
      const kneeStart = threshold - knee / 2;
      const kneeEnd   = threshold + knee / 2;
      if (inDb > kneeEnd) {
        outDb = threshold + (inDb - threshold) / ratio;
      } else if (inDb > kneeStart) {
        const kp = (inDb - kneeStart) / knee;
        outDb = inDb + ((1/ratio - 1) * kp * kp * knee / 2);
      }
      const x = pad + ((inDb - dbMin) / (dbMax - dbMin)) * plotW;
      const y = pad + plotH - ((outDb - dbMin) / (dbMax - dbMin)) * plotH;
      i === 0 ? cCtx.moveTo(x, y) : cCtx.lineTo(x, clamp(y, pad, pad + plotH));
    }
    cCtx.stroke(); cCtx.shadowBlur = 0;
    // Threshold marker
    const tx = pad + ((threshold - dbMin) / (dbMax - dbMin)) * plotW;
    cCtx.strokeStyle = 'rgba(139,92,246,0.5)'; cCtx.lineWidth = 1;
    cCtx.beginPath(); cCtx.moveTo(tx, pad); cCtx.lineTo(tx, pad + plotH); cCtx.stroke();
    // Labels
    cCtx.fillStyle = '#6b6b8a'; cCtx.font = '8px Courier New'; cCtx.textAlign = 'left';
    cCtx.fillText('IN →', pad + 2, pad + plotH - 2);
    cCtx.textAlign = 'right';
    cCtx.fillText('↑ OUT', pad + plotW, pad + 10);
  }

  function drawLimiter(level) {
    const W = limCanvas.offsetWidth || 300;
    limCanvas.width = W; limCanvas.height = 80;
    lCtx.fillStyle = '#0a0a0f'; lCtx.fillRect(0, 0, W, 80);

    const ceil = parseFloat(document.getElementById('lim-ceil').value);
    // Simple level meter with brickwall line
    const levelDb = linearToDb(level);
    const meterX = 20, meterW = W - 40, meterH = 20, meterY = 30;

    lCtx.strokeStyle = '#1e1e2e'; lCtx.lineWidth = 1;
    lCtx.strokeRect(meterX, meterY, meterW, meterH);

    // Level fill
    const fillW = Math.max(0, ((levelDb + 60) / 60) * meterW);
    const gradient = lCtx.createLinearGradient(meterX, 0, meterX + meterW, 0);
    gradient.addColorStop(0, '#06b6d4');
    gradient.addColorStop(0.8, '#f97316');
    gradient.addColorStop(1, '#ef4444');
    lCtx.fillStyle = gradient;
    lCtx.fillRect(meterX, meterY, fillW, meterH);

    // Brickwall line
    const bwX = meterX + ((ceil + 60) / 60) * meterW;
    lCtx.strokeStyle = '#ef4444'; lCtx.lineWidth = 2;
    lCtx.shadowColor = '#ef4444'; lCtx.shadowBlur = 6;
    lCtx.beginPath(); lCtx.moveTo(bwX, meterY - 8); lCtx.lineTo(bwX, meterY + meterH + 8); lCtx.stroke();
    lCtx.shadowBlur = 0;
    lCtx.fillStyle = '#ef4444'; lCtx.font = '8px Courier New'; lCtx.textAlign = 'center';
    lCtx.fillText('CEIL', bwX, meterY - 10);
    lCtx.fillStyle = '#6b6b8a'; lCtx.textAlign = 'left';
    lCtx.fillText('BRICKWALL LIMITER', meterX, 18);
  }

  let rafId;
  function loop() {
    rafId = requestAnimationFrame(loop);
    const now = performance.now();
    const dt = (now - prevT) / 1000;
    prevT = now; t += dt;

    simulateSignal(dt);
    const afterGate = processGate(rawLevel);
    const afterComp = processCompressor(afterGate);
    const afterLim  = processLimiter(afterComp);

    // Update gate history
    gateHistory[gateHistIdx] = afterGate / (rawLevel + 1e-9);
    gateHistIdx = (gateHistIdx + 1) % gateHistory.length;

    const smoothIn  = lagIn.update(rawLevel, dt);
    const smoothOut = lagOut.update(afterLim, dt);
    inFill.style.width  = (smoothIn  * 100) + '%';
    outFill.style.width = (smoothOut * 100) + '%';
    inVal.textContent   = linearToDb(smoothIn).toFixed(1)  + ' dB';
    outVal.textContent  = linearToDb(smoothOut).toFixed(1) + ' dB';

    drawGate();
    drawCompressor();
    drawLimiter(smoothOut);
  }
  loop();
})();


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 4 — MODULATION MATRIX
// ═══════════════════════════════════════════════════════════════════════════════
(function initModMatrix() {
  const SOURCES = ['LFO', 'ENV', 'SEQ'];
  const DESTS   = ['Filter Cut', 'Filter Res', 'Pitch', 'Pan', 'Volume', 'Delay Time'];

  // Matrix state [source][dest] = depth 0..1
  const matrixActive = {};
  const matrixDepth  = {};
  SOURCES.forEach(s => { matrixActive[s] = {}; matrixDepth[s] = {}; DESTS.forEach(d => { matrixActive[s][d] = false; matrixDepth[s][d] = 0.5; }); });

  // Build matrix grid UI
  const grid = document.getElementById('mod-matrix-grid');
  grid.innerHTML = '';
  grid.style.gridTemplateColumns = `repeat(${DESTS.length + 1}, 1fr)`;

  // Header row
  const corner = document.createElement('div');
  corner.className = 'matrix-cell header'; corner.textContent = 'SRC \\ DEST';
  grid.appendChild(corner);
  DESTS.forEach(d => {
    const h = document.createElement('div');
    h.className = 'matrix-cell header'; h.textContent = d;
    grid.appendChild(h);
  });
  // Data rows
  SOURCES.forEach(s => {
    const srcCell = document.createElement('div');
    srcCell.className = 'matrix-cell header'; srcCell.textContent = s;
    grid.appendChild(srcCell);
    DESTS.forEach(d => {
      const cell = document.createElement('div');
      cell.className = 'matrix-cell';
      cell.textContent = '·';
      cell.title = `${s} → ${d}`;
      cell.addEventListener('click', () => {
        matrixActive[s][d] = !matrixActive[s][d];
        cell.classList.toggle('active', matrixActive[s][d]);
        cell.textContent = matrixActive[s][d] ? '●' : '·';
      });
      grid.appendChild(cell);
    });
  });

  const lfoCanvas  = document.getElementById('lfo-canvas');
  const envCanvas  = document.getElementById('env-canvas');
  const seqCanvas  = document.getElementById('seq-canvas');
  const monCanvas  = document.getElementById('mod-matrix-canvas');
  const lCtx = lfoCanvas.getContext('2d');
  const eCtx = envCanvas.getContext('2d');
  const sCtx = seqCanvas.getContext('2d');
  const mCtx = monCanvas.getContext('2d');

  const lagLFO = new LagFilter(0.05);
  const lagEnv = new LagFilter(0.05);
  const lagSeq = new LagFilter(0.05);

  // Step sequencer state
  const seqSteps = [0.8, 0.3, 1.0, 0.5, 0.7, 0.2, 0.9, 0.4];
  let seqStep = 0, seqTimer = 0;
  // Envelope follower state
  let envLevel = 0, envTimer = 0, envBurst = false;
  // LFO random state
  let lfoRandTarget = 0, lfoRandCurrent = 0, lfoRandTimer = 0;

  let prevT = performance.now();
  let t = 0;

  function getLFOValue(t) {
    const rate = parseFloat(document.getElementById('lfo-rate').value);
    document.getElementById('lfo-rate-val').textContent = rate.toFixed(1) + ' Hz';
    const shape = document.getElementById('lfo-shape').value;
    const phase = (t * rate) % 1;
    switch (shape) {
      case 'sine':     return Math.sin(phase * Math.PI * 2);
      case 'triangle': return phase < 0.5 ? (phase * 4 - 1) : (3 - phase * 4);
      case 'square':   return phase < 0.5 ? 1 : -1;
      case 'ramp':     return phase * 2 - 1;
      case 'random':   return lfoRandCurrent;
      default: return 0;
    }
  }

  function updateRandomLFO(dt) {
    const rate = parseFloat(document.getElementById('lfo-rate').value);
    lfoRandTimer += dt * rate;
    if (lfoRandTimer >= 1) { lfoRandTimer = 0; lfoRandTarget = Math.random() * 2 - 1; }
    lfoRandCurrent += (lfoRandTarget - lfoRandCurrent) * Math.min(1, dt * 20);
  }

  function updateEnvFollower(dt) {
    envTimer += dt;
    if (envTimer > 2.5) { envTimer = 0; envBurst = true; }
    if (envBurst && envTimer > 0.4) envBurst = false;
    const atkMs = parseFloat(document.getElementById('env-atk').value);
    const relMs = parseFloat(document.getElementById('env-rel').value);
    document.getElementById('env-atk-val').textContent = atkMs.toFixed(0) + ' ms';
    document.getElementById('env-rel-val').textContent = relMs.toFixed(0) + ' ms';
    const target = envBurst ? 1 : 0;
    if (target > envLevel) envLevel += (target - envLevel) * Math.min(1, dt / (atkMs / 1000));
    else envLevel += (target - envLevel) * Math.min(1, dt / (relMs / 1000));
  }

  function updateSeq(dt) {
    const bpm = parseFloat(document.getElementById('seq-bpm').value);
    document.getElementById('seq-bpm-val').textContent = Math.round(bpm);
    const stepTime = 60 / bpm / 2;
    seqTimer += dt;
    if (seqTimer >= stepTime) { seqTimer -= stepTime; seqStep = (seqStep + 1) % 8; }
  }

  function drawLFOCanvas(lfoVal) {
    const W = lfoCanvas.offsetWidth || 200;
    lfoCanvas.width = W; lfoCanvas.height = 70;
    lCtx.fillStyle = 'rgba(10,10,15,0.3)'; lCtx.fillRect(0, 0, W, 70);
    lCtx.strokeStyle = '#f97316'; lCtx.lineWidth = 1.5;
    lCtx.shadowColor = '#f97316'; lCtx.shadowBlur = 6;
    const rate = parseFloat(document.getElementById('lfo-rate').value);
    const shape = document.getElementById('lfo-shape').value;
    lCtx.beginPath();
    for (let i = 0; i < W; i++) {
      const tt = t - (W - i) / W * (2 / rate);
      const phase = (tt * rate) % 1;
      let v;
      switch (shape) {
        case 'sine':     v = Math.sin(phase * Math.PI * 2); break;
        case 'triangle': v = phase < 0.5 ? (phase * 4 - 1) : (3 - phase * 4); break;
        case 'square':   v = phase < 0.5 ? 1 : -1; break;
        case 'ramp':     v = phase * 2 - 1; break;
        case 'random':   v = lfoRandCurrent; break;
        default: v = 0;
      }
      const y = 35 - v * 28;
      i === 0 ? lCtx.moveTo(i, y) : lCtx.lineTo(i, y);
    }
    lCtx.stroke(); lCtx.shadowBlur = 0;
    lCtx.fillStyle = '#6b6b8a'; lCtx.font = '8px Courier New'; lCtx.textAlign = 'left';
    lCtx.fillText('LFO', 3, 10);
  }

  function drawEnvCanvas() {
    const W = envCanvas.offsetWidth || 200;
    envCanvas.width = W; envCanvas.height = 70;
    eCtx.fillStyle = 'rgba(10,10,15,0.3)'; eCtx.fillRect(0, 0, W, 70);
    // Current level as filled area
    eCtx.strokeStyle = '#8b5cf6'; eCtx.lineWidth = 1.5;
    eCtx.shadowColor = '#8b5cf6'; eCtx.shadowBlur = 6;
    const y = 65 - envLevel * 55;
    eCtx.fillStyle = 'rgba(139,92,246,0.15)';
    eCtx.fillRect(0, y, W, 65 - y);
    eCtx.beginPath(); eCtx.moveTo(0, y); eCtx.lineTo(W, y); eCtx.stroke();
    eCtx.shadowBlur = 0;
    eCtx.fillStyle = '#6b6b8a'; eCtx.font = '8px Courier New'; eCtx.textAlign = 'left';
    eCtx.fillText('ENV FOLLOWER', 3, 10);
    eCtx.fillStyle = '#8b5cf6';
    eCtx.fillText((envLevel * 100).toFixed(0) + '%', W - 30, 10);
  }

  function drawSeqCanvas() {
    const W = seqCanvas.offsetWidth || 200;
    seqCanvas.width = W; seqCanvas.height = 70;
    sCtx.fillStyle = '#0a0a0f'; sCtx.fillRect(0, 0, W, 70);
    const sw = W / 8;
    seqSteps.forEach((v, i) => {
      const x = i * sw, h = v * 50, y = 65 - h;
      const isActive = i === seqStep;
      sCtx.fillStyle = isActive ? '#06b6d4' : '#1e1e2e';
      sCtx.shadowColor = isActive ? '#06b6d4' : 'transparent';
      sCtx.shadowBlur = isActive ? 8 : 0;
      sCtx.fillRect(x + 2, y, sw - 4, h);
      // Click to edit step values
      sCtx.strokeStyle = '#2e2e4e'; sCtx.lineWidth = 0.5;
      sCtx.strokeRect(x + 1, 14, sw - 2, 52);
    });
    sCtx.shadowBlur = 0;
    sCtx.fillStyle = '#6b6b8a'; sCtx.font = '8px Courier New'; sCtx.textAlign = 'left';
    sCtx.fillText('STEP SEQ', 3, 10);
  }

  // Monitor canvas — shows mod signal waves + active destinations
  function drawMonitor(lfoVal, envVal, seqVal) {
    const W = monCanvas.offsetWidth || 600;
    monCanvas.width = W; monCanvas.height = 160;
    mCtx.fillStyle = 'rgba(10,10,15,0.05)'; mCtx.fillRect(0, 0, W, 160);

    const cols = ['#f97316', '#8b5cf6', '#06b6d4'];
    const labels = ['LFO', 'ENV', 'SEQ'];
    const vals   = [lfoVal, envVal, seqVal];

    vals.forEach((v, si) => {
      const yBase = 30 + si * 45;
      // lane background
      mCtx.fillStyle = 'rgba(255,255,255,0.02)'; mCtx.fillRect(0, yBase - 20, W, 38);
      // label
      mCtx.fillStyle = cols[si]; mCtx.font = '9px Courier New'; mCtx.textAlign = 'left';
      mCtx.fillText(labels[si], 4, yBase - 8);
      // wave line (rolling)
      mCtx.strokeStyle = cols[si]; mCtx.lineWidth = 1.5;
      mCtx.shadowColor = cols[si]; mCtx.shadowBlur = 4;
      mCtx.beginPath();
      mCtx.moveTo(W - 2, yBase - v * 16);
      mCtx.lineTo(W - 2, yBase - v * 16);

      // Check active destinations and draw arrows
      SOURCES.forEach((src, srcI) => {
        if (srcI !== si) return;
        DESTS.forEach((dest, di) => {
          if (matrixActive[src][dest]) {
            const arrowX = 80 + di * ((W - 80) / 6);
            mCtx.globalAlpha = 0.5 + Math.abs(v) * 0.5;
            mCtx.strokeStyle = cols[si]; mCtx.lineWidth = 1;
            mCtx.beginPath();
            mCtx.moveTo(arrowX, yBase - v * 14);
            mCtx.lineTo(arrowX, yBase + 10);
            mCtx.stroke();
            // arrowhead
            mCtx.beginPath();
            mCtx.moveTo(arrowX - 4, yBase + 5);
            mCtx.lineTo(arrowX, yBase + 12);
            mCtx.lineTo(arrowX + 4, yBase + 5);
            mCtx.stroke();
            mCtx.globalAlpha = 1;
          }
        });
      });
      mCtx.shadowBlur = 0;
    });

    // Destination labels at bottom
    mCtx.fillStyle = '#6b6b8a'; mCtx.font = '8px Courier New';
    DESTS.forEach((d, i) => {
      const x = 80 + i * ((W - 80) / 6);
      mCtx.textAlign = 'center';
      mCtx.fillText(d, x, 155);
    });
    mCtx.textAlign = 'left';
  }

  let rafId;
  function loop() {
    rafId = requestAnimationFrame(loop);
    const now = performance.now();
    const dt = (now - prevT) / 1000;
    prevT = now; t += dt;

    updateRandomLFO(dt);
    updateEnvFollower(dt);
    updateSeq(dt);

    const lfoRaw = getLFOValue(t);
    const envRaw = envLevel;
    const seqRaw = seqSteps[seqStep];

    drawLFOCanvas(lfoRaw);
    drawEnvCanvas();
    drawSeqCanvas();
    drawMonitor(lfoRaw, envRaw, seqRaw);
  }
  loop();
})();


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 5 — DISTORTION LAB
// ═══════════════════════════════════════════════════════════════════════════════
(function initDistortion() {
  let distMode = 'softclip';
  const lagDrive = new LagFilter(0.1);
  let t = 0, prevT = performance.now();

  const waveCanvas = document.getElementById('dist-wave-canvas');
  const fftCanvas  = document.getElementById('dist-fft-canvas');
  const wCtx = waveCanvas.getContext('2d');
  const fCtx = fftCanvas.getContext('2d');

  window.setDistMode = function(mode, btn) {
    distMode = mode;
    document.querySelectorAll('.dist-mode-btns button').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const bitsGroup = document.getElementById('dist-bits-group');
    bitsGroup.style.display = mode === 'bitcrush' ? 'flex' : 'none';
  };
  // Hide bits group by default
  document.getElementById('dist-bits-group').style.display = 'none';

  function applyDistortion(x, drive, mode, bits) {
    const d = drive;
    switch (mode) {
      case 'softclip':  return Math.tanh(x * (1 + d * 8));
      case 'hardclip':  { const lim = 1 - d * 0.9; return clamp(x * (1 + d * 5), -lim, lim) / lim; }
      case 'foldback':  {
        let v = x * (1 + d * 4);
        while (Math.abs(v) > 1) v = Math.abs(Math.abs(v) - 2) - 1;
        return v;
      }
      case 'bitcrush':  {
        const levels = Math.pow(2, bits) - 1;
        const boosted = x * (1 + d * 2);
        return Math.round(boosted * levels) / levels;
      }
      case 'wavefold':  {
        let v = x * (1 + d * 6);
        return Math.sin(v * Math.PI * 0.5);
      }
      case 'tube':      {
        const gain = 1 + d * 10;
        // Asymmetric — different positive/negative transfer
        const v = x * gain;
        return v > 0 ? Math.tanh(v * 0.8) * 1.2 : Math.tanh(v * 1.2) * 0.8;
      }
      default: return x;
    }
  }

  function drawWaveform() {
    const W = waveCanvas.offsetWidth || 600;
    const H = 140;
    waveCanvas.width = W; waveCanvas.height = H;
    wCtx.fillStyle = 'rgba(10,10,15,0.3)'; wCtx.fillRect(0, 0, W, H);

    const drive = lagDrive.value !== null ? lagDrive.value / 100 : 0.5;
    const bits  = parseInt(document.getElementById('dist-bits').value);
    const halfW = W / 2;

    // Center line
    wCtx.strokeStyle = '#1e1e2e'; wCtx.lineWidth = 0.5;
    wCtx.beginPath(); wCtx.moveTo(0, H/2); wCtx.lineTo(W, H/2); wCtx.stroke();
    wCtx.beginPath(); wCtx.moveTo(halfW, 0); wCtx.lineTo(halfW, H); wCtx.stroke();

    const N = 200;
    // Input (pure sine)
    wCtx.strokeStyle = '#6b6b8a'; wCtx.lineWidth = 1.5;
    wCtx.beginPath();
    for (let i = 0; i < N; i++) {
      const x = (i / N) * halfW;
      const phase = (i / N) * Math.PI * 4 + t * 1.5;
      const y = H/2 - Math.sin(phase) * (H/2 - 8);
      i === 0 ? wCtx.moveTo(x, y) : wCtx.lineTo(x, y);
    }
    wCtx.stroke();
    wCtx.fillStyle = '#6b6b8a'; wCtx.font = '9px Courier New'; wCtx.textAlign = 'left';
    wCtx.fillText('INPUT', 4, 12);

    // Output (distorted)
    wCtx.strokeStyle = '#f97316'; wCtx.lineWidth = 2;
    wCtx.shadowColor = '#f97316'; wCtx.shadowBlur = 8;
    wCtx.beginPath();
    for (let i = 0; i < N; i++) {
      const x = halfW + (i / N) * halfW;
      const phase = (i / N) * Math.PI * 4 + t * 1.5;
      const sinVal = Math.sin(phase);
      const out = applyDistortion(sinVal, drive, distMode, bits);
      const y = H/2 - out * (H/2 - 8);
      i === 0 ? wCtx.moveTo(x, clamp(y, 2, H-2)) : wCtx.lineTo(x, clamp(y, 2, H-2));
    }
    wCtx.stroke(); wCtx.shadowBlur = 0;
    wCtx.fillStyle = '#f97316';
    wCtx.fillText('OUTPUT', halfW + 4, 12);

    // Divider
    wCtx.strokeStyle = '#1e1e2e'; wCtx.lineWidth = 1;
    wCtx.beginPath(); wCtx.moveTo(halfW, 0); wCtx.lineTo(halfW, H); wCtx.stroke();
  }

  function drawHarmonicSpectrum() {
    const W = fftCanvas.offsetWidth || 600;
    const H = 120;
    fftCanvas.width = W; fftCanvas.height = H;
    fCtx.fillStyle = '#0a0a0f'; fCtx.fillRect(0, 0, W, H);

    // Compute synthetic harmonics based on drive and mode
    const drive = lagDrive.value !== null ? lagDrive.value / 100 : 0.5;
    const bits  = parseInt(document.getElementById('dist-bits').value);
    const numHarmonics = 16;
    const harmonics = [];

    for (let h = 1; h <= numHarmonics; h++) {
      let amp = 0;
      // Generate test signal at fundamental and measure harmonic content
      // Use simplified analytical model per mode
      switch (distMode) {
        case 'softclip': // tanh → odd harmonics dominant
          amp = h === 1 ? 1 : (h % 2 === 1 ? Math.pow(drive, h-1) / (h * h) * 3 : Math.pow(drive, h) / (h * h * 2));
          break;
        case 'hardclip': // square-ish → strong odd harmonics
          amp = h % 2 === 1 ? (1 / h) * drive * 1.5 : Math.pow(drive, h) * 0.1;
          amp = h === 1 ? 1 : amp;
          break;
        case 'foldback': // complex — many harmonics
          amp = h === 1 ? 1 : Math.pow(drive, 0.5) * (0.6 / (h * 0.8));
          break;
        case 'bitcrush': {
          const q = Math.pow(2, bits);
          amp = h === 1 ? 1 : (h <= Math.ceil(q / 2) ? 0.5 / h * drive : 0);
          break;
        }
        case 'wavefold':
          amp = h === 1 ? 1 : (Math.pow(drive, 1.2) * 0.8) / (h * 0.9);
          break;
        case 'tube': // asymmetric → even + odd
          amp = h === 1 ? 1 : (h % 2 === 0 ? drive * 0.7 / h : drive * 0.4 / (h * 0.9));
          break;
        default: amp = h === 1 ? 1 : 0;
      }
      harmonics.push(Math.max(0, Math.min(1, amp)));
    }

    const barW = (W - 24) / numHarmonics - 2;
    const maxH = H - 24;
    harmonics.forEach((amp, i) => {
      const x = 12 + i * (barW + 2);
      const h = amp * maxH;
      const y = H - 12 - h;
      const isOdd = (i + 1) % 2 === 1;
      fCtx.fillStyle = isOdd ? '#f97316' : '#06b6d4';
      fCtx.shadowColor = isOdd ? '#f97316' : '#06b6d4';
      fCtx.shadowBlur = 6;
      fCtx.fillRect(x, y, barW, h);
    });
    fCtx.shadowBlur = 0;

    // Labels
    fCtx.fillStyle = '#f97316'; fCtx.font = '8px Courier New'; fCtx.textAlign = 'left';
    fCtx.fillText('■ Odd harmonics', 12, 11);
    fCtx.fillStyle = '#06b6d4';
    fCtx.fillText('■ Even harmonics', 110, 11);
    fCtx.fillStyle = '#6b6b8a';
    fCtx.fillText('1st', 12 + 0, H - 2);
    fCtx.fillText('3rd', 12 + (barW + 2) * 2, H - 2);
    fCtx.fillText('5th', 12 + (barW + 2) * 4, H - 2);
  }

  document.getElementById('dist-drive').addEventListener('input', () => {
    document.getElementById('dist-drive-val').textContent = document.getElementById('dist-drive').value + '%';
  });
  document.getElementById('dist-bits').addEventListener('input', () => {
    document.getElementById('dist-bits-val').textContent = document.getElementById('dist-bits').value;
  });

  let rafId;
  function loop() {
    rafId = requestAnimationFrame(loop);
    const now = performance.now();
    const dt = (now - prevT) / 1000;
    prevT = now; t += dt;
    lagDrive.update(parseFloat(document.getElementById('dist-drive').value), dt);
    drawWaveform();
    drawHarmonicSpectrum();
  }
  loop();
})();

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 6 — CHORUS / FLANGER / PHASER
// ═══════════════════════════════════════════════════════════════════════════════
(function initModFX() {
  let throughZero = false;
  window.toggleThroughZero = function() {
    throughZero = !throughZero;
    const btn = document.getElementById('flanger-tz-btn');
    btn.textContent = 'Through Zero: ' + (throughZero ? 'ON' : 'OFF');
    btn.classList.toggle('active', throughZero);
  };

  const chorCanvas   = document.getElementById('chorus-canvas');
  const flanCanvas   = document.getElementById('flanger-canvas');
  const phaseCanvas  = document.getElementById('phaser-canvas');
  const chorDialC    = document.getElementById('chorus-dial');
  const flanDialC    = document.getElementById('flanger-dial');
  const phaseDialC   = document.getElementById('phaser-dial');
  const cCtx  = chorCanvas.getContext('2d');
  const fCtx  = flanCanvas.getContext('2d');
  const pCtx  = phaseCanvas.getContext('2d');
  const cdCtx = chorDialC.getContext('2d');
  const fdCtx = flanDialC.getContext('2d');
  const pdCtx = phaseDialC.getContext('2d');

  const lagChoRate  = new LagFilter(0.1);
  const lagChoDepth = new LagFilter(0.1);
  const lagFlanRate = new LagFilter(0.1);
  const lagFlanFB   = new LagFilter(0.1);
  const lagPhRate   = new LagFilter(0.1);

  let t = 0, prevT = performance.now();

  function drawDial(ctx, wetPct, color) {
    ctx.clearRect(0, 0, 40, 40);
    ctx.beginPath();
    ctx.arc(20, 20, 16, Math.PI * 0.75, Math.PI * 2.25, false);
    ctx.strokeStyle = '#1e1e2e'; ctx.lineWidth = 4; ctx.stroke();
    const endAngle = Math.PI * 0.75 + (wetPct / 100) * Math.PI * 1.5;
    ctx.beginPath();
    ctx.arc(20, 20, 16, Math.PI * 0.75, endAngle, false);
    ctx.strokeStyle = color; ctx.lineWidth = 4;
    ctx.shadowColor = color; ctx.shadowBlur = 6;
    ctx.stroke(); ctx.shadowBlur = 0;
  }

  function drawChorus() {
    const W = chorCanvas.offsetWidth || 300;
    const H = 100;
    chorCanvas.width = W; chorCanvas.height = H;
    cCtx.fillStyle = 'rgba(10,10,15,0.25)'; cCtx.fillRect(0, 0, W, H);

    const rate  = lagChoRate.value || 0.5;
    const depth = (lagChoDepth.value || 50) / 100;
    const offsets = [0, depth * 20, -depth * 20]; // delay offset in px-equivalent

    const voices = ['rgba(249,115,22,0.9)', 'rgba(139,92,246,0.7)', 'rgba(6,182,212,0.6)'];
    offsets.forEach((off, vi) => {
      const shimmer = Math.sin(t * rate * Math.PI * 2 + vi * 2.1) * off;
      cCtx.strokeStyle = voices[vi]; cCtx.lineWidth = vi === 0 ? 2 : 1.2;
      cCtx.shadowColor = voices[vi]; cCtx.shadowBlur = vi === 0 ? 6 : 3;
      cCtx.beginPath();
      for (let i = 0; i < W; i++) {
        const phase = (i / W) * Math.PI * 8 + t * 2 + shimmer * 0.15;
        const y = H/2 + Math.sin(phase) * (20 - vi * 3);
        i === 0 ? cCtx.moveTo(i, y) : cCtx.lineTo(i, y);
      }
      cCtx.stroke();
    });
    cCtx.shadowBlur = 0;
    cCtx.fillStyle = '#f97316'; cCtx.font = '8px Courier New'; cCtx.textAlign = 'left';
    cCtx.fillText('3 VOICES', 4, 10);

    document.getElementById('chorus-rate-val').textContent  = document.getElementById('chorus-rate').value + ' Hz';
    document.getElementById('chorus-depth-val').textContent = document.getElementById('chorus-depth').value + '%';
    const wet = parseFloat(document.getElementById('chorus-wet').value);
    document.getElementById('chorus-wet-val').textContent = wet + '%';
    drawDial(cdCtx, wet, '#f97316');
  }

  function drawFlanger() {
    const W = flanCanvas.offsetWidth || 300;
    const H = 100;
    flanCanvas.width = W; flanCanvas.height = H;
    fCtx.fillStyle = 'rgba(10,10,15,0.25)'; fCtx.fillRect(0, 0, W, H);

    const rate = lagFlanRate.value || 0.3;
    const fb   = (lagFlanFB.value || 50) / 100;
    // Comb filter response — delay time sweeps
    const delayMs = throughZero
      ? (Math.sin(t * rate * Math.PI * 2) * 5 + 5)
      : (Math.sin(t * rate * Math.PI * 2) * 3 + 5);
    const delaySamp = delayMs * 44.1;

    fCtx.strokeStyle = '#06b6d4'; fCtx.lineWidth = 1.5;
    fCtx.shadowColor = '#06b6d4'; fCtx.shadowBlur = 6;
    fCtx.beginPath();
    for (let i = 0; i < W; i++) {
      const freq = (i / W) * 8000 + 50;
      const phase = 2 * Math.PI * freq * delaySamp / 44100;
      // Comb filter magnitude: |1 + fb*e^(-j*phase)| / (1 + fb)
      const re = 1 + fb * Math.cos(phase);
      const im = fb * Math.sin(phase);
      const mag = Math.sqrt(re * re + im * im) / (1 + fb + 0.01);
      const dbVal = 20 * Math.log10(Math.max(0.001, mag));
      const y = H/2 - (dbVal / 20) * (H/2 - 6);
      i === 0 ? fCtx.moveTo(i, clamp(y, 4, H-4)) : fCtx.lineTo(i, clamp(y, 4, H-4));
    }
    fCtx.stroke(); fCtx.shadowBlur = 0;
    fCtx.fillStyle = '#6b6b8a'; fCtx.font = '8px Courier New'; fCtx.textAlign = 'left';
    fCtx.fillText('COMB FILTER  delay=' + delayMs.toFixed(1) + 'ms', 4, 10);

    document.getElementById('flanger-rate-val').textContent = document.getElementById('flanger-rate').value + ' Hz';
    document.getElementById('flanger-fb-val').textContent   = document.getElementById('flanger-fb').value + '%';
    const wet = parseFloat(document.getElementById('flanger-wet').value);
    document.getElementById('flanger-wet-val').textContent  = wet + '%';
    drawDial(fdCtx, wet, '#06b6d4');
  }

  function drawPhaser() {
    const W = phaseCanvas.offsetWidth || 300;
    const H = 100;
    phaseCanvas.width = W; phaseCanvas.height = H;
    pCtx.fillStyle = 'rgba(10,10,15,0.25)'; pCtx.fillRect(0, 0, W, H);

    const rate   = lagPhRate.value || 0.4;
    const stages = parseInt(document.getElementById('phaser-stages').value);
    document.getElementById('phaser-stages-val').textContent = stages;
    // Modulated center frequency
    const fc = 500 + Math.sin(t * rate * Math.PI * 2) * 400;

    // All-pass phase response: phi(f) = -2*arctan(f/fc) per stage
    pCtx.strokeStyle = '#8b5cf6'; pCtx.lineWidth = 1.5;
    pCtx.shadowColor = '#8b5cf6'; pCtx.shadowBlur = 6;
    pCtx.beginPath();
    for (let i = 0; i < W; i++) {
      const freq = 20 + (i / W) * 19980;
      // Simplified phaser magnitude — phase peaks at certain frequencies
      let totalPhase = 0;
      for (let s = 0; s < stages; s++) {
        totalPhase += -2 * Math.atan(freq / (fc * (1 + s * 0.3)));
      }
      // Interference between dry and wet creates peaks/notches
      const mag = 0.5 + 0.5 * Math.cos(totalPhase);
      const y = H/2 - mag * (H/2 - 6);
      i === 0 ? pCtx.moveTo(i, y) : pCtx.lineTo(i, y);
    }
    pCtx.stroke(); pCtx.shadowBlur = 0;
    pCtx.fillStyle = '#6b6b8a'; pCtx.font = '8px Courier New'; pCtx.textAlign = 'left';
    pCtx.fillText('PHASE RESPONSE  fc=' + fc.toFixed(0) + 'Hz', 4, 10);

    document.getElementById('phaser-rate-val').textContent = document.getElementById('phaser-rate').value + ' Hz';
    const wet = parseFloat(document.getElementById('phaser-wet').value);
    document.getElementById('phaser-wet-val').textContent = wet + '%';
    drawDial(pdCtx, wet, '#8b5cf6');
  }

  let rafId;
  function loop() {
    rafId = requestAnimationFrame(loop);
    const now = performance.now();
    const dt = (now - prevT) / 1000;
    prevT = now; t += dt;

    lagChoRate.update(parseFloat(document.getElementById('chorus-rate').value), dt);
    lagChoDepth.update(parseFloat(document.getElementById('chorus-depth').value), dt);
    lagFlanRate.update(parseFloat(document.getElementById('flanger-rate').value), dt);
    lagFlanFB.update(parseFloat(document.getElementById('flanger-fb').value), dt);
    lagPhRate.update(parseFloat(document.getElementById('phaser-rate').value), dt);

    drawChorus();
    drawFlanger();
    drawPhaser();
  }
  loop();
})();


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 7 — FX CHAIN ARCHITECT
// ═══════════════════════════════════════════════════════════════════════════════
(function initFXChain() {
  const FX_TYPES = ['Filter','Distortion','Compressor','Delay','Reverb','Chorus','Flanger','Phaser','Pitch Shift','Ring Mod'];
  const FX_COLORS = {
    'Filter':'#06b6d4','Distortion':'#f97316','Compressor':'#f97316','Delay':'#8b5cf6',
    'Reverb':'#8b5cf6','Chorus':'#06b6d4','Flanger':'#06b6d4','Phaser':'#8b5cf6',
    'Pitch Shift':'#f97316','Ring Mod':'#8b5cf6'
  };

  // Chain slots state
  const chain = Array(6).fill(null).map(() => ({ effect: null, bypass: false, wet: 70 }));

  // Build palette
  const palette = document.getElementById('fx-palette');
  FX_TYPES.forEach(fx => {
    const item = document.createElement('div');
    item.className = 'palette-item';
    item.textContent = fx;
    item.draggable = true;
    item.addEventListener('dragstart', e => { e.dataTransfer.setData('fx', fx); });
    // Click to add to first empty slot
    item.addEventListener('click', () => {
      const emptyIdx = chain.findIndex(s => !s.effect);
      if (emptyIdx >= 0) { chain[emptyIdx].effect = fx; renderChain(); }
    });
    palette.appendChild(item);
  });

  // Build chain slot UI
  const slotsEl = document.getElementById('chain-slots');

  function renderChain() {
    slotsEl.innerHTML = '';
    chain.forEach((slot, i) => {
      const el = document.createElement('div');
      el.className = 'chain-slot' + (slot.effect ? ' filled' : '') + (slot.bypass ? ' bypassed' : '');
      el.draggable = !!slot.effect;

      if (slot.effect) {
        const col = FX_COLORS[slot.effect] || '#06b6d4';
        el.style.borderColor = slot.bypass ? '#6b6b8a' : col;

        el.innerHTML = `
          <div class="slot-name" style="color:${slot.bypass ? '#6b6b8a' : col}">${slot.effect}</div>
          <div style="font-size:9px;color:#6b6b8a;margin:2px 0">Wet: ${slot.wet}%</div>
          <div style="display:flex;gap:4px;margin-top:4px">
            <button class="slot-bypass ${slot.bypass ? 'active' : ''}" style="font-size:8px;padding:2px 6px;border-color:${col};" data-i="${i}">
              ${slot.bypass ? 'BYPASSED' : 'ACTIVE'}
            </button>
            <button style="font-size:8px;padding:2px 6px;border-color:#6b6b8a;color:#6b6b8a;" data-remove="${i}">✕</button>
          </div>
          <input type="range" min="0" max="100" value="${slot.wet}" style="margin-top:4px;width:100%" data-wet="${i}">
        `;

        // Events
        el.querySelector(`[data-i="${i}"]`).addEventListener('click', e => {
          e.stopPropagation();
          chain[i].bypass = !chain[i].bypass; renderChain();
        });
        el.querySelector(`[data-remove="${i}"]`).addEventListener('click', e => {
          e.stopPropagation();
          chain[i].effect = null; chain[i].bypass = false; renderChain();
        });
        el.querySelector(`[data-wet="${i}"]`).addEventListener('input', ev => {
          chain[i].wet = parseInt(ev.target.value); renderChain();
        });

        // Drag to reorder
        el.addEventListener('dragstart', e => { e.dataTransfer.setData('slot', i); });
        el.addEventListener('dragover', e => { e.preventDefault(); el.style.outline = '2px solid #f97316'; });
        el.addEventListener('dragleave', () => { el.style.outline = ''; });
        el.addEventListener('drop', e => {
          el.style.outline = '';
          const fromSlot = e.dataTransfer.getData('slot');
          const fromFX   = e.dataTransfer.getData('fx');
          if (fromSlot !== '' && fromSlot !== undefined && fromSlot !== 'undefined') {
            const fi = parseInt(fromSlot);
            const tmp = { ...chain[fi] };
            chain[fi] = { ...chain[i] };
            chain[i] = tmp;
          } else if (fromFX) {
            chain[i].effect = fromFX; chain[i].bypass = false;
          }
          renderChain();
        });
      } else {
        el.textContent = 'drop here';
        el.addEventListener('dragover', e => { e.preventDefault(); el.style.outline = '2px dashed #f97316'; });
        el.addEventListener('dragleave', () => { el.style.outline = ''; });
        el.addEventListener('drop', e => {
          el.style.outline = '';
          const fromSlot = e.dataTransfer.getData('slot');
          const fromFX   = e.dataTransfer.getData('fx');
          if (fromFX) { chain[i].effect = fromFX; }
          else if (fromSlot !== '') {
            const fi = parseInt(fromSlot);
            chain[i].effect = chain[fi].effect;
            chain[i].wet = chain[fi].wet;
            chain[fi].effect = null;
          }
          renderChain();
        });
      }
      slotsEl.appendChild(el);
    });
  }
  renderChain();

  // Presets
  const PRESETS = {
    guitar:  ['Filter','Distortion','Chorus','Delay','Reverb','Compressor'],
    vocal:   ['Gate','Compressor','Reverb','Delay','Filter',null],
    bass:    ['Filter','Compressor','Distortion','Chorus',null,null],
    ambient: ['Reverb','Chorus','Delay','Phaser','Filter',null],
    drum:    ['Compressor','Filter','Limiter',null,null,null]
  };

  window.loadChainPreset = function(name) {
    const p = PRESETS[name] || [];
    chain.forEach((s, i) => { s.effect = p[i] || null; s.bypass = false; s.wet = 70; });
    renderChain();
  };

  window.saveChainPreset = function() {
    const saved = document.getElementById('preset-saved');
    saved.style.display = 'block';
    setTimeout(() => { saved.style.display = 'none'; }, 2000);
  };

  // Chain canvas — animated signal flow particles
  const chainCanvas = document.getElementById('chain-canvas');
  const cCtx = chainCanvas.getContext('2d');
  const inFill  = document.getElementById('chain-in-fill');
  const outFill = document.getElementById('chain-out-fill');

  const lagIn  = new LagFilter(0.08);
  const lagOut = new LagFilter(0.08);

  // Particles
  const particles = [];
  for (let i = 0; i < 12; i++) {
    particles.push({ x: Math.random(), speed: 0.002 + Math.random() * 0.003, y: 0.5 + (Math.random() - 0.5) * 0.3 });
  }

  let t = 0, prevT = performance.now();
  let simLevel = 0, simTimer = 0;

  function loop() {
    requestAnimationFrame(loop);
    const now = performance.now();
    const dt = (now - prevT) / 1000;
    prevT = now; t += dt;

    // Simulate input level
    simTimer += dt;
    if (simTimer > 1.8) { simTimer = 0; }
    simLevel = 0.3 + 0.7 * Math.abs(Math.sin(simTimer * Math.PI / 1.8));

    const activeSlots = chain.filter(s => s.effect && !s.bypass);
    const outMult = activeSlots.reduce((acc, s) => acc * (s.wet / 100 * 0.5 + 0.5), 1);
    const smoothIn  = lagIn.update(simLevel, dt);
    const smoothOut = lagOut.update(simLevel * outMult, dt);
    inFill.style.width  = (smoothIn * 100)  + '%';
    outFill.style.width = (smoothOut * 100) + '%';

    // Draw chain canvas
    const W = chainCanvas.offsetWidth || 600;
    chainCanvas.width = W; chainCanvas.height = 60;
    cCtx.fillStyle = 'rgba(10,10,15,0.2)'; cCtx.fillRect(0, 0, W, 60);

    // Slot boxes
    const slotW = W / 8;
    chain.forEach((slot, i) => {
      if (!slot.effect) return;
      const x = slotW + i * slotW * 0.95;
      const col = FX_COLORS[slot.effect] || '#06b6d4';
      cCtx.globalAlpha = slot.bypass ? 0.2 : 0.7;
      cCtx.strokeStyle = col; cCtx.lineWidth = 1;
      cCtx.strokeRect(x, 15, slotW * 0.8, 28);
      cCtx.fillStyle = col + '22'; cCtx.fillRect(x, 15, slotW * 0.8, 28);
      cCtx.fillStyle = col; cCtx.font = '7px Courier New'; cCtx.textAlign = 'center';
      cCtx.fillText(slot.effect.slice(0, 8), x + slotW * 0.4, 32);
      cCtx.globalAlpha = 1;
    });

    // Signal path line
    cCtx.strokeStyle = '#1e1e2e'; cCtx.lineWidth = 1;
    cCtx.beginPath(); cCtx.moveTo(0, 30); cCtx.lineTo(W, 30); cCtx.stroke();

    // Animate particles
    particles.forEach(p => {
      p.x += p.speed * (1 + simLevel * 2);
      if (p.x > 1.05) { p.x = -0.05; p.y = 0.5 + (Math.random() - 0.5) * 0.3; }

      // Skip particle if it's inside a bypassed slot
      const slotIdx = Math.floor((p.x * W - slotW) / (slotW * 0.95));
      const inSlot = slotIdx >= 0 && slotIdx < 6 && chain[slotIdx].effect;
      const bypassed = inSlot && chain[slotIdx].bypass;

      cCtx.globalAlpha = bypassed ? 0.1 : 0.85;
      const col = bypassed ? '#6b6b8a' : '#06b6d4';
      cCtx.fillStyle = col;
      cCtx.shadowColor = col; cCtx.shadowBlur = bypassed ? 0 : 6;
      cCtx.beginPath();
      cCtx.arc(p.x * W, p.y * 60, 2.5, 0, Math.PI * 2);
      cCtx.fill();
    });
    cCtx.shadowBlur = 0; cCtx.globalAlpha = 1;
  }
  loop();
})();

// ═══════════════════════════════════════════════════════════════════════════════
// INTERSECTION OBSERVER — SCROLL ANIMATIONS
// ═══════════════════════════════════════════════════════════════════════════════
(function initScrollAnimations() {
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.hidden').forEach(el => obs.observe(el));
})();

// ═══════════════════════════════════════════════════════════════════════════════
// NAV ACTIVE STATE
// ═══════════════════════════════════════════════════════════════════════════════
(function initNav() {
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        navLinks.forEach(a => {
          a.style.color = a.getAttribute('href') === '#' + e.target.id ? 'var(--accent)' : '';
        });
      }
    });
  }, { threshold: 0.3 });
  sections.forEach(s => obs.observe(s));
})();

</script>
