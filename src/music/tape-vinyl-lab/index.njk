function resizeAllCanvases() {
  [satCurveCanvas, satSpecCanvas, wfWaveCanvas, wfPitchCanvas, riaaCanvas, stackCanvas].forEach(c => {
    if (!c) return;
    const parent = c.parentElement;
    if (parent && parent.offsetWidth > 0) {
      const ratio = c.height / c.width || 0.5;
      c.style.height = '';
    }
  });
}
window.addEventListener('resize', resizeAllCanvases);
resizeAllCanvases();

