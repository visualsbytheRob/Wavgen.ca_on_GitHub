function drawRouting(t){
  const W=rtC.width,H=rtC.height;
  rtX.fillStyle='rgba(2,8,6,0.88)';rtX.fillRect(0,0,W,H);
  const nodes=[
    {id:'ch1',label:'CH1\nDRUMS',x:0.08,y:0.3,color:'#FF4040'},
    {id:'ch2',label:'CH2\nBASSS',x:0.08,y:0.55,color:'#00CC44'},
    {id:'ch3',label:'CH3\nGUITAR',x:0.08,y:0.8,color:'#D4820A'},
    {id:'mix',label:'MIX\nBUS',x:0.35,y:0.55,color:'#80EE90'},
    {id:'echo',label:'ECHO\nRE-201',x:0.6,y:0.25,color:'#D4820A'},
    {id:'spring',label:'SPRING\nREVERB',x:0.6,y:0.55,color:'#80EE90'},
    {id:'ret1',label:'RETURN\nECHO',x:0.78,y:0.3,color:'#D4820A'},
    {id:'ret2',label:'RETURN\nREVERB',x:0.78,y:0.65,color:'#80EE90'},
    {id:'master',label:'MASTER\nOUT',x:0.93,y:0.47,color:'#00CC44'},
  ];
  const edges=[
    {from:'ch1',to:'mix'},{from:'ch2',to:'mix'},{from:'ch3',to:'mix'},
    {from:'mix',to:'echo',dashed:true},{from:'mix',to:'spring',dashed:true},
    {from:'echo',to:'ret1'},{from:'spring',to:'ret2'},
    {from:'mix',to:'master'},{from:'ret1',to:'master'},{from:'ret2',to:'master'},
  ];
  const pos={};
  nodes.forEach(n=>{pos[n.id]={x:n.x*W,y:n.y*H};});

  edges.forEach(e=>{
    const a=pos[e.from],b=pos[e.to];if(!a||!b)return;
    rtX.strokeStyle=e.dashed?'rgba(212,130,10,0.3)':'rgba(0,204,68,0.2)';
    rtX.lineWidth=1.5;
    if(e.dashed)rtX.setLineDash([4,6]);
    rtX.beginPath();
    const cpx=(a.x+b.x)/2,cpy=a.y;
    rtX.moveTo(a.x+44,a.y);
    rtX.quadraticCurveTo(cpx,cpy,b.x-8,b.y);
    rtX.stroke();
    rtX.setLineDash([]);
  });

  rtPackets=rtPackets.filter(p=>p.t<1);
  rtPackets.forEach(p=>{
    p.t+=p.speed;
    const e=edges[Math.min(p.from,edges.length-1)];
    const a=pos[e.from],b=pos[e.to];if(!a||!b)return;
    const px=lerp(a.x+44,b.x-8,p.t);
    const py=lerp(a.y,b.y,p.t);
    rtX.beginPath();rtX.arc(px,py,4,0,Math.PI*2);
    rtX.fillStyle=e.dashed?'#D4820A':'#00CC44';
    rtX.shadowBlur=8;rtX.shadowColor=rtX.fillStyle;
    rtX.fill();rtX.shadowBlur=0;
  });

  nodes.forEach(n=>{
    const {x,y}=pos[n.id];const w=88,h=36;
    rtX.fillStyle='#0A1410';rtX.strokeStyle=n.color;rtX.lineWidth=1.5;
    rtX.fillRect(x-w/2,y-h/2,w,h);rtX.strokeRect(x-w/2,y-h/2,w,h);
    rtX.fillStyle=n.color;rtX.font='8px Courier New';rtX.textAlign='center';
    n.label.split('\n').forEach((line,li)=>rtX.fillText(line,x,y+(li-0.5)*12));
  });
}

