function drawSpring(t){
  const W=spC.width,H=spC.height;
  spX.fillStyle='rgba(2,8,6,0.2)';spX.fillRect(0,0,W,H);
  const tension=lagTension.value;
  const drive=lagDrive.value;
  const crash=lagCrash.value;
  const COILS=20;
  const springX=20,springW=W-40;
  const sy=H/2;
  // Spring coils
  spX.strokeStyle='rgba(0,204,68,0.6)';spX.lineWidth=2;spX.beginPath();
  for(let x=0;x<springW;x++){
    const fi=x/springW;
    const coilPhase=fi*COILS*Math.PI*2;
    const tension_wobble=drive*(1-fi)*Math.sin(coilPhase*tension*2+t*10)*8;
    const waveform=Math.sin(coilPhase+t*2)*(4+tension*4);
    const crashWave=crash*Math.sin(coilPhase*3+t*30)*(2*(1-fi));
    const y=sy+waveform+tension_wobble+crashWave;
    x===0?spX.moveTo(springX+x,y):spX.lineTo(springX+x,y);
  }
  spX.stroke();
  // Transducer
  spX.fillStyle='#D4820A';
  spX.fillRect(springX-8,sy-12,8,24);
  spX.fillStyle='#00CC44';
  spX.fillRect(springX+springW,sy-12,8,24);
  // Labels
  spX.fillStyle='#D4820A';spX.font='8px Courier New';spX.textAlign='center';
  spX.fillText('IN',springX-4,sy-16);
  spX.fillStyle='#00CC44';
  spX.fillText('OUT',springX+springW+4,sy-16);
  spX.fillStyle='#447044';spX.font='9px Courier New';spX.textAlign='left';
  spX.fillText(`SPRING REVERB  TENSION: ${Math.round(tension*100)}%`,8,20);

  // IR Canvas
  const WI=spirC.width,HI=spirC.height;
  spirX.fillStyle='rgba(2,8,6,0.2)';spirX.fillRect(0,0,WI,HI);
  spirX.fillStyle='#447044';spirX.font='9px Courier New';spirX.textAlign='left';
  spirX.fillText('IMPULSE RESPONSE',8,18);
  const decay=lagSpringDecay.value;
  spirX.strokeStyle='rgba(212,130,10,0.8)';spirX.lineWidth=1.5;spirX.beginPath();
  for(let x=0;x<WI;x++){
    const xf=x/WI;
    const env=Math.exp(-xf*decay);
    const noise=fbm(xf*8+t*0.05,t*0.03)*2-1;
    const crashComp=crash*Math.sin(xf*80)*Math.exp(-xf*20)*0.5;
    const w=env*(noise*0.4+crashComp);
    x===0?spirX.moveTo(x,HI/2+w*HI*0.4):spirX.lineTo(x,HI/2+w*HI*0.4);
  }
  spirX.stroke();
  // RT60 line
  const rt60x=WI*(1/decay);
  spirX.strokeStyle='rgba(0,204,68,0.4)';spirX.setLineDash([4,6]);
  spirX.beginPath();spirX.moveTo(rt60x,20);spirX.lineTo(rt60x,HI-20);spirX.stroke();
  spirX.setLineDash([]);
  spirX.fillStyle='#00CC44';spirX.font='8px Courier New';spirX.textAlign='center';
  spirX.fillText(`RT60: ${decay.toFixed(1)}s`,rt60x,HI-8);
}

