function drawMixerCanvas(t){
  const W=mxC.width,H=mxC.height;
  mxX.fillStyle='rgba(2,8,6,0.88)';mxX.fillRect(0,0,W,H);
  // Stereo VU meters
  const meterW=W/3;
  ['L','R'].forEach((ch,ci)=>{
    const mx=ci*(meterW+4)+W/2-meterW-2;
    const level=0.5+noise21(ci*5,t*0.8)*0.4;
    const h=level*(H-20);
    // Background
    mxX.fillStyle='rgba(0,204,68,0.08)';
    mxX.fillRect(mx,10,meterW,H-20);
    // Level
    const grad=mxX.createLinearGradient(0,H-10,0,10);
    grad.addColorStop(0,'#00CC44');grad.addColorStop(0.6,'#80EE90');grad.addColorStop(0.85,'#D4820A');grad.addColorStop(1,'#FF4040');
    mxX.fillStyle=grad;
    mxX.fillRect(mx,H-10-h,meterW,h);
    mxX.fillStyle='#447044';mxX.font='9px Courier New';mxX.textAlign='center';
    mxX.fillText(ch,mx+meterW/2,H-2);
  });
  // Waveform display
  mxX.strokeStyle='rgba(0,204,68,0.5)';mxX.lineWidth=1.5;mxX.beginPath();
  for(let x=0;x<W;x++){
    const xf=x/W;
