<!-- S8: GLOSSARY -->
<section class="hidden" id="s8">
<div class="section-label">08 · REFERENCE</div>
<div class="section-title">Dub Lexicon</div>
<div class="gloss-grid">
<div class="gloss-item"><div class="gloss-term">Dub</div><div class="gloss-def">Instrumental remix created by isolating, manipulating, and re-mixing individual tracks of a reggae recording. Emerged in Jamaica in the early 1970s through engineers like King Tubby and Rudolf Redwood.</div></div>
<div class="gloss-item"><div class="gloss-term">Riddim</div><div class="gloss-def">The instrumental track — drum, bass, rhythm guitar, and keyboard foundation — over which multiple vocal artists record separate cuts. One riddim can underpin dozens of recordings across years and labels.</div></div>
<div class="gloss-item"><div class="gloss-term">Space Echo (RE-201)</div><div class="gloss-def">Roland's classic tape echo unit using a loop of magnetic tape with multiple playback heads. Variable tape speed controls echo rate; feedback routes delayed signal back to the input for self-oscillating repeats.</div></div>
<div class="gloss-item"><div class="gloss-term">Drop</div><div class="gloss-def">The sudden removal of one or more instrument channels from the mix — bass drops out, melody drops out, leaving space that feels louder than its absence. The fundamental tension-release technique of dub production.</div></div>
<div class="gloss-item"><div class="gloss-term">Echo Chamber</div><div class="gloss-def">A physical room or chamber where audio is played through a speaker and recorded with a microphone to capture room reflections. Original studios used actual echo chambers before spring reverbs became standard.</div></div>
<div class="gloss-item"><div class="gloss-term">Spring Reverb</div><div class="gloss-def">Reverb unit using a suspended coil spring as a delay medium. Audio drives a transducer at one end; waves travel the spring's length and return as reflections. Distinctive crash and twang — the signature sound of dub reverb.</div></div>
<div class="gloss-item"><div class="gloss-term">Send / Return</div><div class="gloss-def">Routing architecture where a portion of a channel signal is sent to an effects unit (echo, reverb) via a send bus; the processed signal returns on a separate return channel. Enables shared effects with per-channel intensity control.</div></div>
<div class="gloss-item"><div class="gloss-term">Version</div><div class="gloss-def">The B-side of a Jamaican single — typically an instrumental or dub mix of the A-side. The version tradition established remix culture: the same riddim existing in multiple simultaneous forms for different audiences.</div></div>
<div class="gloss-item"><div class="gloss-term">Pre-Fader Send</div><div class="gloss-def">A send taken from the channel signal before the fader — so pulling down the fader mutes the direct signal but continues feeding the echo/reverb. Creates the effect of echoes hanging in space after the instrument disappears.</div></div>
<div class="gloss-item"><div class="gloss-term">Sound System</div><div class="gloss-def">A mobile DJ and amplification apparatus — often custom-built with custom speaker cabinets — used for outdoor dance events. The competitive sound system culture of Kingston in the 1960s was the nursery of Jamaican popular music.</div></div>
<div class="gloss-item"><div class="gloss-term">Feedback Loop</div><div class="gloss-def">Routing the output of an echo or reverb unit back to its own input, creating self-sustaining, building echoes that can escalate toward controlled chaos. A signature technique of King Tubby and Lee Perry.</div></div>
<div class="gloss-item"><div class="gloss-term">Wow and Flutter</div><div class="gloss-def">Speed variations in tape transport: Wow = slow pitch variation below 6 Hz; Flutter = faster variation 6-100 Hz. In dub, intentional wow adds psychedelic pitch wobble to echo repeats — an aesthetic feature rather than a defect.</div></div>
<div class="gloss-item"><div class="gloss-term">One Drop</div><div class="gloss-def">Reggae rhythmic pattern where the kick drum emphasis falls on beat three rather than one — the "one" is dropped. Creates the characteristic floating suspension of reggae and dub rhythm.</div></div>
<div class="gloss-item"><div class="gloss-term">Plate Reverb</div><div class="gloss-def">Large metal plate (typically 2m × 1m) suspended in a frame, driven by a transducer and sensed by contact microphones. Creates dense, smooth reverb — less mechanical than spring, more mechanical than digital.</div></div>
<div class="gloss-item"><div class="gloss-term">Channel Strip</div><div class="gloss-def">A vertical section of a mixing console containing gain, EQ, auxiliary sends, channel fader, and routing matrix for one input signal. In dub, the channel strip is played as an instrument — fader position is a performance parameter.</div></div>
<div class="gloss-item"><div class="gloss-term">Delay Time</div><div class="gloss-def">The time interval between input and echo repeat, typically synced to a tempo subdivision (quarter-note, dotted eighth). In tape echo, delay time is a function of tape speed and physical head spacing — continuously variable.</div></div>
<div class="gloss-item"><div class="gloss-term">Autopan</div><div class="gloss-def">LFO-driven panning effect rotating audio between left and right channels at a rhythmic rate. In dub, extreme autopan creates spatial movement that animates the stereo field and simulates echo chamber positioning.</div></div>
<div class="gloss-item"><div class="gloss-term">Half-Step (Steppers)</div><div class="gloss-def">Reggae subgenre with four-on-the-floor kick drum pattern — all four beats emphasised. Associated with the Rasta nyahbinghi tradition and 1970s roots reggae. The rhythmic foundation of much UK dub.</div></div>
<div class="gloss-item"><div class="gloss-term">DUB Plate</div><div class="gloss-def">An acetate disc cut one-at-a-time for exclusive use by a sound system or artist — not commercially released. Contains exclusive mixes, specials, or artist greetings for competitive sound system events.</div></div>
<div class="gloss-item"><div class="gloss-term">Selector</div><div class="gloss-def">The DJ role in sound system culture — choosing and playing the records. The Selector curates the selection of riddims and artists, responding to crowd energy and competing against rival systems' selections.</div></div>
<div class="gloss-item"><div class="gloss-term">Roots Dub</div><div class="gloss-def">The foundational style of dub — deep bass, sparse percussion, extended echo and reverb, politically conscious lyrical content. Pioneered by King Tubby, Augustus Pablo, and Scientist in the 1970s Kingston studio complex.</div></div>
<div class="gloss-item"><div class="gloss-term">Oscillator (Dub)</div><div class="gloss-def">In live dub performance, a test-tone oscillator fed through the echo chain creates pure sine-wave repeats that can be tuned to the key of the riddim, producing bass-frequency drone feedback effects.</div></div>
</div>
</section>
<script>
const lerp=(a,b,t)=>a+(b-a)*t;
const clamp=(v,lo,hi)=>Math.max(lo,Math.min(hi,v));
const rand=(lo=0,hi=1)=>lo+Math.random()*(hi-lo);
function noise21(x,y){const ix=Math.floor(x),iy=Math.floor(y);const fx=x-ix,fy=y-iy;const ux=fx*fx*(3-2*fx),uy=fy*fy*(3-2*fy);const h=(a,b)=>{let n=(a*1619+b*31337)^(a*31337);n=(n>>8)^n;return(n&0xffff)/65535;};return lerp(lerp(h(ix,iy),h(ix+1,iy),ux),lerp(h(ix,iy+1),h(ix+1,iy+1),ux),uy);}
function fbm(x,y,oct=4){let v=0,a=0.5,f=1;for(let i=0;i<oct;i++){v+=a*noise21(x*f,y*f);a*=0.5;f*=2.1;}return v;}

class LagFilter{constructor(init,tau){this.value=init;this.tau=tau;}update(target,dt){const k=1-Math.exp(-dt/this.tau);this.value+=k*(target-this.value);return this.value;}}
const lagHMX=new LagFilter(0.5,0.9);
const lagHMY=new LagFilter(0.5,0.9);
const lagHPulse=new LagFilter(0,0.15);
const lagEchoRate=new LagFilter(0.4,0.5);
const lagFeedback=new LagFilter(0.55,0.4);
const lagWF=new LagFilter(0.3,0.4);
const lagTension=new LagFilter(0.5,0.4);
const lagDrive=new LagFilter(0.4,0.3);
const lagSpringDecay=new LagFilter(3,0.5);
const lagCrash=new LagFilter(0.2,0.3);
const lagEchoSend=new LagFilter(0.4,0.3);
const lagRevSend=new LagFilter(0.3,0.3);
const lagBPM=new LagFilter(90,1.0);
const lagDropAnim=new LagFilter(0,0.1);
const lagRiddimEnergy=new LagFilter(0.7,0.2);
const lagSpringAnim=new LagFilter(0,0.08);
const lagMixAnim=new LagFilter(0,0.12);

let mouseX=0.5,mouseY=0.5;
document.addEventListener('mousemove',e=>{mouseX=e.clientX/window.innerWidth;mouseY=e.clientY/window.innerHeight;});

// HERO WebGL
const hc=document.getElementById('hero-canvas');
hc.width=window.innerWidth;hc.height=440;
window.addEventListener('resize',()=>{hc.width=window.innerWidth;hc.height=440;initHGL();});
const HVS=`attribute vec2 pos;void main(){gl_Position=vec4(pos,0,1);}`;
const HFS=`
precision highp float;
uniform vec2 u_res;uniform float u_time;uniform vec2 u_mouse;uniform float u_pulse;
float hash(vec2 p){p=fract(p*vec2(127.1,311.7));p+=dot(p,p+17.5);return fract(p.x*p.y);}
float noise(vec2 p){vec2 i=floor(p),f=fract(p);vec2 u=f*f*(3.-2.*f);return mix(mix(hash(i),hash(i+vec2(1,0)),u.x),mix(hash(i+vec2(0,1)),hash(i+vec2(1)),u.x),u.y);}
float fbm(vec2 p){float v=0.,a=.5;for(int i=0;i<5;i++){v+=a*noise(p);a*=.5;p=p*2.1+vec2(1.7,9.2);}return v;}
void main(){
  vec2 uv=gl_FragCoord.xy/u_res;
  vec2 st=uv*2.-1.;st.x*=u_res.x/u_res.y;
  float t=u_time;
  // Echo trails — multiple delayed versions of same wave
  float echoTrails=0.;
  for(int i=0;i<8;i++){
    float fi=float(i)/8.;
    float delay=fi*0.4;
    float decay=pow(0.6,float(i));
    float wave=sin(st.x*6.+t*2.-delay*12.)*0.12*decay;
    float trail=exp(-abs(st.y-wave)*18.)*decay;
    echoTrails+=trail;
  }
  // Dub psychedelic background field
  vec2 q=vec2(fbm(st*0.4+t*0.04+vec2(0,u_mouse.y)),fbm(st*0.4+vec2(1.7,9.2)+t*0.03));
  vec2 r=vec2(fbm(st*0.6+2.*q+t*0.02),fbm(st*0.6+2.*q+vec2(8.3,2.8)+t*0.02));
  float f=fbm(st+2.*r);
  // Smoke green cols
  vec3 dubGreen=vec3(0.,0.8,0.26);
  vec3 echoAmber=vec3(0.83,0.51,0.04);
  vec3 smokeBlack=vec3(0.01,0.03,0.01);
  vec3 col=smokeBlack;
  col+=dubGreen*echoTrails*0.5;
  col+=mix(dubGreen,echoAmber,f)*f*0.15;
  col+=echoAmber*u_pulse*0.3;
  // Mouse echo center
  vec2 ms=u_mouse*2.-1.;ms.x*=u_res.x/u_res.y;
  col+=dubGreen*exp(-length(st-ms)*4.)*0.25;
  // Smoke grain
  col+=vec3(0.02,0.04,0.01)*noise(st*30.+t)*0.3;
  float vig=1.-length(uv-0.5)*1.5;
  col*=clamp(vig,0.,1.);
  gl_FragColor=vec4(col,1.);
}`;
let hgl,hprog,huniforms={};
function initHGL(){
  hgl=hc.getContext('webgl');if(!hgl)return;
  function mkS(t,src){const s=hgl.createShader(t);hgl.shaderSource(s,src);hgl.compileShader(s);return s;}
  if(hprog)hgl.deleteProgram(hprog);
  hprog=hgl.createProgram();
  hgl.attachShader(hprog,mkS(hgl.VERTEX_SHADER,HVS));
  hgl.attachShader(hprog,mkS(hgl.FRAGMENT_SHADER,HFS));
  hgl.linkProgram(hprog);hgl.useProgram(hprog);
  const buf=hgl.createBuffer();hgl.bindBuffer(hgl.ARRAY_BUFFER,buf);
  hgl.bufferData(hgl.ARRAY_BUFFER,new Float32Array([-1,-1,1,-1,-1,1,1,1]),hgl.STATIC_DRAW);
  const pl=hgl.getAttribLocation(hprog,'pos');hgl.enableVertexAttribArray(pl);hgl.vertexAttribPointer(pl,2,hgl.FLOAT,false,0,0);
  huniforms={res:hgl.getUniformLocation(hprog,'u_res'),time:hgl.getUniformLocation(hprog,'u_time'),mouse:hgl.getUniformLocation(hprog,'u_mouse'),pulse:hgl.getUniformLocation(hprog,'u_pulse')};
}
initHGL();

