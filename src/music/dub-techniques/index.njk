let echoSignals=[];

function drawEcho(t){
  const W=ecC.width,H=ecC.height;
  ecX.fillStyle='rgba(2,8,6,0.18)';
  ecX.fillRect(0,0,W,H);
  const echoRate=lagEchoRate.value;
  const fb=lagFeedback.value;
  const wf=lagWF.value;
  const nHeads=parseInt(document.getElementById('sl-heads').value);

  // Tape loop visualization
  const loopY=60,loopH=H*0.55;
  const tapeX=40,tapeW=W-80;

  // Write head
  ecX.fillStyle='rgba(0,204,68,0.2)';
  ecX.fillRect(tapeX,loopY,10,loopH);
  ecX.fillStyle='#00CC44';ecX.font='9px Courier New';ecX.textAlign='center';
  ecX.fillText('W',tapeX+5,loopY-6);

  // Read heads
  for(let h=0;h<nHeads;h++){
    const hx=tapeX+tapeW*(h+1)/(nHeads+1);
    ecX.fillStyle=`rgba(212,130,10,0.2)`;
    ecX.fillRect(hx-5,loopY,10,loopH);
    ecX.fillStyle='#D4820A';ecX.font='9px Courier New';ecX.textAlign='center';
    ecX.fillText(`R${h+1}`,hx,loopY-6);
    // Delay time label
    const delayMs=Math.round(echoRate*1000*(h+1)/(nHeads));
    ecX.fillStyle='#447044';ecX.font='8px Courier New';
    ecX.fillText(`${delayMs}ms`,hx,loopY+loopH+16);
  }

  // Tape (animated oxide particles)
  const tapePhase=(t*0.5)%1;
  for(let i=0;i<80;i++){
    const fi=(i/80+tapePhase)%1;
    const px=tapeX+fi*tapeW;
    const level=noise21(fi*20,t*0.2);
    const py=loopY+loopH/2+(level-0.5)*loopH*0.6;
    const col=level>0.6?'#00CC44':level>0.4?'#447044':'#224422';
    ecX.fillStyle=col;
    ecX.fillRect(px,py,2,2);
  }

  // Echo cascade visual
  const cascadeY=loopY+loopH+40;
  const maxEchos=12;
  for(let e=0;e<maxEchos;e++){
    const fe=e/maxEchos;
    const decay=Math.pow(fb,e);
    if(decay<0.01)break;
    const ex=tapeX+fe*(W-tapeX-40);
    const bh=(1-fe)*40*decay;
    // Wow/flutter: slight pitch wobble
    const wfOffset=wf*Math.sin(t*3+e*0.7)*4;
    ecX.strokeStyle=`rgba(0,204,68,${decay*0.7})`;
    ecX.lineWidth=1;
    ecX.beginPath();
    for(let px=0;px<60;px++){
      const wave=Math.sin(px*0.3+t*4+e*0.5)*bh+wfOffset;
      px===0?ecX.moveTo(ex+px,cascadeY+wave):ecX.lineTo(ex+px,cascadeY+wave);
    }
    ecX.stroke();
    ecX.fillStyle=`rgba(0,204,68,${decay*0.3})`;
    ecX.beginPath();ecX.arc(ex+5,cascadeY,4,0,Math.PI*2);ecX.fill();
    ecX.fillStyle=`rgba(212,130,10,${decay*0.5})`;
    ecX.font='8px Courier New';ecX.textAlign='center';
    ecX.fillText(`-${Math.round(20*Math.log10(decay))}dB`,ex+30,cascadeY+30);
  }
}

