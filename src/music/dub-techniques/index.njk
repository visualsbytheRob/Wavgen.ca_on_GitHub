    const w=Math.sin(xf*40+t*6)*0.3*(dropActive?0.1:1)*Math.sin(beat)*0.8;
    x===0?mxX.moveTo(x,H/2+w*H*0.4):mxX.lineTo(x,H/2+w*H*0.4);
  }
  mxX.stroke();
  mxX.fillStyle='#447044';mxX.font='9px Courier New';mxX.textAlign='left';
  mxX.fillText(dropActive?'◀ DROP ACTIVE ▶':'LIVE MIX',4,14);
