let currentDepth = 0;
let waterAnimRaf = null;
let depthSoundSrc = null;
const depthData = [
  { depth:0, name:'Surface', desc:'Surf noise, seagull cries, wind across water. Sound travels both in air and begins coupling into the ocean.', freqPeak:1200, reverb:0.2, color:'#bae6fd' },
