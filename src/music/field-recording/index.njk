    volSlider.type = 'range'; volSlider.min = 0; volSlider.max = 1; volSlider.step = 0.01;
    volSlider.value = s.vol; volSlider.style.flex = '1';
    volSlider.oninput = e => { s.vol = parseFloat(e.target.value); drawTimeline(); };
    const panSlider = document.createElement('input');
    panSlider.type = 'range'; panSlider.min = -1; panSlider.max = 1; panSlider.step = 0.01;
    panSlider.value = s.pan; panSlider.style.width='60px';
    panSlider.oninput = e => { s.pan = parseFloat(e.target.value); };
    row.appendChild(cb); row.appendChild(label); row.appendChild(volSlider); row.appendChild(panSlider);
    ctrl.appendChild(row);
  });
}

function drawTimeline() {
  const canvas = document.getElementById('timeline-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle = '#0d0d14'; ctx.fillRect(0,0,W,H);

  const slotH = (H - 30) / compSlots.length;
  const timeW = W - 120;

  // Draw landscape contour background
  ctx.save();
  const landscapeGrad = ctx.createLinearGradient(0,0,0,H);
  landscapeGrad.addColorStop(0,'rgba(13,148,136,0.03)'); landscapeGrad.addColorStop(1,'rgba(13,148,136,0.01)');
  ctx.fillStyle = landscapeGrad; ctx.fillRect(0,0,W,H);
  ctx.restore();

  compSlots.forEach((s, i) => {
    const y = 10 + i * slotH;
    if (!s.active) {
      ctx.fillStyle = 'rgba(30,30,46,0.3)'; ctx.fillRect(120, y, timeW, slotH-2);
      ctx.fillStyle = '#1e1e2e'; ctx.font = '10px monospace'; ctx.textAlign = 'left';
      ctx.fillText(s.name, 125, y+slotH/2+4);
      return;
    }

    // Terrain-like waveform for this slot
    ctx.beginPath();
    ctx.moveTo(120, y + slotH - 2);
    for (let x = 0; x <= timeW; x += 3) {
      const t = x / timeW;
      const fadeIn = Math.min(1, t / s.fade);
      const fadeOut = Math.min(1, (1-t) / s.fade);
      const env = Math.min(fadeIn, fadeOut);
      const noise = Math.sin(x*0.05+i*2.3)*0.3+Math.sin(x*0.13+i)*0.2+Math.random()*0.1;
      const h = (s.vol * env * (0.6 + noise * 0.4)) * (slotH - 4);
      ctx.lineTo(120 + x, y + slotH - 2 - h);
    }
    ctx.lineTo(120 + timeW, y + slotH - 2);
    ctx.closePath();
    ctx.fillStyle = s.color + '44'; ctx.fill();
    ctx.strokeStyle = s.color; ctx.lineWidth = 1.5;
    ctx.shadowBlur = 4; ctx.shadowColor = s.color; ctx.stroke(); ctx.shadowBlur = 0;

    // Label
    ctx.fillStyle = s.color; ctx.font = 'bold 10px monospace'; ctx.textAlign = 'right';
    ctx.fillText(s.name, 115, y + slotH/2 + 4);
  });

  // Time axis
  ctx.fillStyle = 'rgba(100,116,139,0.4)'; ctx.font = '9px monospace'; ctx.textAlign = 'center';
  [0,15,30,45,60].forEach(t => {
    const x = 120 + (t/60)*timeW;
    ctx.fillText(t+'s', x, H-4);
    ctx.beginPath(); ctx.moveTo(x, 8); ctx.lineTo(x, H-14);
    ctx.strokeStyle = 'rgba(30,30,46,0.5)'; ctx.lineWidth=1; ctx.stroke();
  });

  // Playhead
  if (compPlaying || compPlayhead > 0) {
    const px = 120 + (compPlayhead/COMP_DURATION)*timeW;
    ctx.beginPath(); ctx.moveTo(px, 0); ctx.lineTo(px, H);
    ctx.strokeStyle = '#f43f5e'; ctx.lineWidth = 2;
    ctx.shadowBlur = 8; ctx.shadowColor = '#f43f5e'; ctx.stroke(); ctx.shadowBlur = 0;
  }
}

function toggleComposition() {
  if (compPlaying) { stopComposition(); return; }
  startComposition();
}

function startComposition() {
  const ac = getAudioCtx();
  compPlaying = true;
  document.getElementById('comp-play').textContent = '⏹ Stop';
  compSources = [];
  compSlots.forEach(s => {
    if (!s.active || s.vol === 0) return;
    const buf = ac.createBuffer(1, ac.sampleRate*4, ac.sampleRate);
    const d = buf.getChannelData(0);
    for (let i = 0; i < d.length; i++) {
      let v = Math.random()*2-1;
      if (s.name==='Birds') v += Math.sin(i*0.008)*0.2;
      if (s.name==='Insects') v *= Math.abs(Math.sin(i*0.003));
      d[i] = v;
    }
    const src = ac.createBufferSource(); src.buffer = buf; src.loop = true;
    const filt = ac.createBiquadFilter();
    filt.type = 'bandpass';
    const freqMap = {Rain:800,Wind:120,Birds:3000,Traffic:300,Ocean:200,Insects:5000,Voices:1000,Silence:1};
    filt.frequency.value = freqMap[s.name]||500; filt.Q.value=0.8;
    const gain = ac.createGain(); gain.gain.value = s.vol * 0.12;
    const pan = ac.createStereoPanner(); pan.pan.value = s.pan;
    src.connect(filt); filt.connect(gain); gain.connect(pan); pan.connect(ac.destination);
    src.start(); compSources.push({src,gain,s});
  });
  lastCompT = performance.now();
  animateComp();
}

function animateComp() {
  const now = performance.now();
  const dt = (now - lastCompT)/1000; lastCompT = now;
  compPlayhead = Math.min(compPlayhead + dt, COMP_DURATION);
  const t = compPlayhead/COMP_DURATION;
  compSources.forEach(({gain,s}) => {
    const fadeIn = Math.min(1, t/Math.max(s.fade,0.01));
    const fadeOut = Math.min(1,(1-t)/Math.max(s.fade,0.01));
    gain.gain.value = s.vol * Math.min(fadeIn,fadeOut) * 0.12;
  });
  document.getElementById('playhead-time').textContent = `${Math.floor(compPlayhead/60)}:${String(Math.floor(compPlayhead%60)).padStart(2,'0')}`;
  drawTimeline();
  if (compPlayhead >= COMP_DURATION) { stopComposition(); return; }
  if (compPlaying) compRaf = requestAnimationFrame(animateComp);
}

function stopComposition() {
  compPlaying = false;
  cancelAnimationFrame(compRaf);
  document.getElementById('comp-play').textContent = '▶ Play';
  compSources.forEach(({src}) => { try{src.stop();}catch(e){} });
  compSources = [];
}

function resetComposition() {
  stopComposition(); compPlayhead = 0;
  document.getElementById('playhead-time').textContent = '0:00';
  drawTimeline();
}

buildSlotControls();
drawTimeline();

