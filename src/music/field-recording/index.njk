function getBiomeMonth(biome, month) {
  const data = biomeData[biome];
  let closest = Object.keys(data).map(Number).reduce((a,b) => Math.abs(b-month)<Math.abs(a-month)?b:a, 0);
  return data[closest];
}

function setBiome(b) {
  currentBiome = b;
  ['temp','trop','arctic'].forEach(k=>document.getElementById('biome-'+k)?.classList.remove('active'));
  const map={temperate:'temp',tropical:'trop',arctic:'arctic'};
  document.getElementById('biome-'+map[b])?.classList.add('active');
  if(selectedMonth>=0) showMonthInfo(selectedMonth);
}

function handleSeasonClick(e) {
  const canvas = document.getElementById('season-canvas');
  const r=canvas.getBoundingClientRect();
  const x=(e.clientX-r.left)-canvas.width/2;
  const y=(e.clientY-r.top)-canvas.height/2;
  const angle=Math.atan2(y,x)+Math.PI/2;
  const normAngle=((angle%(Math.PI*2))+Math.PI*2)%(Math.PI*2);
  const month=Math.floor(normAngle/(Math.PI*2)*12);
  selectedMonth=month;
  showMonthInfo(month);
  drawSeasonCanvas(month);
}

function showMonthInfo(month) {
  const info=getBiomeMonth(currentBiome,month);
  document.getElementById('season-month').textContent=monthNames[month]+' — '+info.name;
  document.getElementById('season-info').innerHTML=`<p style="font-size:0.85rem;">${info.desc}</p>
    <div style="margin-top:0.5rem;font-size:0.8rem;color:var(--dim);">Acoustic Density: 
    <span style="color:var(--accent)">${Math.round(info.density*100)}%</span></div>`;
  playSeasonSound(info);
  drawSeasonSpectro(info);
}

function playSeasonSound(info) {
  const ac=getAudioCtx();
  if(seasonSoundSrc){try{seasonSoundSrc.stop();}catch(e){} seasonSoundSrc=null;}
  const buf=ac.createBuffer(1,ac.sampleRate*3,ac.sampleRate);
  const d=buf.getChannelData(0);
  for(let i=0;i<d.length;i++) {
    let s=Math.random()*2-1;
    if(info.density>0.5) s+=Math.sin(i*0.01+Math.random())*0.3;
    d[i]=s*info.density;
  }
  seasonSoundSrc=ac.createBufferSource(); seasonSoundSrc.buffer=buf; seasonSoundSrc.loop=true;
  const lpf=ac.createBiquadFilter(); lpf.type='bandpass'; lpf.frequency.value=info.freqPeak; lpf.Q.value=0.8;
  const g=ac.createGain(); g.gain.value=0.08;
  seasonSoundSrc.connect(lpf); lpf.connect(g); g.connect(ac.destination); seasonSoundSrc.start();
  setTimeout(()=>{if(seasonSoundSrc){try{seasonSoundSrc.stop();}catch(e){} seasonSoundSrc=null;}},3000);
}

function drawSeasonCanvas(selMonth) {
  const canvas=document.getElementById('season-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height, cx=W/2, cy=H/2, r=W/2-10;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#0d0d14'; ctx.beginPath(); ctx.arc(cx,cy,r+10,0,Math.PI*2); ctx.fill();

  months.forEach((m,i) => {
    const a0=-Math.PI/2+(i/12)*Math.PI*2, a1=-Math.PI/2+((i+1)/12)*Math.PI*2;
    const info=getBiomeMonth(currentBiome,i);
    ctx.beginPath(); ctx.moveTo(cx,cy); ctx.arc(cx,cy,r,a0,a1); ctx.closePath();
    const isSelected=i===selMonth;
    ctx.fillStyle=monthColors[i]+(isSelected?'ff':'44');
    ctx.shadowBlur=isSelected?20:0; ctx.shadowColor=monthColors[i]; ctx.fill(); ctx.shadowBlur=0;
    ctx.strokeStyle='rgba(13,13,20,0.8)'; ctx.lineWidth=2; ctx.stroke();

    // Month label
    const midA=(a0+a1)/2, labelR=r*0.72;
    ctx.fillStyle=isSelected?'#fff':monthColors[i]; ctx.font=`bold ${isSelected?12:10}px monospace`;
    ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillText(m, cx+Math.cos(midA)*labelR, cy+Math.sin(midA)*labelR);

    // Density arc
    const densR=r*0.4+info.density*r*0.25;
    ctx.beginPath(); ctx.arc(cx,cy,densR,a0+0.05,a1-0.05);
    ctx.strokeStyle=monthColors[i]+'aa'; ctx.lineWidth=3; ctx.stroke();
  });

  ctx.fillStyle='#0d0d14'; ctx.beginPath(); ctx.arc(cx,cy,r*0.28,0,Math.PI*2); ctx.fill();
  ctx.fillStyle='var(--accent)'; ctx.font='bold 10px monospace'; ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillText(currentBiome.slice(0,4).toUpperCase(),cx,cy);
}

function drawSeasonSpectro(info) {
  const canvas=document.getElementById('season-spectro');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#0d0d14'; ctx.fillRect(0,0,W,H);
  for(let x=0;x<W;x++) {
    const freq=20*Math.pow(1000,x/W);
    const dist=Math.abs(Math.log(Math.max(freq,1)/Math.max(info.freqPeak,20)));
    const energy=Math.exp(-dist*1.2)*info.density*(0.8+Math.random()*0.4);
    const h=energy*H*0.9;
    const hue=120+x/W*120;
    ctx.fillStyle=`hsla(${hue},70%,55%,${Math.min(energy,0.9)})`;
    ctx.fillRect(x,H-h,1,h);
  }
  ctx.fillStyle='rgba(100,116,139,0.5)'; ctx.font='8px monospace';
  ctx.textAlign='left'; ctx.fillText('20Hz',4,H-3);
  ctx.textAlign='center'; ctx.fillText('1kHz',W/2,H-3);
  ctx.textAlign='right'; ctx.fillText('20kHz',W-4,H-3);
}

