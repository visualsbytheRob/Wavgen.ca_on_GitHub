// ETHICS LAB
// ═══════════════════════════════════════════════════════
const ethicsScenarios = [
  {
    q: "You notice birds have stopped calling when you arrive with your equipment. The soundscape is now silent because of your presence.",
    choices: [
      { text:"Move on immediately — your presence is the disturbance.", consequence:"Respectful choice. Field recording requires patience but also humility — sometimes the best recording is knowing when not to record." },
      { text:"Wait quietly for 20 minutes, then begin.", consequence:"Good field craft. Animals habituate to a still, silent observer. Many recordists report their best recordings come after long waits." },
      { text:"Record anyway — the silence is itself interesting.", consequence:"Valid perspective. Cage would agree. But be aware: your presence caused this silence, so consider what you're really capturing." }
    ]
  },
  {
    q: "You've made recordings in an indigenous community's ceremonial space with permission from one elder. Another elder objects to publication.",
    choices: [
      { text:"Publish citing the first permission.", consequence:"Legally defensible but ethically fraught. One consent doesn't represent a community. Publishing could damage trust and cause real harm." },
      { text:"Delay publication to consult more widely.", consequence:"The right instinct. Meaningful consent is collective and ongoing, not a single transaction. This is how long-term relationships are built." },
      { text:"Withdraw the recordings entirely.", consequence:"The most conservative choice — and often the right one. No recording is worth fracturing community relationships or violating cultural sovereignty." }
    ]
  },
  {
    q: "You have a beautiful recording of a street musician who didn't know you were recording. It would be perfect for your album.",
    choices: [
      { text:"Share freely — it's a public space.", consequence:"Legal in many jurisdictions, but field recording ethics often exceed legal minimums. The musician's performance is their creative work." },
      { text:"Reach out for permission before using it commercially.", consequence:"Best practice. In the field recording community, this is the standard — permission transforms a captured moment into a collaboration." },
      { text:"Use only in non-commercial work.", consequence:"A reasonable middle path — but 'non-commercial' is increasingly blurry. Still worth seeking permission if you can find the person." }
    ]
  },
  {
    q: "Your hydrophone recordings capture rare whale vocalizations. Publishing raises awareness but might attract boats to the location.",
    choices: [
      { text:"Publish fully — awareness matters more.", consequence:"Well-intentioned, but the unintended consequence could be real harm. Whale researchers have documented boat strikes near published locations." },
      { text:"Publish with location redacted — share the sound, not the place.", consequence:"Increasingly standard practice in bioacoustics. The sound has value; the GPS coordinates don't need to be part of the art." },
      { text:"Share only with researchers under embargo.", consequence:"Conservation-first approach. Limits immediate impact but protects the animals. Some recordists donate sensitive recordings to scientific archives only." }
    ]
  }
];

function buildEthicsCards() {
  const container = document.getElementById('ethics-cards');
  ethicsScenarios.forEach((sc, i) => {
    const card = document.createElement('div');
    card.className = 'ethics-card';
    card.innerHTML = `<h3>Scenario ${i+1}</h3><p style="font-size:0.85rem;">${sc.q}</p>
      <div class="ethics-choices">
        ${sc.choices.map((c,j)=>`<div class="ethics-choice" onclick="revealConsequence(this,'${CSS.escape(c.consequence)}')">${c.text}</div>`).join('')}
      </div>`;
    const consDiv = document.createElement('div');
    consDiv.className = 'consequence'; consDiv.id = `cons-${i}`;
    card.appendChild(consDiv);
    container.appendChild(card);
  });
}

function revealConsequence(el, rawText) {
  const card = el.closest('.ethics-card');
  const cons = card.querySelector('.consequence');
  // Restore text without CSS.escape
  const text = el.textContent;
  const sc = ethicsScenarios.find(s => s.choices.some(c => c.text === text));
  const choice = sc ? sc.choices.find(c => c.text === text) : null;
  if (choice) { cons.textContent = choice.consequence; cons.style.display = 'block'; }
  card.querySelectorAll('.ethics-choice').forEach(c => c.style.borderColor = c===el?'var(--accent)':'var(--border)');
}

buildEthicsCards();

