// STEREO FIELD NAVIGATOR
// ═══════════════════════════════════════════════════════
let stereoTech = 'xy';
let stereoSource = { x: 0.5, y: 0.5 };
let msWidth = 50;
let stereoMouseDown = false;
const stereoDescs = {
  xy: 'XY (Coincident): Two cardioids at ±45°. Mono-compatible. Tight, focused stereo image with minimal phase issues. Preferred for precise imaging.',
  ortf: 'ORTF (Spaced): Microphones 17cm apart at ±55°. More spacious, natural-sounding stereo. Standard for orchestral and nature recording.',
  ms: 'M/S (Mid/Side): One forward-facing cardioid + one figure-8 side mic. Variable stereo width in post. Mono-compatible by design.'
};

function setStereoTech(t) {
  stereoTech = t;
  ['xy','ortf','ms'].forEach(k => document.getElementById(k+'-btn').classList.toggle('active', k===t));
  document.getElementById('stereo-desc').textContent = stereoDescs[t];
  document.getElementById('ms-width-wrap').style.display = t==='ms' ? 'block' : 'none';
  drawStereoCanvas();
}

function setMSWidth(v) { msWidth = parseInt(v); document.getElementById('ms-val').textContent = v+'%'; drawStereoCanvas(); }

function drawStereoCanvas() {
  const canvas = document.getElementById('stereo-canvas');
  const ctx = canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#0d0d14'; ctx.fillRect(0,0,W,H);

  // Room outline
  ctx.strokeStyle='rgba(30,30,46,0.8)'; ctx.lineWidth=2;
  ctx.strokeRect(40,40,W-80,H-80);
  ctx.fillStyle='rgba(13,148,136,0.03)'; ctx.fillRect(40,40,W-80,H-80);

  // Grid
  ctx.strokeStyle='rgba(30,30,46,0.4)'; ctx.lineWidth=1;
  for(let x=80;x<W-40;x+=60){ ctx.beginPath(); ctx.moveTo(x,40); ctx.lineTo(x,H-40); ctx.stroke(); }
  for(let y=80;y<H-40;y+=60){ ctx.beginPath(); ctx.moveTo(40,y); ctx.lineTo(W-40,y); ctx.stroke(); }

  // Mic positions
  const micX = W/2, micY = H*0.65;
  const configs = {
    xy: [{dx:-22,dy:0,angle:-45},{dx:22,dy:0,angle:45}],
    ortf: [{dx:-34,dy:-8,angle:-55},{dx:34,dy:-8,angle:55}],
    ms: [{dx:0,dy:-10,angle:0},{dx:0,dy:10,angle:90}]
  };
  const mics = configs[stereoTech];

  // Coverage zones
  mics.forEach((m,i) => {
    const mx = micX + m.dx, my = micY + m.dy;
    const angleRad = m.angle * Math.PI/180;
    const spreadR = stereoTech==='ms' && i===1 ? Math.PI : Math.PI*0.8;
    const grad = ctx.createRadialGradient(mx,my,0,mx,my,160);
    grad.addColorStop(0, i===0 ? 'rgba(13,148,136,0.15)' : 'rgba(6,182,212,0.15)');
    grad.addColorStop(1, 'transparent');
    ctx.save(); ctx.beginPath();
    ctx.moveTo(mx,my);
    ctx.arc(mx,my,160,angleRad-Math.PI/2-spreadR/2,angleRad-Math.PI/2+spreadR/2);
    ctx.closePath(); ctx.fillStyle=grad; ctx.fill(); ctx.restore();
  });

  // Mic icons
  mics.forEach((m,i) => {
    const mx=micX+m.dx, my=micY+m.dy;
    ctx.save(); ctx.translate(mx,my); ctx.rotate(m.angle*Math.PI/180);
    ctx.fillStyle=i===0?'#0d9488':'#06b6d4';
    ctx.shadowBlur=10; ctx.shadowColor=ctx.fillStyle;
    ctx.fillRect(-5,-14,10,20); ctx.beginPath(); ctx.arc(0,-14,5,Math.PI,0); ctx.fill();
    ctx.shadowBlur=0; ctx.restore();
    ctx.fillStyle='#e2e8f0'; ctx.font='9px monospace'; ctx.textAlign='center';
    ctx.fillText(stereoTech==='ms'?(i===0?'M':'S'):(i===0?'L':'R'), mx, my+22);
  });

  // Source dot
  const sx = 40 + stereoSource.x*(W-80), sy = 40 + stereoSource.y*(H-80);
  ctx.beginPath(); ctx.arc(sx,sy,10,0,Math.PI*2);
  ctx.fillStyle='#f43f5e'; ctx.shadowBlur=14; ctx.shadowColor='#f43f5e'; ctx.fill(); ctx.shadowBlur=0;
  ctx.fillStyle='#fff'; ctx.font='8px monospace'; ctx.textAlign='center'; ctx.fillText('SRC',sx,sy+3);

  // Pan indicator
  const dx = sx-W/2;
  const panPct = Math.round((dx/(W/2))*100);
  document.getElementById('stereo-pan').textContent = panPct<-5?`${Math.abs(panPct)}% Left`:panPct>5?`${panPct}% Right`:'Center';

  // Labels
  ctx.fillStyle='rgba(100,116,139,0.6)'; ctx.font='10px monospace'; ctx.textAlign='center';
  ctx.fillText('RECORDING SPACE — TOP VIEW', W/2, H-18);
}

(function initStereoInteraction() {
  const canvas = document.getElementById('stereo-canvas');
  function updateSource(e) {
    const r = canvas.getBoundingClientRect();
    const x = clamp((e.clientX-r.left)/r.width, 0, 1);
    const y = clamp((e.clientY-r.top)/r.height, 0, 1);
    stereoSource = {x,y};
    drawStereoCanvas();
    if (stereoPlaying) updateStereoPan();
  }
  canvas.addEventListener('mousedown', e => { stereoMouseDown=true; updateSource(e); });
  canvas.addEventListener('mousemove', e => { if(stereoMouseDown) updateSource(e); });
  canvas.addEventListener('mouseup', () => stereoMouseDown=false);
  canvas.addEventListener('touchstart', e => { stereoMouseDown=true; updateSource(e.touches[0]); }, {passive:true});
  canvas.addEventListener('touchmove', e => { updateSource(e.touches[0]); }, {passive:true});
  canvas.addEventListener('touchend', () => stereoMouseDown=false);
  canvas.style.cursor='crosshair';
})();

let stereoPlaying=false, stereoSrcNode=null, stereoPannerL=null, stereoPannerR=null;
function updateStereoPan() {
  if (!stereoPannerL) return;
  const pan = (stereoSource.x - 0.5) * 1.8;
  stereoPannerL.pan.value = clamp(pan - 0.3, -1, 1);
  stereoPannerR.pan.value = clamp(pan + 0.3, -1, 1);
}
function playStereoDemo() {
  const ac = getAudioCtx();
  if (stereoPlaying) {
    stereoPlaying=false; if(stereoSrcNode){stereoSrcNode.stop();stereoSrcNode=null;} return;
  }
  const buf = ac.createBuffer(1,ac.sampleRate*3,ac.sampleRate);
  const d=buf.getChannelData(0);
  for(let i=0;i<d.length;i++) d[i]=(Math.random()*2-1)*0.4+Math.sin(i*0.1)*0.1;
  stereoSrcNode=ac.createBufferSource(); stereoSrcNode.buffer=buf; stereoSrcNode.loop=true;
  stereoPannerL=ac.createStereoPanner(); stereoPannerR=ac.createStereoPanner();
  const gL=ac.createGain(); gL.gain.value=0.5;
  const gR=ac.createGain(); gR.gain.value=0.5;
  stereoSrcNode.connect(stereoPannerL); stereoSrcNode.connect(stereoPannerR);
  stereoPannerL.connect(gL); gL.connect(ac.destination);
  stereoPannerR.connect(gR); gR.connect(ac.destination);
  stereoSrcNode.start(); stereoPlaying=true;
  updateStereoPan();
  setTimeout(()=>{if(stereoPlaying){stereoSrcNode.stop();stereoPlaying=false;}},5000);
}

setStereoTech('xy');

// ═══════════════════════════════════════════════════════
// CONTACT MIC UNIVERSE
// ═══════════════════════════════════════════════════════
const materials = [
  { name:'Metal Plate', color:'#94a3b8', bg:'#1e293b', desc:'Cool, bright resonance. Contact mics on metal reveal complex harmonic overtones and long sustain. Striking near an edge reveals higher partials.',
    synthFn: (ac,pos) => synthMetal(ac,pos) },
  { name:'Wooden Beam', color:'#b45309', bg:'#1c1007', desc:'Warm, organic. Wood absorbs high frequencies. Near the center gives a rounder, fundamental-rich tone; edges brighten the sound.',
    synthFn: (ac,pos) => synthWood(ac,pos) },
  { name:'Glass Sheet', color:'#bae6fd', bg:'#0c1a2e', desc:'Pure, glassy partials with rapid decay. Glass has very specific resonant modes — placement matters enormously.',
    synthFn: (ac,pos) => synthGlass(ac,pos) },
  { name:'Water Surface', color:'#0891b2', bg:'#061220', desc:'Liquid thud and burble. Hydrophone contact with water captures subsurface turbulence. Low-frequency resonance dominates.',
    synthFn: (ac,pos) => synthWater(ac,pos) }
];
let selectedMaterial = 0;
let contactMicPos = { x: 0.5, y: 0.5 };
let airMicMode = false;

function buildMaterialTabs() {
  const tabs = document.getElementById('material-tabs');
  materials.forEach((m,i) => {
    const btn = document.createElement('button');
    btn.className = 'mat-btn' + (i===0?' active':'');
    btn.id = `mat-${i}`; btn.textContent = m.name;
    btn.onclick = () => selectMaterial(i);
    tabs.appendChild(btn);
  });
  drawContactCanvas();
}

function selectMaterial(idx) {
  selectedMaterial = idx;
  document.querySelectorAll('.mat-btn').forEach((b,i)=>b.classList.toggle('active',i===idx));
  document.getElementById('material-name').textContent = materials[idx].name;
  document.getElementById('material-desc').textContent = materials[idx].desc;
  drawContactCanvas();
}

function placeContactMic(e) {
  const canvas = document.getElementById('contact-canvas');
  const r = canvas.getBoundingClientRect();
  contactMicPos = { x:clamp((e.clientX-r.left)/canvas.width,0,1), y:clamp((e.clientY-r.top)/canvas.height,0,1) };
  const side = contactMicPos.x < 0.3 ? 'Near Edge' : contactMicPos.x > 0.7 ? 'Near Far Edge' : 'Center';
  document.getElementById('contact-pos').textContent = side;
  drawContactCanvas();
  strikeContactMic();
}

function drawContactCanvas() {
  const canvas = document.getElementById('contact-canvas');
  const ctx = canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  const mat = materials[selectedMaterial];
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle=mat.bg; ctx.fillRect(0,0,W,H);

  // Material cross-section
  const matH = H*0.55, matY = H*0.25;
  const grad = ctx.createLinearGradient(0,matY,0,matY+matH);
  grad.addColorStop(0, mat.color+'40'); grad.addColorStop(0.3, mat.color+'80'); grad.addColorStop(1, mat.color+'20');
  ctx.fillStyle=grad; ctx.fillRect(20, matY, W-40, matH);
  ctx.strokeStyle=mat.color; ctx.lineWidth=2;
  ctx.strokeRect(20, matY, W-40, matH);

  // Material texture lines
  ctx.strokeStyle=mat.color+'30'; ctx.lineWidth=1;
  if(selectedMaterial===1){ // wood grain
    for(let y=matY+5;y<matY+matH;y+=12){ ctx.beginPath(); ctx.moveTo(20,y); ctx.bezierCurveTo(W/2,y+4,W/2,y-4,W-20,y); ctx.stroke(); }
  } else if(selectedMaterial===0){ // metal grid
    for(let x=30;x<W-20;x+=20){ ctx.beginPath(); ctx.moveTo(x,matY); ctx.lineTo(x,matY+matH); ctx.stroke(); }
    for(let y=matY+10;y<matY+matH;y+=20){ ctx.beginPath(); ctx.moveTo(20,y); ctx.lineTo(W-20,y); ctx.stroke(); }
  } else if(selectedMaterial===3){ // water ripples
    for(let r=10;r<120;r+=18){ ctx.beginPath(); ctx.arc(W/2,matY+matH*0.2,r,0,Math.PI); ctx.globalAlpha=0.3; ctx.stroke(); ctx.globalAlpha=1; }
  }

  // Contact mic dot
  const mx = 20 + contactMicPos.x*(W-40);
  const my = matY + contactMicPos.y*matH;
  ctx.beginPath(); ctx.arc(mx,my,10,0,Math.PI*2);
  ctx.fillStyle=airMicMode?'#f43f5e':'#0d9488'; ctx.shadowBlur=16; ctx.shadowColor=ctx.fillStyle; ctx.fill(); ctx.shadowBlur=0;
  ctx.fillStyle='#fff'; ctx.font='8px monospace'; ctx.textAlign='center'; ctx.fillText(airMicMode?'🎤':'●',mx,my+3);

  // Labels
  ctx.fillStyle='rgba(100,116,139,0.6)'; ctx.font='10px monospace'; ctx.textAlign='center';
  ctx.fillText(mat.name.toUpperCase()+' — CROSS SECTION', W/2, H-14);
