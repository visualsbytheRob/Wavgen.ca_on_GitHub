}

function synthMetal(ac, pos) {
  const freqs = [440,880,1320,2200,3520];
  const nodes = freqs.map(f => {
    const o=ac.createOscillator(); o.type='sine'; o.frequency.value=f*(1+pos.x*0.3);
    const g=ac.createGain(); g.gain.setValueAtTime(0.12,ac.currentTime); g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+1.8+pos.x*1.2);
    o.connect(g); g.connect(ac.destination); o.start(); o.stop(ac.currentTime+2); return {o,g};
  });
}
function synthWood(ac, pos) {
  const o=ac.createOscillator(); o.type='triangle'; o.frequency.value=180+pos.x*120;
  const g=ac.createGain(); g.gain.setValueAtTime(0.18,ac.currentTime); g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+0.8);
  const f=ac.createBiquadFilter(); f.type='lowpass'; f.frequency.value=800+pos.x*600;
  const noise=ac.createBufferSource(); const b=ac.createBuffer(1,ac.sampleRate*0.5,ac.sampleRate);
  const d=b.getChannelData(0); for(let i=0;i<d.length;i++) d[i]=Math.random()*2-1;
  noise.buffer=b; const ng=ac.createGain(); ng.gain.setValueAtTime(0.08,ac.currentTime); ng.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+0.4);
  o.connect(f); f.connect(g); g.connect(ac.destination); noise.connect(ng); ng.connect(ac.destination);
  o.start(); o.stop(ac.currentTime+1); noise.start(); noise.stop(ac.currentTime+0.5);
}
function synthGlass(ac, pos) {
  const freqs=[523,784,1047,2093]; 
  freqs.forEach(f => {
    const o=ac.createOscillator(); o.type='sine'; o.frequency.value=f*(1+pos.x*0.15);
    const g=ac.createGain(); g.gain.setValueAtTime(0.1,ac.currentTime); g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+2.5);
    o.connect(g); g.connect(ac.destination); o.start(); o.stop(ac.currentTime+3);
  });
}
function synthWater(ac, pos) {
  const buf=ac.createBuffer(1,ac.sampleRate*0.8,ac.sampleRate);
  const d=buf.getChannelData(0); for(let i=0;i<d.length;i++) d[i]=Math.random()*2-1;
  const src=ac.createBufferSource(); src.buffer=buf;
  const lpf=ac.createBiquadFilter(); lpf.type='lowpass'; lpf.frequency.value=300+pos.x*200;
  const g=ac.createGain(); g.gain.setValueAtTime(0.2,ac.currentTime); g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+0.6);
  src.connect(lpf); lpf.connect(g); g.connect(ac.destination); src.start(); src.stop(ac.currentTime+1);
}

function strikeContactMic() {
  const ac = getAudioCtx();
  const mat = materials[selectedMaterial];
  if (airMicMode) {
    const buf=ac.createBuffer(1,ac.sampleRate*0.1,ac.sampleRate);
    const d=buf.getChannelData(0); for(let i=0;i<d.length;i++) d[i]=Math.random()*2-1;
    const src=ac.createBufferSource(); src.buffer=buf;
    const g=ac.createGain(); g.gain.setValueAtTime(0.08,ac.currentTime); g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+0.3);
    const rev=ac.createConvolver(); src.connect(g); g.connect(ac.destination); src.start(); src.stop(ac.currentTime+0.5);
    document.getElementById('mic-mode').textContent='Air Mic';
  } else {
    mat.synthFn(ac, contactMicPos);
    document.getElementById('mic-mode').textContent='Contact';
  }
  animateStrike();
}

function animateStrike() {
  const canvas=document.getElementById('contact-canvas');
  const ctx=canvas.getContext('2d');
  const mx=20+contactMicPos.x*(canvas.width-40);
  const mat=materials[selectedMaterial];
  const my=canvas.height*0.25+contactMicPos.y*(canvas.height*0.55);
  let r=0;
  function ring() {
    if(r>80) return;
    ctx.beginPath(); ctx.arc(mx,my,r,0,Math.PI*2);
    ctx.strokeStyle=mat.color; ctx.globalAlpha=Math.max(0,1-r/80);
    ctx.lineWidth=2; ctx.shadowBlur=8; ctx.shadowColor=mat.color; ctx.stroke(); ctx.shadowBlur=0; ctx.globalAlpha=1;
    r+=4; requestAnimationFrame(ring);
  }
  ring();
}

