function getDepthData(d) {
  for(let i=depthData.length-1;i>=0;i--) { if(d>=depthData[i].depth) return depthData[i]; }
  return depthData[0];
}

function setDepth(val) {
  currentDepth = parseInt(val);
  document.getElementById('depth-display').textContent = currentDepth+'m';
  const info = getDepthData(currentDepth);
  document.getElementById('depth-desc').textContent = info.desc;
}

(function initWaterCanvas() {
  const canvas = document.getElementById('water-canvas');
  const ctx = canvas.getContext('2d');
  let t = 0;
  function draw() {
    const W=canvas.width, H=canvas.height;
    const d = currentDepth;
    const maxD = 600;
    const pct = d/maxD;
    t += 0.016;
    ctx.fillStyle='rgba(13,13,20,0.25)'; ctx.fillRect(0,0,W,H);

    // Sky/water gradient
    const skyH = Math.max(0, (1-pct*2)*H*0.25);
    if(skyH>0){
      const skyGrad=ctx.createLinearGradient(0,0,0,skyH);
      skyGrad.addColorStop(0,'#bae6fd30'); skyGrad.addColorStop(1,'#0ea5e920');
      ctx.fillStyle=skyGrad; ctx.fillRect(0,0,W,skyH);
    }

    // Water column
    const waterGrad=ctx.createLinearGradient(0,skyH,0,H);
    const topColor = pct<0.1?'#38bdf8':pct<0.3?'#0ea5e9':pct<0.6?'#0369a1':'#0c4a6e';
    waterGrad.addColorStop(0,topColor+'88'); waterGrad.addColorStop(1,'#020617ee');
    ctx.fillStyle=waterGrad; ctx.fillRect(0,skyH,W,H-skyH);

    // Light rays near surface
    if(pct<0.3) {
      ctx.save(); ctx.globalAlpha=(1-pct/0.3)*0.12;
      for(let r=0;r<6;r++) {
        const rx=W*(0.2+r*0.12), speed=0.4+r*0.15;
        ctx.beginPath(); ctx.moveTo(rx,0);
        ctx.lineTo(rx+30*Math.sin(t*speed+r),H*0.6); ctx.lineTo(rx-30*Math.sin(t*speed+r),H*0.6);
        ctx.fillStyle='#bae6fd'; ctx.fill();
      }
      ctx.restore();
    }

    // Particles (bubbles/sediment)
    ctx.fillStyle=pct<0.3?'rgba(186,230,253,0.4)':'rgba(100,116,139,0.2)';
    for(let p=0;p<8;p++){
      const px=W*(0.1+(p*0.117)%0.9);
      const py=((t*20*(1+p*0.3)+p*137)%(H-skyH))+skyH;
      ctx.beginPath(); ctx.arc(px,py,pct<0.3?2:1,0,Math.PI*2); ctx.fill();
    }

    // Depth zone label
    const info=getDepthData(d);
    ctx.fillStyle=info.color+'cc'; ctx.font='bold 11px monospace'; ctx.textAlign='center';
    ctx.fillText(info.name.toUpperCase(), W/2, H-20);

    // Depth marker line
    const markerY = skyH + pct*(H-skyH)*0.95;
    ctx.beginPath(); ctx.moveTo(W*0.1, markerY); ctx.lineTo(W*0.9, markerY);
    ctx.strokeStyle='rgba(13,148,136,0.5)'; ctx.lineWidth=1; ctx.setLineDash([4,4]); ctx.stroke(); ctx.setLineDash([]);
    ctx.fillStyle='#0d9488'; ctx.font='10px monospace'; ctx.textAlign='left';
    ctx.fillText(d+'m ▶', W*0.1+4, markerY-4);

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();

(function initSpectroCanvas() {
  const canvas = document.getElementById('spectro-canvas');
  const ctx = canvas.getContext('2d');
  let t=0;
  function draw() {
    const W=canvas.width, H=canvas.height;
    ctx.fillStyle='rgba(13,13,20,0.4)'; ctx.fillRect(0,0,W,H);
    t+=0.04;
    const info=getDepthData(currentDepth);
    const peak=info.freqPeak;
    for(let x=0;x<W;x++) {
      const freq=20*Math.pow(1000,x/W);
      const dist=Math.abs(Math.log(freq/Math.max(peak,20)));
      const energy=Math.exp(-dist*1.5)*(0.7+0.3*Math.sin(t+x*0.1));
      const h=energy*H*0.85;
      const hue=180+x/W*60;
      ctx.fillStyle=`hsla(${hue},80%,55%,${energy*0.8})`;
      ctx.fillRect(x,H-h,1,h);
    }
    ctx.fillStyle='rgba(100,116,139,0.5)'; ctx.font='8px monospace'; ctx.textAlign='left';
    ctx.fillText('20Hz',2,H-2); ctx.textAlign='center'; ctx.fillText('1kHz',W*0.5,H-2);
    ctx.textAlign='right'; ctx.fillText('20kHz',W-2,H-2);
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();

function playDepthSound() {
  const ac=getAudioCtx();
  if(depthSoundSrc){depthSoundSrc.stop();depthSoundSrc=null;return;}
  const info=getDepthData(currentDepth);
  const buf=ac.createBuffer(1,ac.sampleRate*3,ac.sampleRate);
  const d=buf.getChannelData(0);
  for(let i=0;i<d.length;i++) d[i]=Math.random()*2-1;
  depthSoundSrc=ac.createBufferSource(); depthSoundSrc.buffer=buf; depthSoundSrc.loop=true;
  const lpf=ac.createBiquadFilter(); lpf.type='lowpass'; lpf.frequency.value=info.freqPeak*2;
  const g=ac.createGain(); g.gain.value=0.1+info.reverb*0.08;
  depthSoundSrc.connect(lpf); lpf.connect(g); g.connect(ac.destination); depthSoundSrc.start();
  setTimeout(()=>{if(depthSoundSrc){depthSoundSrc.stop();depthSoundSrc=null;}},4000);
}

function shiftMammalCall() {
  const ac=getAudioCtx();
  const baseFreq=18;
  const o=ac.createOscillator(); o.type='sine';
  o.frequency.setValueAtTime(baseFreq,ac.currentTime);
  o.frequency.linearRampToValueAtTime(baseFreq*3,ac.currentTime+0.5);
  o.frequency.linearRampToValueAtTime(baseFreq*1.5,ac.currentTime+1.2);
  o.frequency.linearRampToValueAtTime(baseFreq*4,ac.currentTime+1.8);
  const g=ac.createGain(); g.gain.setValueAtTime(0.15,ac.currentTime); g.gain.setValueAtTime(0.15,ac.currentTime+1.7); g.gain.linearRampToValueAtTime(0,ac.currentTime+2.2);
  o.connect(g); g.connect(ac.destination); o.start(); o.stop(ac.currentTime+2.5);
}

