// ═══════════════════════════════════════════════════════
// GLOSSARY
// ═══════════════════════════════════════════════════════
const glossaryTerms = [
  { term:'Field Recording', def:'The practice of capturing audio outside the recording studio, in any acoustic environment.' },
  { term:'Soundscape', def:'The acoustic environment as perceived by humans and animals — the total sonic character of a place.' },
  { term:'Biophony', def:'All sounds produced by living organisms in an ecosystem: birdsong, insect calls, frog choruses.' },
  { term:'Geophony', def:'Non-biological natural sounds: wind, rain, rivers, thunder, geological activity.' },
  { term:'Anthropophony', def:'Human-generated sound: traffic, machinery, construction, music, conversation.' },
  { term:'Acoustic Ecology', def:'The study of the relationship between living beings and their sonic environment, pioneered by R. Murray Schafer.' },
  { term:'Polar Pattern', def:'A diagram showing the directional sensitivity of a microphone — how much sound it captures from each direction.' },
  { term:'Cardioid', def:'Heart-shaped pickup pattern. Captures sound from the front, partially from sides, rejects rear.' },
  { term:'Omnidirectional', def:'Circular pickup pattern — the microphone hears equally from all directions.' },
  { term:'Figure-8', def:'Bidirectional pattern — captures front and back equally, rejects sides. Natural to ribbon microphones.' },
  { term:'Binaural', def:'Two-microphone technique mimicking human hearing — creates immersive 3D audio for headphone listening.' },
  { term:'ORTF', def:'Office de Radiodiffusion-Télévision Française technique: two cardioids spaced 17cm, angled ±55°.' },
  { term:'XY Stereo', def:'Coincident cardioid pair angled ±45°. Mono-compatible, stable stereo image.' },
  { term:'M/S Stereo', def:'Mid/Side technique: one forward mic (Mid) + one figure-8 (Side). Variable width in post-production.' },
  { term:'Contact Microphone', def:'Transducer that captures vibrations directly from a surface rather than through air.' },
  { term:'Hydrophone', def:'Underwater microphone. Pressure-sensitive transducer designed for aquatic acoustic environments.' },
  { term:'Impulse Response', def:'A recording of how a space responds to a brief sonic impulse — captures the acoustic fingerprint of a room.' },
  { term:'Convolution Reverb', def:'Digital reverberation created by mathematically combining a sound with an impulse response.' },
  { term:'Spectrogram', def:'Visual representation of frequency content over time — the standard tool for analyzing field recordings.' },
  { term:'Soundscape Composition', def:'Music composed using field recordings as primary material, pioneered by the World Soundscape Project.' }
];

function buildGlossary() {
  const grid = document.getElementById('glossary-grid');
  glossaryTerms.forEach(g => {
    const item = document.createElement('div');
    item.className = 'gloss-item';
    item.innerHTML = `<div class="gloss-term">${g.term}</div><div class="gloss-def">${g.def}</div>`;
    grid.appendChild(item);
  });
}
buildGlossary();

