  { depth:20, name:'Open Ocean', desc:'Low-frequency resonance dominates. Whale song travels for thousands of kilometers. Boat propellers heard as continuous tonal hum.', freqPeak:200, reverb:0.55, color:'#38bdf8' },
  { depth:100, name:'Deep Shelf', desc:'Near-silence in biological terms. Geological creaking, sediment movement, distant ship noise. Pressure affects sound propagation angles.', freqPeak:60, reverb:0.75, color:'#0ea5e9' },
