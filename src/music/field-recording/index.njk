// MICROPHONE ZOO
// ═══════════════════════════════════════════════════════
const micTypes = [
  { name:'Omnidirectional', short:'Omni', desc:'Captures sound equally from all directions. Ideal for ambient recordings, capturing room acoustics, and ASMR. No proximity effect.',
    pattern: a => 1.0 },
  { name:'Cardioid', short:'Cardioid', desc:'Heart-shaped pattern. Rejects sound from behind. The workhorse of field recording — good off-axis rejection while remaining natural.',
    pattern: a => 0.5 + 0.5 * Math.cos(a) },
  { name:'Supercardioid', short:'Supercardioid', desc:'Narrower than cardioid with a small rear lobe. Excellent directional isolation. Preferred for wildlife recording in noisy environments.',
    pattern: a => 0.37 + 0.63 * Math.cos(a) },
  { name:'Figure-8', short:'Fig-8', desc:'Bidirectional — captures front and back equally, rejects sides. Used in M/S stereo and Mid-Side recording. Ribbon mics use this pattern naturally.',
    pattern: a => Math.abs(Math.cos(a)) },
  { name:'Binaural', short:'Binaural', desc:'Two microphones shaped to mimic human ears, including pinnae. Creates immersive 3D spatial audio that works with headphones.',
    pattern: a => { const l = 0.5 + 0.5 * Math.cos(a + 0.4); const r = 0.5 + 0.5 * Math.cos(a - 0.4); return (l + r) / 2; } },
  { name:'Contact', short:'Contact', desc:'Transducer mounted directly on a surface. Bypasses air entirely — hears the object\'s own resonance, not the air around it.',
    pattern: a => 1.0 }
];

let selectedMic = 0;
let micOrbitActive = false;
let micOrbitAngle = 0;
let micOrbitRaf = null;
let micOscillator = null;
let micPanner = null;

function buildMicGrid() {
  const grid = document.getElementById('mic-grid');
  micTypes.forEach((m, i) => {
    const card = document.createElement('div');
    card.className = 'mic-card' + (i === 0 ? ' selected' : '');
    card.id = `mic-card-${i}`;
    const cv = document.createElement('canvas');
    cv.className = 'mic-canvas'; cv.width = 100; cv.height = 100;
    drawMiniPolar(cv.getContext('2d'), m.pattern, 50, 50, 38);
    card.appendChild(cv);
    const nm = document.createElement('div');
    nm.textContent = m.short; nm.style.fontSize = '0.8rem'; nm.style.fontWeight = '600'; nm.style.color = 'var(--accent)';
    card.appendChild(nm);
    card.onclick = () => selectMic(i);
    grid.appendChild(card);
  });
  selectMic(0);
}

function drawMiniPolar(ctx, patFn, cx, cy, r) {
  ctx.clearRect(0, 0, ctx.canvas.width, ctx.canvas.height);
  ctx.fillStyle = '#0d0d14'; ctx.fillRect(0,0,ctx.canvas.width, ctx.canvas.height);
  ctx.strokeStyle = 'rgba(13,148,136,0.15)'; ctx.lineWidth = 1;
  [0.33,0.66,1].forEach(f => { ctx.beginPath(); ctx.arc(cx,cy,r*f,0,Math.PI*2); ctx.stroke(); });
  ctx.beginPath();
  for (let a = 0; a < Math.PI*2; a += 0.05) {
    const g = patFn(a); const px = cx + Math.cos(a-Math.PI/2)*g*r; const py = cy + Math.sin(a-Math.PI/2)*g*r;
    a === 0 ? ctx.moveTo(px,py) : ctx.lineTo(px,py);
  }
  ctx.closePath();
  ctx.fillStyle = 'rgba(13,148,136,0.2)'; ctx.fill();
  ctx.strokeStyle = '#0d9488'; ctx.lineWidth = 1.5;
  ctx.shadowBlur = 6; ctx.shadowColor = '#0d9488'; ctx.stroke(); ctx.shadowBlur = 0;
}

function selectMic(idx) {
  selectedMic = idx;
  document.querySelectorAll('.mic-card').forEach((c,i) => c.classList.toggle('selected', i===idx));
  document.getElementById('mic-name').textContent = micTypes[idx].name;
  document.getElementById('mic-desc').textContent = micTypes[idx].desc;
  drawPolarCanvas(idx, parseFloat(document.getElementById('angle-slider').value));
}

let polarAnimRaf = null;
function drawPolarCanvas(micIdx, srcAngleDeg) {
  const canvas = document.getElementById('polar-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const cx = W/2, cy = H/2, r = Math.min(W,H)*0.38;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle = '#0d0d14'; ctx.fillRect(0,0,W,H);

  // Grid rings
  for (let i=1; i<=4; i++) {
    ctx.beginPath(); ctx.arc(cx,cy,r*i/4,0,Math.PI*2);
    ctx.strokeStyle = `rgba(13,148,136,${0.08+i*0.04})`; ctx.lineWidth=1; ctx.stroke();
    ctx.fillStyle='rgba(100,116,139,0.5)'; ctx.font='10px monospace'; ctx.textAlign='center';
    ctx.fillText(`${Math.round(i/4*100)}%`, cx+r*i/4+4, cy-3);
  }
  // Direction labels
  ['FRONT','RIGHT','REAR','LEFT'].forEach((l,i) => {
    const a = i*Math.PI/2 - Math.PI/2;
    ctx.fillStyle='rgba(100,116,139,0.7)'; ctx.font='10px monospace'; ctx.textAlign='center';
    ctx.fillText(l, cx+Math.cos(a)*(r+18), cy+Math.sin(a)*(r+18)+4);
  });

  // Pattern
  const pat = micTypes[micIdx].pattern;
  ctx.beginPath();
  for (let a=0; a<Math.PI*2; a+=0.02) {
    const g=pat(a); const px=cx+Math.cos(a-Math.PI/2)*g*r; const py=cy+Math.sin(a-Math.PI/2)*g*r;
    a===0 ? ctx.moveTo(px,py) : ctx.lineTo(px,py);
  }
  ctx.closePath();
  ctx.fillStyle='rgba(13,148,136,0.15)'; ctx.fill();
  ctx.strokeStyle='#0d9488'; ctx.lineWidth=2;
  ctx.shadowBlur=10; ctx.shadowColor='#0d9488'; ctx.stroke(); ctx.shadowBlur=0;

  // Source dot
  const rad = srcAngleDeg * Math.PI / 180;
  const gain = pat(rad);
  const sx = cx + Math.cos(rad - Math.PI/2) * r * 1.05;
  const sy = cy + Math.sin(rad - Math.PI/2) * r * 1.05;
  ctx.beginPath(); ctx.arc(sx, sy, 8, 0, Math.PI*2);
  ctx.fillStyle = '#f43f5e'; ctx.shadowBlur=14; ctx.shadowColor='#f43f5e'; ctx.fill(); ctx.shadowBlur=0;

  // Gain line
  const gx = cx + Math.cos(rad - Math.PI/2) * gain * r;
  const gy = cy + Math.sin(rad - Math.PI/2) * gain * r;
  ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(gx,gy);
  ctx.strokeStyle='rgba(250,255,100,0.5)'; ctx.lineWidth=1.5; ctx.stroke();

  document.getElementById('gain-display').textContent = gain.toFixed(3);
  document.getElementById('angle-display').textContent = Math.round(srcAngleDeg) + '°';
}

function setSourceAngle(val) {
  drawPolarCanvas(selectedMic, parseFloat(val));
  if (micPanner) micPanner.pan.value = Math.sin(parseFloat(val) * Math.PI / 180) * micTypes[selectedMic].pattern(parseFloat(val) * Math.PI / 180);
}

function toggleMicOrbit() {
  micOrbitActive = !micOrbitActive;
  document.getElementById('mic-orbit-btn').textContent = micOrbitActive ? '⏹ Stop Orbit' : '▶ Orbit Source';
  if (micOrbitActive) orbitStep(); else { cancelAnimationFrame(micOrbitRaf); }
}
function orbitStep() {
  micOrbitAngle = (micOrbitAngle + 1.2) % 360;
  document.getElementById('angle-slider').value = micOrbitAngle;
  setSourceAngle(micOrbitAngle);
  if (micOrbitActive) micOrbitRaf = requestAnimationFrame(orbitStep);
}

function playMicDemo() {
  const ac = getAudioCtx();
  if (micOscillator) { micOscillator.stop(); micOscillator = null; return; }
  micOscillator = ac.createOscillator();
  micPanner = ac.createStereoPanner();
  const gain = ac.createGain(); gain.gain.value = 0.15;
  micOscillator.type = 'sine'; micOscillator.frequency.value = 440;
  micOscillator.connect(micPanner); micPanner.connect(gain); gain.connect(ac.destination);
  micOscillator.start();
  setTimeout(() => { if (micOscillator) { micOscillator.stop(); micOscillator = null; }}, 2000);
}

buildMicGrid();

