<script>
// ═══════════════════════════════════════════════════════
// CORE UTILITIES
// ═══════════════════════════════════════════════════════
class LagFilter {
  constructor(tau) { this.tau = tau; this.value = 0; }
  update(target, dt) {
    this.value += (1 - Math.exp(-dt / this.tau)) * (target - this.value);
    return this.value;
  }
}

let audioCtx = null;
function getAudioCtx() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();
  return audioCtx;
}

function lerp(a, b, t) { return a + (b - a) * t; }
function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
function rnd(min, max) { return Math.random() * (max - min) + min; }

// IntersectionObserver for scroll entrances
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.hidden').forEach(el => obs.observe(el));

// Nav active state
const navLinks = document.querySelectorAll('nav a');
const secObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      navLinks.forEach(a => {
        a.classList.toggle('active', a.getAttribute('href') === '#' + e.target.id);
      });
    }
  });
}, { threshold: 0.4 });
document.querySelectorAll('section[id]').forEach(s => secObs.observe(s));

// ═══════════════════════════════════════════════════════
// HERO RADAR CANVAS
// ═══════════════════════════════════════════════════════
(function initHero() {
  const canvas = document.getElementById('hero-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, cx, cy, maxR;
  const sources = [];
  const envNames = ['Forest Clearing','Coastal Marsh','Urban Park','Mountain Stream','Desert Dusk'];
  let envIdx = 0, envTimer = 0;
  const windLevels = ['Calm','Light','Moderate','Gusty'];
  let windIdx = 0;
  const sourceTypes = [
    { name:'Bird', freqLo:2000, freqHi:8000, color:'#0d9488', cat:'bio' },
    { name:'Wind', freqLo:80, freqHi:500, color:'#d97706', cat:'geo' },
    { name:'Water', freqLo:200, freqHi:4000, color:'#06b6d4', cat:'geo' },
    { name:'Insect', freqLo:4000, freqHi:12000, color:'#a3e635', cat:'bio' },
    { name:'Traffic', freqLo:200, freqHi:1000, color:'#f43f5e', cat:'anthro' },
    { name:'Human', freqLo:200, freqHi:3000, color:'#a78bfa', cat:'anthro' }
  ];
  let radarAngle = 0;
  let lastT = 0;

  function resize() {
    const wrap = document.getElementById('hero-wrap');
    W = canvas.width = wrap.clientWidth;
    H = canvas.height = wrap.clientHeight;
    cx = W / 2; cy = H / 2;
    maxR = Math.min(W, H) * 0.42;
  }

  function spawnSource() {
    if (sources.length >= 14) return;
    const t = sourceTypes[Math.floor(Math.random() * sourceTypes.length)];
    const angle = Math.random() * Math.PI * 2;
    const dist = rnd(0.15, 0.95);
    sources.push({ ...t, angle, dist, life: 1, decay: rnd(0.003, 0.008), pulsePhase: Math.random() * Math.PI * 2, pulseRate: rnd(1.5, 4) });
  }

  function drawHero(ts) {
    const dt = Math.min((ts - lastT) / 1000, 0.05);
    lastT = ts;
    ctx.fillStyle = 'rgba(5,5,8,0.18)';
    ctx.fillRect(0, 0, W, H);

    radarAngle = (radarAngle + dt * 0.6) % (Math.PI * 2);

    // Radar rings
    for (let i = 1; i <= 4; i++) {
      const r = maxR * (i / 4);
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(13,148,136,${0.08 + i * 0.03})`;
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Radar sweep
    const sweepGrad = ctx.createConicalGradient ? null : null;
    for (let a = 0; a < 60; a++) {
      const sweepA = radarAngle - (a / 60) * (Math.PI * 0.7);
      const alpha = (1 - a / 60) * 0.18;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, maxR, sweepA, sweepA + 0.05);
      ctx.closePath();
      ctx.fillStyle = `rgba(13,148,136,${alpha})`;
      ctx.fill();
    }
    // Sweep leading edge
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + Math.cos(radarAngle) * maxR, cy + Math.sin(radarAngle) * maxR);
    ctx.strokeStyle = 'rgba(13,148,136,0.9)';
    ctx.lineWidth = 2;
    ctx.shadowBlur = 12; ctx.shadowColor = '#0d9488';
    ctx.stroke();
    ctx.shadowBlur = 0;

    // Crosshairs
    ctx.strokeStyle = 'rgba(13,148,136,0.15)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(cx - maxR, cy); ctx.lineTo(cx + maxR, cy); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(cx, cy - maxR); ctx.lineTo(cx, cy + maxR); ctx.stroke();

    // Sources
    envTimer += dt;
    if (envTimer > 6) { envTimer = 0; envIdx = (envIdx + 1) % envNames.length; windIdx = Math.floor(Math.random() * windLevels.length); }
    if (Math.random() < 0.02) spawnSource();

    const alive = [];
    for (const s of sources) {
      s.life -= s.decay;
      if (s.life <= 0) continue;
      alive.push(s);
      const x = cx + Math.cos(s.angle) * s.dist * maxR;
      const y = cy + Math.sin(s.angle) * s.dist * maxR;
      const pulse = 0.5 + 0.5 * Math.sin(ts * 0.001 * s.pulseRate + s.pulsePhase);
      const r = 4 + pulse * 6;
      const alpha = s.life * 0.9;
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle = s.color.replace(')', `,${alpha})`).replace('rgb(', 'rgba(').replace('#', 'rgba(').replace('rgba(', 'rgba(');
      // simpler approach:
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.shadowBlur = 16; ctx.shadowColor = s.color;
      ctx.fillStyle = s.color;
      ctx.fill();
      ctx.shadowBlur = 0;
      ctx.restore();

      // Trail dot
      if (s.life > 0.3) {
        ctx.beginPath(); ctx.arc(x, y, 2, 0, Math.PI * 2);
        ctx.fillStyle = '#ffffff'; ctx.globalAlpha = s.life * 0.6; ctx.fill(); ctx.globalAlpha = 1;
      }
    }
    sources.length = 0; sources.push(...alive);

    // Center dot
    ctx.beginPath(); ctx.arc(cx, cy, 4, 0, Math.PI * 2);
    ctx.fillStyle = '#0d9488'; ctx.shadowBlur = 20; ctx.shadowColor = '#0d9488'; ctx.fill(); ctx.shadowBlur = 0;

    // Update badges
    document.getElementById('b-sources').textContent = alive.length;
    document.getElementById('b-env').textContent = envNames[envIdx];
    document.getElementById('b-wind').textContent = windLevels[windIdx];

    requestAnimationFrame(drawHero);
  }

  window.addEventListener('resize', resize);
  resize();
  for (let i = 0; i < 6; i++) spawnSource();
  requestAnimationFrame(drawHero);
})();

// ═══════════════════════════════════════════════════════
// SOUNDSCAPE ECOLOGIST
// ═══════════════════════════════════════════════════════
const ecoElements = [
  { name:'Dawn Chorus', cat:'bio', color:'#0d9488', freqLo:0.1, freqHi:0.9, active:false, osc:null },
  { name:'Rain', cat:'geo', color:'#64748b', freqLo:0.0, freqHi:1.0, active:false, osc:null },
  { name:'Wind', cat:'geo', color:'#d97706', freqLo:0.0, freqHi:0.35, active:false, osc:null },
  { name:'Traffic', cat:'anthro', color:'#f43f5e', freqLo:0.05, freqHi:0.28, active:false, osc:null },
  { name:'Construction', cat:'anthro', color:'#fb923c', freqLo:0.03, freqHi:0.4, active:false, osc:null },
  { name:'Insects', cat:'bio', color:'#a3e635', freqLo:0.55, freqHi:1.0, active:false, osc:null }
];

function buildEcoControls() {
  const ctrl = document.getElementById('eco-controls');
  ecoElements.forEach((el, i) => {
    const btn = document.createElement('button');
    btn.className = 'btn'; btn.id = `eco-btn-${i}`;
    btn.textContent = el.name;
    btn.style.borderColor = el.color; btn.style.color = el.color;
    btn.onclick = () => toggleEcoElement(i);
    ctrl.appendChild(btn);
  });
}
buildEcoControls();

function toggleEcoElement(idx) {
  const el = ecoElements[idx];
  el.active = !el.active;
  const btn = document.getElementById(`eco-btn-${idx}`);
  btn.style.background = el.active ? el.color : 'transparent';
  btn.style.color = el.active ? '#050508' : el.color;
  if (el.active) startEcoSound(idx); else stopEcoSound(idx);
  updateHealthMeter();
}

function startEcoSound(idx) {
  const ac = getAudioCtx();
  const el = ecoElements[idx];
  if (el.osc) return;
  const buf = ac.createBuffer(1, ac.sampleRate * 2, ac.sampleRate);
  const data = buf.getChannelData(0);
  for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1);
  const src = ac.createBufferSource();
  src.buffer = buf; src.loop = true;
  const filter = ac.createBiquadFilter();
  const freqLo = 20 + el.freqLo * 8000;
  const freqHi = 20 + el.freqHi * 8000;
  filter.type = 'bandpass';
  filter.frequency.value = (freqLo + freqHi) / 2;
  filter.Q.value = 1.2;
  const gain = ac.createGain(); gain.gain.value = 0.12;
  src.connect(filter); filter.connect(gain); gain.connect(ac.destination);
  src.start();
  el.osc = { src, gain };
}

function stopEcoSound(idx) {
  const el = ecoElements[idx];
  if (!el.osc) return;
  el.osc.gain.gain.setTargetAtTime(0, getAudioCtx().currentTime, 0.3);
  setTimeout(() => { try { el.osc.src.stop(); } catch(e){} el.osc = null; }, 600);
}

function updateHealthMeter() {
  let bio = 0, geo = 0, anthro = 0;
  ecoElements.forEach(el => { if (el.active) { if (el.cat==='bio') bio++; else if(el.cat==='geo') geo++; else anthro++; } });
  const total = bio + geo + anthro;
  const health = total === 0 ? 100 : Math.max(0, Math.min(100, Math.round((bio * 2 - anthro * 1.5 + geo * 0.5) / Math.max(total, 1) * 50 + 50)));
  document.getElementById('health-fill').style.width = health + '%';
  document.getElementById('health-pct').textContent = health + '%';
  document.getElementById('bio-count').textContent = bio;
  document.getElementById('geo-count').textContent = geo;
  document.getElementById('anthro-count').textContent = anthro;
}

// Eco canvas
(function initEcoCanvas() {
  const canvas = document.getElementById('eco-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let t = 0;
  function draw() {
    const W = canvas.width, H = canvas.height;
    ctx.fillStyle = 'rgba(13,13,20,0.3)';
    ctx.fillRect(0, 0, W, H);
    t += 0.016;
    const active = ecoElements.filter(e => e.active);
    if (active.length === 0) {
      ctx.fillStyle = 'rgba(13,13,20,0.6)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle = '#1e1e2e'; ctx.font = '12px monospace';
      ctx.textAlign = 'center'; ctx.fillText('Add elements to build the soundscape', W/2, H/2);
    } else {
      active.forEach((el, i) => {
        const bandH = H / active.length;
        const y0 = i * bandH;
        const freq = 0.5 + el.freqLo * 6 + i * 0.7;
        for (let x = 0; x < W; x += 3) {
          const wave = Math.sin(x * 0.04 + t * freq) * 0.4 + Math.sin(x * 0.11 + t * freq * 1.3) * 0.3 + (Math.random() - 0.5) * 0.15;
          const h = (0.4 + wave * 0.3) * bandH * 0.8;
          const alpha = 0.5 + wave * 0.3;
          ctx.fillStyle = el.color;
          ctx.globalAlpha = Math.max(0.1, alpha);
          ctx.fillRect(x, y0 + bandH / 2 - h / 2, 2, h);
        }
        ctx.globalAlpha = 1;
        ctx.fillStyle = 'rgba(5,5,8,0.5)';
        ctx.fillRect(0, y0, 90, 18);
        ctx.fillStyle = el.color; ctx.font = '10px monospace'; ctx.textAlign = 'left';
        ctx.fillText(el.name, 6, y0 + 13);
      });
    }
    ctx.globalAlpha = 1;
    // Freq axis labels
    ctx.fillStyle = 'rgba(100,116,139,0.5)'; ctx.font = '9px monospace'; ctx.textAlign = 'right';
    ['20Hz','1kHz','4kHz','20kHz'].forEach((l, i) => ctx.fillText(l, W - 4, H - (i / 3) * H + 10));
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();

