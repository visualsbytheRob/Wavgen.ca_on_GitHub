<section id="protocol">
<div class="inner">
<div class="section-label hidden stagger-1">Section 02</div>
<div class="section-title hidden stagger-2">MIDI Protocol Explorer</div>
<div class="section-sub hidden stagger-3">Click any byte to reveal its role. Adjust the sliders to send virtual MIDI messages and watch the bytes update live.</div>
<div class="grid-2 hidden stagger-4">
<!-- Note On/Off -->
<div>
<div style="font-size:.7rem;color:var(--dim);letter-spacing:.12em;margin-bottom:.6rem">NOTE ON / NOTE OFF</div>
<div class="byte-packet" id="note-packet">
<div class="byte byte-status" data-tip="Status byte: 0x9n = Note On, channel n (1–16). Upper nibble = message type, lower nibble = channel.">
<div class="byte-hex" id="byte-status-note">9<span id="byte-ch-disp">0</span></div>
<div class="byte-lbl">STATUS</div>
</div>
<div style="color:var(--dim);font-size:1.2rem">→</div>
<div class="byte byte-data1" data-tip="Note Number: 0–127. Middle C = 60. Each step = one semitone. C4=60, D4=62, E4=64, F4=65, G4=67, A4=69, B4=71.">
<div class="byte-hex" id="byte-note-num">3C</div>
<div class="byte-lbl">NOTE</div>
</div>
<div style="color:var(--dim);font-size:1.2rem">→</div>
<div class="byte byte-data2" data-tip="Velocity: 0–127. How hard the key was struck. 0 = Note Off (in some implementations). 64 = medium, 127 = maximum.">
<div class="byte-hex" id="byte-velocity">64</div>
<div class="byte-lbl">VELOCITY</div>
</div>
</div>
<div class="byte-tooltip" id="note-tip">← Click a byte to learn what it means</div>
<div class="slider-row"><span class="slider-label">Channel</span><input id="sl-channel" max="15" min="0" type="range" value="0"/><span class="slider-val" id="sv-channel">1</span></div>
<div class="slider-row"><span class="slider-label">Note</span><input id="sl-note" max="127" min="0" type="range" value="60"/><span class="slider-val" id="sv-note">C4 (60)</span></div>
<div class="slider-row"><span class="slider-label">Velocity</span><input id="sl-vel" max="127" min="1" type="range" value="100"/><span class="slider-val" id="sv-vel">100</span></div>
</div>
<!-- CC Message -->
<div>
<div style="font-size:.7rem;color:var(--dim);letter-spacing:.12em;margin-bottom:.6rem">CONTROL CHANGE (CC)</div>
<div class="byte-packet" id="cc-packet">
<div class="byte byte-status" data-tip="Status byte: 0xBn = Control Change on channel n. B = 11 in hex, indicating CC message type.">
<div class="byte-hex" id="byte-status-cc">B<span id="byte-ch-disp2">0</span></div>
<div class="byte-lbl">STATUS</div>
</div>
<div style="color:var(--dim);font-size:1.2rem">→</div>
<div class="byte byte-data1" data-tip="Controller Number: 0–127. Common: CC1=Mod Wheel, CC7=Volume, CC10=Pan, CC11=Expression, CC64=Sustain Pedal, CC74=Filter Cutoff.">
<div class="byte-hex" id="byte-cc-num">01</div>
<div class="byte-lbl">CTRL#</div>
</div>
<div style="color:var(--dim);font-size:1.2rem">→</div>
<div class="byte byte-data2" data-tip="Controller Value: 0–127. Meaning depends on controller. For switches (CC64 sustain): 0=off, 127=on. For continuous: 0=min, 127=max.">
<div class="byte-hex" id="byte-cc-val">40</div>
<div class="byte-lbl">VALUE</div>
</div>
</div>
<div class="byte-tooltip" id="cc-tip">← Click a byte to learn what it means</div>
<div class="slider-row"><span class="slider-label">Controller</span>
<select id="sl-cc-num" style="flex:1">
<option value="1">CC1 — Mod Wheel</option>
<option value="7">CC7 — Volume</option>
<option value="10">CC10 — Pan</option>
<option value="11">CC11 — Expression</option>
<option value="64">CC64 — Sustain Pedal</option>
<option value="74">CC74 — Filter Cutoff</option>
</select>
</div>
<div class="slider-row"><span class="slider-label">Value</span><input id="sl-cc-val" max="127" min="0" type="range" value="64"/><span class="slider-val" id="sv-cc-val">64</span></div>
