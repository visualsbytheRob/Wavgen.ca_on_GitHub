<div style="padding:3rem 1rem;text-align:center;color:var(--dim);font-size:0.7rem;letter-spacing:0.15em;border-top:1px solid var(--border)">
  WAVGEN MUSIC WORLD 05 — REVERB LAB  |  SPACE IS THE FINAL INSTRUMENT
</div>
<script>
// ══════════════════════════════════════════════════════════════════════
// UTILITIES
// ══════════════════════════════════════════════════════════════════════
function lerp(a, b, t) { return a + (b - a) * t; }
function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
function map(v, a, b, c, d) { return c + (v - a) / (b - a) * (d - c); }

// ══════════════════════════════════════════════════════════════════════
// INTERSECTION OBSERVER — scroll animations + nav active
// ══════════════════════════════════════════════════════════════════════
const animObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.hidden').forEach(el => animObserver.observe(el));

const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav-link');
const navObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      navLinks.forEach(l => l.classList.remove('active'));
      const active = document.querySelector(`.nav-link[href="#${e.target.id}"]`);
      if (active) active.classList.add('active');
    }
  });
}, { threshold: 0.5 });
sections.forEach(s => navObserver.observe(s));

// ══════════════════════════════════════════════════════════════════════
// HERO CANVAS — Concentric expanding rings
// ══════════════════════════════════════════════════════════════════════
(function() {
  const cv = document.getElementById('hero-canvas');
  const ctx = cv.getContext('2d');
  let W, H;
  function resize() {
    W = cv.width = cv.offsetWidth;
    H = cv.height = cv.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  const rings = [];
  function spawnRing() {
    rings.push({ r: 0, maxR: Math.hypot(W, H) * 0.55, alpha: 0.9, born: performance.now() });
  }
  spawnRing();
  setInterval(spawnRing, 1800);

  function draw(ts) {
    requestAnimationFrame(draw);
    ctx.fillStyle = 'rgba(5,5,10,0.12)';
    ctx.fillRect(0, 0, W, H);
    const cx = W / 2, cy = H / 2;
    rings.forEach((ring, i) => {
      const age = (ts - ring.born) / 4000;
      ring.r = ring.maxR * Math.min(age, 1);
      ring.alpha = (1 - Math.min(age, 1)) * 0.7;
      if (ring.alpha < 0.01) { rings.splice(i, 1); return; }
      ctx.beginPath();
      ctx.arc(cx, cy, ring.r, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(139,92,246,${ring.alpha})`;
      ctx.lineWidth = 1.5;
      ctx.shadowBlur = 16;
      ctx.shadowColor = '#8b5cf6';
      ctx.stroke();
      ctx.shadowBlur = 0;
      if (ring.r > 20) {
        ctx.beginPath();
        ctx.arc(cx, cy, ring.r * 0.6, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(139,92,246,${ring.alpha * 0.4})`;
        ctx.lineWidth = 0.7;
        ctx.stroke();
      }
    });
    // central glow dot
    const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, 60);
    g.addColorStop(0, 'rgba(139,92,246,0.25)');
    g.addColorStop(1, 'rgba(139,92,246,0)');
    ctx.beginPath();
    ctx.arc(cx, cy, 60, 0, Math.PI * 2);
    ctx.fillStyle = g;
    ctx.fill();
  }
  requestAnimationFrame(draw);
})();

// ══════════════════════════════════════════════════════════════════════
// ROOM IR VIEWER
// ══════════════════════════════════════════════════════════════════════
(function() {
  const cv = document.getElementById('ir-canvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H;
  function resize() {
    W = cv.width = cv.offsetWidth;
    H = cv.height = parseInt(cv.getAttribute('height')) || 220;
  }
  resize();
  window.addEventListener('resize', resize);

  let roomSize = 50, damping = 30;
  function drawIR() {
    ctx.fillStyle = '#0d0d14';
    ctx.fillRect(0, 0, W, H);
    const midY = H * 0.65;
    const totalSamples = W - 60;
    const roomT = roomSize / 100; // 0..1
    const dampT = damping / 100;  // 0..1
    const tailLen = Math.floor(totalSamples * (0.3 + roomT * 0.7));
    const decayK  = 4 + dampT * 14; // higher damp = faster decay

    // Axis
    ctx.strokeStyle = '#1e1e2e';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(40, 20); ctx.lineTo(40, H - 30); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(40, midY); ctx.lineTo(W - 10, midY); ctx.stroke();

    // Labels
    ctx.fillStyle = '#64748b';
    ctx.font = '9px system-ui';
    ctx.fillText('0ms', 42, midY + 12);
    ctx.fillText('80ms', 42 + tailLen * 0.15, midY + 12);
    ctx.fillText('2s+', 42 + tailLen * 0.8, midY + 12);
    ctx.fillText('+dB', 30, 24);

    // Draw waveform
    for (let x = 0; x < totalSamples; x++) {
      const t = x / tailLen;
      if (t > 1) break;
      const tNorm = x / totalSamples;
      let amp = 0;
      if (x === 0) {
        amp = 0.9; // direct sound spike
      } else if (t < 0.15) {
        // Early reflections
        const seed = Math.sin(x * 47.3 + roomSize * 0.1) * 0.5 + 0.5;
        const env = Math.exp(-t * 12) * 0.7;
        amp = seed * env * (0.4 + roomT * 0.3);
      } else {
        // Late reverberation — decaying noise
        const noise = Math.sin(x * 13.7) * Math.sin(x * 7.3 + 0.5) * Math.sin(x * 3.1 + 1.2);
        amp = noise * Math.exp(-decayK * (t - 0.15)) * 0.5;
      }

      let color;
      if (x === 0) {
        color = 'rgba(255,255,255,0.95)';
      } else if (t < 0.15) {
        const a = clamp(Math.abs(amp) * 2, 0, 1);
        color = `rgba(139,92,246,${a})`;
      } else {
        const a = clamp(Math.abs(amp), 0, 0.6);
        color = `rgba(100,60,200,${a})`;
      }

      const h = Math.abs(amp) * (H * 0.35);
      ctx.fillStyle = color;
      ctx.fillRect(40 + x, midY - h, 1, h * 2);
    }

    // Annotation lines
    const earlyX = 40 + tailLen * 0.15;
    const lateX  = 40 + tailLen * 0.15;
    ctx.setLineDash([4, 4]);
    ctx.strokeStyle = 'rgba(139,92,246,0.4)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(earlyX, 20); ctx.lineTo(earlyX, H - 30); ctx.stroke();
    ctx.setLineDash([]);

    // Zone labels
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 9px system-ui';
    ctx.fillText('DIRECT', 42, 18);
    ctx.fillStyle = '#8b5cf6';
    ctx.fillText('EARLY REFLECTIONS', earlyX + 4, 18);
    ctx.fillStyle = '#64748b';
    ctx.fillText('LATE REVERBERATION', earlyX + tailLen * 0.3, 18);
  }

  const sizeSlider = document.getElementById('ir-size');
  const dampSlider = document.getElementById('ir-damp');
  const sizeVal = document.getElementById('ir-size-val');
  const dampVal = document.getElementById('ir-damp-val');
  sizeSlider.addEventListener('input', () => {
    roomSize = +sizeSlider.value;
    sizeVal.textContent = roomSize + '%';
    drawIR();
  });
  dampSlider.addEventListener('input', () => {
    damping = +dampSlider.value;
    dampVal.textContent = damping + '%';
    drawIR();
  });
  window.addEventListener('resize', drawIR);
  drawIR();
})();
</script>
<script>
// ══════════════════════════════════════════════════════════════════════
// SCHROEDER REVERBERATOR — pipe-organ signal flow
// ══════════════════════════════════════════════════════════════════════
(function() {
  const cv = document.getElementById('schroeder-canvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H;
  function resize() { W = cv.width = cv.offsetWidth; H = parseInt(cv.getAttribute('height')) || 260; }
  resize(); window.addEventListener('resize', () => { resize(); draw(); });

  let decay = 1.5, diff = 50, mix = 50;
  const combs = [
    { delay: 29.7, fb: 0.805 },
    { delay: 37.1, fb: 0.827 },
    { delay: 41.1, fb: 0.783 },
    { delay: 43.7, fb: 0.764 }
  ];
  const allpasses = [
    { delay: 5.0, gain: 0.7 },
    { delay: 1.7, gain: 0.7 }
  ];

  const dots = [];
  let phase = 0;
  function spawnDots() {
    combs.forEach((c, i) => {
      dots.push({ comb: i, t: 0, speed: 0.4 + i * 0.05 });
    });
  }
  spawnDots();
  setInterval(spawnDots, 1200);

  function draw() {
    ctx.fillStyle = '#0d0d14';
    ctx.fillRect(0, 0, W, H);
    phase += 0.02;
    const padL = 60, padR = 40, padT = 30, padB = 40;
    const pipeW = (W - padL - padR);
    const pipeH = 28;
    const combStartY = padT;
    const apStartX = padL + pipeW * 0.7;
    const feedH = (H - padT - padB - pipeH * 2.5) / 3;

    // Input label
    ctx.fillStyle = '#64748b'; ctx.font = '10px system-ui';
    ctx.fillText('INPUT', 4, H / 2 + 4);
    // Input line
    ctx.strokeStyle = '#1e1e2e'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(padL - 10, H / 2); ctx.lineTo(padL + 10, H / 2); ctx.stroke();

    // Draw 4 comb filter pipes
    const combYs = [];
    combs.forEach((c, i) => {
      const y = padT + i * ((H - padT - padB - pipeH) / 4);
      combYs.push(y + pipeH / 2);

      // Pipe body
      const gradient = ctx.createLinearGradient(padL, y, padL, y + pipeH);
      gradient.addColorStop(0, '#1e1e2e');
      gradient.addColorStop(0.5, '#2a2a3e');
      gradient.addColorStop(1, '#1e1e2e');
      ctx.fillStyle = gradient;
      ctx.fillRect(padL, y, apStartX - padL - 20, pipeH);
      ctx.strokeStyle = 'rgba(139,92,246,0.3)';
      ctx.lineWidth = 1;
      ctx.strokeRect(padL, y, apStartX - padL - 20, pipeH);

      // Pipe label
      ctx.fillStyle = '#8b5cf6'; ctx.font = 'bold 9px system-ui';
      ctx.fillText(`COMB ${i + 1}`, padL + 4, y + 11);
      ctx.fillStyle = '#64748b'; ctx.font = '8px system-ui';
      ctx.fillText(`${c.delay}ms`, padL + 4, y + 22);
      const fbPct = Math.round(c.fb * 100 * (decay / 1.5));
      ctx.fillText(`FB: ${Math.min(fbPct, 99)}%`, padL + 55, y + 22);

      // Fan-in line from left
      ctx.strokeStyle = '#64748b'; ctx.lineWidth = 0.7;
      ctx.beginPath(); ctx.moveTo(padL - 10, H / 2);
      ctx.lineTo(padL, y + pipeH / 2); ctx.stroke();
    });

    // Draw 2 allpass filters
    const apYs = [];
    allpasses.forEach((a, i) => {
      const x = apStartX + i * 70;
      const y = H / 2 - pipeH / 2;
      apYs.push({ x, y });
      ctx.fillStyle = 'rgba(30,30,50,0.9)';
      ctx.fillRect(x, y, 60, pipeH);
      ctx.strokeStyle = 'rgba(245,158,11,0.4)';
      ctx.lineWidth = 1;
      ctx.strokeRect(x, y, 60, pipeH);
      ctx.fillStyle = '#f59e0b'; ctx.font = 'bold 9px system-ui';
      ctx.fillText(`AP ${i + 1}`, x + 4, y + 11);
      ctx.fillStyle = '#64748b'; ctx.font = '8px system-ui';
      ctx.fillText(`${a.delay}ms`, x + 4, y + 22);
    });

    // Fan-in from combs to AP1
    combYs.forEach(cy => {
      ctx.strokeStyle = '#64748b'; ctx.lineWidth = 0.7;
      ctx.beginPath(); ctx.moveTo(apStartX - 20, cy);
      ctx.lineTo(apYs[0].x, H / 2); ctx.stroke();
    });
    // AP1 -> AP2
    ctx.beginPath(); ctx.moveTo(apYs[0].x + 60, H / 2); ctx.lineTo(apYs[1].x, H / 2); ctx.stroke();
    // AP2 -> output
    const outX = apYs[1].x + 70;
    ctx.beginPath(); ctx.moveTo(apYs[1].x + 60, H / 2); ctx.lineTo(outX, H / 2); ctx.stroke();
    ctx.fillStyle = '#64748b'; ctx.font = '10px system-ui';
    ctx.fillText('OUT', outX + 2, H / 2 + 4);

    // Animate signal dots through combs
    dots.forEach((d, idx) => {
      d.t += d.speed * 0.012;
      const pipe = combs[d.comb];
      const pipeLen = apStartX - padL - 24;
      const x = padL + d.t * pipeLen;
      const y = combYs[d.comb];
      if (x > padL + pipeLen) { dots.splice(idx, 1); return; }
      const alpha = 1 - d.t;
      ctx.beginPath();
      ctx.arc(x, y, 3, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(139,92,246,${alpha})`;
      ctx.shadowBlur = 8; ctx.shadowColor = '#8b5cf6';
      ctx.fill(); ctx.shadowBlur = 0;
    });

    // Title
    ctx.fillStyle = '#64748b'; ctx.font = '9px system-ui';
    ctx.fillText(`Decay: ${decay.toFixed(1)}s  Diffusion: ${diff}%  Mix: ${mix}%`, padL, H - 8);
  }

  function animate() { requestAnimationFrame(animate); draw(); }
  animate();

  document.getElementById('sch-decay').addEventListener('input', function() {
    decay = this.value / 10;
    document.getElementById('sch-decay-val').textContent = decay.toFixed(1) + 's';
  });
  document.getElementById('sch-diff').addEventListener('input', function() {
    diff = +this.value;
    document.getElementById('sch-diff-val').textContent = diff + '%';
  });
  document.getElementById('sch-mix').addEventListener('input', function() {
    mix = +this.value;
    document.getElementById('sch-mix-val').textContent = mix + '%';
  });

  // Play test tone
  document.getElementById('sch-play-btn').addEventListener('click', function() {
    try {
      const ac = new AudioContext();
      const osc = ac.createOscillator();
      const gain = ac.createGain();
      osc.frequency.value = 440;
      osc.connect(gain);
      gain.connect(ac.destination);
      gain.gain.setValueAtTime(0.15, ac.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 0.3);
      osc.start();
      osc.stop(ac.currentTime + 0.3);
      this.textContent = '♪ Playing...';
      setTimeout(() => { this.textContent = '▶ Play Test Tone'; }, 400);
    } catch(e) {}
  });
})();

// ══════════════════════════════════════════════════════════════════════
// PLATE REVERB — ripple physics
// ══════════════════════════════════════════════════════════════════════
(function() {
  const cv = document.getElementById('plate-canvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H;
  function resize() { W = cv.width = cv.offsetWidth; H = parseInt(cv.getAttribute('height')) || 300; }
  resize(); window.addEventListener('resize', resize);

  let plateSize = 50, plateDecay = 50, plateTone = 50;
  const ripples = [];

  cv.addEventListener('click', (e) => {
    const rect = cv.getBoundingClientRect();
    const x = (e.clientX - rect.left) * (W / rect.width);
    const y = (e.clientY - rect.top) * (H / rect.height);
    ripples.push({ x, y, r: 0, born: performance.now(), maxR: Math.hypot(W, H) * 0.7 });
  });

  function draw() {
    requestAnimationFrame(draw);
    ctx.fillStyle = 'rgba(5,5,10,0.18)';
    ctx.fillRect(0, 0, W, H);

    // Plate background
    const mg = ctx.createLinearGradient(20, 20, W - 20, H - 20);
    mg.addColorStop(0, 'rgba(50,45,70,0.3)');
    mg.addColorStop(0.5, 'rgba(70,65,90,0.2)');
    mg.addColorStop(1, 'rgba(40,38,55,0.3)');
    ctx.fillStyle = mg;
    ctx.fillRect(20, 20, W - 40, H - 40);
    ctx.strokeStyle = 'rgba(139,92,246,0.2)';
    ctx.lineWidth = 1;
    ctx.strokeRect(20, 20, W - 40, H - 40);

    // EMT label
    ctx.fillStyle = 'rgba(139,92,246,0.15)';
    ctx.font = 'bold 28px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('EMT 140', W / 2, H / 2 + 10);
    ctx.textAlign = 'left';

    const speedFactor = 0.4 + (plateSize / 100) * 1.2;
    const decayFactor = 3 + ((100 - plateDecay) / 100) * 10;
    const toneMix = plateTone / 100;

    const now = performance.now();
    for (let i = ripples.length - 1; i >= 0; i--) {
      const rp = ripples[i];
      const age = (now - rp.born) / 1000;
      rp.r = rp.maxR * Math.min(age * speedFactor, 1);
      const alpha = Math.exp(-decayFactor * age) * 0.8;
      if (alpha < 0.01) { ripples.splice(i, 1); continue; }

      // Main elliptical ripple (plate has different X/Y propagation)
      const rx = rp.r;
      const ry = rp.r * 0.65;
      ctx.beginPath();
      ctx.ellipse(rp.x, rp.y, rx, ry, 0, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(${Math.round(139 + toneMix * 60)},${Math.round(92 + toneMix * 40)},246,${alpha})`;
      ctx.lineWidth = 1.5;
      ctx.shadowBlur = 10;
      ctx.shadowColor = '#8b5cf6';
      ctx.stroke();
      ctx.shadowBlur = 0;

      // Inner ring (harmonic)
      if (rp.r > 15) {
        ctx.beginPath();
        ctx.ellipse(rp.x, rp.y, rx * 0.65, ry * 0.65, 0, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(139,92,246,${alpha * 0.4})`;
        ctx.lineWidth = 0.7;
        ctx.stroke();
      }
    }
  }
  draw();

  document.getElementById('plate-size').addEventListener('input', function() {
    plateSize = +this.value;
    const lbl = plateSize < 33 ? 'Small' : plateSize < 66 ? 'Medium' : 'Large';
    document.getElementById('plate-size-val').textContent = lbl;
  });
  document.getElementById('plate-decay').addEventListener('input', function() {
    plateDecay = +this.value;
    document.getElementById('plate-decay-val').textContent = plateDecay + '%';
  });
  document.getElementById('plate-tone').addEventListener('input', function() {
    plateTone = +this.value;
    document.getElementById('plate-tone-val').textContent = plateTone + '%';
  });
})();
</script>
<script>
// ══════════════════════════════════════════════════════════════════════
// PRE-DELAY — Singer and Wall
// ══════════════════════════════════════════════════════════════════════
(function() {
  const cv = document.getElementById('predelay-canvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H;
  function resize() { W = cv.width = cv.offsetWidth; H = parseInt(cv.getAttribute('height')) || 260; }
  resize(); window.addEventListener('resize', () => { resize(); });

  let pdMs = 30;
  let wavePhase = 0;
  let waveFwd = null, waveBack = null;
  let lastFire = -9999;

  function fireWave() {
    const t = performance.now();
    waveFwd  = { t: 0, fired: t };
    waveBack = null;
  }
  fireWave();
  setInterval(fireWave, 2200);

  function draw(ts) {
    requestAnimationFrame(draw);
    ctx.fillStyle = '#0d0d14';
    ctx.fillRect(0, 0, W, H);

    const t = pdMs / 1000;
    const dist = (t * 343) / 2;
    const distLabel = dist.toFixed(1) + 'm';

    // Wall position: map 0..150ms => 20%..85% of width
    const wallXPct = 0.2 + (pdMs / 150) * 0.65;
    const wallX = Math.floor(W * wallXPct);
    const singerX = Math.floor(W * 0.10);
    const midY = H / 2;

    // Floor / ceiling
    ctx.strokeStyle = '#1e1e2e'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(singerX - 20, H - 30); ctx.lineTo(wallX + 10, H - 30); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(singerX - 20, 30); ctx.lineTo(wallX + 10, 30); ctx.stroke();

    // Wall
    ctx.fillStyle = 'rgba(139,92,246,0.12)';
    ctx.fillRect(wallX, 25, 14, H - 50);
    ctx.strokeStyle = 'rgba(139,92,246,0.5)';
    ctx.lineWidth = 2;
    ctx.strokeRect(wallX, 25, 14, H - 50);

    // Singer (geometric figure)
    ctx.strokeStyle = '#e2e8f0'; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.arc(singerX, midY - 22, 10, 0, Math.PI * 2); ctx.stroke(); // head
    ctx.beginPath(); ctx.moveTo(singerX, midY - 12); ctx.lineTo(singerX, midY + 18); ctx.stroke(); // body
    ctx.beginPath(); ctx.moveTo(singerX, midY - 5); ctx.lineTo(singerX - 14, midY + 5); ctx.stroke(); // L arm
    ctx.beginPath(); ctx.moveTo(singerX, midY - 5); ctx.lineTo(singerX + 14, midY + 5); ctx.stroke(); // R arm (mic)
    ctx.beginPath(); ctx.moveTo(singerX, midY + 18); ctx.lineTo(singerX - 10, midY + 36); ctx.stroke(); // L leg
    ctx.beginPath(); ctx.moveTo(singerX, midY + 18); ctx.lineTo(singerX + 10, midY + 36); ctx.stroke(); // R leg

    // Wave animation
    const now = performance.now();
    if (waveFwd) {
      const age = (now - waveFwd.fired) / 1000;
      const spd = 0.4; // normalised canvas speed
      const fwdX = singerX + (wallX - singerX) * Math.min(age * spd, 1);
      ctx.beginPath();
      ctx.arc(fwdX, midY, 6 + age * 4, 0, Math.PI * 2);
      const a = Math.max(0, 1 - age * spd);
      ctx.strokeStyle = `rgba(139,92,246,${a * 0.9})`;
      ctx.lineWidth = 2;
      ctx.shadowBlur = 10; ctx.shadowColor = '#8b5cf6';
      ctx.stroke(); ctx.shadowBlur = 0;

      if (age * spd >= 1) {
        waveFwd = null;
        waveBack = { fired: now, startX: wallX };
      }
    }
    if (waveBack) {
      const age2 = (now - waveBack.fired) / 1000;
      const spd2 = 0.4;
      const bkX = waveBack.startX - (wallX - singerX) * Math.min(age2 * spd2, 1);
      ctx.beginPath();
      ctx.arc(bkX, midY, 5 + age2 * 3, 0, Math.PI * 2);
      const a2 = Math.max(0, 1 - age2 * spd2);
      ctx.strokeStyle = `rgba(245,158,11,${a2 * 0.9})`;
      ctx.lineWidth = 2;
      ctx.shadowBlur = 10; ctx.shadowColor = '#f59e0b';
      ctx.stroke(); ctx.shadowBlur = 0;
      if (age2 * spd2 >= 1) waveBack = null;
    }

    // Distance label
    ctx.setLineDash([3, 3]);
    ctx.strokeStyle = 'rgba(100,116,139,0.4)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(singerX + 14, H - 16); ctx.lineTo(wallX, H - 16); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = '#64748b'; ctx.font = '10px system-ui'; ctx.textAlign = 'center';
    ctx.fillText(distLabel, (singerX + wallX) / 2, H - 5);
    ctx.textAlign = 'left';

    // Labels
    ctx.fillStyle = '#64748b'; ctx.font = '9px system-ui';
    ctx.fillText('SINGER', singerX - 18, H - 45);
    ctx.fillText('WALL', wallX + 2, midY - 30);
    ctx.fillStyle = '#8b5cf6';
    ctx.fillText('PRE-DELAY: ' + pdMs + 'ms', W - 130, 18);
  }
  requestAnimationFrame(draw);

  const pdSlider = document.getElementById('pd-slider');
  pdSlider.addEventListener('input', function() {
    pdMs = +this.value;
    document.getElementById('pd-val').textContent = pdMs + 'ms';
    document.getElementById('pd-ms').textContent = pdMs + 'ms';
    const d = ((pdMs / 1000) * 343 / 2).toFixed(1) + 'm';
    document.getElementById('pd-distance').textContent = d;
    const ch = pdMs < 20 ? 'Intimate' : pdMs < 50 ? 'Room' : pdMs < 100 ? 'Hall' : 'Cathedral';
    document.getElementById('pd-char').textContent = ch;
  });
})();

// ══════════════════════════════════════════════════════════════════════
// RT60 PHYSICS LAB
// ══════════════════════════════════════════════════════════════════════
(function() {
  const cv = document.getElementById('rt60-canvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H;
  function resize() { W = cv.width = cv.offsetWidth; H = parseInt(cv.getAttribute('height')) || 240; }
  resize(); window.addEventListener('resize', () => { resize(); drawRT60(); });

  let vol = 500, sa = 400, abs = 0.20;

  function sabine(V, S, alpha) { return 0.161 * V / (S * alpha); }

  function drawRT60() {
    ctx.fillStyle = '#0d0d14';
    ctx.fillRect(0, 0, W, H);
    const padL = 50, padR = 20, padT = 20, padB = 35;
    const gW = W - padL - padR, gH = H - padT - padB;
    const rt = sabine(vol, sa, abs);
    const maxT = Math.max(rt * 1.5, 0.5);

    // Grid
    ctx.strokeStyle = '#1a1a2a'; ctx.lineWidth = 1;
    for (let db = 0; db <= 60; db += 10) {
      const y = padT + (db / 60) * gH;
      ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(padL + gW, y); ctx.stroke();
      ctx.fillStyle = '#64748b'; ctx.font = '8px system-ui'; ctx.textAlign = 'right';
      ctx.fillText('-' + db + 'dB', padL - 4, y + 3);
    }
    ctx.textAlign = 'left';

    // Decay curve
    ctx.beginPath();
    for (let px = 0; px <= gW; px++) {
      const t = (px / gW) * maxT;
      const db = -60 * (t / rt);
      const y = padT + clamp(-db / 60, 0, 1) * gH;
      if (px === 0) ctx.moveTo(padL + px, y);
      else ctx.lineTo(padL + px, y);
    }
    ctx.strokeStyle = '#8b5cf6';
    ctx.lineWidth = 2;
    ctx.shadowBlur = 14; ctx.shadowColor = '#8b5cf6';
    ctx.stroke(); ctx.shadowBlur = 0;

    // -60dB marker
    const rt60X = padL + (rt / maxT) * gW;
    ctx.setLineDash([4, 4]);
    ctx.strokeStyle = 'rgba(139,92,246,0.4)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(rt60X, padT); ctx.lineTo(rt60X, padT + gH); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = '#8b5cf6'; ctx.font = 'bold 9px system-ui';
    ctx.fillText('RT60', rt60X + 3, padT + 12);

    // Reference lines
    const refs = [
      { t: 0.01, label: 'Anechoic' },
      { t: 0.2,  label: 'Studio' },
      { t: 2.0,  label: 'Concert Hall' },
      { t: 6.0,  label: 'Cathedral' }
    ];
    refs.forEach(r => {
      const rx = padL + (r.t / maxT) * gW;
      if (rx < padL || rx > padL + gW) return;
      ctx.strokeStyle = 'rgba(100,116,139,0.25)'; ctx.lineWidth = 0.7;
      ctx.beginPath(); ctx.moveTo(rx, padT); ctx.lineTo(rx, padT + gH); ctx.stroke();
      ctx.fillStyle = '#64748b'; ctx.font = '8px system-ui';
      ctx.fillText(r.label, rx + 2, padT + gH - 4);
    });

    // Axis labels
    ctx.fillStyle = '#64748b'; ctx.font = '9px system-ui'; ctx.textAlign = 'center';
    ctx.fillText('Time (s)', padL + gW / 2, H - 4);
    ctx.textAlign = 'left';

    // X axis ticks
    for (let t = 0; t <= maxT; t += maxT > 4 ? 1 : 0.5) {
      const x = padL + (t / maxT) * gW;
      ctx.fillStyle = '#64748b'; ctx.font = '8px system-ui'; ctx.textAlign = 'center';
      ctx.fillText(t.toFixed(1) + 's', x, padT + gH + 12);
    }
    ctx.textAlign = 'left';

    // Update stats
    document.getElementById('rt60-result').textContent = rt.toFixed(2) + 's';
    const type = rt < 0.1 ? 'Anechoic' : rt < 0.4 ? 'Studio' : rt < 1.0 ? 'Live Room'
                : rt < 2.5 ? 'Concert Hall' : rt < 5 ? 'Large Hall' : 'Cathedral';
    document.getElementById('rt60-type').textContent = type;
  }

  ['rt60-vol','rt60-sa','rt60-abs'].forEach(id => {
    document.getElementById(id).addEventListener('input', function() {
      vol = +document.getElementById('rt60-vol').value;
      sa  = +document.getElementById('rt60-sa').value;
      abs = +document.getElementById('rt60-abs').value / 100;
      document.getElementById('rt60-vol-val').textContent = vol;
      document.getElementById('rt60-sa-val').textContent  = sa;
      document.getElementById('rt60-abs-val').textContent = abs.toFixed(2);
      drawRT60();
    });
  });
  window.addEventListener('resize', drawRT60);
  drawRT60();
})();
</script>
<script>
// ══════════════════════════════════════════════════════════════════════
// FREQUENCY-DEPENDENT DECAY — Spectrogram + Band Curves
// ══════════════════════════════════════════════════════════════════════
(function() {
  const specCv = document.getElementById('spec-canvas');
  const bandCv = document.getElementById('band-canvas');
  if (!specCv || !bandCv) return;
  const sCtx = specCv.getContext('2d');
  const bCtx = bandCv.getContext('2d');
  let SW, SH, BW, BH;
  function resize() {
    SW = specCv.width = specCv.offsetWidth; SH = parseInt(specCv.getAttribute('height')) || 260;
    BW = bandCv.width = bandCv.offsetWidth; BH = parseInt(bandCv.getAttribute('height')) || 260;
  }
  resize(); window.addEventListener('resize', () => { resize(); drawSpec(); });

  // Material absorption profiles: decay multiplier per band (higher = faster decay)
  const materials = {
    concrete: [0.8, 1.0, 1.2, 1.8, 2.8, 4.5],
    wood:     [1.0, 1.2, 1.5, 2.0, 2.8, 3.5],
    carpet:   [0.9, 1.1, 1.8, 3.2, 5.0, 7.0],
    curtains: [0.8, 1.2, 2.2, 4.0, 6.0, 8.0],
    glass:    [1.5, 1.6, 1.8, 2.0, 2.2, 2.5]
  };
  const bandLabels = ['60Hz','250Hz','500Hz','2kHz','6kHz','16kHz'];
  const bandColors = ['#38bdf8','#34d399','#a3e635','#fbbf24','#f87171','#c084fc'];

  let material = 'concrete', rtScale = 2.0;

  function hotmap(v) {
    // v: 0..1  ->  black->blue->cyan->yellow->white
    if (v < 0.25) return `rgb(0,0,${Math.round(v * 4 * 200)})`;
    if (v < 0.5)  return `rgb(0,${Math.round((v-0.25)*4*255)},255)`;
    if (v < 0.75) return `rgb(${Math.round((v-0.5)*4*255)},255,${255-Math.round((v-0.5)*4*200)})`;
    return `rgb(255,255,${Math.round((1-v)*4*255)})`;
  }

  function drawSpec() {
    // ── Spectrogram ──
    sCtx.fillStyle = '#0d0d14';
    sCtx.fillRect(0, 0, SW, SH);
    const padL = 40, padR = 10, padT = 20, padB = 30;
    const gW = SW - padL - padR, gH = SH - padT - padB;
    const mults = materials[material];
    const cols = gW;
    const rows = 64;
    for (let py = 0; py < rows; py++) {
      const freqT = py / rows; // 0=low, 1=high
      const bandIdx = Math.min(5, Math.floor(freqT * 6));
      const decayMult = mults[bandIdx];
      const baseK = (1 / rtScale) * decayMult * 3;
      for (let px = 0; px < cols; px++) {
        const t = (px / cols) * rtScale;
        const intensity = Math.exp(-baseK * t);
        const noise = 0.85 + Math.sin(px * 7.3 + py * 3.1) * 0.08 + Math.sin(px * 2.1 + py * 9.7) * 0.07;
        const v = clamp(intensity * noise, 0, 1);
        sCtx.fillStyle = v < 0.04 ? '#0d0d14' : hotmap(v);
        const yy = padT + (1 - (py + 1) / rows) * gH;
        sCtx.fillRect(padL + px, yy, 1, gH / rows + 1);
      }
    }

    // Axes
    sCtx.strokeStyle = '#1e1e2e'; sCtx.lineWidth = 1;
    sCtx.beginPath(); sCtx.moveTo(padL, padT); sCtx.lineTo(padL, padT + gH); sCtx.stroke();
    sCtx.beginPath(); sCtx.moveTo(padL, padT + gH); sCtx.lineTo(padL + gW, padT + gH); sCtx.stroke();

    // Y-axis labels
    const freqTicks = ['20Hz','100','500','2k','10k','20kHz'];
    freqTicks.forEach((f, i) => {
      const y = padT + (1 - i / (freqTicks.length - 1)) * gH;
      sCtx.fillStyle = '#64748b'; sCtx.font = '8px system-ui'; sCtx.textAlign = 'right';
      sCtx.fillText(f, padL - 2, y + 3);
    });
    sCtx.textAlign = 'left';
    // X-axis
    for (let t = 0; t <= rtScale; t += rtScale > 3 ? 1 : 0.5) {
      const x = padL + (t / rtScale) * gW;
      sCtx.fillStyle = '#64748b'; sCtx.font = '8px system-ui'; sCtx.textAlign = 'center';
      sCtx.fillText(t.toFixed(1) + 's', x, padT + gH + 12);
    }
    sCtx.textAlign = 'left';
    sCtx.fillStyle = '#64748b'; sCtx.font = '9px system-ui'; sCtx.textAlign = 'center';
    sCtx.fillText('Time', padL + gW / 2, SH - 2);
    sCtx.textAlign = 'left';

    // ── Band Curves ──
    bCtx.fillStyle = '#0d0d14';
    bCtx.fillRect(0, 0, BW, BH);
    const bPadL = 40, bPadR = 15, bPadT = 20, bPadB = 30;
    const bgW = BW - bPadL - bPadR, bgH = BH - bPadT - bPadB;

    // Grid
    bCtx.strokeStyle = '#1a1a2a'; bCtx.lineWidth = 0.7;
    for (let i = 0; i <= 4; i++) {
      const y = bPadT + (i / 4) * bgH;
      bCtx.beginPath(); bCtx.moveTo(bPadL, y); bCtx.lineTo(bPadL + bgW, y); bCtx.stroke();
      bCtx.fillStyle = '#64748b'; bCtx.font = '8px system-ui'; bCtx.textAlign = 'right';
      bCtx.fillText('-' + (i * 15) + 'dB', bPadL - 2, y + 3);
    }
    bCtx.textAlign = 'left';

    mults.forEach((mult, bi) => {
      const k = (1 / rtScale) * mult * 3;
      bCtx.beginPath();
      for (let px = 0; px <= bgW; px++) {
        const t = (px / bgW) * rtScale;
        const db = -20 * Math.log10(Math.exp(-k * t) + 1e-9);
        const y = bPadT + clamp(-db / 60, 0, 1) * bgH;
        if (px === 0) bCtx.moveTo(bPadL + px, y);
        else bCtx.lineTo(bPadL + px, y);
      }
      bCtx.strokeStyle = bandColors[bi];
      bCtx.lineWidth = 1.5;
      bCtx.shadowBlur = 6; bCtx.shadowColor = bandColors[bi];
      bCtx.stroke(); bCtx.shadowBlur = 0;

      // Legend
      bCtx.fillStyle = bandColors[bi]; bCtx.font = '8px system-ui';
      bCtx.fillText(bandLabels[bi], BW - bPadR - 32, bPadT + bi * 13 + 10);
    });

    // X axis
    for (let t = 0; t <= rtScale; t += rtScale > 3 ? 1 : 0.5) {
      const x = bPadL + (t / rtScale) * bgW;
      bCtx.fillStyle = '#64748b'; bCtx.font = '8px system-ui'; bCtx.textAlign = 'center';
      bCtx.fillText(t.toFixed(1) + 's', x, BH - 4);
    }
    bCtx.textAlign = 'left';
  }

  document.getElementById('material-sel').addEventListener('change', function() {
    material = this.value; drawSpec();
  });
  document.getElementById('spec-rt').addEventListener('input', function() {
    rtScale = +this.value / 10;
    document.getElementById('spec-rt-val').textContent = rtScale.toFixed(1) + 's';
    drawSpec();
  });
  drawSpec();
})();

// ══════════════════════════════════════════════════════════════════════
// GATED REVERB
// ══════════════════════════════════════════════════════════════════════
(function() {
  const cv = document.getElementById('gate-canvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H;
  function resize() { W = cv.width = cv.offsetWidth; H = parseInt(cv.getAttribute('height')) || 280; }
  resize(); window.addEventListener('resize', () => { resize(); drawGate(); });

  let gatePD = 10, gateRT = 2.0, gateHold = 200, gateRel = 50;
  let gateFlash = 0;

  function drawGate() {
    ctx.fillStyle = '#0d0d14';
    ctx.fillRect(0, 0, W, H);

    const panelW = Math.floor((W - 20) / 3) - 4;
    const panels = [6, panelW + 10, panelW * 2 + 14];
    const pH = H - 20;
    const labels = ['INPUT', 'GATE ENVELOPE', 'OUTPUT + GATE'];

    panels.forEach((px, pi) => {
      ctx.strokeStyle = '#1e1e2e'; ctx.lineWidth = 1;
      ctx.strokeRect(px, 10, panelW, pH - 10);
      ctx.fillStyle = '#64748b'; ctx.font = '8px system-ui';
      ctx.fillText(labels[pi], px + 4, 22);
    });

    const pT = 30, pB = pH - 10, pGH = pB - pT;
    const sampleW = panelW - 12;
    const totalT = (gateRT + gatePD / 1000 + gateHold / 1000 + gateRel / 1000) * 1.3;

    // ── Panel 1: Input (impulse + decay tail) ──
    const p1x = panels[0] + 6;
    for (let px = 0; px < sampleW; px++) {
      const t = (px / sampleW) * totalT;
      let amp = 0;
      if (px < 2) amp = 0.9;
      else {
        const noise = Math.sin(px * 17.3) * Math.sin(px * 5.1 + 0.4);
        amp = noise * Math.exp(-(px / sampleW) * 4);
      }
      const h = Math.abs(amp) * pGH * 0.45;
      const midY = pT + pGH / 2;
      ctx.fillStyle = `rgba(139,92,246,${Math.abs(amp) * 0.8 + 0.1})`;
      ctx.fillRect(p1x + px, midY - h, 1, h * 2);
    }

    // ── Panel 2: Gate envelope ──
    const p2x = panels[1] + 6;
    const pdPx    = Math.floor((gatePD / 1000 / totalT) * sampleW);
    const holdPx  = Math.floor((gateHold / 1000 / totalT) * sampleW);
    const relPx   = Math.floor((gateRel / 1000 / totalT) * sampleW);
    const openEnd = pdPx + holdPx;
    const closeEnd = openEnd + relPx;

    ctx.beginPath();
    ctx.moveTo(p2x, pT + pGH);
    ctx.lineTo(p2x + pdPx, pT + pGH);
    ctx.lineTo(p2x + pdPx, pT + 4);
    ctx.lineTo(p2x + openEnd, pT + 4);
    ctx.lineTo(p2x + closeEnd, pT + pGH);
    ctx.lineTo(p2x + sampleW, pT + pGH);
    ctx.strokeStyle = '#10b981'; ctx.lineWidth = 2;
    ctx.shadowBlur = 8; ctx.shadowColor = '#10b981';
    ctx.stroke(); ctx.shadowBlur = 0;

    // Trapdoor animation
    const doorX = p2x + openEnd - 4;
    const doorY = pT + 4;
    const flashA = clamp(gateFlash, 0, 1);
    ctx.fillStyle = `rgba(239,68,68,${0.15 + flashA * 0.4})`;
    ctx.fillRect(doorX - 3, doorY, relPx + 6, pGH - 4);
    if (flashA > 0) {
      ctx.fillStyle = `rgba(239,68,68,${flashA})`;
      ctx.fillRect(doorX, doorY, 6, pGH - 4);
      gateFlash *= 0.92;
    }
    ctx.fillStyle = '#64748b'; ctx.font = '8px system-ui';
    ctx.fillText('OPEN', p2x + pdPx + 2, pT + pGH - 4);
    ctx.fillText('CLOSE', p2x + openEnd + 2, pT + pGH - 4);

    // ── Panel 3: Output (gated) ──
    const p3x = panels[2] + 6;
    for (let px = 0; px < sampleW; px++) {
      const t = px / sampleW;
      const tAbs = t * totalT;
      const pdT = gatePD / 1000, holdT = gateHold / 1000, relT = gateRel / 1000;
      let gate = 0;
      if (tAbs >= pdT && tAbs < pdT + holdT) gate = 1;
      else if (tAbs >= pdT + holdT && tAbs < pdT + holdT + relT)
        gate = 1 - (tAbs - pdT - holdT) / relT;
      const noise = Math.sin(px * 17.3) * Math.sin(px * 5.1 + 0.4);
      const amp = noise * Math.exp(-px / sampleW * 4) * gate;
      const h = Math.abs(amp) * pGH * 0.45;
      const midY = pT + pGH / 2;
      const red = gate < 0.1 ? 0.3 : 0;
      ctx.fillStyle = `rgba(${Math.round(139 + red * 100)},${Math.round(92 - red * 60)},246,${Math.abs(amp) * 0.8 + 0.05})`;
      ctx.fillRect(p3x + px, midY - h, 1, h * 2);
    }

    // Gate slam line
    ctx.strokeStyle = `rgba(239,68,68,0.6)`;
    ctx.lineWidth = 1.5;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    ctx.moveTo(p3x + openEnd, pT); ctx.lineTo(p3x + openEnd, pT + pGH);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = '#ef4444'; ctx.font = '8px system-ui';
    ctx.fillText('GATE', p3x + openEnd + 2, pT + 10);
  }

  function triggerFlash() { gateFlash = 1; drawGate(); }

  ['gate-pd','gate-rt','gate-hold','gate-rel'].forEach(id => {
    document.getElementById(id).addEventListener('input', function() {
      gatePD   = +document.getElementById('gate-pd').value;
      gateRT   = +document.getElementById('gate-rt').value / 10;
      gateHold = +document.getElementById('gate-hold').value;
      gateRel  = +document.getElementById('gate-rel').value;
      document.getElementById('gate-pd-val').textContent   = gatePD + 'ms';
      document.getElementById('gate-rt-val').textContent   = gateRT.toFixed(1) + 's';
      document.getElementById('gate-hold-val').textContent = gateHold + 'ms';
      document.getElementById('gate-rel-val').textContent  = gateRel + 'ms';
      triggerFlash();
    });
  });

  function applyPreset(pd, rt, hold, rel) {
    gatePD = pd; gateRT = rt; gateHold = hold; gateRel = rel;
    document.getElementById('gate-pd').value   = pd;
    document.getElementById('gate-rt').value   = rt * 10;
    document.getElementById('gate-hold').value = hold;
    document.getElementById('gate-rel').value  = rel;
    document.getElementById('gate-pd-val').textContent   = pd + 'ms';
    document.getElementById('gate-rt-val').textContent   = rt.toFixed(1) + 's';
    document.getElementById('gate-hold-val').textContent = hold + 'ms';
    document.getElementById('gate-rel-val').textContent  = rel + 'ms';
    triggerFlash();
  }

  document.getElementById('gate-preset-1').addEventListener('click', () => applyPreset(10, 2.0, 200, 50));
  document.getElementById('gate-preset-2').addEventListener('click', () => applyPreset(5,  1.5, 120, 30));
  document.getElementById('gate-preset-3').addEventListener('click', () => applyPreset(20, 3.0, 350, 80));

  window.addEventListener('resize', drawGate);
  drawGate();
})();
</script>
<script>
// ══════════════════════════════════════════════════════════════════════
// CONVOLUTION vs ALGORITHMIC
// ══════════════════════════════════════════════════════════════════════
(function() {
  const convCv = document.getElementById('conv-canvas');
  const algoCv = document.getElementById('algo-canvas');
  if (!convCv || !algoCv) return;
  const cCtx = convCv.getContext('2d');
  const aCtx = algoCv.getContext('2d');

  function resize() {
    convCv.width = convCv.offsetWidth;
    algoCv.width = algoCv.offsetWidth;
  }
  resize(); window.addEventListener('resize', () => { resize(); draw(); });

  const spaces = {
    abbey:  { name: 'Abbey Road Chamber', rt: 1.1, pd: 8,  desc: 'Brick chamber beneath Studio 2. Dense, musical, with low-mid warmth.', sim: 94 },
    lexicon:{ name: 'Lexicon 480L Hall',  rt: 3.2, pd: 35, desc: 'Classic algorithmic hall. Smooth diffusion, shimmer in HF.', sim: 78 },
    plate:  { name: 'Plate #4',           rt: 1.8, pd: 12, desc: 'Large steel plate. No flutter, extremely dense early reflections.', sim: 91 },
    spring: { name: 'Spring Tank',        rt: 0.8, pd: 20, desc: 'Coil spring reverb. Characteristic metallic "boing" resonance.', sim: 82 }
  };
  let space = 'abbey';

  function drawIR(ctx, W, H, isConv) {
    ctx.fillStyle = '#0d0d14';
    ctx.fillRect(0, 0, W, H);
    const sp = spaces[space];
    const padL = 10, padR = 10, padT = 30, padB = 20;
    const gW = W - padL - padR, gH = H - padT - padB;
    const midY = padT + gH / 2;
    const samples = gW;
    const rtNorm = sp.rt / 4;

    for (let x = 0; x < samples; x++) {
      const t = x / samples;
      let amp = 0;
      if (x === 0) {
        amp = 0.9;
      } else if (isConv) {
        // Convolution: realistic IR with physical irregularities
        const n1 = Math.sin(x * 31.7 + sp.rt * 10) * 0.4;
        const n2 = Math.sin(x * 11.3 + 0.7) * Math.sin(x * 7.9 + 1.3) * 0.35;
        const n3 = Math.sin(x * 53.1) * 0.15;
        amp = (n1 + n2 + n3) * Math.exp(-t / rtNorm * 3);
        // Add subtle room modes
        if (t < 0.15) amp += Math.sin(x * 4.3) * 0.2 * Math.exp(-t * 25);
      } else {
        // Algorithmic: smoother, exponential
        const n = Math.sin(x * 13.7) * Math.sin(x * 7.3 + 0.5);
        amp = n * Math.exp(-t / rtNorm * 3.5);
      }
      const h = Math.abs(amp) * gH * 0.42;
      const alpha = Math.abs(amp) * 0.9 + 0.05;
      ctx.fillStyle = isConv
        ? `rgba(139,92,246,${alpha})`
        : `rgba(56,189,248,${alpha * 0.85})`;
      ctx.fillRect(padL + x, midY - h, 1, h * 2);
    }

    // Labels
    ctx.fillStyle = '#64748b'; ctx.font = '9px system-ui';
    ctx.fillText(sp.name, padL, 14);
    ctx.fillText(`RT60: ${sp.rt}s  Pre-delay: ${sp.pd}ms`, padL, 24);
    ctx.fillStyle = isConv ? '#8b5cf6' : '#38bdf8';
    ctx.font = '8px system-ui';
    ctx.fillText(sp.desc.substring(0, 50) + (sp.desc.length > 50 ? '…' : ''), padL, H - 6);
  }

  function draw() {
    const W1 = convCv.width, H1 = parseInt(convCv.getAttribute('height')) || 220;
    const W2 = algoCv.width, H2 = parseInt(algoCv.getAttribute('height')) || 220;
    drawIR(cCtx, W1, H1, true);
    drawIR(aCtx, W2, H2, false);
    document.getElementById('conv-similarity').textContent = spaces[space].sim + '%';
  }

  document.getElementById('conv-space-sel').addEventListener('change', function() {
    space = this.value; draw();
  });
  draw();
})();

// ══════════════════════════════════════════════════════════════════════
// ENO SYSTEM — generative feedback loop
// ══════════════════════════════════════════════════════════════════════
(function() {
  const cv = document.getElementById('eno-canvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H;
  function resize() { W = cv.width = cv.offsetWidth; H = parseInt(cv.getAttribute('height')) || 300; }
  resize(); window.addEventListener('resize', resize);

  let loops = 4, pitchShift = 2, decayPerLoop = 0.85, stereoW = 60;
  let evolve = false;
  let phase = 0;
  let evolveOffsets = [0,0,0,0,0,0,0,0];

  function draw() {
    requestAnimationFrame(draw);
    ctx.fillStyle = 'rgba(5,5,10,0.1)';
    ctx.fillRect(0, 0, W, H);
    phase += 0.008;

    const cx = W / 2, cy = H / 2;
    const outerR = Math.min(W, H) * 0.40;
    const innerR = outerR * 0.28;

    // Draw loop arcs
    for (let i = 0; i < loops; i++) {
      const amp = Math.pow(decayPerLoop, i);
      const startAngle = (i / loops) * Math.PI * 2 - Math.PI / 2;
      const endAngle = startAngle + (Math.PI * 2 / loops) * 0.88;
      const hue = (i / loops) * 260 + 200;
      const evoOff = evolve ? (evolveOffsets[i] += (Math.random() - 0.5) * 0.001) : 0;
      const r = outerR - i * (outerR - innerR) / Math.max(loops - 1, 1);

      ctx.beginPath();
      ctx.arc(cx, cy, r + evoOff * 20, startAngle + phase, endAngle + phase);
      ctx.strokeStyle = `hsla(${hue},80%,65%,${amp * 0.85})`;
      ctx.lineWidth = 3 * amp + 0.5;
      ctx.shadowBlur = 10 * amp;
      ctx.shadowColor = `hsla(${hue},80%,65%,0.5)`;
      ctx.stroke();
      ctx.shadowBlur = 0;

      // Pitch indicator
      const midAngle = startAngle + (endAngle - startAngle) / 2 + phase;
      const lx = cx + Math.cos(midAngle) * (r + 14);
      const ly = cy + Math.sin(midAngle) * (r + 14);
      const semis = i * pitchShift;
      ctx.fillStyle = `hsla(${hue},80%,75%,${amp})`;
      ctx.font = '9px system-ui';
      ctx.textAlign = 'center';
      ctx.fillText(semis > 0 ? `+${semis}st` : semis === 0 ? '0' : `${semis}st`, lx, ly);
    }
    ctx.textAlign = 'left';

    // Centre dot
    const pg = ctx.createRadialGradient(cx, cy, 0, cx, cy, innerR * 0.6);
    pg.addColorStop(0, 'rgba(139,92,246,0.7)');
    pg.addColorStop(1, 'rgba(139,92,246,0)');
    ctx.beginPath();
    ctx.arc(cx, cy, innerR * 0.6, 0, Math.PI * 2);
    ctx.fillStyle = pg;
    ctx.fill();

    // Info
    ctx.fillStyle = '#64748b'; ctx.font = '9px system-ui';
    ctx.fillText(`${loops} LOOPS  ·  PITCH +${pitchShift}st/loop  ·  DECAY ${decayPerLoop.toFixed(2)}/loop  ·  WIDTH ${stereoW}%`, 10, H - 8);
    if (evolve) {
      ctx.fillStyle = '#8b5cf6';
      ctx.fillText('AUTO-EVOLVE ACTIVE', W - 140, H - 8);
    }
  }
  draw();

  document.getElementById('eno-loops').addEventListener('input', function() {
    loops = +this.value;
    document.getElementById('eno-loops-val').textContent = loops;
  });
  document.getElementById('eno-pitch').addEventListener('input', function() {
    pitchShift = +this.value;
    const s = pitchShift >= 0 ? '+' + pitchShift : '' + pitchShift;
    document.getElementById('eno-pitch-val').textContent = s + ' st';
  });
  document.getElementById('eno-decay').addEventListener('input', function() {
    decayPerLoop = +this.value / 100;
    document.getElementById('eno-decay-val').textContent = decayPerLoop.toFixed(2);
  });
  document.getElementById('eno-width').addEventListener('input', function() {
    stereoW = +this.value;
    document.getElementById('eno-width-val').textContent = stereoW + '%';
  });
  document.getElementById('eno-evolve-btn').addEventListener('click', function() {
    evolve = !evolve;
    this.classList.toggle('active-btn', evolve);
    this.textContent = evolve ? '⟳ Evolving…' : '⟳ Auto-Evolve';
  });
})();

// ══════════════════════════════════════════════════════════════════════
// EMOTION MAP
// ══════════════════════════════════════════════════════════════════════
(function() {
  const cv = document.getElementById('emotion-canvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H;
  function resize() { W = cv.width = cv.offsetWidth; H = parseInt(cv.getAttribute('height')) || 420; }
  resize(); window.addEventListener('resize', () => { resize(); draw(); });

  const zones = [
    { name:'Bathroom',      x:0.18, y:0.78, rt:0.3, pd:5,   damp:70, char:'Bright, intimate', col:'#f59e0b' },
    { name:'Vocal Booth',   x:0.12, y:0.65, rt:0.1, pd:2,   damp:90, char:'Dead, controlled', col:'#f59e0b' },
    { name:'Small Studio',  x:0.22, y:0.58, rt:0.2, pd:8,   damp:65, char:'Tight, punchy',    col:'#f59e0b' },
    { name:'Cathedral',     x:0.78, y:0.78, rt:6.0, pd:60,  damp:20, char:'Sacred, vast',     col:'#8b5cf6' },
    { name:'Concert Hall',  x:0.70, y:0.72, rt:2.2, pd:35,  damp:35, char:'Rich, musical',    col:'#8b5cf6' },
    { name:'Ballroom',      x:0.82, y:0.62, rt:1.8, pd:30,  damp:40, char:'Warm, lush',       col:'#8b5cf6' },
    { name:'Anechoic',      x:0.12, y:0.22, rt:0.01,pd:0,   damp:99, char:'No reverb',        col:'#38bdf8' },
    { name:'Dead Room',     x:0.20, y:0.30, rt:0.05,pd:1,   damp:95, char:'Controlled',       col:'#38bdf8' },
    { name:'Rec. Booth',    x:0.28, y:0.22, rt:0.15,pd:4,   damp:80, char:'Isolated',         col:'#38bdf8' },
    { name:'Cavern',        x:0.75, y:0.25, rt:4.5, pd:80,  damp:30, char:'Primordial, deep',  col:'#c084fc' },
    { name:'Concrete Bunker',x:0.65,y:0.18, rt:3.0, pd:50,  damp:25, char:'Harsh, brutal',    col:'#c084fc' },
    { name:'Ice Cathedral', x:0.85, y:0.20, rt:7.0, pd:100, damp:15, char:'Crystalline, vast', col:'#c084fc' },
  ];

  let cursor = { x: 0.5, y: 0.5 };
  let dragging = false;

  function interpZone(cx, cy) {
    let totalW = 0, rt = 0, pd = 0, damp = 0;
    zones.forEach(z => {
      const d = Math.hypot(cx - z.x, cy - z.y);
      const w = 1 / Math.max(d * d, 0.001);
      totalW += w; rt += z.rt * w; pd += z.pd * w; damp += z.damp * w;
    });
    rt /= totalW; pd /= totalW; damp /= totalW;
    // Find nearest zone name
    let nearest = zones[0], minD = Infinity;
    zones.forEach(z => {
      const d = Math.hypot(cx - z.x, cy - z.y);
      if (d < minD) { minD = d; nearest = z; }
    });
    return { rt, pd, damp, char: nearest.char };
  }

  function draw() {
    ctx.fillStyle = '#0d0d14';
    ctx.fillRect(0, 0, W, H);

    // Background quadrant gradient
    const corners = [
      { x:0,   y:H,   col:'rgba(245,158,11,0.08)' }, // intimate+warm BL
      { x:W,   y:H,   col:'rgba(139,92,246,0.08)' }, // vast+warm BR
      { x:0,   y:0,   col:'rgba(56,189,248,0.06)' }, // intimate+cold TL
      { x:W,   y:0,   col:'rgba(192,132,252,0.08)' } // vast+cold TR
    ];
    corners.forEach(c => {
      const g = ctx.createRadialGradient(c.x, c.y, 0, c.x, c.y, Math.hypot(W, H) * 0.65);
      g.addColorStop(0, c.col);
      g.addColorStop(1, 'transparent');
      ctx.fillStyle = g; ctx.fillRect(0, 0, W, H);
    });

    // Grid
    ctx.strokeStyle = '#1e1e2e'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(W/2, 10); ctx.lineTo(W/2, H - 10); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(10, H/2); ctx.lineTo(W - 10, H/2); ctx.stroke();

    // Axis labels
    ctx.fillStyle = '#64748b'; ctx.font = '10px system-ui'; ctx.textAlign = 'center';
    ctx.fillText('INTIMATE', W / 4, H - 10);
    ctx.fillText('VAST', W * 3/4, H - 10);
    ctx.save(); ctx.translate(12, H/2); ctx.rotate(-Math.PI/2);
    ctx.fillText('WARM', 50, 0);
    ctx.fillText('COLD', -50, 0);
    ctx.restore();
    ctx.textAlign = 'left';

    // Zone dots
    zones.forEach(z => {
      const px = z.x * W, py = (1 - z.y) * H;
      ctx.beginPath();
      ctx.arc(px, py, 6, 0, Math.PI * 2);
      ctx.fillStyle = z.col;
      ctx.shadowBlur = 12; ctx.shadowColor = z.col;
      ctx.fill(); ctx.shadowBlur = 0;
      ctx.fillStyle = z.col; ctx.font = 'bold 9px system-ui';
      ctx.fillText(z.name, px + 9, py + 3);

      // Click detection
      z._px = px; z._py = py;
    });

    // Cursor
    const cpx = cursor.x * W, cpy = (1 - cursor.y) * H;
    ctx.beginPath();
    ctx.arc(cpx, cpy, 10, 0, Math.PI * 2);
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 2;
    ctx.shadowBlur = 16; ctx.shadowColor = '#8b5cf6';
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(cpx, cpy, 4, 0, Math.PI * 2);
    ctx.fillStyle = '#8b5cf6'; ctx.fill();
    ctx.shadowBlur = 0;

    // Update stats
    const { rt, pd, damp, char } = interpZone(cursor.x, cursor.y);
    document.getElementById('em-rt60').textContent = rt.toFixed(2) + 's';
    document.getElementById('em-pd').textContent   = Math.round(pd) + 'ms';
    document.getElementById('em-damp').textContent = Math.round(damp) + '%';
    document.getElementById('em-char').textContent = char;
  }

  function getPos(e, rect) {
    const cx = e.touches ? e.touches[0].clientX : e.clientX;
    const cy = e.touches ? e.touches[0].clientY : e.clientY;
    return {
      x: clamp((cx - rect.left) / rect.width, 0.02, 0.98),
      y: clamp(1 - (cy - rect.top) / rect.height, 0.02, 0.98)
    };
  }

  cv.addEventListener('mousedown', e => {
    dragging = true;
    const r = cv.getBoundingClientRect();
    const sx = (e.clientX - r.left) * (W / r.width);
    const sy = (e.clientY - r.top) * (H / r.height);
    // Check zone clicks
    zones.forEach(z => {
      if (Math.hypot(sx - z._px, sy - z._py) < 14) {
        cursor = { x: z.x, y: z.y };
      }
    });
    const p = getPos(e, r);
    cursor = p; draw();
  });
  cv.addEventListener('mousemove', e => {
    if (!dragging) return;
    cursor = getPos(e, cv.getBoundingClientRect());
    draw();
  });
  cv.addEventListener('mouseup', () => dragging = false);
  cv.addEventListener('touchstart', e => { e.preventDefault(); dragging = true; cursor = getPos(e, cv.getBoundingClientRect()); draw(); }, { passive:false });
  cv.addEventListener('touchmove',  e => { e.preventDefault(); if(dragging) { cursor = getPos(e, cv.getBoundingClientRect()); draw(); } }, { passive:false });
  cv.addEventListener('touchend',   () => dragging = false);
  window.addEventListener('resize', () => { resize(); draw(); });
  draw();
})();
</script>
