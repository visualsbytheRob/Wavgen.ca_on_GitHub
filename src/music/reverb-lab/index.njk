<!-- GLOSSARY -->
<section class="section" id="glossary">
<p class="section-label hidden">Section 12</p>
<h2 class="section-title hidden stagger-1">Glossary</h2>
<p class="section-desc hidden stagger-2">24 essential terms for understanding reverberation, acoustics, and spatial audio processing.</p>
<div id="glossary-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:0.75rem;margin-top:1rem">
