    { name:'Boards of Canada', technique:'Tape Decay & Warping',    work:'Music Has the Right to Children',year:1998,quote:'"Time degrading through magnetic oxide."' },
    { name:'Jon Hassell',      technique:'Possible Musics / Space', work:'Fourth World Vol. 1',         year:1980, quote:'"Drone, space, mist — geography as instrument."' },
    { name:'Pauline Oliveros', technique:'Deep Listening',          work:'Sonic Meditations',           year:1974, quote:'"Listen to everything all the time."' },
