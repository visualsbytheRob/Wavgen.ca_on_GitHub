})();

// ══════════════════════════════════════════════════════════════════════
// GLOSSARY
// ══════════════════════════════════════════════════════════════════════
(function() {
  const terms = [
    { t:'RT60',                  d:'Time for a sound to decay by 60 decibels after the source stops.' },
    { t:'Impulse Response',      d:'The acoustic fingerprint of a space, captured by a brief broadband sound.' },
    { t:'Convolution',           d:'Multiplying a signal with an IR in the frequency domain to simulate a space.' },
    { t:'Early Reflections',     d:'First discrete echoes arriving 5–80ms after the direct sound; encode room geometry.' },
    { t:'Late Reverberation',    d:'Diffuse, exponentially decaying sound field that follows early reflections.' },
    { t:'Diffusion',             d:'The spreading of reflected energy to create a dense, smooth reverb tail.' },
    { t:'Pre-Delay',             d:'Time gap between dry signal and first reverb reflection; creates perceptual separation.' },
    { t:'Comb Filter',           d:'A delay-feedback circuit that reinforces certain frequencies; creates metallic colouration.' },
    { t:'Allpass Filter',        d:'Scatters echo density while preserving frequency content; key to Schroeder reverb.' },
    { t:'Plate Reverb',          d:'A large sheet of metal driven by a transducer; creates smooth, dense reverb.' },
    { t:'Spring Reverb',         d:'A coil spring reverb unit; characteristic "boing" resonance used in surf and dub.' },
    { t:'Gated Reverb',          d:'Reverb tail cut abruptly short by a noise gate; defines 1980s drum production.' },
    { t:'Haas Effect',           d:'Sounds arriving within 40ms of the first are fused into one perceptual event.' },
    { t:'HRTF',                  d:'Head-Related Transfer Function: how ear/head shape localises sound in 3D space.' },
    { t:'Schroeder Frequency',   d:'Below ~200Hz, a room has discrete modes; above, diffuse reverberation takes over.' },
    { t:'Sabine Formula',        d:'RT60 = 0.161 × V / (S × α) — the fundamental equation of room acoustics.' },
    { t:'Modal Resonance',       d:'Standing wave resonances at low frequencies determined by room dimensions.' },
    { t:'Flutter Echo',          d:'Rapid, repeating echo between two parallel reflective surfaces.' },
    { t:'Slapback',              d:'Single short echo (40–120ms); classic in rockabilly and Sun Records production.' },
    { t:'Room Modes',            d:'Axial, tangential, oblique: three types of standing wave patterns in rooms.' },
    { t:'Absorption Coefficient',d:'α — ratio of absorbed to incident sound energy; 0 = reflective, 1 = total absorption.' },
    { t:'Diffusion Coefficient', d:'Measure of how evenly a surface scatters sound in all directions.' },
    { t:'Dry/Wet Mix',           d:'Ratio of unprocessed (dry) to reverb-processed (wet) signal in the output.' },
    { t:'Send/Return',           d:'Parallel routing: dry signal passes through; reverb runs on a send buss.' },
  ];

  const grid = document.getElementById('glossary-grid');
  if (!grid) return;

  terms.forEach((term, i) => {
    const card = document.createElement('div');
    card.className = 'hidden stagger-' + ((i % 5) + 1);
    card.style.cssText = `
      background:#0d0d14;
      border:1px solid #1e1e2e;
      border-radius:8px;
      padding:0.85rem 1rem;
    `;
    card.innerHTML = `
      <div style="font-size:0.8rem;font-weight:700;color:#8b5cf6;margin-bottom:0.3rem;letter-spacing:0.03em">${term.t}</div>
      <div style="font-size:0.8rem;color:#94a3b8;line-height:1.55">${term.d}</div>
    `;
    grid.appendChild(card);
    animObserver.observe(card);
  });
})();
</script>
