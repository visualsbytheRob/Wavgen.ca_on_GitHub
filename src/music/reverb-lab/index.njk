    { name:'Priscilla Ermel',  technique:'Sacred Space Recording',  work:'Musica Cósmica',              year:1990, quote:'"Sacred acoustics are embedded in the architecture."' },
    { name:'Burial',           technique:'London Urban Reverb',     work:'Untrue',                      year:2007, quote:'"The city at 4am, rain on concrete."' },
