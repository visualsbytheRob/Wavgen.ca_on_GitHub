function spawnM4LPacket(){
  const patch=PATCHES[currentPatch];
  if(!patch)return;
  const edgeIdx=Math.floor(rand(0,patch.edges.length));
  m4lPackets.push({edge:edgeIdx,t:0,speed:rand(0.01,0.025)});
}

function drawM4L(t){
  const W=m4lCanvas.width,H=m4lCanvas.height;
  m4lCtx.fillStyle='rgba(6,8,6,0.85)';
  m4lCtx.fillRect(0,0,W,H);
  const patch=PATCHES[currentPatch];
  if(!patch)return;
  const nodePos={};
  patch.nodes.forEach(n=>{nodePos[n.id]={x:n.x*W,y:n.y*H};});

  // Edges
  patch.edges.forEach(([from,to],idx)=>{
    const a=nodePos[from],b=nodePos[to];
    if(!a||!b)return;
    m4lCtx.strokeStyle='rgba(91,224,60,0.2)';
    m4lCtx.lineWidth=1.5;
    m4lCtx.beginPath();m4lCtx.moveTo(a.x+40,a.y);m4lCtx.lineTo(b.x,b.y);m4lCtx.stroke();
  });

  // Packets
  m4lPackets=m4lPackets.filter(p=>p.t<1);
  m4lPackets.forEach(p=>{
    p.t+=p.speed;
    const [from,to]=patch.edges[p.edge]||[];
    const a=nodePos[from],b=nodePos[to];
    if(!a||!b)return;
    const px=lerp(a.x+40,b.x,p.t);
    const py=lerp(a.y,b.y,p.t);
    m4lCtx.beginPath();m4lCtx.arc(px,py,4,0,Math.PI*2);
    m4lCtx.fillStyle='#5BE03C';
    m4lCtx.shadowBlur=10;m4lCtx.shadowColor='#5BE03C';
    m4lCtx.fill();m4lCtx.shadowBlur=0;
  });

  // Nodes
  const TYPE_COLORS={audio:'#5BE03C',control:'#E0A020',midi:'#5BE0C8'};
  patch.nodes.forEach(n=>{
    const {x,y}=nodePos[n.id];
    const col=TYPE_COLORS[n.type]||'#5BE03C';
    m4lCtx.fillStyle='#0E110E';
    m4lCtx.strokeStyle=col;
    m4lCtx.lineWidth=1.5;
    const w=80,h=28;
    m4lCtx.fillRect(x,y-h/2,w,h);
    m4lCtx.strokeRect(x,y-h/2,w,h);
    m4lCtx.fillStyle=col;
    m4lCtx.font='10px Courier New';
    m4lCtx.textAlign='center';
    m4lCtx.fillText(n.label,x+w/2,y+4);
    // Inlet/outlet dots
    m4lCtx.fillStyle=col;
    m4lCtx.beginPath();m4lCtx.arc(x,y,3,0,Math.PI*2);m4lCtx.fill();
    m4lCtx.beginPath();m4lCtx.arc(x+w,y,3,0,Math.PI*2);m4lCtx.fill();
  });
}

