const clipStates=[];
const clipProgress=[];
let isPlaying=false;
let beatCount=0;
let lastBeatTime=0;
let bpm=128;

function buildMatrix(){
  const grid=document.getElementById('clip-grid');
  grid.innerHTML='';
  grid.style.gridTemplateColumns=`80px repeat(8,1fr)`;

  for(let scene=0;scene<8;scene++){
    const lbl=document.createElement('div');
    lbl.className='track-label';
    lbl.textContent=`SCENE ${scene+1}`;
    grid.appendChild(lbl);
    if(!clipStates[scene])clipStates[scene]=[];
    if(!clipProgress[scene])clipProgress[scene]=[];
    for(let track=0;track<8;track++){
      const name=CLIP_NAMES[track][scene];
      const isEmpty=(name==='—');
      const cell=document.createElement('div');
      cell.className='clip-cell'+(isEmpty?' empty':'');
      if(!isEmpty){
        cell.style.background=`${TRACK_COLORS[track]}22`;
        cell.style.borderColor=`${TRACK_COLORS[track]}55`;
        cell.style.color=TRACK_COLORS[track];
        cell.textContent=name;
        const bar=document.createElement('div');
        bar.className='clip-bar';
        bar.style.background=TRACK_COLORS[track];
        cell.appendChild(bar);
        clipStates[scene][track]=false;
        clipProgress[scene][track]=0;
        cell.addEventListener('click',()=>toggleClip(scene,track,cell,bar));
      } else {
        clipStates[scene][track]=false;
        clipProgress[scene][track]=0;
      }
      grid.appendChild(cell);
    }
  }

  // Scene buttons
  const sceneRow=document.getElementById('scene-row');
  sceneRow.innerHTML='';
  const sl=document.createElement('div');
  sl.className='scene-label';sl.textContent='LAUNCH';
  sceneRow.appendChild(sl);
  for(let track=0;track<8;track++){
    const btn=document.createElement('button');
    btn.className='scene-btn';
    btn.textContent=`▶ T${track+1}`;
    btn.style.borderColor=`${TRACK_COLORS[track]}60`;
    btn.style.color=TRACK_COLORS[track];
    sceneRow.appendChild(btn);
  }
}

function toggleClip(scene,track,cell,bar){
  clipStates[scene][track]=!clipStates[scene][track];
  if(clipStates[scene][track]){
    cell.classList.add('playing');
    cell.style.background=`${TRACK_COLORS[track]}44`;
    cell.style.borderColor=TRACK_COLORS[track];
  } else {
    cell.classList.remove('playing');
    cell.style.background=`${TRACK_COLORS[track]}22`;
    cell.style.borderColor=`${TRACK_COLORS[track]}55`;
    clipProgress[scene][track]=0;
    bar.style.width='0%';
  }
}

