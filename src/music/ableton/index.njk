function drawArr(t){
  const W=arrCanvas.width,H=arrCanvas.height;
  arrCtx.fillStyle='rgba(6,8,6,0.85)';
  arrCtx.fillRect(0,0,W,H);
  const zoom=lagZoom.value;
  const numTracks=Math.round(lagTracks.value);
  const ph=lagPH.value;
  const loopBars=lagLoopW.value;
  const trackH=(H-30)/numTracks;
  const HEADER=60;
  const BAR_W=(W-HEADER)/(32/zoom);

  // Time axis
  arrCtx.fillStyle='#1A2A1A';
  arrCtx.fillRect(0,0,W,30);
  for(let b=0;b<=32;b++){
    const x=HEADER+b*BAR_W;
    arrCtx.strokeStyle=b%4===0?'rgba(91,224,60,0.25)':'rgba(91,224,60,0.08)';
    arrCtx.lineWidth=1;
    arrCtx.beginPath();arrCtx.moveTo(x,0);arrCtx.lineTo(x,H);arrCtx.stroke();
    if(b%4===0){
      arrCtx.fillStyle='#5A7A5A';
      arrCtx.font='9px Courier New';
      arrCtx.textAlign='center';
      arrCtx.fillText(`${b+1}`,x,20);
    }
  }

  // Loop region
  const lx=HEADER;
  const lw=loopBars*BAR_W;
  arrCtx.fillStyle='rgba(91,224,60,0.05)';
  arrCtx.fillRect(lx,0,lw,H);
  arrCtx.strokeStyle='rgba(91,224,60,0.3)';
  arrCtx.lineWidth=1;
  arrCtx.strokeRect(lx,0,lw,H);

  // Tracks
  for(let tr=0;tr<numTracks;tr++){
    const ty=30+tr*trackH;
    const color=TRACK_COLORS[tr%TRACK_COLORS.length];
    arrCtx.fillStyle='#0E110E';
    arrCtx.fillRect(0,ty,W,trackH-2);
    arrCtx.fillStyle='#131813';
    arrCtx.fillRect(0,ty,HEADER-4,trackH-2);
    arrCtx.fillStyle=color;
    arrCtx.font='9px Courier New';
    arrCtx.textAlign='left';
    arrCtx.fillText(TRACK_NAMES[tr%TRACK_NAMES.length],4,ty+trackH/2+3);

    // Clips in arrangement
    const seed=tr*7+3;
    let cx=HEADER;
    for(let cl=0;cl<12;cl++){
      const cw=BAR_W*(1+Math.floor(noise21(cl*0.3,seed*0.1)*3));
      const gap=BAR_W*(0.2+noise21(cl*0.5,seed*0.2)*0.8);
      if(cx+cw>W)break;
      arrCtx.fillStyle=color+'33';
      arrCtx.strokeStyle=color+'88';
      arrCtx.lineWidth=1;
      arrCtx.fillRect(cx,ty+2,cw-1,trackH-5);
      arrCtx.strokeRect(cx,ty+2,cw-1,trackH-5);
      // Waveform
      arrCtx.strokeStyle=color+'BB';
      arrCtx.lineWidth=1;
      arrCtx.beginPath();
      for(let px=0;px<cw-1;px++){
        const wv=noise21(px*0.05+cl*3,tr*5+t*0.1)*2-1;
        const wy=ty+trackH/2+wv*(trackH*0.35);
        px===0?arrCtx.moveTo(cx+px,wy):arrCtx.lineTo(cx+px,wy);
      }
      arrCtx.stroke();
      cx+=cw+gap;
    }
  }

  // Playhead
  const phx=HEADER+ph*(W-HEADER);
  arrCtx.strokeStyle='rgba(91,224,60,0.9)';
  arrCtx.lineWidth=2;
  arrCtx.beginPath();arrCtx.moveTo(phx,0);arrCtx.lineTo(phx,H);arrCtx.stroke();
  arrCtx.fillStyle='#5BE03C';
  arrCtx.beginPath();arrCtx.moveTo(phx-6,0);arrCtx.lineTo(phx+6,0);arrCtx.lineTo(phx,10);arrCtx.fill();
}

