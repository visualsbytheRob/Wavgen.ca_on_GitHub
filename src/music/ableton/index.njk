<!-- S8: GLOSSARY -->
<section class="hidden" id="s8">
<div class="section-label">08 · REFERENCE</div>
<div class="section-title">Ableton Lexicon</div>
<div class="gloss-grid">
<div class="gloss-item"><div class="gloss-term">Session View</div><div class="gloss-def">Non-linear clip launcher. Tracks run vertically, scenes horizontally. Clips trigger independently or by scene. Ideal for improvised performance where structure emerges from material.</div></div>
<div class="gloss-item"><div class="gloss-term">Arrangement View</div><div class="gloss-def">Traditional horizontal timeline. Fixed structure, recorded automation, stems and MIDI laid out left-to-right. Session recordings commit here — the two views communicate through record-arm workflow.</div></div>
<div class="gloss-item"><div class="gloss-term">Clip</div><div class="gloss-def">The fundamental unit — a self-contained audio sample or MIDI pattern with its own loop, warp, pitch, and envelope settings. Lives inside a clip slot in Session View or as a block in Arrangement.</div></div>
<div class="gloss-item"><div class="gloss-term">Follow Actions</div><div class="gloss-def">Rules executed when a clip ends: play next, play random, play linked, stop, or trigger specific clips. Enables generative structures and self-evolving sets without live intervention.</div></div>
<div class="gloss-item"><div class="gloss-term">Warp</div><div class="gloss-def">Time-stretching that makes audio follow project tempo without pitch change. Warp Markers allow granular tempo mapping of audio with complex original timing — recordings, vinyl, field recordings.</div></div>
<div class="gloss-item"><div class="gloss-term">Max for Live</div><div class="gloss-def">Deep integration of Cycling '74's Max/MSP inside Live. Build custom instruments, effects, MIDI processors, and generative tools as M4L devices that behave like native Live devices.</div></div>
<div class="gloss-item"><div class="gloss-term">Rack</div><div class="gloss-def">Container chain: Instrument Rack, Effect Rack, or Drum Rack. Macro controls map single knobs to multiple parameters across all devices in the chain — essential for expressive live performance.</div></div>
<div class="gloss-item"><div class="gloss-term">Ableton Link</div><div class="gloss-def">Zero-latency peer-to-peer tempo and phase sync protocol. Any enabled device on the same LAN joins automatically. No master/slave — all peers negotiate consensus in realtime.</div></div>
<div class="gloss-item"><div class="gloss-term">Return Track</div><div class="gloss-def">Auxiliary bus receiving signal from any track's Send knobs. Shared effects (reverb, delay) live on Return tracks — all instruments send to them at different levels, creating cohesive spatial glue.</div></div>
<div class="gloss-item"><div class="gloss-term">Push</div><div class="gloss-def">Ableton's dedicated controller — velocity-sensitive pad grid plus encoders. Designed for hands-on performance, step sequencing, and melodic playing entirely without touching the computer screen.</div></div>
<div class="gloss-item"><div class="gloss-term">Operator</div><div class="gloss-def">Live's FM synthesizer — four-operator FM engine with individual LFO, filter, and modulation matrix. Capable of bells, plucks, harsh basses, metallic textures, and complex FM timbres.</div></div>
<div class="gloss-item"><div class="gloss-term">Wavetable</div><div class="gloss-def">Live's wavetable synthesizer. Two oscillators morph through wavetables with modulation matrix and polished filter section. Introduced in Live 10 — now essential for modern electronic sound design.</div></div>
<div class="gloss-item"><div class="gloss-term">Scene</div><div class="gloss-def">A horizontal row of clips across all tracks. Launching a Scene triggers all clips simultaneously — primary way to cue sections in live performance. Scenes can have tempo and time signature settings.</div></div>
<div class="gloss-item"><div class="gloss-term">Capture MIDI</div><div class="gloss-def">Retroactive MIDI recording — Live listens silently and can capture what you played before pressing record. Never lose a spontaneous musical idea again even if you forgot to arm recording first.</div></div>
<div class="gloss-item"><div class="gloss-term">Crossfader</div><div class="gloss-def">DJ-style A/B fader. Tracks assigned to A or B crossfade between them. Used for live blend transitions, DJ-style cuts, and set structure — assignable to any hardware controller.</div></div>
<div class="gloss-item"><div class="gloss-term">Groove Pool</div><div class="gloss-def">Quantise-feel system. Groove templates extracted from loops or built-in presets apply micro-timing and velocity swing to any clip — imparting the feel of a specific drummer or loop to MIDI.</div></div>
<div class="gloss-item"><div class="gloss-term">Envelope Follower</div><div class="gloss-def">M4L and native devices that analyse signal amplitude over time and output a control signal — fundamental tool for sidechain-style modulation, amplitude-reactive processing, and ducking effects.</div></div>
<div class="gloss-item"><div class="gloss-term">MIDI Polyphonic Expression</div><div class="gloss-def">MPE assigns MIDI channels per-note for independent pitch bend, pressure, and slide control. Live 11 supports MPE — enables expressive playing on Roli Seaboard, Linnstrument, and similar instruments.</div></div>
<div class="gloss-item"><div class="gloss-term">Comping</div><div class="gloss-def">Live 11 take-lane system. Multiple recorded takes stack vertically; the best sections are selected and combined into a composite performance. Professional vocal and instrument editing workflow.</div></div>
<div class="gloss-item"><div class="gloss-term">Looper</div><div class="gloss-def">Live's real-time loop recording device. Records, overdubs, and plays back live audio loops in sync with the project tempo. Foundation of live ambient and electronic performance.</div></div>
<div class="gloss-item"><div class="gloss-term">Set</div><div class="gloss-def">A complete Ableton project file (.als) containing all tracks, clips, devices, and routing configuration. Sets are self-contained performance environments — including all Session and Arrangement content.</div></div>
<div class="gloss-item"><div class="gloss-term">Beat Repeat</div><div class="gloss-def">Glitch effect that captures an interval of incoming audio and repeats it rhythmically. Controls: Interval, Offset, Grid, Variation, Chance. Creates stutters, fills, and rhythmic disintegration effects.</div></div>
</div>
</section>
<script>
// ─── UTILITIES ───────────────────────────────────────────────────────────
const lerp = (a,b,t) => a+(b-a)*t;
const clamp = (v,lo,hi) => Math.max(lo,Math.min(hi,v));
const rand = (lo=0,hi=1) => lo+Math.random()*(hi-lo);
function noise21(x,y){
  const ix=Math.floor(x),iy=Math.floor(y);
  const fx=x-ix,fy=y-iy;
  const ux=fx*fx*(3-2*fx),uy=fy*fy*(3-2*fy);
  const h=(a,b)=>{let n=(a*1619+b*31337)^(a*31337);n=(n>>8)^n;return(n&0xffff)/65535;};
  return lerp(lerp(h(ix,iy),h(ix+1,iy),ux),lerp(h(ix,iy+1),h(ix+1,iy+1),ux),uy);
}
function fbm(x,y,oct=4){let v=0,a=0.5,f=1;for(let i=0;i<oct;i++){v+=a*noise21(x*f,y*f);a*=0.5;f*=2.1;}return v;}

// ─── LAG FILTERS (17) ────────────────────────────────────────────────────
class LagFilter{constructor(init,tau){this.value=init;this.tau=tau;}update(target,dt){const k=1-Math.exp(-dt/this.tau);this.value+=k*(target-this.value);return this.value;}}
const lagHMX    = new LagFilter(0.5,0.9);
const lagHMY    = new LagFilter(0.5,0.9);
const lagHBeat  = new LagFilter(0,  0.08);
const lagBPM    = new LagFilter(128,1.5);
const lagZoom   = new LagFilter(3,  0.5);
const lagTracks = new LagFilter(8,  0.4);
const lagPH     = new LagFilter(0.15,0.3);
const lagM4LSig = new LagFilter(0,  0.15);
const lagM4LSpd = new LagFilter(1,  0.5);
const lagLinkBeat= new LagFilter(0, 0.1);
const lagLinkTap = new LagFilter(0, 0.05);
const lagRtgMX  = new LagFilter(0.5,0.8);
const lagRtgMY  = new LagFilter(0.5,0.8);
const lagClipA  = new LagFilter(0,  0.12);
const lagLoopW  = new LagFilter(8,  0.4);
const lagArrScroll=new LagFilter(0, 0.3);
const lagSendAmt= new LagFilter(0.4,0.3);

let mouseX=0.5,mouseY=0.5;
document.addEventListener('mousemove',e=>{mouseX=e.clientX/window.innerWidth;mouseY=e.clientY/window.innerHeight;});

// ─── HERO WebGL ───────────────────────────────────────────────────────────
const heroCanvas=document.getElementById('hero-canvas');
heroCanvas.width=window.innerWidth; heroCanvas.height=440;
window.addEventListener('resize',()=>{heroCanvas.width=window.innerWidth;initGL();});

const VS=`attribute vec2 pos;void main(){gl_Position=vec4(pos,0,1);}`;
const FS=`
precision highp float;
uniform vec2 u_res; uniform float u_time; uniform vec2 u_mouse; uniform float u_beat;
float hash(vec2 p){p=fract(p*vec2(127.1,311.7));p+=dot(p,p+17.5);return fract(p.x*p.y);}
float noise(vec2 p){vec2 i=floor(p),f=fract(p);vec2 u=f*f*(3.-2.*f);return mix(mix(hash(i),hash(i+vec2(1,0)),u.x),mix(hash(i+vec2(0,1)),hash(i+vec2(1)),u.x),u.y);}
float fbm(vec2 p){float v=0.,a=.5;for(int i=0;i<4;i++){v+=a*noise(p);a*=.5;p=p*2.1+vec2(1.7,9.2);}return v;}
void main(){
  vec2 uv=gl_FragCoord.xy/u_res;
  vec2 st=uv*2.-1.;st.x*=u_res.x/u_res.y;
  float t=u_time;
  // Session grid feel — vertical track columns
  float gridX=step(0.97,fract(uv.x*8.+0.02));
  float gridY=step(0.95,fract(uv.y*8.));
  float grid=(gridX+gridY)*0.05;
  // Waveforms per track
  float waves=0.;
  for(int i=0;i<8;i++){
    float fi=float(i)/8.;
    float cx=fi+0.0625;
    float cy=0.15+fbm(vec2(fi*3.+t*0.3,t*0.2))*0.7;
    float amp=0.08+0.04*sin(t*2.+fi*7.3);
    float wave=sin(uv.x*30.+fi*2.+t*(1.+fi*0.5))*amp;
    waves+=exp(-abs(uv.y-cy-wave)*60.)*0.4;
  }
  // Beat flash
  float beat=u_beat*0.3;
  // Green clip glow field
  vec2 q=vec2(fbm(st+t*0.05),fbm(st+vec2(1.7,9.2)+t*0.04));
  float f=fbm(st+1.8*q);
  vec3 col=vec3(0.02,0.04,0.02);
  col+=vec3(0.1,0.6,0.1)*waves;
  col+=vec3(0.0,0.2,0.0)*f*0.3;
  col+=vec3(0.1,0.5,0.1)*grid;
  col+=vec3(0.15,0.8,0.15)*beat;
  // Mouse glow
  vec2 ms=u_mouse*2.-1.;ms.x*=u_res.x/u_res.y;
  col+=vec3(0.05,0.35,0.05)*exp(-length(st-ms)*3.)*0.6;
  float vig=1.-length(uv-0.5)*1.5;
  col*=clamp(vig,0.,1.);
  gl_FragColor=vec4(col,1.);
}`;

let gl,prog,uniforms={};
function initGL(){
  gl=heroCanvas.getContext('webgl');
  if(!gl)return;
  function mkS(t,src){const s=gl.createShader(t);gl.shaderSource(s,src);gl.compileShader(s);return s;}
  if(prog)gl.deleteProgram(prog);
  prog=gl.createProgram();
  gl.attachShader(prog,mkS(gl.VERTEX_SHADER,VS));
  gl.attachShader(prog,mkS(gl.FRAGMENT_SHADER,FS));
  gl.linkProgram(prog);gl.useProgram(prog);
  const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);
  gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,1,-1,-1,1,1,1]),gl.STATIC_DRAW);
  const p=gl.getAttribLocation(prog,'pos');gl.enableVertexAttribArray(p);gl.vertexAttribPointer(p,2,gl.FLOAT,false,0,0);
  uniforms={res:gl.getUniformLocation(prog,'u_res'),time:gl.getUniformLocation(prog,'u_time'),mouse:gl.getUniformLocation(prog,'u_mouse'),beat:gl.getUniformLocation(prog,'u_beat')};
}
initGL();

// ─── CLIP MATRIX ─────────────────────────────────────────────────────────
const TRACK_NAMES=['DRUMS','BASS','KEYS','LEAD','PAD','FX','VOC','SEND'];
const TRACK_COLORS=['#5BE03C','#3CB8E0','#E0A020','#E05B5B','#9B5BE0','#5BE0C8','#E0C85B','#A0A0A0'];
const CLIP_NAMES=[
  ['Beat A','Kick 1','Lo Shuf','Hats','Perc B','—','—','Fills'],
  ['Bass 1','Sub A','Walk','Acid 1','—','Slide','—','Bass 2'],
  ['Pad C','Rhodes','Organ B','—','Chord 1','—','Atm 1','Keys 2'],
  ['Melody 1','Lead 2','—','Riff A','—','Stab','Solo A','—'],
  ['Pad 1','String A','—','Atm 2','—','Sweep','Drone','—'],
  ['Riser 1','—','Crash 1','White 1','—','Rev A','FX 2','—'],
