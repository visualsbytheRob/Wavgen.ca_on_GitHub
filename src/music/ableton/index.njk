    {id:'send',label:'SEND BUS',x:0.73,y:0.2,color:'#E05B5B'},
    {id:'ret',label:'RETURN TRACK',x:0.58,y:0.2,color:'#E05B5B'},
    {id:'master',label:'MASTER',x:0.88,y:0.5,color:'#5BE03C'},
  ];
  const edges=[['inst','prefx'],['prefx','chain'],['chain','postfx'],['postfx','strip'],['strip','send'],['send','ret'],['strip','master']];
  const pos={};
  nodes.forEach(n=>{pos[n.id]={x:n.x*W,y:n.y*H};});

  edges.forEach(([a,b])=>{
    const pa=pos[a],pb=pos[b];
    rtgCtx.strokeStyle='rgba(91,224,60,0.18)';
    rtgCtx.lineWidth=2;
    rtgCtx.setLineDash([4,6]);
    rtgCtx.beginPath();rtgCtx.moveTo(pa.x+56,pa.y);rtgCtx.lineTo(pb.x,pb.y);rtgCtx.stroke();
    rtgCtx.setLineDash([]);
  });

  rtgPackets=rtgPackets.filter(p=>p.t<1);
  rtgPackets.forEach(p=>{
    p.t+=p.speed;
    const paths=[edges[0],edges[1],edges[2],edges[3]];
    const e=edges[Math.min(p.path,edges.length-1)];
    const pa=pos[e[0]],pb=pos[e[1]];
    if(!pa||!pb)return;
    const px=lerp(pa.x+56,pb.x,p.t);
    const py=lerp(pa.y,pb.y,p.t);
    rtgCtx.beginPath();rtgCtx.arc(px,py,4,0,Math.PI*2);
    rtgCtx.fillStyle='#5BE03C';
    rtgCtx.shadowBlur=8;rtgCtx.shadowColor='#5BE03C';
    rtgCtx.fill();rtgCtx.shadowBlur=0;
  });

  nodes.forEach(n=>{
    const {x,y}=pos[n.id];
    const w=112,h=32;
    rtgCtx.fillStyle='#0E110E';
    rtgCtx.strokeStyle=n.color;
    rtgCtx.lineWidth=1.5;
    rtgCtx.fillRect(x-w/2,y-h/2,w,h);
    rtgCtx.strokeRect(x-w/2,y-h/2,w,h);
    rtgCtx.fillStyle=n.color;
    rtgCtx.font='9px Courier New';
    rtgCtx.textAlign='center';
    rtgCtx.fillText(n.label,x,y+4);
  });
}

// ─── MAIN LOOP ────────────────────────────────────────────────────────────
let lastT=0,spawnT=0,pkT=0,rtgT=0;
let beatT=0;

function frame(now){
  const dt=Math.min((now-lastT)/1000,0.05);lastT=now;
  const t=now/1000;

  lagHMX.update(mouseX,dt);lagHMY.update(mouseY,dt);
  lagZoom.update(parseFloat(document.getElementById('sl-zoom').value),dt);
  lagTracks.update(parseFloat(document.getElementById('sl-tracks').value),dt);
  lagPH.update(parseFloat(document.getElementById('sl-ph').value),dt);
  lagLoopW.update(parseFloat(document.getElementById('sl-loop').value),dt);

  // Beat simulation
  const beatInterval=60/bpm;
  beatT+=dt;
  let beat=0;
  if(beatT>beatInterval){beatT%=beatInterval;beat=1;beatCount++;}
  lagHBeat.update(beat,dt);

  // Update clip progress
  if(isPlaying){
    for(let scene=0;scene<8;scene++){
      for(let track=0;track<8;track++){
        if(clipStates[scene]&&clipStates[scene][track]){
          clipProgress[scene][track]=(clipProgress[scene][track]+(dt/(beatInterval*4)))%1;
          const cell=document.querySelector(`#clip-grid .clip-cell:nth-child(${scene*9+track+2})`);
          const bar=cell&&cell.querySelector('.clip-bar');
          if(bar)bar.style.width=(clipProgress[scene][track]*100)+'%';
        }
      }
    }
  }

  // Tempo display
  document.getElementById('tempo-display').textContent=`♩ ${bpm.toFixed(1)} BPM`;

  // Hero
  if(gl&&prog){
    gl.viewport(0,0,heroCanvas.width,heroCanvas.height);
    gl.useProgram(prog);
    gl.uniform2f(uniforms.res,heroCanvas.width,heroCanvas.height);
    gl.uniform1f(uniforms.time,t);
    gl.uniform2f(uniforms.mouse,lagHMX.value,1-lagHMY.value);
    gl.uniform1f(uniforms.beat,lagHBeat.value);
    gl.drawArrays(gl.TRIANGLE_STRIP,0,4);
  }

  drawArr(t);

  // M4L
  pkT+=dt;
  if(pkT>0.08){spawnM4LPacket();pkT=0;}
  drawM4L(t);

  drawLink(t);

  rtgT+=dt;
  if(rtgT>0.15){spawnRtgPacket();rtgT=0;}
  drawRouting(t);

  requestAnimationFrame(frame);
}
requestAnimationFrame(t=>{lastT=t;requestAnimationFrame(frame);});

// ─── INTERSECTION OBSERVER ────────────────────────────────────────────────
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:0.1});
document.querySelectorAll('.hidden').forEach(el=>obs.observe(el));
</script>
