function drawLink(t){
  const W=linkCanvas.width,H=linkCanvas.height;
  linkCtx.fillStyle='rgba(6,8,6,0.9)';
  linkCtx.fillRect(0,0,W,H);
  const bpm=lagBPM.value;
  const phase=(t*(bpm/60))%1;
  lagLinkBeat.update(phase<0.05?1:0,1/60);
  // Phase circles for 6 peers
  const peers=['Live 12','Push 3','TD','Resolume','iOS','Reason'];
  const offsets=[0,0.002,0.001,-0.001,0.05,0.003];
  const cx=W/2,cy=H/2;
  const R=Math.min(W,H)*0.38;
  peers.forEach((peer,i)=>{
    const offline=i===4;
    const angle=-Math.PI/2+((phase+offsets[i])%1)*Math.PI*2;
    const px=cx+R*Math.cos(i*(Math.PI*2/6)-Math.PI/2);
    const py=cy+R*Math.sin(i*(Math.PI*2/6)-Math.PI/2);
    const dotX=px+30*Math.cos(angle);
    const dotY=py+30*Math.sin(angle);
    // Beat ring
    linkCtx.strokeStyle=offline?'rgba(90,122,90,0.3)':'rgba(91,224,60,0.25)';
    linkCtx.lineWidth=1;
    linkCtx.beginPath();linkCtx.arc(px,py,30,0,Math.PI*2);linkCtx.stroke();
    // Phase dot
    linkCtx.fillStyle=offline?'#5A7A5A':'#5BE03C';
    linkCtx.beginPath();linkCtx.arc(dotX,dotY,5,0,Math.PI*2);linkCtx.fill();
    // Label
    linkCtx.fillStyle=offline?'#5A7A5A':'#D8E8D0';
    linkCtx.font='9px Courier New';
    linkCtx.textAlign='center';
    linkCtx.fillText(peer,px,py+48);
  });
  // Central BPM display
  linkCtx.fillStyle='#5BE03C';
  linkCtx.font='bold 28px Courier New';
  linkCtx.textAlign='center';
  linkCtx.fillText(bpm.toFixed(1),cx,cy+8);
  linkCtx.fillStyle='#5A7A5A';
  linkCtx.font='9px Courier New';
  linkCtx.fillText('BPM · LINK',cx,cy+28);
  // Beat pulse
  const bf=lagLinkBeat.value;
  linkCtx.strokeStyle=`rgba(91,224,60,${0.5*bf})`;
  linkCtx.lineWidth=2*bf;
  linkCtx.beginPath();linkCtx.arc(cx,cy,R*1.05,0,Math.PI*2);linkCtx.stroke();
}

