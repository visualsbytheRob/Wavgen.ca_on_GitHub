<script>
// ═══════════════════════════════════════════════════════════════════════════
// 1. HERO CANVAS — color field breathing (very slow, 70-second cycle)
// ═══════════════════════════════════════════════════════════════════════════
const heroCanvas = document.getElementById('hero-canvas');
const heroCtx = heroCanvas.getContext('2d');
let heroPhase = 0;

function resizeHero() {
  heroCanvas.width = window.innerWidth;
  heroCanvas.height = window.innerHeight;
}
window.addEventListener('resize', resizeHero);
resizeHero();

function drawHero() {
  heroPhase += 0.00004; // full cycle ~70 seconds
  const intensity = (Math.sin(heroPhase) + 1) / 2;
  heroCtx.clearRect(0, 0, heroCanvas.width, heroCanvas.height);
  heroCtx.fillStyle = '#030309';
  heroCtx.fillRect(0, 0, heroCanvas.width, heroCanvas.height);
  const cx = heroCanvas.width / 2, cy = heroCanvas.height / 2;
  const r = Math.min(heroCanvas.width, heroCanvas.height) * 0.6;
  const grad = heroCtx.createRadialGradient(cx, cy, 0, cx, cy, r);
  grad.addColorStop(0,   `rgba(30,60,140,${intensity * 0.15})`);
  grad.addColorStop(0.5, `rgba(15,30,80,${intensity * 0.08})`);
  grad.addColorStop(1,   'rgba(3,3,9,0)');
  heroCtx.fillStyle = grad;
  heroCtx.fillRect(0, 0, heroCanvas.width, heroCanvas.height);
  requestAnimationFrame(drawHero);
}
drawHero();

// ═══════════════════════════════════════════════════════════════════════════
// 2. TAPE LOOP MACHINE
// ═══════════════════════════════════════════════════════════════════════════
const TAPE_LOOPS  = [7, 11, 13, 17];
const TAPE_CIRC   = 2 * Math.PI * 78; // circumference for r=78 → ~490
const TAPE_COLORS = ['#3b82f6','#6366f1','#8b5cf6','#a855f7'];
const TAPE_IDS    = ['tape-a','tape-b','tape-c','tape-d'];
const TAPE_BEAT_IDS = ['reel-a-beat','reel-b-beat','reel-c-beat','reel-d-beat'];
let tapeRunning = false, tapeBeat = 0, tapeInterval = null;
let tapeArcPos = [0,0,0,0]; // current arc position per reel (0–1)

function gcd(a,b){ return b===0?a:gcd(b,a%b); }
function lcm(a,b){ return a/gcd(a,b)*b; }
function lcmArr(arr){ return arr.reduce((a,b)=>lcm(a,b),1); }

function tapeBpmMs(bpm){ return 60000/bpm; }

function tapeUpdateLcm(bpm){
  const l = lcmArr(TAPE_LOOPS);
  const mins = Math.round(l/bpm);
  document.getElementById('tape-lcm').innerHTML =
    `Loops repeat together in: <strong>${l.toLocaleString()} beats</strong> (${mins} minutes at ${bpm} BPM)`;
}

function tapeStep(){
  tapeBeat++;
  TAPE_LOOPS.forEach((len,i)=>{
    const beat = tapeBeat % len;
    tapeArcPos[i] = beat/len;
    const arc = TAPE_CIRC * (1/len); // one beat of arc
    const pos = tapeArcPos[i] * TAPE_CIRC;
    const el = document.getElementById(TAPE_IDS[i]);
    el.setAttribute('stroke-dasharray', arc + ' ' + (TAPE_CIRC - arc));
    el.setAttribute('stroke-dashoffset', -pos);
    document.getElementById(TAPE_BEAT_IDS[i]).textContent = `BEAT ${beat+1} / ${len}`;
  });
  // Timeline canvas
  const tl = document.getElementById('tape-timeline');
  if(tl){
    const ctx = tl.getContext('2d');
    tl.width = tl.offsetWidth || 800;
    const w = tl.width, h = tl.height;
    ctx.fillStyle = 'rgba(10,10,24,0.8)';
    ctx.fillRect(0,0,w,h);
    const step = w / 32;
    TAPE_LOOPS.forEach((len,i)=>{
      if(tapeBeat % len === 0){
        const x = ((tapeBeat % 32) / 32) * w;
        ctx.fillStyle = TAPE_COLORS[i];
        ctx.globalAlpha = 0.6;
        ctx.fillRect(x - step/2, i*(h/4), step, h/4 - 2);
        ctx.globalAlpha = 1;
      }
    });
  }
}

function tapeToggle(){
  const btn = document.getElementById('tape-play-btn');
  const bpm = parseInt(document.getElementById('tape-bpm').value);
  if(tapeRunning){
    clearInterval(tapeInterval); tapeRunning=false;
    btn.textContent='▶ BEGIN'; btn.classList.remove('running');
  } else {
    tapeRunning=true;
    btn.textContent='■ STOP'; btn.classList.add('running');
    tapeInterval = setInterval(tapeStep, tapeBpmMs(bpm));
  }
}

document.getElementById('tape-bpm').addEventListener('input', function(){
  document.getElementById('tape-bpm-val').textContent = this.value;
  tapeUpdateLcm(parseInt(this.value));
  if(tapeRunning){
    clearInterval(tapeInterval);
    tapeInterval = setInterval(tapeStep, tapeBpmMs(parseInt(this.value)));
  }
});
tapeUpdateLcm(60);

// ═══════════════════════════════════════════════════════════════════════════
// 3. DRONE LAB — WebAudio
// ═══════════════════════════════════════════════════════════════════════════
let droneCtx = null;
const DRONE_FREQS = [4000, 1200, 500, 150, 60, 30];
const DRONE_TYPES = ['triangle','sine','sine','sine','sine','sine'];
const droneNodes = [null,null,null,null,null,null];
const droneGains = [null,null,null,null,null,null];
const droneFilters = [null,null,null,null,null,null];
const droneActive = [false,false,false,false,false,false];

function getDroneCtx(){
  if(!droneCtx) droneCtx = new (window.AudioContext||window.webkitAudioContext)();
  return droneCtx;
}

function droneToggle(i){
  const ctx = getDroneCtx();
  if(droneActive[i]){
    if(droneNodes[i]){ droneNodes[i].stop(); droneNodes[i]=null; }
    if(droneGains[i]){ droneGains[i].disconnect(); droneGains[i]=null; }
    droneActive[i]=false;
    document.querySelector(`.drone-toggle[data-layer="${i}"]`).textContent='OFF';
    document.getElementById(`drone-layer-${i}`).classList.remove('active');
  } else {
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    const filt = ctx.createBiquadFilter();
    osc.type = DRONE_TYPES[i];
    osc.frequency.value = DRONE_FREQS[i];
    const vol = parseInt(document.querySelector(`.drone-vol[data-layer="${i}"]`).value)/100 * 0.3;
    gain.gain.value = vol;
    filt.type = 'bandpass';
    filt.frequency.value = DRONE_FREQS[i];
    filt.Q.value = 1.5;
    osc.connect(filt); filt.connect(gain); gain.connect(ctx.destination);
    osc.start();
    droneNodes[i]=osc; droneGains[i]=gain; droneFilters[i]=filt;
    droneActive[i]=true;
    document.querySelector(`.drone-toggle[data-layer="${i}"]`).textContent='ON';
    document.querySelector(`.drone-toggle[data-layer="${i}"]`).classList.add('active');
    document.getElementById(`drone-layer-${i}`).classList.add('active');
  }
}

function droneToggleAll(){ DRONE_FREQS.forEach((_,i)=>{ if(!droneActive[i]) droneToggle(i); }); }
function droneSilenceAll(){ DRONE_FREQS.forEach((_,i)=>{ if(droneActive[i]) droneToggle(i); }); }

document.querySelectorAll('.drone-vol').forEach(el=>{
  el.addEventListener('input',function(){
    const i = parseInt(this.dataset.layer);
    this.closest('.drone-layer').querySelector('.drone-vol-val').textContent = this.value;
    if(droneGains[i]) droneGains[i].gain.value = parseInt(this.value)/100 * 0.3;
  });
});
document.querySelectorAll('.drone-filter').forEach(el=>{
  el.addEventListener('input',function(){
    const i = parseInt(this.dataset.layer);
    this.closest('.drone-layer').querySelector('.drone-filter-val').textContent = this.value;
    if(droneFilters[i]) droneFilters[i].Q.value = parseInt(this.value)/10;
  });
});
document.querySelectorAll('.drone-reverb').forEach(el=>{
  el.addEventListener('input',function(){
    const i = parseInt(this.dataset.layer);
    this.closest('.drone-layer').querySelector('.drone-reverb-val').textContent = this.value;
  });
});

// ═══════════════════════════════════════════════════════════════════════════
// 4. FEEDBACK ECOSYSTEM
// ═══════════════════════════════════════════════════════════════════════════
let fbCtx=null, fbOsc=null, fbGainNode=null, fbRunning=false;
let fbDashOffset = 0;
let fbDashAnim = null;

function getFbCtx(){ if(!fbCtx) fbCtx=new(window.AudioContext||window.webkitAudioContext)(); return fbCtx; }

function fbUpdateGain(val){
  document.getElementById('fb-gain-val').textContent = val+'%';
  const warning = document.getElementById('fb-warning');
  const zoneLabel = document.getElementById('fb-zone-label');
  const dot = document.getElementById('fb-stability-dot');
  const v = parseInt(val);
  if(v < 50){
    warning.style.opacity='0';
    zoneLabel.textContent='◈ STABLE ZONE'; zoneLabel.style.color='rgba(34,197,94,0.9)';
    dot.setAttribute('fill','rgba(34,197,94,0.8)');
    dot.setAttribute('cx','150'); dot.setAttribute('cy','80');
  } else if(v < 70){
    warning.style.opacity='0';
    zoneLabel.textContent='◈ RICH ZONE'; zoneLabel.style.color='rgba(245,158,11,0.9)';
    dot.setAttribute('fill','rgba(245,158,11,0.8)');
    dot.setAttribute('cx','150'); dot.setAttribute('cy','50');
  } else {
    warning.style.opacity='1';
    zoneLabel.textContent='⚠ UNSTABLE ZONE'; zoneLabel.style.color='rgba(239,68,68,0.9)';
    dot.setAttribute('fill','rgba(239,68,68,0.8)');
    dot.setAttribute('cx','150'); dot.setAttribute('cy','22');
  }
  if(fbGainNode) fbGainNode.gain.value = v/100 * 0.9;
}

function fbUpdateDelay(val){
  document.getElementById('fb-delay-val').textContent=val+'ms';
  document.getElementById('fb-delay-label').textContent=val+'ms';
}

function fbAnimDash(){
  fbDashOffset -= 0.4;
  document.getElementById('feedback-dash').setAttribute('stroke-dashoffset', fbDashOffset);
  if(fbRunning) fbDashAnim = requestAnimationFrame(fbAnimDash);
}

function fbToggle(){
  const btn = document.getElementById('fb-play-btn');
  const ctx = getFbCtx();
  if(fbRunning){
    fbRunning=false;
    if(fbOsc){ fbOsc.stop(); fbOsc=null; }
    btn.textContent='▶ START TONE'; btn.classList.remove('running');
    cancelAnimationFrame(fbDashAnim);
  } else {
    fbRunning=true;
    btn.textContent='■ STOP'; btn.classList.add('running');
    const gain = parseInt(document.getElementById('fb-gain').value)/100 * 0.9;
    fbOsc = ctx.createOscillator();
    fbGainNode = ctx.createGain();
    fbOsc.type='sine'; fbOsc.frequency.value=220;
    fbGainNode.gain.value = gain;
    fbOsc.connect(fbGainNode); fbGainNode.connect(ctx.destination);
    fbOsc.start();
    fbAnimDash();
  }
}

// ═══════════════════════════════════════════════════════════════════════════
// 5. PROBABILITY MUSIC MACHINE
// ═══════════════════════════════════════════════════════════════════════════
let probRunning=false, probInterval=null, probStep=0;
let probScale='pentatonic';
const PROB_SCALES = {
  'pentatonic': [293.66,349.23,392,440,523.25,587.33,659.25,784],
  'whole-tone': [261.63,293.66,329.63,369.99,415.30,466.16,523.25,587.33],
  'drone':      [220,220,220,220,220,440,440,440]
};
let probCtx=null;
function getProbCtx(){ if(!probCtx) probCtx=new(window.AudioContext||window.webkitAudioContext)(); return probCtx; }

function probCellClick(el){
  const states=[0,50,100];
  const current=parseInt(el.dataset.prob||'0');
  const nextIdx=(states.indexOf(current)+1)%states.length;
  const next=states[nextIdx];
  el.dataset.prob=next;
  el.querySelector('.prob-cell-fill').style.height=next+'%';
  el.querySelector('.prob-cell-label').textContent = next===0?'—':next+'%';
}

function probPlayNote(freq, long){
  const ctx=getProbCtx();
  const osc=ctx.createOscillator(), g=ctx.createGain();
  osc.type='sine'; osc.frequency.value=freq;
  g.gain.setValueAtTime(0.12,ctx.currentTime);
  if(long){
    g.gain.linearRampToValueAtTime(0.1,ctx.currentTime+0.3);
    g.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+2.5);
    osc.stop(ctx.currentTime+2.5);
  } else {
    g.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+0.4);
    osc.stop(ctx.currentTime+0.4);
  }
  osc.connect(g); g.connect(ctx.destination); osc.start();
}

function probTick(){
  const cells=[...document.querySelectorAll('.prob-grid .prob-cell')];
  const stepCells=cells.filter(c=>parseInt(c.dataset.step)===probStep);
  const chaos=parseInt(document.getElementById('prob-chaos').value)/100;
  const scale=PROB_SCALES[probScale];
  stepCells.forEach(cell=>{
    const track=parseInt(cell.dataset.track);
    const prob=parseInt(cell.dataset.prob||'0')/100;
    const fires=Math.random()<prob;
    if(fires){
      const freqIdx=Math.floor(Math.random()*scale.length);
      const pitchVar = chaos>0 ? scale[freqIdx]*(1+(Math.random()-0.5)*chaos*0.5):scale[freqIdx];
      if(track===0) probPlayNote(pitchVar,true);
      else if(track===1) probPlayNote(pitchVar,false);
      cell.classList.add('flash');
      setTimeout(()=>cell.classList.remove('flash'),300);
    }
  });
  probStep=(probStep+1)%16;
}

function probToggle(){
  const btn=document.getElementById('prob-run-btn');
  const bpm=parseInt(document.getElementById('prob-bpm').value);
  if(probRunning){
    clearInterval(probInterval); probRunning=false;
    btn.textContent='▶ RUN'; btn.classList.remove('running');
  } else {
    probRunning=true;
    btn.textContent='■ STOP'; btn.classList.add('running');
    probInterval=setInterval(probTick,60000/bpm);
  }
}

function probClear(){
  document.querySelectorAll('.prob-cell').forEach(c=>{
    c.dataset.prob='0';
    c.querySelector('.prob-cell-fill').style.height='0%';
    c.querySelector('.prob-cell-label').textContent='—';
  });
}

function probRandomize(){
  document.querySelectorAll('.prob-cell').forEach(c=>{
    const states=[0,50,100];
    const v=states[Math.floor(Math.random()*states.length)];
    c.dataset.prob=v;
    c.querySelector('.prob-cell-fill').style.height=v+'%';
    c.querySelector('.prob-cell-label').textContent=v===0?'—':v+'%';
  });
}

function probSetScale(s,btn){
  probScale=s;
  document.querySelectorAll('#prob-scale-btns .btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function probDensity(val){
  document.getElementById('prob-density-val').textContent=val+'%';
  const factor=parseInt(val)/100;
  document.querySelectorAll('.prob-cell').forEach(c=>{
    const cur=parseInt(c.dataset.prob||'0');
    if(cur>0){
      const states=[50,100];
      const newV=Math.min(100,Math.round(cur*factor));
      const snapped=newV<25?0:newV<75?50:100;
      c.dataset.prob=snapped;
      c.querySelector('.prob-cell-fill').style.height=snapped+'%';
      c.querySelector('.prob-cell-label').textContent=snapped===0?'—':snapped+'%';
    }
  });
}

document.getElementById('prob-bpm').addEventListener('input',function(){
  document.getElementById('prob-bpm-val').textContent=this.value;
  if(probRunning){ clearInterval(probInterval); probInterval=setInterval(probTick,60000/parseInt(this.value)); }
});
</script>
<script>
// ═══════════════════════════════════════════════════════════════════════════
// 6. PHASE MACHINE
// ═══════════════════════════════════════════════════════════════════════════
const PHASE_PATTERNS = {
  'pentatonic': ['D','E','G','A','C','D','E','G'],
  'whole-tone': ['C','D','E','F#','G#','A#','C','D'],
  'custom':     ['A','B','C','D','E','F','G','A']
};
let phaseRunning=false, phasePatLen=7, phaseRatio=1.010;
let phaseStepA=0, phaseStepB=0;
let phaseAccA=0, phaseAccB=0;
let phaseLastTime=null, phaseAnimId=null;
let phasePat='pentatonic';
let phaseCtx=null;
function getPhaseCtx(){if(!phaseCtx)phaseCtx=new(window.AudioContext||window.webkitAudioContext)();return phaseCtx;}

// Draw hour marks on both clocks
function phaseDrawMarks(svgId, len){
  const g=document.getElementById(svgId==='phase-clock-a'?'phase-marks-a':'phase-marks-b');
  g.innerHTML='';
  for(let i=0;i<len;i++){
    const angle=(i/len)*2*Math.PI-Math.PI/2;
    const x1=100+80*Math.cos(angle), y1=100+80*Math.sin(angle);
    const x2=100+88*Math.cos(angle), y2=100+88*Math.sin(angle);
    const line=document.createElementNS('http://www.w3.org/2000/svg','line');
    line.setAttribute('x1',x1);line.setAttribute('y1',y1);
    line.setAttribute('x2',x2);line.setAttribute('y2',y2);
    line.setAttribute('stroke','rgba(255,255,255,0.2)');line.setAttribute('stroke-width','1.5');
    g.appendChild(line);
  }
}

function phaseUpdateHand(handId, step, len){
  const angle=(step/len)*2*Math.PI-Math.PI/2;
  const x=100+80*Math.cos(angle), y=100+80*Math.sin(angle);
  const hand=document.getElementById(handId);
  hand.setAttribute('x2',x); hand.setAttribute('y2',y);
}

function phasePlayNote(freq){
  const ctx=getPhaseCtx();
  const osc=ctx.createOscillator(), g=ctx.createGain();
  osc.type='sine'; osc.frequency.value=freq;
  g.gain.setValueAtTime(0.08,ctx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+1.2);
  osc.stop(ctx.currentTime+1.2);
  osc.connect(g); g.connect(ctx.destination); osc.start();
}

const PHASE_FREQS_PEN = [293.66,329.63,392,440,523.25,587.33,659.25,784];
const PHASE_FREQS_WT  = [261.63,293.66,329.63,369.99,415.30,466.16,523.25,587.33];

function phaseGetFreqs(){
  return phasePat==='whole-tone'?PHASE_FREQS_WT:PHASE_FREQS_PEN;
}

const BEAT_MS_PHASE = 600; // 100 BPM equivalent for phase

function phaseFrame(ts){
  if(!phaseLastTime){ phaseLastTime=ts; }
  const dt=ts-phaseLastTime; phaseLastTime=ts;
  const stepDur = BEAT_MS_PHASE;
  phaseAccA+=dt; phaseAccB+=dt*phaseRatio;
  if(phaseAccA>=stepDur){
    phaseAccA-=stepDur;
    const freqs=phaseGetFreqs();
    phasePlayNote(freqs[phaseStepA%freqs.length]*0.5);
    phaseStepA=(phaseStepA+1)%phasePatLen;
    phaseUpdateHand('phase-hand-a',phaseStepA,phasePatLen);
    const pat=PHASE_PATTERNS[phasePat];
    document.getElementById('phase-display-a').textContent=pat.slice(0,phasePatLen).join(' · ');
  }
  if(phaseAccB>=stepDur){
    phaseAccB-=stepDur;
    const freqs=phaseGetFreqs();
    phasePlayNote(freqs[phaseStepB%freqs.length]*0.5*1.004);
    phaseStepB=(phaseStepB+1)%phasePatLen;
    phaseUpdateHand('phase-hand-b',phaseStepB,phasePatLen);
  }
  if(phaseRunning) phaseAnimId=requestAnimationFrame(phaseFrame);
}

function phaseToggle(){
  const btn=document.getElementById('phase-play-btn');
  if(phaseRunning){
    phaseRunning=false; cancelAnimationFrame(phaseAnimId);
    btn.textContent='▶ START'; btn.classList.remove('running');
  } else {
    phaseRunning=true; phaseLastTime=null; phaseAccA=0; phaseAccB=0;
    btn.textContent='■ STOP'; btn.classList.add('running');
    phaseAnimId=requestAnimationFrame(phaseFrame);
  }
}

function phaseSetPattern(p,btn){
  phasePat=p;
  document.querySelectorAll('#phase-pattern-btns .btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  phaseDrawMarks('phase-clock-a',phasePatLen);
  phaseDrawMarks('phase-clock-b',phasePatLen);
}

function phaseSetLen(n,btn){
  phasePatLen=n;
  document.querySelectorAll('#phase-len-btns .btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  phaseDrawMarks('phase-clock-a',n); phaseDrawMarks('phase-clock-b',n);
  const convergence=Math.round(n/Math.abs(phaseRatio-1));
  document.getElementById('convergence-beats').textContent=convergence.toLocaleString();
}

function phaseUpdateRatio(val){
  phaseRatio=parseInt(val)/1000;
  document.getElementById('phase-ratio-val').textContent='1:'+phaseRatio.toFixed(3);
  const convergence=Math.round(phasePatLen/Math.abs(phaseRatio-1));
  document.getElementById('convergence-beats').textContent=convergence.toLocaleString();
}

// Init clocks
phaseDrawMarks('phase-clock-a',7); phaseDrawMarks('phase-clock-b',7);
document.getElementById('convergence-beats').textContent='700';

// Spectrogram canvas (simple scrolling)
const phaseSpec = document.getElementById('phase-spectrogram');
let phaseSpecCtx=null;
if(phaseSpec){
  phaseSpec.width=phaseSpec.offsetWidth||800;
  phaseSpecCtx=phaseSpec.getContext('2d');
  setInterval(()=>{
    if(!phaseSpecCtx)return;
    const w=phaseSpec.width,h=phaseSpec.height;
    const img=phaseSpecCtx.getImageData(1,0,w-1,h);
    phaseSpecCtx.putImageData(img,0,0);
    phaseSpecCtx.fillStyle='rgba(10,10,24,1)';
    phaseSpecCtx.fillRect(w-1,0,1,h);
    if(phaseRunning){
      const heat=Math.random()*0.6+0.2;
      phaseSpecCtx.fillStyle=`rgba(59,130,246,${heat})`;
      const barH=Math.random()*h*0.8+h*0.1;
      phaseSpecCtx.fillRect(w-1,h-barH,1,barH);
    }
  },80);
}

// ═══════════════════════════════════════════════════════════════════════════
// 7. SHIMMER REVERB ROOM — canvas visualization
// ═══════════════════════════════════════════════════════════════════════════
const shimCanvas = document.getElementById('shimmer-canvas');
const shimCtx = shimCanvas.getContext('2d');
let shimRays = [], shimRunning = true, shimInterval='fifth';
let shimCtxAudio=null, shimABMode=true;
function getShimCtxAudio(){if(!shimCtxAudio)shimCtxAudio=new(window.AudioContext||window.webkitAudioContext)();return shimCtxAudio;}

function drawShimmerRoom(){
  const W=shimCanvas.width, H=shimCanvas.height;
  shimCtx.clearRect(0,0,W,H);
  // Background
  shimCtx.fillStyle='rgba(10,10,24,0.97)';
  shimCtx.fillRect(0,0,W,H);
  // Floor (perspective trapezoid)
  shimCtx.beginPath();
  shimCtx.moveTo(0,H);shimCtx.lineTo(W,H);shimCtx.lineTo(W*0.75,H*0.55);shimCtx.lineTo(W*0.25,H*0.55);
  shimCtx.closePath();
  shimCtx.fillStyle='rgba(20,20,40,0.6)';shimCtx.fill();
  shimCtx.strokeStyle='rgba(59,130,246,0.12)';shimCtx.lineWidth=1;shimCtx.stroke();
  // Left wall
  shimCtx.beginPath();
  shimCtx.moveTo(0,0);shimCtx.lineTo(W*0.25,H*0.55);shimCtx.lineTo(0,H);
  shimCtx.closePath();
  shimCtx.fillStyle='rgba(15,15,35,0.7)';shimCtx.fill();
  shimCtx.strokeStyle='rgba(59,130,246,0.1)';shimCtx.stroke();
  // Back wall
  shimCtx.beginPath();
  shimCtx.moveTo(W*0.25,H*0.55);shimCtx.lineTo(W*0.75,H*0.55);shimCtx.lineTo(W*0.75,0);shimCtx.lineTo(W*0.25,0);
  shimCtx.closePath();
  shimCtx.fillStyle='rgba(12,12,28,0.8)';shimCtx.fill();
  shimCtx.strokeStyle='rgba(59,130,246,0.15)';shimCtx.stroke();
  // Right wall
  shimCtx.beginPath();
  shimCtx.moveTo(W,0);shimCtx.lineTo(W*0.75,H*0.55);shimCtx.lineTo(W,H);
  shimCtx.closePath();
  shimCtx.fillStyle='rgba(15,15,35,0.7)';shimCtx.fill();
  shimCtx.strokeStyle='rgba(59,130,246,0.1)';shimCtx.stroke();
  // Ceiling
  shimCtx.beginPath();
  shimCtx.moveTo(0,0);shimCtx.lineTo(W,0);shimCtx.lineTo(W*0.75,H*0.55);shimCtx.lineTo(W*0.25,H*0.55);
  shimCtx.closePath();
  shimCtx.fillStyle='rgba(18,18,38,0.5)';shimCtx.fill();
  shimCtx.strokeStyle='rgba(59,130,246,0.18)';shimCtx.stroke();
  // Draw rays
  shimRays.forEach(ray=>{
    shimCtx.strokeStyle=`rgba(${ray.r},${ray.g},${ray.b},${ray.alpha})`;
    shimCtx.lineWidth=ray.width;
    shimCtx.beginPath();
    shimCtx.moveTo(ray.x1,ray.y1);shimCtx.lineTo(ray.x2,ray.y2);
    shimCtx.stroke();
    ray.alpha-=0.004;
    ray.y1-=0.15; ray.y2-=0.15;
  });
  shimRays=shimRays.filter(r=>r.alpha>0.01);
}

function shimAddRay(){
  const decay=parseFloat(document.getElementById('shimmer-decay').value);
  const count=Math.floor(decay*0.7);
  const W=shimCanvas.width, H=shimCanvas.height;
  for(let b=0;b<count;b++){
    const startX=Math.random()*W*0.3;
    const startY=H*0.3+Math.random()*H*0.4;
    const endX=W*0.25+Math.random()*W*0.5;
    const endY=H*0.1+Math.random()*H*0.45;
    const blue=Math.min(255,150+b*15);
    shimRays.push({
      x1:startX,y1:startY,x2:endX,y2:endY,
      r:59+b*8, g:100+b*5, b:blue,
      alpha:0.5-b*0.04,
      width:1.5-b*0.1
    });
  }
}

setInterval(shimAddRay,2000);
setInterval(()=>{ if(shimRunning){ drawShimmerRoom(); } }, 80);

function shimmerSetInterval(intv, btn){
  shimInterval=intv;
  document.querySelectorAll('#shimmer-interval-btns .btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function shimmerPlayNote(){
  const ctx=getShimCtxAudio();
  const freqs=[261.63,329.63,392,523.25];
  const decay=parseFloat(document.getElementById('shimmer-decay').value);
  freqs.forEach((f,i)=>{
    const osc=ctx.createOscillator(), g=ctx.createGain();
    osc.type='sine'; osc.frequency.value=f;
    g.gain.setValueAtTime(0.1,ctx.currentTime+i*0.08);
    g.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+decay);
    osc.stop(ctx.currentTime+decay);
    osc.connect(g); g.connect(ctx.destination); osc.start();
    // Shimmer — add pitch-shifted harmonic
    if(shimABMode){
      const osc2=ctx.createOscillator(), g2=ctx.createGain();
      const ratio = shimInterval==='octave'?2:shimInterval==='fifth'?1.5:shimInterval==='fourth'?1.333:1;
      osc2.type='sine'; osc2.frequency.value=f*ratio;
      g2.gain.setValueAtTime(0.04,ctx.currentTime+i*0.08+0.3);
      g2.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+decay*1.3);
      osc2.stop(ctx.currentTime+decay*1.3);
      osc2.connect(g2); g2.connect(ctx.destination); osc2.start();
    }
  });
  shimAddRay(); shimAddRay();
  document.getElementById('shimmer-play-btn').textContent='■ SOUNDING';
  setTimeout(()=>document.getElementById('shimmer-play-btn').textContent='▶ PLAY NOTE', decay*1000);
}

function shimmerToggleAB(){
  shimABMode=!shimABMode;
  document.getElementById('shimmer-ab-btn').textContent = shimABMode?'A — SHIMMER':'B — DRY REVERB';
}

// ═══════════════════════════════════════════════════════════════════════════
// 8. DEEP LISTENING — timer, prompt rotation, fade behavior
// ═══════════════════════════════════════════════════════════════════════════
const DL_PROMPTS=[
  "Listen for the quietest sound you can hear.",
  "Find a sound that has rhythm.",
  "What is the farthest sound from where you are?",
  "Listen to the space between sounds.",
  "What sounds existed before you started listening?",
  "Find a sound that moves.",
  "Listen for a sound that changes while you listen to it."
];
let dlPromptIdx=0, dlTimerInterval=null, dlSecondsLeft=0, dlTotalSeconds=0;
let dlFadeTimeout=null, dlFaded=false;
let dlPromptInterval=null;

function dlStart(minutes){
  dlStop();
  dlTotalSeconds=dlSecondsLeft=minutes*60;
  document.getElementById('dl-stop-btn').style.display='';
  document.getElementById('dl-timer').textContent=dlFormatTime(dlSecondsLeft);
  dlTimerInterval=setInterval(dlTick,1000);
  dlPromptInterval=setInterval(dlNextPrompt,60000);
  dlFadeTimeout=setTimeout(dlFadeInterface,30000);
}

function dlTick(){
  dlSecondsLeft--;
  if(dlSecondsLeft<=0){ dlStop(); return; }
  document.getElementById('dl-timer').textContent=dlFormatTime(dlSecondsLeft);
  // Progress ring: circumference=691, shrink as time passes
  const progress=1-(dlSecondsLeft/dlTotalSeconds);
  const offset=691*(1-progress);
  document.getElementById('dl-progress-ring').style.strokeDashoffset=offset;
}

function dlStop(){
  clearInterval(dlTimerInterval); clearInterval(dlPromptInterval);
  clearTimeout(dlFadeTimeout); dlTimerInterval=null;
  document.getElementById('dl-stop-btn').style.display='none';
  document.getElementById('dl-timer').textContent='—:——';
  document.getElementById('dl-progress-ring').style.strokeDashoffset='691';
  dlRestoreInterface();
}

function dlNextPrompt(){
  const el=document.getElementById('listening-prompt');
  el.style.opacity='0';
  setTimeout(()=>{
    dlPromptIdx=(dlPromptIdx+1)%DL_PROMPTS.length;
    el.textContent=DL_PROMPTS[dlPromptIdx];
    el.style.opacity='1';
  },2000);
}

function dlFormatTime(s){
  const m=Math.floor(s/60),sec=s%60;
  return String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');
}

function dlFadeInterface(){
  if(dlFaded)return; dlFaded=true;
  const controls=document.getElementById('deep-listening-controls');
  const info=document.getElementById('dl-info-text');
  // Fade everything except timer
  const els=controls.querySelectorAll('button,.attention-field-wrap>svg');
  els.forEach(el=>el.classList.add('faded'));
  if(info) info.classList.add('faded');
}

function dlRestoreInterface(){
  dlFaded=false;
  document.querySelectorAll('.faded').forEach(el=>el.classList.remove('faded'));
}

document.getElementById('deep-listening').addEventListener('mousemove', dlRestoreInterface);

// ═══════════════════════════════════════════════════════════════════════════
// 9. 77 MILLION PAINTINGS
// ═══════════════════════════════════════════════════════════════════════════
const PAINTING_DURATIONS=[13,17,19,23,29,31,37,41]; // seconds (primes)
let paintingsRunning=false, paintingsCombos=0, paintingsSeconds=0;
let paintingsTimerInterval=null, paintingsLoopAngles=[0,0,0,0,0,0,0,0];
let paintingsAnimId=null;

function paintingsToggle(){
  const btn=document.getElementById('paintings-play-btn');
  if(paintingsRunning){
    paintingsRunning=false;
    clearInterval(paintingsTimerInterval);
    cancelAnimationFrame(paintingsAnimId);
    btn.textContent='▶ BEGIN'; btn.classList.remove('running');
  } else {
    paintingsRunning=true;
    btn.textContent='■ STOP'; btn.classList.add('running');
    paintingsTimerInterval=setInterval(()=>{
      paintingsSeconds++;
      // Increment combos whenever any loop completes
      PAINTING_DURATIONS.forEach((d,i)=>{
        if(paintingsSeconds%d===0) paintingsCombos++;
      });
      document.getElementById('paintings-combos').textContent=paintingsCombos.toLocaleString();
      document.getElementById('paintings-time').textContent=paintingsFormatTime(paintingsSeconds);
    },1000);
    paintingsAnimFrame();
  }
}

function paintingsAnimFrame(){
  PAINTING_DURATIONS.forEach((dur,i)=>{
    paintingsLoopAngles[i]=(paintingsLoopAngles[i]+0.3/dur)%(2*Math.PI);
    const ring=document.getElementById(`loop-ring-${i}`);
    if(ring) ring.style.transform=`rotate(${paintingsLoopAngles[i]}rad)`;
  });
  if(paintingsRunning) paintingsAnimId=requestAnimationFrame(paintingsAnimFrame);
}

function paintingsFormatTime(s){
  const h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sec=s%60;
  return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');
}

// ═══════════════════════════════════════════════════════════════════════════
// 10. UTILITY — slider value updater
// ═══════════════════════════════════════════════════════════════════════════
function updateVal(el, targetId, suffix){
  document.getElementById(targetId).textContent = el.value + suffix;
}

// ═══════════════════════════════════════════════════════════════════════════
// 11. INTERSECTION OBSERVER — .hidden → .visible scroll entrance
// ═══════════════════════════════════════════════════════════════════════════
const revealObserver = new IntersectionObserver((entries)=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.hidden').forEach(el=>revealObserver.observe(el));

// ═══════════════════════════════════════════════════════════════════════════
// 12. NAV ACTIVE STATE — highlight current section
// ═══════════════════════════════════════════════════════════════════════════
const navObserver = new IntersectionObserver((entries)=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){
      const nav=entry.target.dataset.nav;
      if(nav){
        document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('active'));
        const activeLink=document.querySelector(`.nav-links a[data-nav="${nav}"]`);
        if(activeLink) activeLink.classList.add('active');
      }
    }
  });
},{ threshold:0.3 });

document.querySelectorAll('section[data-nav]').forEach(s=>navObserver.observe(s));

// ═══════════════════════════════════════════════════════════════════════════
// 13. DEEP LISTENING — 30-second auto-fade via IntersectionObserver
// ═══════════════════════════════════════════════════════════════════════════
let dlSectionVisible=false, dlAutoFadeTimer=null;
const dlSectionObserver=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting && !dlSectionVisible){
      dlSectionVisible=true;
      dlAutoFadeTimer=setTimeout(()=>{
        if(dlSectionVisible && !dlTimerInterval) dlFadeInterface();
      },30000);
    } else if(!e.isIntersecting){
      dlSectionVisible=false;
      clearTimeout(dlAutoFadeTimer);
    }
  });
},{threshold:0.3});
dlSectionObserver.observe(document.getElementById('deep-listening'));

// ═══════════════════════════════════════════════════════════════════════════
// 14. HERO STAGGER TRIGGER (on load)
// ═══════════════════════════════════════════════════════════════════════════
window.addEventListener('load',()=>{
  document.querySelectorAll('#hero .hidden').forEach(el=>{
    setTimeout(()=>el.classList.add('visible'),100);
  });
});
</script>
