<!-- ═══════════════════ 8. ARTISTS + GLOSSARY ═══════════════════ -->
<section id="artists">
<div class="section-label hidden stagger-1">REFERENCE 07</div>
<h2 class="hidden stagger-2">Artists &amp; Glossary</h2>
<p class="hidden stagger-3">The innovators who turned echo into art — and the vocabulary of delay.</p>
<div class="grid-2" id="artist-grid" style="margin-top:20px;"></div>
<h3 class="hidden" style="margin-top:40px;">GLOSSARY OF DELAY</h3>
<div class="glossary-grid hidden" id="glossary-grid" style="margin-top:12px;"></div>
</section>
