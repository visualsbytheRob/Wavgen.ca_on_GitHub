// TOUCH SUPPORT — loop record button
// ═══════════════════════════════════════════════════════
const loopBtn = document.getElementById('loop-rec-btn');
if (loopBtn) {
  loopBtn.addEventListener('touchstart', e => { e.preventDefault(); startLoop(); });
  loopBtn.addEventListener('touchend', e => { e.preventDefault(); endLoop(); });
}

