  WAVGEN DELAY &amp; ECHO LAB — Part of The Waveform Generation Music Universe — <a href="https://wavgen.ca" target="_blank">wavgen.ca</a>
</footer>
<script>
'use strict';
// ═══════════════════════════════════════════════════════
// AUDIO CONTEXT
// ═══════════════════════════════════════════════════════
let AC = null;
function getAC() {
  if (!AC) { AC = new (window.AudioContext || window.webkitAudioContext)(); }
  if (AC.state === 'suspended') AC.resume();
  return AC;
}

// ═══════════════════════════════════════════════════════
// LAG FILTER
// ═══════════════════════════════════════════════════════
class LagFilter {
  constructor(tau) { this.tau = tau; this.value = 0; }
  update(target, dt) {
    this.value += (1 - Math.exp(-dt / this.tau)) * (target - this.value);
    return this.value;
  }
}

// ═══════════════════════════════════════════════════════
// INTERSECTION OBSERVER (scroll entrance + nav active)
// ═══════════════════════════════════════════════════════
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.hidden').forEach(el => obs.observe(el));

const navObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    const id = e.target.id;
    const link = document.querySelector(`nav a[data-section="${id}"]`);
    if (!link) return;
    if (e.isIntersecting) {
      document.querySelectorAll('nav a').forEach(a => a.classList.remove('active'));
      link.classList.add('active');
    }
  });
}, { threshold: 0.4 });
document.querySelectorAll('section, #hero').forEach(s => navObs.observe(s));

// ═══════════════════════════════════════════════════════
// HERO CANVAS — Echo Chamber
// ═══════════════════════════════════════════════════════
const heroCanvas = document.getElementById('hero-canvas');
const hCtx = heroCanvas.getContext('2d');
let heroW, heroH, heroRings = [];
let heroBpm = 120, heroFeedback = 0.6, heroDelayMs = 500;
let heroAnimFrame;

function resizeHero() {
  heroW = heroCanvas.offsetWidth; heroH = heroCanvas.offsetHeight;
  heroCanvas.width = heroW; heroCanvas.height = heroH;
}

function spawnHeroRing() {
  heroRings.push({ r: 0, alpha: 1.0, birth: performance.now() });
}

function animateHero(ts) {
  heroAnimFrame = requestAnimationFrame(animateHero);
  hCtx.fillStyle = 'rgba(5,5,8,0.12)';
  hCtx.fillRect(0, 0, heroW, heroH);
  const cx = heroW / 2, cy = heroH / 2;
  const speed = 80;
  const dt = 0.016;

  // spawn rings based on delay time
  if (!animateHero._last) animateHero._last = ts;
  const elapsed = ts - animateHero._last;
  if (!animateHero._sinceSpawn) animateHero._sinceSpawn = 0;
  animateHero._sinceSpawn += elapsed;
  if (animateHero._sinceSpawn > heroDelayMs) {
    spawnHeroRing();
    animateHero._sinceSpawn = 0;
  }
  animateHero._last = ts;

  heroRings = heroRings.filter(ring => ring.alpha > 0.01);
  heroRings.forEach((ring, i) => {
    ring.r += speed * dt * (elapsed / 16);
    ring.alpha *= (1 - (1 - heroFeedback) * dt * 2);
    const grad = hCtx.createRadialGradient(cx, cy, ring.r - 4, cx, cy, ring.r + 4);
    const col = i === 0 ? `rgba(245,158,11,${ring.alpha})` : `rgba(180,83,9,${ring.alpha * 0.7})`;
    grad.addColorStop(0, 'transparent');
    grad.addColorStop(0.5, col);
    grad.addColorStop(1, 'transparent');
    hCtx.beginPath();
    hCtx.arc(cx, cy, ring.r, 0, Math.PI * 2);
    hCtx.strokeStyle = grad;
    hCtx.lineWidth = 3;
    hCtx.shadowBlur = 16;
    hCtx.shadowColor = '#b45309';
    hCtx.stroke();
    hCtx.shadowBlur = 0;
  });

  // source dot
  const pulse = 0.5 + 0.5 * Math.sin(ts * 0.004);
  hCtx.beginPath();
  hCtx.arc(cx, cy, 8 + pulse * 4, 0, Math.PI * 2);
  hCtx.fillStyle = `rgba(245,158,11,${0.8 + pulse * 0.2})`;
  hCtx.shadowBlur = 30; hCtx.shadowColor = '#f59e0b';
  hCtx.fill(); hCtx.shadowBlur = 0;
}

window.addEventListener('resize', resizeHero);
resizeHero();
animateHero(0);
</script>
<script>
// ═══════════════════════════════════════════════════════
// BPM CALCULATOR
// ═══════════════════════════════════════════════════════
let bpm = 120, pingPongOn = false;
let tapTimes = [], tapTimer = null;
const bpmCanvas = document.getElementById('bpm-canvas');
const bpmCtx = bpmCanvas.getContext('2d');
let bpmW, bpmH, bpmAnimFrame;
const subdivisions = [
  { name: 'Whole',      mult: 4,       label: '4/4' },
  { name: 'Half',       mult: 2,       label: '2/4' },
  { name: 'Quarter',    mult: 1,       label: '1/4' },
  { name: 'Dotted 8th', mult: 0.75,    label: '3/8' },
  { name: '8th',        mult: 0.5,     label: '1/8' },
  { name: 'Triplet 8th',mult: 1/3,     label: '1/8T' },
  { name: '16th',       mult: 0.25,    label: '1/16' },
  { name: '32nd',       mult: 0.125,   label: '1/32' },
];

function msPerBeat(b) { return 60000 / b; }
function getDelayMs(b, mult) { return msPerBeat(b) * mult; }

function resizeBpmCanvas() {
  bpmW = bpmCanvas.offsetWidth || 600; bpmH = 220;
  bpmCanvas.width = bpmW; bpmCanvas.height = bpmH;
}

function drawBpmClock(ts) {
  bpmAnimFrame = requestAnimationFrame(t => drawBpmClock(t));
  bpmCtx.fillStyle = 'rgba(5,5,8,0.2)';
  bpmCtx.fillRect(0, 0, bpmW, bpmH);
  const cx = 110, cy = bpmH / 2, r = 85;

  // clock face
  bpmCtx.beginPath(); bpmCtx.arc(cx, cy, r, 0, Math.PI * 2);
  bpmCtx.strokeStyle = '#1e1e2e'; bpmCtx.lineWidth = 2; bpmCtx.stroke();

  // ticks
  for (let i = 0; i < 12; i++) {
    const a = (i / 12) * Math.PI * 2 - Math.PI / 2;
    bpmCtx.beginPath();
    bpmCtx.moveTo(cx + (r - 8) * Math.cos(a), cy + (r - 8) * Math.sin(a));
    bpmCtx.lineTo(cx + r * Math.cos(a), cy + r * Math.sin(a));
    bpmCtx.strokeStyle = '#3d3d5c'; bpmCtx.lineWidth = 1; bpmCtx.stroke();
  }

  const colors = ['#f59e0b','#b45309','#854d0e','#78350f','#451a03','#92400e','#b45309','#78350f'];
  subdivisions.forEach((sub, i) => {
    const delayMs = getDelayMs(bpm, sub.mult);
    const period = delayMs;
    const phase = ((ts % period) / period) * Math.PI * 2 - Math.PI / 2;
    bpmCtx.beginPath();
    bpmCtx.moveTo(cx, cy);
    const len = r * (0.4 + sub.mult * 0.4);
    bpmCtx.lineTo(cx + len * Math.cos(phase), cy + len * Math.sin(phase));
    bpmCtx.strokeStyle = colors[i]; bpmCtx.lineWidth = i < 3 ? 2 : 1.5;
    bpmCtx.shadowBlur = i === 2 ? 8 : 4; bpmCtx.shadowColor = colors[i];
    bpmCtx.stroke(); bpmCtx.shadowBlur = 0;
  });

  // BPM label
  bpmCtx.fillStyle = '#e2e8f0'; bpmCtx.font = 'bold 18px Courier New';
  bpmCtx.textAlign = 'center'; bpmCtx.fillText(bpm + ' BPM', cx, cy + r + 18);

  // subdivision table on right
  const tx = 230, tw = bpmW - tx - 8;
  subdivisions.forEach((sub, i) => {
    const ms = getDelayMs(bpm, sub.mult);
    const y = 22 + i * 24;
    bpmCtx.fillStyle = i % 2 === 0 ? 'rgba(255,255,255,0.03)' : 'transparent';
    bpmCtx.fillRect(tx, y - 10, tw, 22);
    bpmCtx.fillStyle = colors[i]; bpmCtx.font = '11px Courier New';
    bpmCtx.textAlign = 'left'; bpmCtx.fillText(sub.name, tx + 4, y + 4);
    bpmCtx.textAlign = 'right'; bpmCtx.fillStyle = '#e2e8f0';
    bpmCtx.fillText(ms.toFixed(1) + 'ms', tx + tw - 4, y + 4);
  });
}

function tapTempo() {
  const now = performance.now();
  tapTimes.push(now);
  clearTimeout(tapTimer);
  tapTimer = setTimeout(() => { tapTimes = []; }, 2500);
  if (tapTimes.length > 1) {
    const diffs = [];
    for (let i = 1; i < tapTimes.length; i++) diffs.push(tapTimes[i] - tapTimes[i-1]);
    const avg = diffs.reduce((a,b) => a+b,0) / diffs.length;
    bpm = Math.round(60000 / avg);
    bpm = Math.max(60, Math.min(180, bpm));
    document.getElementById('bpm-slider').value = bpm;
    document.getElementById('bpm-val').textContent = bpm;
    document.getElementById('badge-bpm').textContent = bpm;
    updateEdgeInsight();
  }
  document.getElementById('tap-hint').textContent = `Tap ${tapTimes.length}...`;
  playTapClick();
}

function togglePingPong() {
  pingPongOn = !pingPongOn;
  const btn = document.getElementById('ping-pong-btn');
  btn.textContent = 'PING-PONG: ' + (pingPongOn ? 'ON' : 'OFF');
  btn.classList.toggle('active', pingPongOn);
}

function updateEdgeInsight() {
  const ms = getDelayMs(bpm, 0.75).toFixed(1);
  document.getElementById('edge-insight').innerHTML =
    `At ${bpm} BPM, dotted 8th = <strong style="color:var(--gold)">${ms}ms</strong> — the signature delay of U2's "Where The Streets Have No Name." The note repeats land just behind the beat, creating forward momentum.`;
}

function playTapClick() {
  const ac = getAC();
  const osc = ac.createOscillator();
  const g = ac.createGain();
  osc.connect(g); g.connect(ac.destination);
  osc.frequency.value = 880;
  g.gain.setValueAtTime(0.3, ac.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 0.06);
  osc.start(); osc.stop(ac.currentTime + 0.06);
}

document.getElementById('bpm-slider').addEventListener('input', function() {
  bpm = parseInt(this.value);
  document.getElementById('bpm-val').textContent = bpm;
  document.getElementById('badge-bpm').textContent = bpm;
  updateEdgeInsight();
});

resizeBpmCanvas();
updateEdgeInsight();
drawBpmClock(0);
window.addEventListener('resize', resizeBpmCanvas);
</script>
<script>
// ═══════════════════════════════════════════════════════
// DELAY TYPE MUSEUM
// ═══════════════════════════════════════════════════════
const delayRooms = [
  { id:'slapback', title:'Slapback',
    specs:'30–60ms | 0 feedback | no modulation',
    desc:'A single short repeat with zero feedback — the echo hits once and dies. Born in Sam Phillips\'s Sun Studio, it defined rockabilly guitar and early rock vocals. Elvis\'s voice, Scotty Moore\'s guitar.',
    tech:'A tape loop with very short head-to-head distance, or a digital single-tap delay.',
    artists:'Elvis Presley, Carl Perkins, Eddie Cochran, early Beatles',
    delayTime:45, feedback:0, wet:0.8 },
  { id:'tape', title:'Tape Echo',
    specs:'80–500ms | variable feedback | wow & flutter',
