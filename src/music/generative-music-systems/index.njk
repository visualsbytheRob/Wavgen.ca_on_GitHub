<!-- SECTION 2: GENERATIVE SEQUENCER -->
<section class="hidden" id="sequencer">
<div class="section-label">02 — PROBABILISTIC ENGINE</div>
<div class="section-title">Generative Sequencer</div>
<div class="section-desc">An 8-step sequencer where each step fires based on probability. Set pitch, probability, and velocity per step. Press Evolve to drift the system autonomously.</div>
<div class="canvas-wrap">
<canvas height="90" id="seq-canvas" style="width:100%;height:90px" width="900"></canvas>
</div>
<div id="seq-steps" style="display:grid;grid-template-columns:repeat(8,1fr);gap:8px;margin:12px 0"></div>
