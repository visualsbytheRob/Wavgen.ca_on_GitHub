<!-- Recent Releases -->
<section id="recent-releases" class="py-40 bg-gray-900 border-t border-b border-white/10">
  <div class="container mx-auto px-4">
    <div class="h-px bg-white/10 mb-8"></div>
    <h3 class="text-3xl font-bold mb-10">Recent releases</h3>
    <div id="recent-releases" class="grid md:grid-cols-3 gap-8" aria-live="polite">
      {% set m = collections.music | reverse | first %}
      {% set v = collections.video | reverse | first %}
      {% set d = collections.data | reverse | first %}

      {% if m %}
      <a href="{{ m.url }}" class="whats-new-card inline-flex items-center gap-4 bg-wavgen-purple/50 hover:bg-wavgen-purple/60 text-white no-underline border-2 border-wavgen-purple hover:border-wavgen-yellow transition-colors rounded-2xl shadow-lg px-6 h-40 min-w-[300px] transition-colors duration-200">
        <span class="inline-block w-4 h-4 rounded-full bg-wavgen-yellow"></span>
        <span class="flex flex-col leading-tight">
          <span class="text-sm opacity-80">Music</span>
          <span class="text-lg font-semibold">{{ m.data.title or m.fileSlug }}</span>
        </span>
      </a>
      {% endif %}

      {% if v %}
      <a href="{{ v.url }}" class="whats-new-card inline-flex items-center gap-4 bg-black/40 hover:bg-black/50 text-white no-underline border-2 border-wavgen-purple hover:border-wavgen-yellow rounded-2xl shadow-lg px-6 h-40 min-w-[300px] transition-colors duration-200">
        <span class="inline-block w-4 h-4 rounded-full bg-wavgen-light-purple"></span>
        <span class="flex flex-col leading-tight">
          <span class="text-sm opacity-80">Video</span>
          <span class="text-lg font-semibold">{{ v.data.title or v.fileSlug }}</span>
        </span>
      </a>
      {% endif %}

      {% if d %}
      <a href="{{ d.url }}" class="whats-new-card inline-flex items-center gap-4 bg-black/30 hover:bg-black/40 text-white no-underline border-2 border-wavgen-purple hover:border-wavgen-yellow rounded-2xl shadow-lg px-6 h-40 min-w-[300px] transition-colors duration-200">
        <span class="inline-block w-4 h-4 rounded-full bg-white"></span>
        <span class="flex flex-col leading-tight">
          <span class="text-sm opacity-80">Data</span>
          <span class="text-lg font-semibold">{{ d.data.title or d.fileSlug }}</span>
        </span>
      </a>
      {% endif %}
    </div>

    <!-- Latest tracks (Bandcamp) + Latest videos (YouTube), refreshed monthly -->
    <div class="mt-12 grid md:grid-cols-2 gap-10">
      <div>
        <div class="flex items-baseline justify-between mb-4">
          <h4 class="text-2xl font-semibold">Latest tracks</h4>
          <a href="/music/" class="text-sm text-wavgen-yellow underline hover:text-white">See all Music →</a>
        </div>
        {% if latestTracks.items and latestTracks.items.length > 0 %}
          <div class="space-y-4">
            {% for item in latestTracks.items %}
              <div class="bg-black/30 border border-white/10 rounded-lg overflow-hidden">
                <iframe
                  loading="lazy"
                  style="border:0; width:100%; height:470px;"
                  src="{{ item.embed_url }}"
                  seamless
                  title="{{ item.title }} on Bandcamp">
                </iframe>
                <a class="block px-3 py-2 text-sm text-wavgen-yellow hover:text-white underline" href="{{ item.page_url }}" target="_blank" rel="noopener">{{ item.title }} →</a>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="text-gray-400">No tracks yet.</p>
        {% endif %}
      </div>
      <div>
        <div class="flex items-baseline justify-between mb-4">
          <h4 class="text-2xl font-semibold">Latest videos</h4>
          <a href="/video/" class="text-sm text-wavgen-yellow underline hover:text-white">See all Videos →</a>
        </div>
        {% if latestVideos.items and latestVideos.items.length > 0 %}
          <div class="space-y-4">
            {% for item in latestVideos.items %}
              <div class="bg-black/30 border border-white/10 rounded-lg overflow-hidden">
                <div class="relative" style="padding-bottom:56.25%;">
                  <iframe
                    loading="lazy"
                    class="absolute inset-0 w-full h-full"
                    src="{{ item.embed_url }}"
                    title="{{ item.title }}"
                    frameborder="0"
                    allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen></iframe>
                </div>
                <a class="block px-3 py-2 text-sm text-wavgen-yellow hover:text-white underline" href="{{ item.page_url }}" target="_blank" rel="noopener">{{ item.title }} →</a>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="text-gray-400">No videos yet.</p>
        {% endif %}
      </div>
    </div>
    <div class="h-px bg-white/10 mt-12"></div>
  </div>
  </section>

