<!-- Hero Section -->
{# 
  HERO SECTION WITH DUAL BACKGROUND SLIDESHOW SYSTEM
  
  This section implements a sophisticated dual slideshow system:
  1. Full-section background slideshow covering the entire hero area
  2. Individual hero card background slideshow behind the text content
  
  The dual system creates visual depth and interest while maintaining excellent readability.
  Technical implementation uses GSAP animations with staggered timing for visual variety.
#}
{# 
  HERO SECTION - 2x2 GRID LAYOUT
  
  Layout:
  ┌─────────────────┬─────────────────┐
  │  Hello Section  │  Image Gallery  │
  │   (Top Left)    │   (Top Right)   │
  ├─────────────────┼─────────────────┤
  │   What's New    │ Image Carousel  │
  │  (Bottom Left)  │ (Bottom Right)  │
  └─────────────────┴─────────────────┘
#}
<section class="relative bg-gradient-to-br from-gray-900 via-wavgen-dark-purple to-wavgen-purple min-h-screen">
    <!-- Background Slideshow -->
    <div class="hero-section-bg-slideshow absolute inset-0">
        {%- for img in collections.homeImages %}
          <img src="{{ img.url }}" alt="{{ img.fileSlug }}" loading="lazy" decoding="async" class="hero-section-bg-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-1000" style="opacity: {% if loop.first %}0.3{% else %}0{% endif %};">
        {%- endfor %}
    </div>
    <div class="absolute inset-0 bg-black opacity-20"></div>

    <!-- 2x2 Grid Container: Reduced 54/36 split (10% smaller) -->
    <div class="relative z-10 h-screen grid grid-cols-1 lg:grid-cols-2 gap-3 p-4 pt-2 pb-4" style="grid-template-rows: 54% 36%;">
        
        <!-- TOP LEFT: Hello Section -->
        <div class="relative animate-fade-in overflow-hidden">
            <!-- Background slideshow behind Hello text -->
            <div class="hero-bg-slideshow absolute inset-0 rounded-lg overflow-hidden pointer-events-none">
                {%- for img in collections.homeImages %}
                  <img src="{{ img.url }}" alt="{{ img.fileSlug }}" loading="lazy" decoding="async" class="hero-bg-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-1000" style="opacity: {% if loop.first %}0.1{% else %}0{% endif %};">
                {%- endfor %}
                {# Placeholder will be injected here by JS if no images #}
            </div>
            <div class="relative z-10 h-full bg-black/40 rounded-lg p-4 shadow-xl border border-white/10 flex flex-col justify-start pt-6">
                <h1 class="hero-text text-2xl lg:text-4xl mb-2">
                    Hello, I'm <span class="text-wavgen-yellow">Rob McDonald</span>
                </h1>
                <p class="subtitle-text text-sm lg:text-base mb-3">
                    Creative technologist exploring the intersection of music, visual art, and emerging technology
                </p>
                <div class="space-y-1 text-sm lg:text-base text-gray-300 mb-4">
                    <p>📍 Based in Toronto, Ontario, Canada</p>
                    <p>🎵 Electronic music producer and sound designer</p>
                    <p>🎨 Visual artist working with TouchDesigner and real-time graphics</p>
                    <p>💻 Developer exploring AI, quantum computing, and immersive experiences</p>
                </div>
                <div class="flex flex-wrap gap-2 items-center">
                    <a id="hero-cta" href="#portfolio" class="control-btn bg-wavgen-yellow text-black px-4 py-1.5 rounded-lg font-semibold text-sm hover:bg-yellow-400 transition-colors duration-300">
                        Explore My Work
                    </a>
                    <a href="#about" class="control-btn border-2 border-wavgen-yellow text-wavgen-yellow px-4 py-1.5 rounded-lg font-semibold text-sm hover:bg-wavgen-yellow hover:text-black transition-all duration-300">
                        Learn More
                    </a>
                    <button id="cmdk-hint" class="control-btn text-xs px-2 py-1 rounded bg-black/30 text-white hover:bg-black/40">Ctrl+K</button>
                </div>
            </div>
        </div>

        <!-- TOP RIGHT: Image Gallery Slideshow - Uses images from all sections -->
        <div class="hidden lg:block overflow-hidden">
          <div class="hero-slideshow relative w-full h-full rounded-lg shadow-xl border-2 border-wavgen-purple hover:border-wavgen-yellow transition-colors overflow-hidden cursor-pointer bg-wavgen-dark-purple">
            {# Home images #}
            {%- for img in collections.homeImages %}
              <img src="{{ img.url }}" alt="{{ img.fileSlug }}" loading="lazy" decoding="async" class="hero-slide gallery-img absolute inset-0 w-full h-full object-contain transition-opacity duration-1000" style="opacity: {% if loop.first %}1{% else %}0{% endif %};">
            {%- endfor %}
            {# Data section images #}
            {%- for img in collections.codingImages %}
              <img src="{{ img.url }}" alt="{{ img.fileSlug }}" loading="lazy" decoding="async" class="hero-slide gallery-img absolute inset-0 w-full h-full object-contain transition-opacity duration-1000" style="opacity: 0;">
            {%- endfor %}
            {%- for img in collections.genaiImages %}
              <img src="{{ img.url }}" alt="{{ img.fileSlug }}" loading="lazy" decoding="async" class="hero-slide gallery-img absolute inset-0 w-full h-full object-contain transition-opacity duration-1000" style="opacity: 0;">
            {%- endfor %}
            {%- for img in collections.webdevImages %}
              <img src="{{ img.url }}" alt="{{ img.fileSlug }}" loading="lazy" decoding="async" class="hero-slide gallery-img absolute inset-0 w-full h-full object-contain transition-opacity duration-1000" style="opacity: 0;">
            {%- endfor %}
            {# Art section images #}
            {%- for img in collections.paintingImages %}
              <img src="{{ img.url }}" alt="{{ img.fileSlug }}" loading="lazy" decoding="async" class="hero-slide gallery-img absolute inset-0 w-full h-full object-contain transition-opacity duration-1000" style="opacity: 0;">
            {%- endfor %}
            {# Ken Burns effect and transitions handled by JS #}
          </div>
        </div>

        <!-- BOTTOM LEFT: What's New -->
        <div id="whats-new" class="rounded-lg border-2 border-wavgen-purple hover:border-wavgen-yellow transition-colors bg-wavgen-dark-purple/80 overflow-hidden flex flex-col">
            <div class="w-full border-b border-wavgen-purple/40 bg-black/30 px-2 py-1 flex-shrink-0">
              <h3 class="text-wavgen-yellow font-bold text-sm">What's new</h3>
            </div>
            <div class="relative flex-1 min-h-0 py-1">
              <div class="whats-new-track absolute inset-0 flex items-stretch gap-2 px-2 will-change-transform"></div>
            </div>
            {# Server-side fallback #}
            <div class="sr-only">
              {% if collections.music %}{% for item in collections.music | reverse | slice(0,2) %}<a href="{{ item.url }}">Music: {{ item.data.title or item.fileSlug }}</a>{% endfor %}{% endif %}
              {% if collections.video %}{% for item in collections.video | reverse | slice(0,2) %}<a href="{{ item.url }}">Video: {{ item.data.title or item.fileSlug }}</a>{% endfor %}{% endif %}
              {% if collections.data %}{% for item in collections.data | reverse | slice(0,2) %}<a href="{{ item.url }}">Data: {{ item.data.title or item.fileSlug }}</a>{% endfor %}{% endif %}
            </div>
        </div>

        <!-- BOTTOM RIGHT: Gallery - Multiple scrolling rows (4 for homepage) -->
        <div class="hidden lg:block rounded-lg border-2 border-wavgen-purple hover:border-wavgen-yellow transition-colors bg-wavgen-dark-purple/80 overflow-hidden flex flex-col">
          <div class="w-full border-b border-wavgen-purple/40 bg-black/30 px-2 py-1 flex-shrink-0">
            <h3 class="text-wavgen-yellow font-bold text-sm">Gallery</h3>
          </div>
          <div class="gallery-rows flex-1 flex flex-col justify-evenly gap-1 p-1 overflow-hidden" data-rows="5"></div>
        </div>
    </div>
</section>

<!-- GitHub Repo Constellation -->
<section id="github-constellation" style="height: calc(100vh - 64px); position: relative; display: flex; flex-direction: column; background: #050a1a;">

  {# Breadcrumb — sticky within this section, sits at 64px (below site header) #}
  <nav aria-label="Constellation navigation" style="position: sticky; top: 64px; z-index: 50; flex-shrink: 0; display: flex; align-items: center; gap: 0.4rem; padding: 0 2rem; height: 36px; background: #2c0077; border-bottom: 1px solid rgba(255,255,255,0.08); font-size: 0.75rem; white-space: nowrap; overflow: hidden;">
    <a href="/" style="color: rgba(255,255,255,0.6); text-decoration: none;">Home</a>
    <span style="color: rgba(255,255,255,0.3);">›</span>
    <span style="color: rgba(255,255,255,0.9); font-weight: 500;">GitHub Constellation</span>
    <span style="margin-left: auto; display: flex; gap: 0.5rem; align-items: center;">
      <button onclick="document.getElementById('constellation-frame').contentWindow.document.getElementById('hero')?.scrollIntoView({behavior:'smooth'})" style="background: none; border: none; color: rgba(255,255,255,0.45); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; padding: 0 0.5rem;">Galaxy</button>
      <button onclick="document.getElementById('constellation-frame').contentWindow.document.getElementById('constellation')?.scrollIntoView({behavior:'smooth'})" style="background: none; border: none; color: rgba(255,255,255,0.45); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; padding: 0 0.5rem;">Graph</button>
      <button onclick="document.getElementById('constellation-frame').contentWindow.document.getElementById('domains')?.scrollIntoView({behavior:'smooth'})" style="background: none; border: none; color: rgba(255,255,255,0.45); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; padding: 0 0.5rem;">Domains</button>
      <button onclick="document.getElementById('constellation-frame').contentWindow.document.getElementById('canonical')?.scrollIntoView({behavior:'smooth'})" style="background: none; border: none; color: rgba(255,255,255,0.45); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; padding: 0 0.5rem;">Canonical</button>
      <button onclick="document.getElementById('constellation-frame').contentWindow.document.getElementById('bridges')?.scrollIntoView({behavior:'smooth'})" style="background: none; border: none; color: rgba(255,255,255,0.45); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; padding: 0 0.5rem;">Bridges</button>
      <button onclick="document.getElementById('constellation-frame').contentWindow.document.getElementById('worldmap')?.scrollIntoView({behavior:'smooth'})" style="background: none; border: none; color: rgba(255,255,255,0.45); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; padding: 0 0.5rem;">Worlds</button>
      <a href="#recent-releases" style="color: rgba(255,255,255,0.3); font-size: 0.68rem; text-decoration: none; padding: 0 0.5rem;">↓</a>
    </span>
  </nav>

  {# World iframe — fills the remaining height (100vh - 64px site header - 36px breadcrumb) #}
  <iframe
    id="constellation-frame"
    src="/worlds/repo_constellation_world.html"
    style="display: block; width: 100%; flex: 1; border: none;"
    title="GitHub Repository Constellation"
    loading="lazy"
  ></iframe>
</section>

