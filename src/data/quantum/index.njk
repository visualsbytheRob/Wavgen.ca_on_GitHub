<style>
/* ===== RESET & BASE ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --navy: #050a1a;
  --navy2: #080f24;
  --navy3: #0d1730;
  --blue: #1a2a5e;
  --electric: #3b82f6;
  --cyan: #06b6d4;
  --purple: #8b5cf6;
  --violet: #6d28d9;
  --pink: #ec4899;
  --green: #10b981;
  --yellow: #f59e0b;
  --text: #e2e8f0;
  --text-muted: #94a3b8;
  --text-dim: #64748b;
  --card: rgba(255,255,255,0.04);
  --card-border: rgba(255,255,255,0.08);
  --glow-blue: 0 0 40px rgba(59,130,246,0.3);
  --glow-purple: 0 0 40px rgba(139,92,246,0.3);
  --glow-cyan: 0 0 40px rgba(6,182,212,0.3);
}
html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--navy);
  color: var(--text);
  line-height: 1.6;
  overflow-x: hidden;
}
/* ===== STARFIELD ===== */
#starfield {
  position: fixed; top:0; left:0; width:100%; height:100%;
  pointer-events: none; z-index: 0; overflow: hidden;
}
.star {
  position: absolute; background: white; border-radius: 50%;
  animation: twinkle var(--dur) ease-in-out infinite;
}
@keyframes twinkle {
  0%,100% { opacity: var(--min-op); transform: scale(1); }
  50% { opacity: 1; transform: scale(1.3); }
}
/* ===== NAV ===== */
nav {
  position: fixed; top:0; left:0; right:0; z-index:100;
  background: rgba(5,10,26,0.85); backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--card-border);
  padding: 0 2rem;
  display: flex; align-items: center; justify-content: space-between;
  height: 60px;
}
.nav-logo {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700; font-size: 1.1rem;
  background: linear-gradient(90deg, var(--electric), var(--cyan));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  display: flex; align-items: center; gap: 0.5rem;
}
.nav-links { display: flex; gap: 1.5rem; list-style: none; }
.nav-links a {
  color: var(--text-muted); text-decoration: none; font-size: 0.85rem;
  font-weight: 500; transition: color 0.2s;
}
.nav-links a:hover { color: var(--cyan); }
/* ===== SECTIONS ===== */
section { position: relative; z-index: 1; }
.container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
/* ===== HERO ===== */
#hero {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  padding: 80px 1.5rem 60px;
  text-align: center;
}
.hero-inner { max-width: 800px; }
.hero-badge {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.3);
  border-radius: 100px; padding: 0.35rem 1rem; margin-bottom: 2rem;
  font-size: 0.8rem; font-weight: 600; color: var(--electric);
  letter-spacing: 0.05em; text-transform: uppercase;
}
.hero-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(2.8rem, 7vw, 5rem);
  font-weight: 700; line-height: 1.1; margin-bottom: 1.5rem;
}
.hero-title span {
  background: linear-gradient(135deg, var(--electric) 0%, var(--purple) 50%, var(--cyan) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.hero-sub {
  font-size: 1.15rem; color: var(--text-muted); margin-bottom: 3rem;
  max-width: 600px; margin-left: auto; margin-right: auto;
}
/* Spinning Coin Animation */
.coin-demo {
  display: flex; align-items: center; justify-content: center;
  gap: 4rem; flex-wrap: wrap; margin: 3rem 0;
}
.coin-wrapper { text-align: center; }
.coin-label {
  font-size: 0.8rem; font-weight: 600; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--text-muted); margin-top: 1rem;
}
/* Classical bit */
.coin-classical {
  width: 80px; height: 80px; border-radius: 50%;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  border: 3px solid #f59e0b;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem; font-weight: 800; color: #1a0a00;
  box-shadow: 0 0 20px rgba(245,158,11,0.4);
  position: relative;
}
.bit-label {
  position: absolute; bottom: -30px; left: 50%; transform: translateX(-50%);
  font-size: 0.85rem; font-weight: 700; color: var(--yellow);
  white-space: nowrap;
}
/* Spinning qubit coin */
@keyframes coinSpin {
  0% { transform: perspective(200px) rotateY(0deg); }
  100% { transform: perspective(200px) rotateY(360deg); }
}
.coin-qubit {
  width: 80px; height: 80px; border-radius: 50%;
  background: linear-gradient(135deg, var(--electric), var(--purple));
  border: 3px solid var(--cyan);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem; font-weight: 800; color: white;
  box-shadow: 0 0 30px rgba(139,92,246,0.6);
  animation: coinSpin 1.5s linear infinite;
}
.vs-divider {
  font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--text-dim);
}
.hero-scroll {
  display: flex; align-items: center; justify-content: center;
  gap: 0.5rem; color: var(--text-dim); font-size: 0.85rem;
  animation: bounce 2s ease infinite;
}
@keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(6px)} }
/* ===== SECTION HEADERS ===== */
.section-header { text-align: center; margin-bottom: 3.5rem; }
.section-tag {
  display: inline-block;
  font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--cyan); margin-bottom: 0.75rem;
}
.section-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 700;
  line-height: 1.2; margin-bottom: 0.75rem;
}
.section-desc { color: var(--text-muted); font-size: 1rem; max-width: 540px; margin: 0 auto; }
/* ===== CONCEPTS GRID ===== */
#concepts { padding: 100px 0; }
.concepts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 1.5rem;
}
.concept-card {
  background: var(--card); border: 1px solid var(--card-border);
  border-radius: 20px; padding: 2rem; overflow: hidden;
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  position: relative;
}
.concept-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--card-accent, linear-gradient(90deg, var(--electric), var(--cyan)));
  border-radius: 20px 20px 0 0;
}
.concept-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--glow-blue);
  border-color: rgba(59,130,246,0.3);
}
.concept-visual {
  height: 140px; display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.5rem;
}
.concept-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem;
  color: white;
}
.concept-desc { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1rem; line-height: 1.7; }
.analogy-box {
  background: rgba(255,255,255,0.04); border-left: 3px solid var(--cyan);
  border-radius: 0 8px 8px 0; padding: 0.75rem 1rem;
  font-size: 0.82rem; color: var(--text-muted);
}
.analogy-box strong { color: var(--cyan); }

/* ===== INTERACTIVE DEMO ===== */
#demo { padding: 100px 0; background: linear-gradient(180deg, transparent, rgba(59,130,246,0.03), transparent); }
.demo-card {
  background: var(--card); border: 1px solid var(--card-border);
  border-radius: 24px; padding: 3rem; max-width: 700px; margin: 0 auto;
  box-shadow: var(--glow-blue);
}
.demo-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.4rem; font-weight: 700; margin-bottom: 0.5rem;
}
.demo-subtitle { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 2rem; }
.qubit-display {
  display: flex; align-items: center; justify-content: center;
  gap: 3rem; flex-wrap: wrap; margin: 2rem 0;
}
.bloch-container { position: relative; width: 160px; height: 160px; }
.bloch-svg { width: 100%; height: 100%; }
.state-display { flex: 1; min-width: 200px; }
.state-label {
  font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--text-dim); margin-bottom: 0.5rem;
}
.state-formula {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1.1rem; color: var(--cyan); margin-bottom: 1.5rem;
  min-height: 28px;
}
.prob-row { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
.prob-header { display: flex; justify-content: space-between; margin-bottom: 4px; }
.prob-name { font-size: 0.8rem; font-weight: 600; font-family: 'JetBrains Mono', monospace; }
.prob-pct { font-size: 0.8rem; color: var(--text-muted); }
.prob-bar { height: 10px; background: rgba(255,255,255,0.06); border-radius: 5px; overflow: hidden; }
.prob-fill-0 { height: 100%; border-radius: 5px; background: linear-gradient(90deg, var(--electric), var(--cyan)); transition: width 0.6s cubic-bezier(0.34,1.56,0.64,1); }
.prob-fill-1 { height: 100%; border-radius: 5px; background: linear-gradient(90deg, var(--purple), var(--pink)); transition: width 0.6s cubic-bezier(0.34,1.56,0.64,1); }
.demo-buttons { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn {
  padding: 0.65rem 1.5rem; border-radius: 10px; border: none;
  font-size: 0.9rem; font-weight: 600; cursor: pointer;
  transition: all 0.2s; font-family: 'Inter', sans-serif;
  display: inline-flex; align-items: center; gap: 0.5rem;
}
.btn-primary {
  background: linear-gradient(135deg, var(--electric), var(--violet));
  color: white; box-shadow: 0 4px 20px rgba(59,130,246,0.4);
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 30px rgba(59,130,246,0.5); }
.btn-measure {
  background: rgba(139,92,246,0.15); border: 1px solid rgba(139,92,246,0.4);
  color: var(--purple);
}
.btn-measure:hover { background: rgba(139,92,246,0.25); transform: translateY(-2px); }
.btn-reset {
  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
  color: var(--text-muted);
}
.btn-reset:hover { background: rgba(255,255,255,0.1); color: var(--text); }
.result-display {
  margin-top: 1.5rem; padding: 1rem 1.5rem;
  background: rgba(255,255,255,0.04); border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.08);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.9rem; min-height: 64px;
  display: flex; align-items: center; gap: 1rem;
  transition: all 0.3s;
}
.result-icon { font-size: 1.4rem; flex-shrink: 0; }
.result-text { color: var(--text-muted); font-size: 0.82rem; font-family: 'Inter', sans-serif; line-height: 1.5; }
.result-value { font-weight: 700; margin-bottom: 2px; }

/* ===== RESOURCES ===== */
#resources { padding: 100px 0; }
.tabs-header {
  display: flex; gap: 0.5rem; flex-wrap: wrap;
  justify-content: center; margin-bottom: 2.5rem;
}
.tab-btn {
  padding: 0.6rem 1.5rem; border-radius: 100px;
  border: 1px solid var(--card-border);
  background: transparent; color: var(--text-muted);
  font-size: 0.88rem; font-weight: 600; cursor: pointer;
  transition: all 0.2s; font-family: 'Inter', sans-serif;
}
.tab-btn.active, .tab-btn:hover {
  background: rgba(59,130,246,0.15); border-color: rgba(59,130,246,0.4);
  color: var(--electric);
}
.tab-panel { display: none; }
.tab-panel.active { display: block; }
.resource-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}
.resource-card {
  background: var(--card); border: 1px solid var(--card-border);
  border-radius: 16px; padding: 1.5rem;
  transition: transform 0.2s, border-color 0.2s;
  text-decoration: none; display: block; color: inherit;
}
.resource-card:hover {
  transform: translateY(-3px);
  border-color: rgba(59,130,246,0.3);
}
.resource-icon {
  width: 42px; height: 42px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.3rem; margin-bottom: 1rem;
}
.resource-name { font-weight: 700; font-size: 0.95rem; margin-bottom: 0.3rem; color: white; }
.resource-why { font-size: 0.82rem; color: var(--text-muted); line-height: 1.6; }
.resource-tag {
  display: inline-block; margin-top: 0.75rem;
  font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em;
  text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 4px;
}

/* ===== LEARNING PATH ===== */
#path { padding: 100px 0; }
.path-timeline {
  position: relative; max-width: 800px; margin: 0 auto; padding: 0 1rem;
}
.path-timeline::before {
  content: ''; position: absolute; left: 50%; top: 0; bottom: 0;
  width: 2px; background: linear-gradient(180deg, var(--electric), var(--purple), var(--cyan));
  transform: translateX(-50%);
}
.path-item {
  display: flex; align-items: flex-start; margin-bottom: 3rem;
  position: relative;
}
.path-item:nth-child(odd) { flex-direction: row; }
.path-item:nth-child(even) { flex-direction: row-reverse; }
.path-dot {
  position: absolute; left: 50%; top: 1.2rem;
  width: 14px; height: 14px; border-radius: 50%;
  background: var(--dot-color, var(--electric));
  border: 3px solid var(--navy);
  transform: translateX(-50%);
  box-shadow: 0 0 12px var(--dot-color, var(--electric));
  z-index: 2;
}
.path-content {
  width: 44%; padding: 1.5rem;
  background: var(--card); border: 1px solid var(--card-border);
  border-radius: 16px;
}
.path-item:nth-child(odd) .path-content { margin-right: 6%; }
.path-item:nth-child(even) .path-content { margin-left: 6%; }
.path-stage {
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; margin-bottom: 0.5rem;
}
.path-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.05rem; font-weight: 700; margin-bottom: 0.75rem;
}
.path-items-list { list-style: none; }
.path-items-list li {
  font-size: 0.83rem; color: var(--text-muted); padding: 0.3rem 0;
  display: flex; align-items: flex-start; gap: 0.5rem;
}
.path-items-list li::before {
  content: '▸'; color: var(--cyan); font-size: 0.7rem; flex-shrink: 0; margin-top: 3px;
}

/* ===== CHEAT SHEET ===== */
#cheatsheet { padding: 100px 0; background: linear-gradient(180deg, transparent, rgba(139,92,246,0.04), transparent); }
.cheat-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1.25rem;
}
.cheat-card {
  background: var(--card); border: 1px solid var(--card-border);
  border-radius: 16px; padding: 1.5rem; transition: all 0.2s;
}
.cheat-card:hover { border-color: rgba(139,92,246,0.4); transform: translateY(-2px); }
.cheat-term {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.9rem; font-weight: 600; color: var(--cyan); margin-bottom: 0.5rem;
}
.cheat-def { font-size: 0.82rem; color: var(--text-muted); line-height: 1.6; }
.cheat-formula {
  margin-top: 0.75rem; padding: 0.5rem 0.75rem;
  background: rgba(255,255,255,0.04); border-radius: 8px;
  font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
  color: var(--yellow);
}

/* ===== RESEARCH MILESTONES ===== */
#research-milestones { padding: 100px 0; background: linear-gradient(180deg, transparent, rgba(59,130,246,0.04), transparent); }
.milestone-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
.milestone-card {
  background: var(--card); border: 1px solid var(--card-border);
  border-radius: 20px; padding: 1.75rem; position: relative; overflow: hidden;
  transition: transform 0.3s, border-color 0.3s;
}
.milestone-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--ms-accent, linear-gradient(90deg, var(--electric), var(--cyan)));
  border-radius: 20px 20px 0 0;
}
.milestone-card:hover { transform: translateY(-4px); border-color: rgba(59,130,246,0.3); }
.milestone-year {
  font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 700;
  color: var(--text-dim); letter-spacing: 0.1em; margin-bottom: 0.4rem;
}
.milestone-title {
  font-family: 'Space Grotesk', sans-serif; font-size: 1.1rem; font-weight: 700;
  color: white; margin-bottom: 0.35rem;
}
.milestone-author { font-size: 0.75rem; color: var(--cyan); font-weight: 600; margin-bottom: 0.75rem; }
.milestone-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin-bottom: 0.9rem; }
.milestone-impact {
  background: rgba(255,255,255,0.04); border-left: 3px solid var(--cyan);
  border-radius: 0 8px 8px 0; padding: 0.6rem 0.9rem;
  font-size: 0.8rem; color: var(--text-muted); line-height: 1.5;
}
.milestone-impact strong { color: var(--text); }
.hw-race { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 1rem; margin-top: 3rem; }
.hw-card {
  background: var(--card); border: 1px solid var(--card-border); border-radius: 16px;
  padding: 1.4rem; text-align: center; transition: border-color 0.2s;
}
.hw-card:hover { border-color: rgba(6,182,212,0.4); }
.hw-logo { font-size: 2rem; margin-bottom: 0.5rem; }
.hw-company { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 1rem; margin-bottom: 0.5rem; }
.hw-stat { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--cyan); margin-bottom: 0.3rem; }
.hw-desc { font-size: 0.78rem; color: var(--text-muted); line-height: 1.5; }
/* ===== PRIMARY KEY TERMS ===== */
#primary-key-terms { padding: 100px 0; }
.pkt-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; margin-top: 2.5rem; }
.pkt-card {
  background: var(--card); border: 1px solid var(--card-border);
  border-radius: 14px; padding: 1.4rem 1.6rem; transition: border-color 0.25s, transform 0.25s; position: relative;
}
.pkt-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: var(--pkt-bar, linear-gradient(90deg, var(--electric), var(--purple)));
}
.pkt-card:hover { border-color: rgba(139,92,246,0.4); transform: translateY(-2px); }
.pkt-term { font-family: 'Space Grotesk', sans-serif; font-size: 1rem; font-weight: 700; color: white; margin-bottom: 0.3rem; }
.pkt-source { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--purple); margin-bottom: 0.6rem; display: block; }
.pkt-def { font-size: 0.875rem; color: var(--text-muted); line-height: 1.55; }
.pkt-formula { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--electric); background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2); border-radius: 6px; padding: 0.3rem 0.6rem; display: inline-block; margin-top: 0.65rem; }
/* ===== EXPERT QUIZ ===== */
#expert-quiz { padding: 100px 0; background: linear-gradient(180deg, transparent, rgba(139,92,246,0.04), transparent); }
/* ===== GLOW ORBS ===== */
.orb {
  position: fixed; border-radius: 50%; filter: blur(80px);
  pointer-events: none; z-index: 0;
}
.orb-1 {
  width: 500px; height: 500px; background: rgba(59,130,246,0.08);
  top: -100px; left: -100px;
  animation: orbDrift1 20s ease-in-out infinite;
}
.orb-2 {
  width: 400px; height: 400px; background: rgba(139,92,246,0.08);
  bottom: 20%; right: -100px;
  animation: orbDrift2 25s ease-in-out infinite;
}
@keyframes orbDrift1 { 0%,100%{transform:translate(0,0)} 33%{transform:translate(80px,60px)} 66%{transform:translate(-40px,120px)} }
@keyframes orbDrift2 { 0%,100%{transform:translate(0,0)} 33%{transform:translate(-60px,-80px)} 66%{transform:translate(40px,-40px)} }

/* ===== FOOTER ===== */
footer {
  padding: 3rem 1.5rem; text-align: center;
  border-top: 1px solid var(--card-border);
  color: var(--text-dim); font-size: 0.85rem; position: relative; z-index: 1;
}
footer a { color: var(--electric); text-decoration: none; }

/* ===== CURRICULUM SECTION ===== */
#curriculum { padding: 100px 0; background: linear-gradient(180deg, transparent, rgba(6,182,212,0.03), transparent); }
.module-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 2rem; margin-bottom: 3rem; }
.module-card {
  background: var(--card); border: 1px solid var(--card-border);
  border-radius: 20px; padding: 2rem; position: relative; overflow: hidden;
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
}
.module-card:hover { transform: translateY(-4px); border-color: rgba(59,130,246,0.25); }
.module-num {
  font-family: 'Space Grotesk', sans-serif; font-size: 5rem; font-weight: 800; line-height: 1;
  opacity: 0.06; position: absolute; top: 0.5rem; right: 1rem; pointer-events: none;
}
.module-badge {
  display: inline-block; padding: 0.25rem 0.75rem; border-radius: 100px;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase; margin-bottom: 1rem;
}
.module-title { font-family: 'Space Grotesk', sans-serif; font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; line-height: 1.3; }
.module-topics { list-style: none; margin-bottom: 1.25rem; }
.module-topics li {
  font-size: 0.82rem; color: var(--text-muted); padding: 0.32rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  display: flex; align-items: flex-start; gap: 0.5rem;
}
.module-topics li::before { content: '▸'; flex-shrink: 0; margin-top: 3px; font-size: 0.68rem; }
.module-highlight { background: rgba(255,255,255,0.04); border-radius: 10px; padding: 0.8rem 1rem; font-size: 0.8rem; color: var(--text-muted); line-height: 1.6; }
.mh-label { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 0.35rem; display: block; }
/* 6-Step Process */
.process-flow { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; justify-content: center; margin: 2.5rem 0; }
.proc-step {
  background: var(--card); border: 1px solid var(--card-border);
  border-radius: 12px; padding: 0.8rem 0.9rem; text-align: center;
  flex: 1; min-width: 100px; transition: border-color 0.2s, transform 0.2s;
}
.proc-step:hover { border-color: rgba(59,130,246,0.35); transform: translateY(-2px); }
.proc-num {
  width: 22px; height: 22px; border-radius: 50%;
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 0.65rem; font-weight: 700; margin-bottom: 0.4rem;
}
.proc-name { font-size: 0.78rem; font-weight: 700; }
.proc-sub { font-size: 0.67rem; color: var(--text-dim); margin-top: 0.2rem; line-height: 1.3; }
.proc-arrow { color: var(--text-dim); font-size: 0.9rem; flex-shrink: 0; }
/* ===== COMPUTATIONAL MODELS ===== */
#models { padding: 100px 0; }
.models-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
.model-card {
  background: var(--card); border: 1px solid var(--card-border);
  border-radius: 20px; padding: 1.75rem; transition: transform 0.2s, border-color 0.2s;
  position: relative; overflow: hidden;
}
.model-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: var(--model-accent, linear-gradient(90deg, var(--electric), var(--cyan)));
}
.model-card:hover { transform: translateY(-3px); border-color: rgba(59,130,246,0.3); }
.model-icon { font-size: 2rem; margin-bottom: 0.75rem; display: block; }
.model-name { font-family: 'Space Grotesk', sans-serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 0.2rem; }
.model-abbr { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: var(--text-dim); display: block; margin-bottom: 0.75rem; }
.model-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 1rem; }
.model-analogy { background: rgba(255,255,255,0.04); border-left: 3px solid var(--cyan); border-radius: 0 8px 8px 0; padding: 0.65rem 0.9rem; font-size: 0.79rem; color: var(--text-muted); }
.model-analogy strong { color: var(--cyan); }
.model-use { margin-top: 0.75rem; font-size: 0.75rem; color: var(--text-dim); }
.model-use span { color: var(--yellow); font-weight: 600; }
/* ===== LAB CASES ===== */
#labcases { padding: 100px 0; background: linear-gradient(180deg, transparent, rgba(139,92,246,0.04), transparent); }
.lab-tabs { display: flex; gap: 0.5rem; justify-content: center; margin-bottom: 2.5rem; flex-wrap: wrap; }
.lab-tab {
  padding: 0.6rem 1.5rem; border-radius: 100px; border: 1px solid var(--card-border);
  background: transparent; color: var(--text-muted);
  font-size: 0.88rem; font-weight: 600; cursor: pointer;
  transition: all 0.2s; font-family: 'Inter', sans-serif;
}
.lab-tab.active, .lab-tab:hover { background: rgba(139,92,246,0.15); border-color: rgba(139,92,246,0.4); color: var(--purple); }
.lab-panel { display: none; }
.lab-panel.active { display: block; }
.lab-case { background: var(--card); border: 1px solid var(--card-border); border-radius: 24px; padding: 2.5rem; max-width: 820px; margin: 0 auto; }
.lab-header { display: flex; align-items: flex-start; gap: 1.25rem; margin-bottom: 2rem; }
.lab-badge { width: 52px; height: 52px; border-radius: 14px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
.lab-org { font-family: 'Space Grotesk', sans-serif; font-size: 1.25rem; font-weight: 700; margin-bottom: 0.2rem; }
.lab-org-detail { font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; }
.lab-exs { display: flex; flex-direction: column; gap: 1rem; }
.lab-ex { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; padding: 1.25rem 1.5rem; transition: border-color 0.2s; }
.lab-ex:hover { border-color: rgba(139,92,246,0.25); }
.lab-ex-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem; gap: 1rem; }
.lab-ex-num { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: var(--text-dim); white-space: nowrap; }
.lab-technique { font-size: 0.7rem; font-weight: 700; padding: 0.18rem 0.6rem; border-radius: 100px; letter-spacing: 0.04em; white-space: nowrap; }
.lab-problem { font-size: 0.87rem; color: var(--text-muted); margin-bottom: 0.6rem; }
