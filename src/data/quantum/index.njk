<!-- CORE CONCEPTS -->
<section id="concepts">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">Core Concepts</div>
      <h2 class="section-title">The Six Big Ideas</h2>
      <p class="section-desc">Every quantum computing concept, explained visually with real-world analogies.</p>
    </div>

    <div class="concepts-grid">

      <!-- 1. Superposition -->
      <div class="concept-card" style="--card-accent: linear-gradient(90deg, #3b82f6, #06b6d4)">
        <div class="concept-visual">
          <svg width="220" height="130" viewBox="0 0 220 130">
            <defs>
              <linearGradient id="wg1" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.7"/>
                <stop offset="50%" stop-color="#8b5cf6" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="#06b6d4" stop-opacity="0.7"/>
              </linearGradient>
            </defs>
            <!-- State |0> circle -->
            <circle cx="45" cy="55" r="32" fill="rgba(59,130,246,0.12)" stroke="#3b82f6" stroke-width="2"/>
            <text x="45" y="63" text-anchor="middle" fill="#3b82f6" font-family="Georgia,serif" font-size="24" font-weight="700">0</text>
            <text x="45" y="100" text-anchor="middle" fill="rgba(59,130,246,0.7)" font-size="10" font-family="monospace">|0⟩</text>
            <!-- Plus -->
            <text x="110" y="63" text-anchor="middle" fill="#475569" font-size="22">+</text>
            <!-- State |1> circle -->
            <circle cx="175" cy="55" r="32" fill="rgba(139,92,246,0.12)" stroke="#8b5cf6" stroke-width="2"/>
            <text x="175" y="63" text-anchor="middle" fill="#8b5cf6" font-family="Georgia,serif" font-size="24" font-weight="700">1</text>
            <text x="175" y="100" text-anchor="middle" fill="rgba(139,92,246,0.7)" font-size="10" font-family="monospace">|1⟩</text>
            <!-- Animated wave path -->
            <path id="superWave" fill="none" stroke="url(#wg1)" stroke-width="2.5" stroke-dasharray="160" stroke-dashoffset="160">
              <animate attributeName="stroke-dashoffset" from="160" to="0" dur="1.5s" fill="freeze" begin="0.5s"/>
            </path>
            <text x="110" y="122" text-anchor="middle" fill="#64748b" font-size="9" font-style="italic">Both states simultaneously</text>
          </svg>
        </div>
        <div class="concept-title">⟨ψ⟩ Superposition</div>
        <p class="concept-desc">A qubit can exist in a combination of |0⟩ and |1⟩ at the same time — not one or the other, but literally both, with different probabilities. Measuring it forces it to "choose."</p>
        <div class="analogy-box"><strong>Analogy:</strong> A coin spinning in the air is neither heads nor tails — it's both. The moment it lands (is measured), it picks one.</div>
      </div>

      <!-- 2. Entanglement -->
      <div class="concept-card" style="--card-accent: linear-gradient(90deg, #ec4899, #8b5cf6)">
        <div class="concept-visual">
          <svg width="220" height="130" viewBox="0 0 220 130">
            <defs>
              <linearGradient id="entGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#3b82f6"/>
                <stop offset="100%" stop-color="#ec4899"/>
              </linearGradient>
            </defs>
            <!-- Connection line with dashes -->
            <line x1="75" y1="65" x2="145" y2="65" stroke="url(#entGrad)" stroke-width="2" stroke-dasharray="5,4"/>
            <!-- Moving spark along line -->
            <circle r="5" fill="white" opacity="0.9">
              <animateMotion dur="1.8s" repeatCount="indefinite" path="M75,65 L145,65"/>
              <animate attributeName="opacity" values="1;0" dur="1.8s" repeatCount="indefinite"/>
            </circle>
            <!-- Particle A -->
            <circle cx="50" cy="65" r="32" fill="rgba(59,130,246,0.15)" stroke="#3b82f6" stroke-width="2.5">
              <animate attributeName="r" values="32;36;32" dur="2s" repeatCount="indefinite"/>
            </circle>
            <text x="50" y="72" text-anchor="middle" fill="#3b82f6" font-size="20" font-weight="700">A</text>
            <!-- Particle B -->
            <circle cx="170" cy="65" r="32" fill="rgba(236,72,153,0.15)" stroke="#ec4899" stroke-width="2.5">
              <animate attributeName="r" values="32;36;32" dur="2s" repeatCount="indefinite" begin="1s"/>
            </circle>
            <text x="170" y="72" text-anchor="middle" fill="#ec4899" font-size="20" font-weight="700">B</text>
            <!-- Labels -->
            <text x="50" y="110" text-anchor="middle" fill="#64748b" font-size="9">Qubit A</text>
            <text x="170" y="110" text-anchor="middle" fill="#64748b" font-size="9">Qubit B</text>
            <text x="110" y="20" text-anchor="middle" fill="#94a3b8" font-size="9" font-style="italic">Instant correlation</text>
            <text x="110" y="125" text-anchor="middle" fill="#64748b" font-size="9">Measure A → B state determined</text>
          </svg>
        </div>
        <div class="concept-title">🔗 Entanglement</div>
        <p class="concept-desc">Two qubits become "entangled" — measuring one instantly determines the other, regardless of the distance between them. Einstein called it "spooky action at a distance."</p>
        <div class="analogy-box"><strong>Analogy:</strong> Two magic dice that always land on opposite numbers, no matter how far apart they are when rolled.</div>
      </div>

      <!-- 3. Interference -->
      <div class="concept-card" style="--card-accent: linear-gradient(90deg, #10b981, #06b6d4)">
        <div class="concept-visual">
          <svg width="220" height="130" viewBox="0 0 220 130">
            <text x="55" y="14" text-anchor="middle" fill="#10b981" font-size="8" font-weight="700">CONSTRUCTIVE</text>
            <text x="165" y="14" text-anchor="middle" fill="#ef4444" font-size="8" font-weight="700">DESTRUCTIVE</text>
            <!-- Divider -->
            <line x1="110" y1="18" x2="110" y2="120" stroke="#1e293b" stroke-width="1.5"/>
            <!-- Wave 1 (left, constructive) -->
            <path d="M5,65 Q18,30 32,65 Q46,100 60,65 Q74,30 88,65 Q100,87 110,75" fill="none" stroke="#3b82f6" stroke-width="2" opacity="0.7"/>
            <!-- Wave 2 (left, constructive) -->
            <path d="M5,65 Q18,30 32,65 Q46,100 60,65 Q74,30 88,65 Q100,87 110,75" fill="none" stroke="#8b5cf6" stroke-width="2" opacity="0.5" transform="translate(0,5)"/>
            <!-- Result wave (bigger) -->
            <path d="M5,65 Q18,15 32,65 Q46,115 60,65 Q74,15 88,65 Q100,85 110,75" fill="rgba(16,185,129,0.15)" stroke="#10b981" stroke-width="2.5"/>
            <!-- Wave right (destructive, cancels) -->
            <path d="M110,65 Q124,30 138,65 Q152,100 166,65 Q180,30 194,65 Q208,88 215,72" fill="none" stroke="#3b82f6" stroke-width="2" opacity="0.7"/>
            <path d="M110,65 Q124,100 138,65 Q152,30 166,65 Q180,100 194,65 Q208,42 215,58" fill="none" stroke="#ef4444" stroke-width="2" opacity="0.7"/>
            <!-- Flat result line (cancelled) -->
            <line x1="110" y1="65" x2="220" y2="65" stroke="#ef4444" stroke-width="2.5"/>
            <text x="5" y="126" fill="#64748b" font-size="8">Waves add up → bigger</text>
            <text x="115" y="126" fill="#64748b" font-size="8">Waves cancel → zero</text>
          </svg>
        </div>
        <div class="concept-title">〰 Interference</div>
        <p class="concept-desc">Quantum states can add together (constructive interference) or cancel out (destructive interference), just like waves. Algorithms use this to amplify correct answers and suppress wrong ones.</p>
        <div class="analogy-box"><strong>Analogy:</strong> Noise-canceling headphones — they create sound waves that destructively interfere with noise, canceling it out.</div>
      </div>

      <!-- 4. Quantum Gates -->
      <div class="concept-card" style="--card-accent: linear-gradient(90deg, #f59e0b, #ef4444)">
        <div class="concept-visual">
          <svg width="220" height="120" viewBox="0 0 220 120">
            <!-- Qubit wire 1 -->
            <line x1="5" y1="40" x2="215" y2="40" stroke="#1e293b" stroke-width="2"/>
            <!-- Qubit wire 2 -->
            <line x1="5" y1="85" x2="215" y2="85" stroke="#1e293b" stroke-width="2"/>
            <!-- Labels -->
            <text x="2" y="44" fill="#64748b" font-size="10" font-family="monospace">|0⟩</text>
            <text x="2" y="89" fill="#64748b" font-size="10" font-family="monospace">|0⟩</text>
            <!-- H gate -->
            <rect x="42" y="27" width="30" height="26" rx="5" fill="rgba(59,130,246,0.2)" stroke="#3b82f6" stroke-width="1.5"/>
            <text x="57" y="45" text-anchor="middle" fill="#3b82f6" font-size="14" font-weight="800" font-family="monospace">H</text>
            <!-- CNOT control dot -->
            <circle cx="115" cy="40" r="7" fill="#8b5cf6"/>
            <!-- CNOT vertical line -->
            <line x1="115" y1="47" x2="115" y2="75" stroke="#8b5cf6" stroke-width="2"/>
            <!-- CNOT target -->
            <circle cx="115" cy="85" r="12" fill="none" stroke="#8b5cf6" stroke-width="2"/>
            <line x1="103" y1="85" x2="127" y2="85" stroke="#8b5cf6" stroke-width="2"/>
            <line x1="115" y1="73" x2="115" y2="97" stroke="#8b5cf6" stroke-width="2"/>
            <!-- X gate -->
            <rect x="163" y="72" width="28" height="26" rx="5" fill="rgba(245,158,11,0.2)" stroke="#f59e0b" stroke-width="1.5"/>
            <text x="177" y="90" text-anchor="middle" fill="#f59e0b" font-size="14" font-weight="800" font-family="monospace">X</text>
            <!-- Measurement box -->
            <rect x="193" y="27" width="22" height="26" rx="4" fill="rgba(16,185,129,0.15)" stroke="#10b981" stroke-width="1.5"/>
            <text x="204" y="44" text-anchor="middle" fill="#10b981" font-size="10">M</text>
            <!-- Labels -->
            <text x="57" y="112" text-anchor="middle" fill="#475569" font-size="8">Hadamard</text>
            <text x="115" y="112" text-anchor="middle" fill="#475569" font-size="8">CNOT</text>
            <text x="177" y="112" text-anchor="middle" fill="#475569" font-size="8">Pauli-X</text>
          </svg>
        </div>
        <div class="concept-title">⊞ Quantum Gates</div>
        <p class="concept-desc">Like classical logic gates (AND, OR, NOT), quantum gates manipulate qubit states. The Hadamard gate creates superposition; CNOT creates entanglement. They're the building blocks of quantum circuits.</p>
        <div class="analogy-box"><strong>Analogy:</strong> Classical gates flip switches (0→1). Quantum gates rotate the state of a qubit on a sphere — far more nuanced.</div>
      </div>

      <!-- 5. Bloch Sphere / Qubits -->
      <div class="concept-card" style="--card-accent: linear-gradient(90deg, #8b5cf6, #ec4899)">
        <div class="concept-visual">
          <svg width="140" height="140" viewBox="-70 -70 140 140">
            <defs>
              <radialGradient id="sg" cx="40%" cy="35%" r="65%">
                <stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.3"/>
                <stop offset="100%" stop-color="#3b82f6" stop-opacity="0.08"/>
              </radialGradient>
            </defs>
            <!-- Sphere -->
            <circle cx="0" cy="0" r="55" fill="url(#sg)" stroke="rgba(139,92,246,0.35)" stroke-width="1.5"/>
            <!-- Equator -->
            <ellipse cx="0" cy="0" rx="55" ry="17" fill="none" stroke="rgba(139,92,246,0.2)" stroke-width="1" stroke-dasharray="3,3"/>
            <!-- Axes -->
            <line x1="0" y1="-62" x2="0" y2="62" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
            <line x1="-62" y1="0" x2="62" y2="0" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
            <!-- North pole |0> -->
            <circle cx="0" cy="-55" r="4.5" fill="#06b6d4"/>
            <text x="10" y="-51" fill="#06b6d4" font-size="10" font-weight="700" font-family="monospace">|0⟩</text>
            <!-- South pole |1> -->
            <circle cx="0" cy="55" r="4.5" fill="#8b5cf6"/>
            <text x="10" y="59" fill="#8b5cf6" font-size="10" font-weight="700" font-family="monospace">|1⟩</text>
            <!-- State vector rotating -->
            <line x1="0" y1="0" x2="36" y2="-42" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round">
              <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="6s" repeatCount="indefinite"/>
            </line>
            <circle cx="36" cy="-42" r="5.5" fill="#f59e0b">
              <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="6s" repeatCount="indefinite"/>
            </circle>
            <text x="0" y="70" text-anchor="middle" fill="#94a3b8" font-size="8" font-style="italic">Any point = valid qubit state</text>
          </svg>
        </div>
        <div class="concept-title">⊙ Qubits & the Bloch Sphere</div>
        <p class="concept-desc">A qubit's state can be visualized as a point on a sphere. The north pole is |0⟩, south is |1⟩, and any point on the surface is a valid superposition. Quantum gates rotate this point.</p>
        <div class="analogy-box"><strong>Analogy:</strong> A classical bit is a light switch (up/down). A qubit is a dial you can point in any 3D direction on a globe.</div>
      </div>

      <!-- 6. Quantum Advantage -->
      <div class="concept-card" style="--card-accent: linear-gradient(90deg, #10b981, #f59e0b)">
        <div class="concept-visual">
          <svg width="215" height="130" viewBox="0 0 215 130">
            <!-- Title -->
            <text x="107" y="15" text-anchor="middle" fill="#94a3b8" font-size="9" font-weight="700">OPERATIONS NEEDED TO FACTOR A LARGE NUMBER</text>
            <!-- Classical bar -->
            <text x="8" y="36" fill="#64748b" font-size="8.5" font-weight="600">Classical</text>
            <rect x="8" y="42" width="190" height="22" rx="4" fill="rgba(71,85,105,0.5)" stroke="#475569" stroke-width="1"/>
            <text x="205" y="57" text-anchor="end" fill="#94a3b8" font-size="8.5">2^2048 ops</text>
            <!-- Quantum bar -->
            <text x="8" y="86" fill="#10b981" font-size="8.5" font-weight="600">Quantum</text>
            <rect x="8" y="92" width="190" height="22" rx="4" fill="rgba(255,255,255,0.05)" stroke="#10b981" stroke-width="1"/>
            <rect x="8" y="92" width="42" height="22" rx="4" fill="rgba(16,185,129,0.45)">
              <animate attributeName="width" from="0" to="42" dur="1.5s" fill="freeze"/>
            </rect>
            <text x="205" y="107" text-anchor="end" fill="#10b981" font-size="8.5">(2048)³ ops</text>
            <!-- Speedup label -->
            <rect x="40" y="118" width="135" height="10" rx="2" fill="rgba(245,158,11,0.08)"/>
            <text x="107" y="126" text-anchor="middle" fill="#f59e0b" font-size="9" font-weight="700">⚡ Exponential Quantum Speedup</text>
          </svg>
        </div>
        <div class="concept-title">⚡ Quantum Advantage</div>
        <p class="concept-desc">For certain problems — factoring, search, molecular simulation — quantum computers need exponentially fewer operations. Shor's algorithm factors large numbers efficiently; classical computers simply can't match it.</p>
        <div class="analogy-box"><strong>Analogy:</strong> Classical search = checking every book one by one. Grover's quantum algorithm = reading all books simultaneously.</div>
      </div>

    </div>
  </div>
</section>

