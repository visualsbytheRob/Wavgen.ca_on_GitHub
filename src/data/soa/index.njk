          </linearGradient>
          <filter id="glow"><feGaussianBlur stdDeviation="3" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        </defs>
        <!-- Background panels -->
        <rect x="8" y="20" width="240" height="180" rx="14" fill="rgba(22,33,62,0.85)" stroke="rgba(245,166,35,0.25)" stroke-width="1.5"/>
