          <rect x="76" y="28" width="50" height="24" rx="5" fill="rgba(74,222,128,0.08)" stroke="rgba(74,222,128,0.35)" stroke-width="1.5"/>
          <text x="101" y="44" text-anchor="middle" fill="#9ca3c8" font-size="8.5" font-family="Inter,sans-serif">Payment Svc</text>
          <rect x="148" y="28" width="50" height="24" rx="5" fill="rgba(74,222,128,0.08)" stroke="rgba(74,222,128,0.35)" stroke-width="1.5"/>
