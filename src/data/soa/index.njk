        </svg>
        <h4>API Gateway</h4>
        <p>Single entry point that routes, authenticates, and aggregates responses. Decouples clients from internal service topology.</p>
      </div>

      <!-- Saga -->
      <div class="pattern-card">
        <span class="pattern-tag">Data Consistency</span>
        <svg viewBox="0 0 260 80">
          <rect x="4" y="28" width="50" height="24" rx="5" fill="rgba(74,222,128,0.08)" stroke="rgba(74,222,128,0.35)" stroke-width="1.5"/>
