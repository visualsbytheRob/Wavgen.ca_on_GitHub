          <rect x="196" y="8" width="60" height="20" rx="4" fill="rgba(74,222,128,0.08)" stroke="rgba(74,222,128,0.35)" stroke-width="1"/>
          <text x="226" y="22" text-anchor="middle" fill="#9ca3c8" font-size="8.5" font-family="Inter,sans-serif">Svc A</text>
          <rect x="196" y="34" width="60" height="20" rx="4" fill="rgba(74,222,128,0.08)" stroke="rgba(74,222,128,0.35)" stroke-width="1"/>
          <text x="226" y="48" text-anchor="middle" fill="#9ca3c8" font-size="8.5" font-family="Inter,sans-serif">Svc B</text>
          <rect x="196" y="60" width="60" height="20" rx="4" fill="rgba(74,222,128,0.08)" stroke="rgba(74,222,128,0.35)" stroke-width="1"/>
          <text x="226" y="74" text-anchor="middle" fill="#9ca3c8" font-size="8.5" font-family="Inter,sans-serif">Svc C</text>
