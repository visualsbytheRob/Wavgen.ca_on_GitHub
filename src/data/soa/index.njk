          <line x1="198" y1="40" x2="220" y2="40" stroke="rgba(74,222,128,0.5)" stroke-width="1.5" class="flow-line-3"/>
          <!-- compensating arrows -->
          <path d="M198 54 Q173 72 148 54" stroke="rgba(248,113,113,0.5)" stroke-width="1.5" fill="none" stroke-dasharray="4 3"/>
          <text x="173" y="74" text-anchor="middle" fill="rgba(248,113,113,0.6)" font-size="8" font-family="Inter,sans-serif">compensate on failure</text>
        </svg>
        <h4>Saga Pattern</h4>
        <p>Manages distributed transactions across services. Each step publishes an event; failures trigger compensating transactions to undo prior steps.</p>
      </div>

      <!-- CQRS -->
      <div class="pattern-card">
        <span class="pattern-tag">Data Access</span>
        <svg viewBox="0 0 260 80">
          <rect x="4" y="10" width="72" height="28" rx="5" fill="rgba(0,180,216,0.08)" stroke="rgba(0,180,216,0.35)" stroke-width="1.5"/>
