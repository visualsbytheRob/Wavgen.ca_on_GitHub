          <rect x="4" y="46" width="72" height="28" rx="5" fill="rgba(245,166,35,0.08)" stroke="rgba(245,166,35,0.35)" stroke-width="1.5"/>
          <text x="40" y="63" text-anchor="middle" fill="#9ca3c8" font-size="9" font-family="Inter,sans-serif">Read Model</text>
          <rect x="112" y="28" width="60" height="24" rx="5" fill="rgba(167,139,250,0.12)" stroke="rgba(167,139,250,0.4)" stroke-width="1.5"/>
          <text x="142" y="44" text-anchor="middle" fill="#a78bfa" font-size="9" font-family="Inter,sans-serif">Event Bus</text>
          <rect x="198" y="10" width="58" height="24" rx="5" fill="rgba(0,180,216,0.08)" stroke="rgba(0,180,216,0.3)" stroke-width="1"/>
          <text x="227" y="26" text-anchor="middle" fill="#9ca3c8" font-size="8.5" font-family="Inter,sans-serif">Write DB</text>
          <rect x="198" y="46" width="58" height="24" rx="5" fill="rgba(245,166,35,0.08)" stroke="rgba(245,166,35,0.3)" stroke-width="1"/>
          <text x="227" y="62" text-anchor="middle" fill="#9ca3c8" font-size="8.5" font-family="Inter,sans-serif">Read DB</text>
          <line x1="76" y1="24" x2="112" y2="36" stroke="rgba(0,180,216,0.4)" stroke-width="1.5" class="flow-line"/>
          <line x1="172" y1="36" x2="198" y2="22" stroke="rgba(0,180,216,0.4)" stroke-width="1.5" class="flow-line-2"/>
          <line x1="172" y1="44" x2="198" y2="58" stroke="rgba(245,166,35,0.4)" stroke-width="1.5" class="flow-line-3"/>
        </svg>
        <h4>CQRS</h4>
        <p>Command Query Responsibility Segregation — separate write and read models. Write side handles commands; read side is optimized for queries with denormalized views.</p>
      </div>

      <!-- Event Sourcing -->
      <div class="pattern-card">
        <span class="pattern-tag">Data Storage</span>
        <svg viewBox="0 0 260 80">
          <rect x="4" y="28" width="56" height="24" rx="5" fill="rgba(167,139,250,0.08)" stroke="rgba(167,139,250,0.35)" stroke-width="1.5"/>
