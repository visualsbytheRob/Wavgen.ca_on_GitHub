<style>
/* ═══════════════════════════════════════════════
   CSS VARIABLES & RESET
═══════════════════════════════════════════════ */
:root {
  --bg-dark: #1a1a2e;
  --bg-card: #16213e;
  --bg-surface: #0f3460;
  --accent-orange: #f5a623;
  --accent-amber: #e8872a;
  --accent-teal: #00b4d8;
  --accent-green: #4ade80;
  --accent-purple: #a78bfa;
  --accent-red: #f87171;
  --text-primary: #f0f4ff;
  --text-secondary: #9ca3c8;
  --text-muted: #6b7280;
  --border: rgba(245,166,35,0.2);
  --border-subtle: rgba(255,255,255,0.07);
  --shadow: 0 4px 24px rgba(0,0,0,0.4);
  --shadow-lg: 0 8px 48px rgba(0,0,0,0.6);
  --radius: 12px;
  --radius-lg: 20px;
  --font-sans: 'Inter', 'Segoe UI', system-ui, sans-serif;
  --font-mono: 'Fira Code', 'Cascadia Code', monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--font-sans); background: var(--bg-dark); color: var(--text-primary); line-height: 1.6; overflow-x: hidden; }

/* TYPOGRAPHY */
h1, h2, h3, h4 { line-height: 1.2; font-weight: 700; }
h1 { font-size: clamp(2.2rem, 5vw, 3.8rem); }
h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); }
h3 { font-size: 1.25rem; }
p { color: var(--text-secondary); }
.section-label { text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.75rem; color: var(--accent-orange); font-weight: 600; margin-bottom: 0.5rem; }
.section-title { margin-bottom: 0.75rem; }
.section-subtitle { color: var(--text-secondary); font-size: 1.05rem; max-width: 600px; margin: 0 auto 3rem; }

/* LAYOUT */
.container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
section { padding: 5rem 0; }
section:nth-child(even) { background: rgba(15,52,96,0.18); }
.text-center { text-align: center; }

/* NAV */
nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(26,26,46,0.94); backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border); padding: 0.8rem 0;
}
.nav-inner {
  max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;
  display: flex; align-items: center; gap: 0.35rem; overflow-x: auto; scrollbar-width: none;
}
.nav-inner::-webkit-scrollbar { display: none; }
.nav-logo { font-weight: 800; color: var(--accent-orange); white-space: nowrap; margin-right: 1rem; font-size: 0.9rem; }
.nav-link {
  color: var(--text-secondary); text-decoration: none; font-size: 0.8rem;
  padding: 0.3rem 0.7rem; border-radius: 6px; white-space: nowrap; transition: all 0.2s;
}
.nav-link:hover { color: var(--accent-orange); background: rgba(245,166,35,0.1); }

/* BUTTONS */
.btn-primary {
  background: linear-gradient(135deg, var(--accent-orange), var(--accent-amber));
  color: #1a1a2e; font-weight: 700; padding: 0.7rem 1.6rem; border-radius: 50px;
  border: none; cursor: pointer; text-decoration: none; font-size: 0.9rem;
  transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 20px rgba(245,166,35,0.35); display: inline-block;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 28px rgba(245,166,35,0.5); }
.btn-secondary {
  background: transparent; color: var(--text-primary); font-weight: 600;
  padding: 0.7rem 1.6rem; border-radius: 50px; border: 1px solid var(--border);
  cursor: pointer; text-decoration: none; font-size: 0.9rem; transition: all 0.2s; display: inline-block;
}
.btn-secondary:hover { border-color: var(--accent-orange); color: var(--accent-orange); }

/* CARDS */
.card {
  background: var(--bg-card); border: 1px solid var(--border-subtle);
  border-radius: var(--radius); padding: 1.5rem; transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
}
.card:hover { transform: translateY(-3px); border-color: var(--border); box-shadow: var(--shadow); }
.card-grid { display: grid; gap: 1.25rem; }
.card-grid-2 { grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); }
.card-grid-3 { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
.card-grid-4 { grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); }
.card-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 1rem; }
.card h3 { margin-bottom: 0.5rem; font-size: 1.1rem; }
.card p { font-size: 0.9rem; }

/* BADGE */
.badge {
  display: inline-flex; align-items: center; gap: 0.4rem;
  padding: 0.25rem 0.7rem; border-radius: 100px; font-size: 0.75rem; font-weight: 600;
}
.badge-orange { background: rgba(245,166,35,0.15); color: var(--accent-orange); border: 1px solid rgba(245,166,35,0.3); }
.badge-teal   { background: rgba(0,180,216,0.15);  color: var(--accent-teal);   border: 1px solid rgba(0,180,216,0.3); }
.badge-green  { background: rgba(74,222,128,0.15); color: var(--accent-green);  border: 1px solid rgba(74,222,128,0.3); }
.badge-purple { background: rgba(167,139,250,0.15);color: var(--accent-purple); border: 1px solid rgba(167,139,250,0.3); }
.badge-red    { background: rgba(248,113,113,0.15);color: var(--accent-red);    border: 1px solid rgba(248,113,113,0.3); }

/* TABS */
.tab-bar { display: flex; gap: 0.25rem; background: rgba(0,0,0,0.3); border-radius: 10px; padding: 0.3rem; margin-bottom: 2rem; flex-wrap: wrap; }
.tab-btn {
  flex: 1; min-width: 80px; background: transparent; border: none; color: var(--text-secondary);
  font-size: 0.85rem; font-weight: 600; padding: 0.55rem 0.9rem; border-radius: 7px;
  cursor: pointer; transition: all 0.2s; white-space: nowrap;
}
.tab-btn.active { background: linear-gradient(135deg, var(--accent-orange), var(--accent-amber)); color: #1a1a2e; }
.tab-btn:hover:not(.active) { color: var(--text-primary); background: rgba(255,255,255,0.06); }
.tab-panel { display: none; }
.tab-panel.active { display: block; animation: fadeIn 0.3s ease; }

/* TIMELINE */
.timeline { position: relative; padding: 1rem 0; }
.timeline::before {
  content: ''; position: absolute; left: 50%; transform: translateX(-50%);
  top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--accent-orange), var(--accent-teal));
}
.timeline-item { display: flex; gap: 2rem; margin-bottom: 3.5rem; position: relative; }
.timeline-item:nth-child(even) { flex-direction: row-reverse; }
.timeline-item:nth-child(even) .timeline-content { text-align: right; }
.timeline-side { flex: 1; }
.timeline-center {
  flex-shrink: 0; width: 48px; height: 48px; border-radius: 50%;
  background: var(--bg-card); border: 3px solid var(--accent-orange);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; z-index: 1; position: relative;
}
.timeline-content { background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius); padding: 1.25rem; }
.timeline-era { font-size: 0.78rem; color: var(--accent-orange); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.3rem; }
.timeline-content h3 { margin-bottom: 0.4rem; }
.timeline-content p { font-size: 0.88rem; }

/* COMPARISON TABLE */
.comp-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; overflow: hidden; border-radius: var(--radius); }
.comp-table thead th { background: rgba(245,166,35,0.12); padding: 0.9rem 1.1rem; text-align: left; font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent-orange); border-bottom: 2px solid var(--border); }
.comp-table tbody td { padding: 0.85rem 1.1rem; border-bottom: 1px solid var(--border-subtle); vertical-align: top; line-height: 1.5; }
.comp-table tbody tr:hover td { background: rgba(255,255,255,0.03); }
.comp-table tbody td:first-child { color: var(--text-primary); font-weight: 600; }
.comp-table tbody td:nth-child(2) { color: var(--accent-teal); }
.comp-table tbody td:nth-child(3) { color: var(--accent-green); }

/* CODE BLOCK */
.code-block {
  background: rgba(0,0,0,0.4); border: 1px solid var(--border-subtle);
  border-radius: var(--radius); padding: 1rem 1.25rem; font-family: var(--font-mono);
  font-size: 0.82rem; color: var(--accent-green); overflow-x: auto; line-height: 1.7;
}
.code-comment { color: var(--text-muted); }
.code-key { color: var(--accent-orange); }
.code-val { color: var(--accent-teal); }

/* VISUALIZER */
.viz-container { background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); padding: 2rem; }
.viz-svg-wrap { min-height: 280px; display: flex; align-items: center; justify-content: center; }
.viz-svg-wrap svg { width: 100%; max-width: 780px; height: auto; }

/* PATTERN GALLERY */
.pattern-card {
  background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius);
  padding: 1.5rem; transition: all 0.25s; cursor: default;
}
.pattern-card:hover { border-color: rgba(167,139,250,0.4); transform: translateY(-3px); box-shadow: 0 8px 32px rgba(167,139,250,0.15); }
.pattern-card svg { width: 100%; height: 90px; margin-bottom: 1rem; }
.pattern-tag { display: inline-block; font-size: 0.7rem; padding: 0.2rem 0.55rem; border-radius: 4px; background: rgba(167,139,250,0.12); color: var(--accent-purple); font-weight: 600; margin-bottom: 0.5rem; }
.pattern-card h4 { color: var(--text-primary); margin-bottom: 0.4rem; }
.pattern-card p { font-size: 0.83rem; }

/* ROADMAP */
.roadmap { display: flex; gap: 0; flex-wrap: nowrap; overflow-x: auto; padding-bottom: 1rem; scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
.roadmap-step {
  flex-shrink: 0; background: var(--bg-card); border: 1px solid var(--border-subtle);
  border-radius: var(--radius); padding: 1.25rem; width: 180px; position: relative;
}
.roadmap-step::after {
  content: '→'; position: absolute; right: -18px; top: 50%; transform: translateY(-50%);
  color: var(--accent-orange); font-size: 1.2rem; font-weight: 700; z-index: 1;
}
.roadmap-step:last-child::after { display: none; }
.roadmap-num { width: 28px; height: 28px; border-radius: 50%; background: linear-gradient(135deg, var(--accent-orange), var(--accent-amber)); color: #1a1a2e; font-weight: 800; font-size: 0.8rem; display: flex; align-items: center; justify-content: center; margin-bottom: 0.75rem; }
.roadmap-step h4 { font-size: 0.9rem; color: var(--text-primary); margin-bottom: 0.3rem; }
.roadmap-step p { font-size: 0.78rem; }
.roadmap-gap { flex-shrink: 0; width: 36px; }

/* CHEAT CARDS */
.cheat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 1rem; }
.cheat-card {
  background: var(--bg-card); border: 1px solid var(--border-subtle);
  border-radius: var(--radius); padding: 1.1rem; transition: all 0.2s;
}
.cheat-card:hover { border-color: var(--border); transform: translateY(-2px); }
.cheat-term { font-size: 0.78rem; font-weight: 800; color: var(--accent-orange); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.2rem; }
.cheat-card h4 { font-size: 0.95rem; color: var(--text-primary); margin-bottom: 0.35rem; }
.cheat-card p { font-size: 0.8rem; }

/* RESOURCES */
.resource-item {
  display: flex; align-items: flex-start; gap: 1rem;
  padding: 0.9rem; border-radius: var(--radius); background: rgba(0,0,0,0.2);
  border: 1px solid var(--border-subtle); margin-bottom: 0.75rem; transition: all 0.2s;
}
.resource-item:hover { border-color: var(--border); background: rgba(245,166,35,0.05); }
.resource-icon { font-size: 1.3rem; flex-shrink: 0; width: 40px; text-align: center; }
.resource-info { flex: 1; }
.resource-info a { color: var(--text-primary); text-decoration: none; font-weight: 600; font-size: 0.9rem; }
.resource-info a:hover { color: var(--accent-orange); }
.resource-info p { font-size: 0.82rem; margin-top: 0.2rem; }
.resource-info .resource-meta { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem; }

/* FOOTER */
footer { background: rgba(0,0,0,0.4); border-top: 1px solid var(--border-subtle); padding: 2.5rem 0; text-align: center; }
footer p { font-size: 0.85rem; color: var(--text-muted); }

/* UTILS */
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeSlideUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
@keyframes pulse-ring { 0%,100% { opacity: 0.8; } 50% { opacity: 0.3; } }
@keyframes data-flow { 0% { stroke-dashoffset: 80; } 100% { stroke-dashoffset: 0; } }
.pulse-circle { animation: pulse-ring 2.5s ease-in-out infinite; }
.flow-line { stroke-dasharray: 6 4; stroke-dashoffset: 80; animation: data-flow 2.8s linear infinite; }
.flow-line-2 { stroke-dasharray: 6 4; stroke-dashoffset: 80; animation: data-flow 2.8s 0.9s linear infinite; }
.flow-line-3 { stroke-dasharray: 6 4; stroke-dashoffset: 80; animation: data-flow 2.8s 1.8s linear infinite; }

/* hero specific */
.hero {
  min-height: 100vh; display: flex; align-items: center; justify-content: center;
  background:
    radial-gradient(ellipse 80% 60% at 50% -10%, rgba(245,166,35,0.12) 0%, transparent 65%),
    radial-gradient(ellipse 50% 40% at 80% 80%, rgba(0,180,216,0.08) 0%, transparent 60%),
    var(--bg-dark);
  text-align: center; padding: 6rem 1.5rem 4rem; position: relative; overflow: hidden;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(245,166,35,0.12); border: 1px solid rgba(245,166,35,0.35);
  color: var(--accent-orange); font-size: 0.8rem; font-weight: 600;
  padding: 0.4rem 1rem; border-radius: 100px; margin-bottom: 1.5rem; letter-spacing: 0.05em;
  animation: fadeSlideUp 0.5s ease both;
}
.hero-title { background: linear-gradient(135deg, #fff 30%, var(--accent-orange) 70%, var(--accent-amber)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 1.25rem; animation: fadeSlideUp 0.5s 0.1s ease both; }
.hero-subtitle { font-size: 1.15rem; color: var(--text-secondary); max-width: 560px; margin: 0 auto 2.5rem; animation: fadeSlideUp 0.5s 0.2s ease both; }
.hero-ctas { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 4rem; animation: fadeSlideUp 0.5s 0.3s ease both; }
.hero-diagram { width: 100%; max-width: 860px; margin: 0 auto; animation: fadeSlideUp 0.6s 0.45s ease both; }

/* ─── 12-FACTOR GRID ─── */
.factor-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.75rem; }
.factor-item { background: rgba(0,0,0,0.3); border: 1px solid var(--border-subtle); border-radius: 8px; padding: 0.75rem; font-size: 0.82rem; }
.factor-item .fi-num { color: var(--accent-orange); font-weight: 800; font-size: 0.7rem; margin-bottom: 0.2rem; }
.factor-item .fi-name { color: var(--text-primary); font-weight: 600; font-size: 0.83rem; }
.factor-item .fi-desc { color: var(--text-secondary); font-size: 0.75rem; margin-top: 0.15rem; }

/* ─── CIRCUIT BREAKER ─── */
.cb-states { display: flex; gap: 1rem; flex-wrap: wrap; }
.cb-state { flex: 1; min-width: 160px; border-radius: var(--radius); padding: 1rem; text-align: center; font-size: 0.85rem; }
.cb-closed  { background: rgba(74,222,128,0.1);  border: 2px solid rgba(74,222,128,0.4);  }
.cb-open    { background: rgba(248,113,113,0.1); border: 2px solid rgba(248,113,113,0.4); }
.cb-half    { background: rgba(245,166,35,0.1);  border: 2px solid rgba(245,166,35,0.4);  }
.cb-state .cb-icon { font-size: 1.8rem; margin-bottom: 0.5rem; }
.cb-state h4 { margin-bottom: 0.25rem; }

@media (max-width: 768px) {
  .timeline::before { left: 24px; }
  .timeline-item, .timeline-item:nth-child(even) { flex-direction: column; padding-left: 56px; }
  .timeline-item:nth-child(even) .timeline-content { text-align: left; }
  .timeline-center { position: absolute; left: 0; }
  .timeline-side.empty { display: none; }
  .roadmap { gap: 0.5rem; }
  .roadmap-step::after { display: none; }
}

/* KNOWLEDGE CHECK QUIZ */
.kc-opt {
  background: rgba(0,0,0,0.2); border: 1px solid var(--border-subtle);
  border-radius: 8px; color: var(--text-secondary); font-size: 0.85rem;
  padding: 0.65rem 0.9rem; cursor: pointer; text-align: left;
  transition: all 0.18s; font-family: var(--font-sans); line-height: 1.4;
}
.kc-opt:hover:not(:disabled) {
  border-color: var(--border); color: var(--text-primary);
  background: rgba(245,166,35,0.06);
}
.kc-opt:disabled { cursor: default; }
.kc-q[data-answered="true"] .kc-opt:not(.kc-correct-ans):not([style*="red"]) {
  opacity: 0.5;
}

/* DEFINITION CARD SOURCE CITATION */
.def-source { font-size: 0.78rem; color: var(--accent-orange); margin-top: 0.75rem; font-style: italic; }
.def-source-teal { font-size: 0.78rem; color: var(--accent-teal); margin-top: 0.75rem; font-style: italic; }
.def-source-purple { font-size: 0.78rem; color: var(--accent-purple); margin-top: 0.75rem; font-style: italic; }
.def-source-green { font-size: 0.78rem; color: var(--accent-green); margin-top: 0.75rem; font-style: italic; }
.def-source-red { font-size: 0.78rem; color: var(--accent-red); margin-top: 0.75rem; font-style: italic; }

/* ── Wavgen back link inside world nav ── */
.nav-brand-group { display:flex; align-items:center; gap:0.9rem; }
.nav-back { color:var(--text-dim,rgba(255,255,255,.5)); font-size:0.7rem; font-weight:600; letter-spacing:.05em; opacity:.7; transition:opacity 0.2s; text-decoration:none; white-space:nowrap; }
.nav-back:hover { opacity:1; text-decoration:none; }
</style>

