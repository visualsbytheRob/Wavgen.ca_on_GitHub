        <span class="pattern-tag">Deployment</span>
        <svg viewBox="0 0 260 80">
          <rect x="20" y="16" width="220" height="52" rx="8" fill="rgba(22,33,62,0.8)" stroke="rgba(74,222,128,0.25)" stroke-width="1.5" stroke-dasharray="5 3"/>
