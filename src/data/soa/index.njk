        <div style="padding:0.7rem 0.9rem;background:rgba(0,0,0,0.25);border-radius:8px;border:1px solid var(--border-subtle);"><span style="color:var(--accent-orange);font-weight:800;font-size:0.8rem;">X.</span> <span style="color:var(--text-primary);font-size:0.88rem;font-weight:600;">Dev/Prod Parity</span> <span style="color:var(--text-muted);font-size:0.8rem;">&#8212; keep environments similar</span></div>
