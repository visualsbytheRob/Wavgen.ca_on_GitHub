      <text x="210" y="24"  text-anchor="middle" fill="#00e5ff" font-size="8"  font-family="Segoe UI,sans-serif" font-weight="700">Consistency</text>
      <text x="210" y="34"  text-anchor="middle" fill="#00e5ff" font-size="11" font-family="Segoe UI,sans-serif" font-weight="700">C</text>
      <text x="24"  y="268" text-anchor="middle" fill="#7c4dff" font-size="8"  font-family="Segoe UI,sans-serif" font-weight="700">Availability</text>
      <text x="24"  y="279" text-anchor="middle" fill="#7c4dff" font-size="11" font-family="Segoe UI,sans-serif" font-weight="700">A</text>
