---
layout: immersive.njk
title: Big Data — Visual Learning World
description: Master Big Data from zero to production. Explore the 5 V's, build pipelines, map the ecosystem, and launch your big data career.
worldJs: /js/worlds/big-data.js
---
<style>
/* ═══════════════════════════════════════════════
   ROOT & RESET
═══════════════════════════════════════════════ */
:root {
  --navy-900: #050d1a;
  --navy-800: #091428;
  --navy-700: #0d1f3c;
  --navy-600: #122a52;
  --teal:     #00e5ff;
  --teal-dim: #00b8cc;
  --teal-glow:#00e5ff33;
  --cyan:     #18ffff;
  --purple:   #7c4dff;
  --purple-dim:#5c35cc;
  --green:    #00e676;
  --amber:    #ffab40;
  --red:      #ff5252;
  --text:     #cdd9f0;
  --text-dim: #7a93b8;
  --card-bg:  #0b1a30;
  --border:   #1a3a5c;
  --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font);
  background: var(--navy-900);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}
a { color: var(--teal); text-decoration: none; }
a:hover { text-decoration: underline; color: var(--cyan); }

/* ═══════════════════════════════════════════════
   SCROLLBAR
═══════════════════════════════════════════════ */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--navy-800); }
::-webkit-scrollbar-thumb { background: var(--teal-dim); border-radius: 3px; }

/* ═══════════════════════════════════════════════
   DATA STREAM BACKGROUND
═══════════════════════════════════════════════ */
.data-stream-bg {
  position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden;
}
.stream-col {
  position: absolute; top: -100%; width: 1px;
  background: linear-gradient(to bottom, transparent, var(--teal), transparent);
  opacity: 0; animation: streamFall linear infinite;
}

@keyframes streamFall {
  0%   { transform: translateY(0);     opacity: 0; }
  10%  { opacity: 0.15; }
  90%  { opacity: 0.08; }
  100% { transform: translateY(200vh); opacity: 0; }
}

/* ═══════════════════════════════════════════════
   NAV
═══════════════════════════════════════════════ */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  background: rgba(5,13,26,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 2rem; height: 60px;
}
.nav-brand {
  font-size: 1.15rem; font-weight: 700; color: var(--teal);
  letter-spacing: 0.05em;
  display: flex; align-items: center; gap: 0.5rem;
}
.nav-brand span { color: var(--text); }
.nav-links {
  display: flex; gap: 0.25rem; list-style: none; flex-wrap: wrap;
}
.nav-links a {
  color: var(--text-dim); font-size: 0.8rem; padding: 0.35rem 0.7rem;
  border-radius: 6px; transition: all 0.2s;
}
.nav-links a:hover, .nav-links a.active {
  color: var(--teal); background: var(--teal-glow); text-decoration: none;
}

/* ═══════════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════════ */
.world-main { position: relative; z-index: 1; padding-top: 60px; }
section { padding: 4rem 2rem; max-width: 1200px; margin: 0 auto; }
.section-title {
  font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;
  background: linear-gradient(90deg, var(--teal), var(--cyan));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.section-subtitle {
  color: var(--text-dim); font-size: 1rem; margin-bottom: 2.5rem;
}
.divider {
  width: 100%; height: 1px;
  background: linear-gradient(90deg, transparent, var(--border), transparent);
  margin: 0;
}

/* ═══════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════ */
#hero {
  min-height: 100vh; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center; padding: 2rem; position: relative;
  max-width: 100%;
}
.hero-eyebrow {
  font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--teal-dim); margin-bottom: 1.2rem;
  animation: fadeSlideUp 0.8s ease both;
}
.hero-title {
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 900; line-height: 1.05;
  margin-bottom: 1.2rem;
  animation: fadeSlideUp 0.8s 0.15s ease both;
}
.hero-title .accent { color: var(--teal); }
.hero-sub {
  font-size: 1.15rem; color: var(--text-dim); max-width: 560px;
  margin: 0 auto 2.5rem;
  animation: fadeSlideUp 0.8s 0.3s ease both;
}

/* 5 V badges */
.v-badges {
  display: flex; flex-wrap: wrap; gap: 0.75rem;
  justify-content: center; margin-bottom: 3rem;
}
.v-badge {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 0.9rem 1.4rem;
  display: flex; flex-direction: column; align-items: center; gap: 0.25rem;
  min-width: 120px;
  opacity: 0; transform: translateY(20px) scale(0.95);
  animation: vBadgeIn 0.6s ease forwards;
  position: relative; overflow: hidden;
  cursor: default;
  transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
}
.v-badge::before {
  content: ''; position: absolute; inset: 0;
  background: var(--v-color, var(--teal));
  opacity: 0; transition: opacity 0.25s;
}
.v-badge:hover { transform: translateY(-4px) scale(1.04); border-color: var(--v-color, var(--teal)); box-shadow: 0 0 24px var(--v-color, var(--teal-glow)); }
.v-badge:hover::before { opacity: 0.06; }
.v-letter {
  font-size: 2rem; font-weight: 900; color: var(--v-color, var(--teal));
  position: relative; z-index: 1;
}
.v-name {
  font-size: 0.75rem; font-weight: 600; color: var(--text);
  text-transform: uppercase; letter-spacing: 0.08em;
  position: relative; z-index: 1;
}
.v-badge:nth-child(1) { --v-color: #00e5ff; animation-delay: 0.5s; }
.v-badge:nth-child(2) { --v-color: #7c4dff; animation-delay: 0.7s; }
.v-badge:nth-child(3) { --v-color: #00e676; animation-delay: 0.9s; }
.v-badge:nth-child(4) { --v-color: #ffab40; animation-delay: 1.1s; }
.v-badge:nth-child(5) { --v-color: #ff5252; animation-delay: 1.3s; }

@keyframes vBadgeIn {
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.hero-cta {
  display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;
  animation: fadeSlideUp 0.8s 1.5s ease both;
}
.btn {
  padding: 0.75rem 1.8rem; border-radius: 8px; font-weight: 700;
  font-size: 0.9rem; border: none; cursor: pointer;
  transition: all 0.2s; letter-spacing: 0.04em;
}
.btn-primary {
  background: linear-gradient(135deg, var(--teal), var(--teal-dim));
  color: var(--navy-900);
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px var(--teal-glow); }
.btn-outline {
  background: transparent; border: 1px solid var(--border);
  color: var(--text);
}
.btn-outline:hover { border-color: var(--teal); color: var(--teal); transform: translateY(-2px); }

.scroll-hint {
  position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
  color: var(--text-dim); font-size: 0.75rem;
  animation: bounce 2s 2s ease infinite;
}
.scroll-hint svg { opacity: 0.5; }

@keyframes bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50%       { transform: translateX(-50%) translateY(8px); }
}
@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ═══════════════════════════════════════════════
   STAT BAR
═══════════════════════════════════════════════ */
.stat-bar {
  background: var(--navy-800); border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  display: flex; flex-wrap: wrap; justify-content: center;
  gap: 0; padding: 0;
}
.stat-item {
  padding: 1.25rem 2.5rem; text-align: center;
  border-right: 1px solid var(--border);
  flex: 1; min-width: 150px;
}
.stat-item:last-child { border-right: none; }
.stat-number {
  font-size: 1.8rem; font-weight: 900; color: var(--teal);
  display: block;
}
.stat-label { font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em; }

/* ═══════════════════════════════════════════════
   CARDS GRID
═══════════════════════════════════════════════ */
.cards-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 1.5rem;
}
.card {
  background: var(--card-bg); border: 1px solid var(--border);
  border-radius: 16px; padding: 1.75rem;
  transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
  position: relative; overflow: hidden;
}
.card::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--card-accent, var(--teal));
  transform: scaleX(0); transform-origin: left;
  transition: transform 0.3s;
}
.card:hover { transform: translateY(-4px); border-color: var(--card-accent, var(--teal)); }
.card:hover::after { transform: scaleX(1); }
.card:hover { box-shadow: 0 12px 40px rgba(0,229,255,0.08); }
.card-icon { font-size: 2rem; margin-bottom: 0.75rem; display: block; }
.card-title { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text); }
.card-body { font-size: 0.875rem; color: var(--text-dim); line-height: 1.65; }
.card-tag {
  display: inline-block; margin-top: 0.75rem;
  background: var(--teal-glow); color: var(--teal);
  border-radius: 4px; padding: 0.2rem 0.6rem; font-size: 0.7rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.08em;
}

/* ═══════════════════════════════════════════════
   COMPARISON TABLE
═══════════════════════════════════════════════ */
.compare-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  margin-top: 1rem;
}
.compare-card {
  background: var(--card-bg); border: 1px solid var(--border); border-radius: 14px;
  overflow: hidden; transition: transform 0.25s, box-shadow 0.25s;
}
.compare-card:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(0,229,255,0.07); }
.compare-header {
  padding: 1.25rem 1.5rem;
  background: linear-gradient(135deg, var(--ch-from), var(--ch-to));
  display: flex; align-items: center; gap: 0.6rem;
}
.compare-header h3 { font-size: 1rem; font-weight: 800; color: #fff; }
.compare-body { padding: 1.25rem 1.5rem; }
.compare-row { display: flex; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.65rem; font-size: 0.82rem; }
.compare-row .dot { flex-shrink: 0; width: 6px; height: 6px; border-radius: 50%; background: var(--teal); margin-top: 0.35rem; }
.compare-row span { color: var(--text-dim); line-height: 1.5; }

/* ═══════════════════════════════════════════════
   PIPELINE BUILDER
═══════════════════════════════════════════════ */
#pipeline { background: var(--navy-800); }
#pipeline > .inner { max-width: 1200px; margin: 0 auto; padding: 4rem 2rem; }
.pipeline-controls {
  display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 2.5rem;
}
.pipe-toggle {
  background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px;
  padding: 0.65rem 1.2rem; cursor: pointer; transition: all 0.2s;
  display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.85rem; font-weight: 600; color: var(--text-dim);
  user-select: none;
}
.pipe-toggle:hover { border-color: var(--teal-dim); color: var(--text); }
.pipe-toggle.active {
  border-color: var(--teal); color: var(--teal);
  background: var(--teal-glow);
  box-shadow: 0 0 16px var(--teal-glow);
}
.pipe-toggle .tog-icon { font-size: 1.1rem; }

.pipeline-canvas {
  background: var(--navy-900); border: 1px solid var(--border);
  border-radius: 16px; padding: 2rem 1.5rem;
  overflow-x: auto;
}
.pipe-flow {
  display: flex; align-items: center; gap: 0; min-width: 700px;
}
.pipe-node {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  gap: 0.5rem; padding: 0.75rem 0.5rem; border-radius: 12px;
  border: 2px dashed var(--border); transition: all 0.3s;
  position: relative; min-width: 90px;
}
.pipe-node.active-node {
  border-color: var(--teal); background: rgba(0,229,255,0.05);
  box-shadow: 0 0 20px var(--teal-glow);
}
.pipe-node .node-icon { font-size: 1.75rem; }
.pipe-node .node-label { font-size: 0.7rem; font-weight: 700; text-align: center; color: var(--text-dim); }
.pipe-node.active-node .node-label { color: var(--teal); }

.pipe-arrow {
  flex-shrink: 0; display: flex; flex-direction: column; align-items: center;
  width: 40px;
}
.pipe-arrow svg { transition: all 0.3s; }
.pipe-arrow.active-arrow svg { filter: drop-shadow(0 0 4px var(--teal)); }
.pipe-arrow path { stroke: var(--border); transition: stroke 0.3s; }
.pipe-arrow.active-arrow path { stroke: var(--teal); }

.pipe-info-box {
  margin-top: 1.5rem; background: var(--card-bg); border: 1px solid var(--border);
  border-radius: 12px; padding: 1.25rem 1.5rem; min-height: 80px;
  transition: all 0.3s;
}
.pipe-info-box h4 { font-size: 0.9rem; color: var(--teal); margin-bottom: 0.4rem; }
.pipe-info-box p { font-size: 0.82rem; color: var(--text-dim); line-height: 1.6; }

/* ═══════════════════════════════════════════════
   GALAXY MAP (SVG)
═══════════════════════════════════════════════ */
#ecosystem { background: var(--navy-900); }
.galaxy-wrapper {
  background: var(--navy-800); border: 1px solid var(--border);
  border-radius: 20px; overflow: hidden; margin-bottom: 3rem;
}
.galaxy-wrapper svg { width: 100%; height: auto; display: block; }

/* ═══════════════════════════════════════════════
   RESOURCE TABS
═══════════════════════════════════════════════ */
.tab-bar {
  display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem;
}
.tab-btn {
  background: var(--card-bg); border: 1px solid var(--border);
  border-radius: 8px; padding: 0.55rem 1.1rem; cursor: pointer;
  font-size: 0.85rem; font-weight: 600; color: var(--text-dim);
  transition: all 0.2s; display: flex; align-items: center; gap: 0.4rem;
}
.tab-btn:hover { border-color: var(--teal-dim); color: var(--text); }
.tab-btn.active { border-color: var(--teal); color: var(--teal); background: var(--teal-glow); }

.tab-panel { display: none; }
.tab-panel.active { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }

.resource-card {
  background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px;
  padding: 1.1rem 1.25rem; display: flex; gap: 0.75rem;
  transition: all 0.2s; align-items: flex-start;
}
.resource-card:hover { border-color: var(--teal-dim); transform: translateY(-2px); }
.resource-card .rc-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 0.1rem; }
.resource-card .rc-body { flex: 1; }
.resource-card .rc-title { font-size: 0.88rem; font-weight: 700; color: var(--text); margin-bottom: 0.2rem; }
.resource-card .rc-desc { font-size: 0.77rem; color: var(--text-dim); line-height: 1.5; }
.resource-card .rc-link { font-size: 0.73rem; color: var(--teal); margin-top: 0.35rem; display: block; }

/* ═══════════════════════════════════════════════
   ROADMAP
═══════════════════════════════════════════════ */
#roadmap { background: var(--navy-800); }
#roadmap > .inner { max-width: 1200px; margin: 0 auto; padding: 4rem 2rem; }

.roadmap-track {
  display: flex; gap: 1rem;
  overflow-x: auto; padding-bottom: 1rem;
  scrollbar-width: thin;
}
.roadmap-phase {
  flex-shrink: 0; width: 240px;
  background: var(--card-bg); border: 1px solid var(--border);
  border-radius: 14px; overflow: hidden;
}
.roadmap-phase-header {
  padding: 0.9rem 1.1rem;
  background: linear-gradient(135deg, var(--rp-from), var(--rp-to));
  display: flex; align-items: center; gap: 0.5rem;
}
.roadmap-phase-header h3 { font-size: 0.9rem; font-weight: 800; color: #fff; }
.phase-num {
  width: 24px; height: 24px; border-radius: 50%; background: rgba(255,255,255,0.2);
  font-size: 0.75rem; font-weight: 900; color: #fff;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.roadmap-items { padding: 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
.roadmap-item {
  background: var(--navy-800); border-radius: 8px; padding: 0.6rem 0.75rem;
  font-size: 0.8rem; color: var(--text-dim); display: flex; gap: 0.5rem; align-items: flex-start;
}
.roadmap-item .ri-check { color: var(--teal); font-size: 0.75rem; margin-top: 0.1rem; flex-shrink: 0; }
.phase-duration {
  padding: 0.6rem 1.1rem; font-size: 0.72rem; color: var(--teal);
  border-top: 1px solid var(--border); background: var(--teal-glow);
  text-align: center; font-weight: 700; letter-spacing: 0.05em;
}

/* ═══════════════════════════════════════════════
   CHEAT SHEET
═══════════════════════════════════════════════ */
.cheat-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1rem;
}
.cheat-card {
  background: var(--card-bg); border: 1px solid var(--border);
  border-radius: 12px; padding: 1rem 1.1rem;
  transition: all 0.2s; cursor: default;
  position: relative;
}
.cheat-card:hover { border-color: var(--teal-dim); transform: translateY(-2px); }
.cheat-term {
  font-size: 0.82rem; font-weight: 800; color: var(--teal);
  text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 0.3rem;
}
.cheat-def { font-size: 0.78rem; color: var(--text-dim); line-height: 1.55; }
.cheat-copy-btn {
  position: absolute; top: 0.6rem; right: 0.7rem;
  background: none; border: none; cursor: pointer;
  color: var(--text-dim); font-size: 0.75rem; padding: 0.2rem;
  opacity: 0; transition: opacity 0.2s;
}
.cheat-card:hover .cheat-copy-btn { opacity: 1; }
.cheat-copy-btn:hover { color: var(--teal); }

/* ═══════════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════════ */
footer {
  background: var(--navy-800); border-top: 1px solid var(--border);
  padding: 2.5rem 2rem; text-align: center;
  color: var(--text-dim); font-size: 0.82rem;
}
footer .footer-brand { font-size: 1.1rem; font-weight: 800; color: var(--teal); margin-bottom: 0.5rem; }

/* ═══════════════════════════════════════════════
   TOOLTIP
═══════════════════════════════════════════════ */
.tooltip-wrap { position: relative; display: inline-block; }
.tooltip-wrap .tt {
  display: none; position: absolute; bottom: 120%; left: 50%; transform: translateX(-50%);
  background: var(--navy-700); border: 1px solid var(--border); border-radius: 8px;
  padding: 0.5rem 0.75rem; font-size: 0.75rem; color: var(--text); white-space: nowrap;
  z-index: 100; pointer-events: none; box-shadow: 0 4px 16px rgba(0,0,0,0.4);
}
.tooltip-wrap:hover .tt { display: block; }

/* ═══════════════════════════════════════════════
   PROGRESS BAR (for skill levels)
═══════════════════════════════════════════════ */
.skill-bar-wrap { margin-top: 0.5rem; }
.skill-bar-label { display: flex; justify-content: space-between; font-size: 0.72rem; color: var(--text-dim); margin-bottom: 0.25rem; }
.skill-bar-track { height: 5px; background: var(--navy-700); border-radius: 3px; overflow: hidden; }
.skill-bar-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--teal), var(--cyan)); transition: width 1s ease; }

/* ═══════════════════════════════════════════════
   DEEP-DIVE ACCORDION
═══════════════════════════════════════════════ */
.accordion { margin-top: 1rem; }
.acc-item { border: 1px solid var(--border); border-radius: 10px; margin-bottom: 0.5rem; overflow: hidden; }
.acc-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0.9rem 1.1rem; cursor: pointer; background: var(--card-bg);
  font-size: 0.88rem; font-weight: 700; color: var(--text);
  transition: background 0.2s;
}
.acc-header:hover { background: var(--navy-700); }
.acc-header .acc-chevron { transition: transform 0.3s; color: var(--teal-dim); }
.acc-item.open .acc-chevron { transform: rotate(180deg); }
.acc-body { display: none; padding: 1rem 1.1rem; background: var(--navy-900); font-size: 0.83rem; color: var(--text-dim); line-height: 1.65; }
.acc-item.open .acc-body { display: block; }

/* ═══════════════════════════════════════════════
   NOTIFICATION TOAST
═══════════════════════════════════════════════ */
#toast {
  position: fixed; bottom: 2rem; right: 2rem; z-index: 9999;
  background: var(--navy-700); border: 1px solid var(--teal);
  border-radius: 10px; padding: 0.75rem 1.25rem;
  font-size: 0.85rem; color: var(--teal);
