      <text x="113" y="161" text-anchor="middle" fill="rgba(255,255,255,.6)"  font-size="12" font-weight="700" font-family="Segoe UI,sans-serif">CA</text>
      <text x="113" y="175" text-anchor="middle" fill="rgba(255,255,255,.32)" font-size="8.5" font-family="Segoe UI,sans-serif">PostgreSQL, MySQL</text>
      <text x="307" y="161" text-anchor="middle" fill="rgba(255,255,255,.6)"  font-size="12" font-weight="700" font-family="Segoe UI,sans-serif">CP</text>
      <text x="307" y="175" text-anchor="middle" fill="rgba(255,255,255,.32)" font-size="8.5" font-family="Segoe UI,sans-serif">HBase, Zookeeper</text>
      <text x="210" y="242" text-anchor="middle" fill="rgba(255,255,255,.6)"  font-size="12" font-weight="700" font-family="Segoe UI,sans-serif">AP</text>
      <text x="210" y="255" text-anchor="middle" fill="rgba(255,255,255,.32)" font-size="8.5" font-family="Segoe UI,sans-serif">Cassandra, DynamoDB</text>
