          <div class="arch-year">Gu &amp; Dao, 2023</div>
        </div>
        <div class="arch-diagram">
          <div class="arch-block" style="--bc:var(--cyan);">Input sequence</div>
          <div class="arch-arrow">↓</div>
          <div class="arch-block" style="--bc:var(--electric);">Selective State Space</div>
