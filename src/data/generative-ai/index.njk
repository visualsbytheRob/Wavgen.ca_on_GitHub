<style>
/* ===== RESET & BASE ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg:        #0a0010;
  --bg2:       #0f0020;
  --bg3:       #14002e;
  --card:      #1a003a;
  --card2:     #200045;
  --purple:    #7c3aed;
  --violet:    #9333ea;
  --magenta:   #c026d3;
  --pink:      #ec4899;
  --hot:       #f472b6;
  --electric:  #a855f7;
  --cyan:      #22d3ee;
  --text:      #f0e6ff;
  --muted:     #a78bca;
  --glow-p:    rgba(124,58,237,0.35);
  --glow-m:    rgba(192,38,211,0.35);
  --glow-k:    rgba(236,72,153,0.3);
  --border:    rgba(168,85,247,0.25);
  --border2:   rgba(236,72,153,0.2);
  --radius:    14px;
  --radius-lg: 22px;
}
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
  line-height: 1.6;
  overflow-x: hidden;
}
/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg2); }
::-webkit-scrollbar-thumb { background: var(--purple); border-radius: 3px; }

/* ===== CANVAS BACKGROUND ===== */
#particle-canvas {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0; pointer-events: none;
  opacity: 0.55;
}

/* ===== LAYOUT ===== */
.page-wrap { position: relative; z-index: 1; }
.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* ===== NAV ===== */
nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(10,0,16,0.85);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid var(--border);
  padding: 14px 0;
}
.nav-inner {
  display: flex; align-items: center; justify-content: space-between;
  max-width: 1200px; margin: 0 auto; padding: 0 24px;
}
.nav-logo {
  font-size: 1.15rem; font-weight: 700; letter-spacing: -0.02em;
  background: linear-gradient(90deg, var(--electric), var(--pink));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; text-decoration: none;
}
.nav-links { display: flex; gap: 6px; flex-wrap: wrap; }
.nav-links a {
  color: var(--muted); text-decoration: none; font-size: 0.8rem;
  padding: 5px 12px; border-radius: 20px;
  border: 1px solid transparent;
  transition: all 0.25s;
}
.nav-links a:hover {
  color: var(--text); border-color: var(--border);
  background: rgba(124,58,237,0.15);
}

/* ===== SECTION HEADERS ===== */
.section-label {
  font-size: 0.72rem; font-weight: 600; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--electric);
  margin-bottom: 10px;
}
.section-title {
  font-size: clamp(1.7rem, 4vw, 2.6rem);
  font-weight: 800; line-height: 1.15;
  margin-bottom: 14px;
}
.section-sub {
  font-size: 1rem; color: var(--muted); max-width: 600px;
  margin-bottom: 48px;
}
section { padding: 80px 0; }

/* ===== GRADIENT TEXT ===== */
.g-purple { background: linear-gradient(135deg, var(--electric), var(--pink)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.g-magenta { background: linear-gradient(135deg, var(--magenta), var(--hot)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.g-cyan { background: linear-gradient(135deg, var(--cyan), var(--electric)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

/* ===== CARDS ===== */
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 28px;
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  position: relative; overflow: hidden;
}
.card::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at top left, rgba(124,58,237,0.08) 0%, transparent 60%);
  pointer-events: none;
}
.card:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 60px rgba(124,58,237,0.25);
  border-color: rgba(168,85,247,0.5);
}
.card-icon {
  font-size: 2rem; margin-bottom: 14px;
  display: inline-block;
}
.card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 10px; color: var(--text); }
.card p  { font-size: 0.88rem; color: var(--muted); line-height: 1.65; }

/* ===== GRID HELPERS ===== */
.grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 22px; }
.grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; }
.grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 18px; }

/* ===== BUTTONS ===== */
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 12px 26px; border-radius: 50px; font-size: 0.9rem; font-weight: 600;
  text-decoration: none; cursor: pointer; border: none; transition: all 0.25s;
}
.btn-primary {
  background: linear-gradient(135deg, var(--purple), var(--magenta));
  color: #fff;
  box-shadow: 0 6px 30px rgba(124,58,237,0.4);
}
.btn-primary:hover {
  box-shadow: 0 10px 40px rgba(192,38,211,0.55);
  transform: translateY(-2px);
}
.btn-ghost {
  background: transparent;
  color: var(--text);
  border: 1px solid var(--border);
}
.btn-ghost:hover {
  background: rgba(124,58,237,0.15);
  border-color: var(--electric);
}

/* ===== TAG / BADGE ===== */
.tag {
  display: inline-block; font-size: 0.72rem; font-weight: 600;
  padding: 3px 10px; border-radius: 20px;
  border: 1px solid var(--border2);
  color: var(--hot); background: rgba(236,72,153,0.1);
  margin-right: 6px; margin-bottom: 6px;
}

/* ===== DIVIDER ===== */
.divider {
  border: none; height: 1px;
  background: linear-gradient(90deg, transparent, var(--border), transparent);
  margin: 0;
}

/* ===== HERO SECTION ===== */
#hero {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center; padding: 100px 24px 60px;
  position: relative;
}
.hero-eyebrow {
  font-size: 0.78rem; font-weight: 600; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--electric);
  margin-bottom: 20px;
  border: 1px solid rgba(168,85,247,0.35);
  padding: 6px 18px; border-radius: 20px;
  background: rgba(124,58,237,0.1);
  display: inline-block;
}
.hero-title {
  font-size: clamp(2.6rem, 8vw, 5.5rem);
  font-weight: 900; line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 22px;
}
.hero-sub {
  font-size: clamp(1rem, 2.5vw, 1.25rem);
  color: var(--muted); max-width: 620px;
  margin: 0 auto 40px;
}
.hero-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 70px; }

/* ===== FLOW DIAGRAM (Hero Visual) ===== */
.flow-wrap {
  width: 100%; max-width: 820px;
  background: rgba(20,0,46,0.7);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 32px 24px;
  backdrop-filter: blur(10px);
  position: relative;
}
.flow-row {
  display: flex; align-items: center; justify-content: center;
  gap: 0; flex-wrap: nowrap; overflow-x: auto;
  padding: 4px 0;
}
.flow-box {
  display: flex; flex-direction: column; align-items: center;
  min-width: 110px;
}
.flow-node {
  padding: 10px 18px; border-radius: 10px; font-size: 0.78rem;
  font-weight: 700; text-align: center; white-space: nowrap;
  position: relative;
}
.fn-input  { background: rgba(34,211,238,0.12); border: 1px solid rgba(34,211,238,0.4); color: var(--cyan); }
.fn-tok    { background: rgba(168,85,247,0.12); border: 1px solid rgba(168,85,247,0.4); color: var(--electric); }
.fn-embed  { background: rgba(124,58,237,0.12); border: 1px solid rgba(124,58,237,0.4); color: #c084fc; }
.fn-attn   { background: rgba(192,38,211,0.12); border: 1px solid rgba(192,38,211,0.5); color: var(--magenta); }
.fn-out    { background: rgba(236,72,153,0.12); border: 1px solid rgba(236,72,153,0.4); color: var(--pink); }
.fn-label {
  font-size: 0.65rem; color: var(--muted); margin-top: 8px;
  text-align: center;
}
.flow-arrow {
  font-size: 1.1rem; color: var(--purple); padding: 0 4px;
  animation: pulse-arrow 1.8s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes pulse-arrow {
  0%,100% { opacity: 0.4; transform: scaleX(1); }
  50%      { opacity: 1;   transform: scaleX(1.3); }
}
.flow-title {
  font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--electric);
  text-align: center; margin-bottom: 18px;
}

/* Token stream animation */
.token-stream {
  display: flex; gap: 6px; flex-wrap: wrap;
  justify-content: center; margin-top: 20px; padding-top: 18px;
  border-top: 1px solid var(--border);
}
.token {
  font-size: 0.72rem; padding: 4px 10px; border-radius: 6px;
  font-family: 'Courier New', monospace; font-weight: 700;
  animation: token-glow 3s ease-in-out infinite;
}
.token:nth-child(1)  { background: rgba(168,85,247,0.2); color: var(--electric); animation-delay: 0s; }
.token:nth-child(2)  { background: rgba(192,38,211,0.2); color: var(--magenta);  animation-delay: 0.3s; }
.token:nth-child(3)  { background: rgba(236,72,153,0.2); color: var(--pink);     animation-delay: 0.6s; }
.token:nth-child(4)  { background: rgba(124,58,237,0.2); color: #c084fc;         animation-delay: 0.9s; }
.token:nth-child(5)  { background: rgba(34,211,238,0.15); color: var(--cyan);    animation-delay: 1.2s; }
.token:nth-child(6)  { background: rgba(168,85,247,0.2); color: var(--electric); animation-delay: 1.5s; }
.token:nth-child(7)  { background: rgba(192,38,211,0.2); color: var(--magenta);  animation-delay: 1.8s; }
.token:nth-child(8)  { background: rgba(244,114,182,0.2); color: var(--hot);     animation-delay: 2.1s; }
@keyframes token-glow {
  0%,100% { box-shadow: none; opacity: 0.7; }
  50%      { box-shadow: 0 0 12px currentColor; opacity: 1; }
}

/* Prompt → Output animated display */
.prompt-display {
  margin-top: 18px; padding: 14px 18px;
  background: rgba(0,0,0,0.3); border-radius: 10px;
  border: 1px solid var(--border); text-align: left;
}
.prompt-label { font-size: 0.66rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
.prompt-text  { font-size: 0.85rem; font-family: 'Courier New', monospace; color: var(--text); }
.prompt-cursor {
  display: inline-block; width: 2px; height: 1em;
  background: var(--electric); margin-left: 2px; vertical-align: text-bottom;
  animation: blink 1s step-end infinite;
}
@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0;} }

/* Stats row */
.hero-stats {
  display: flex; gap: 40px; justify-content: center;
  margin-top: 50px; flex-wrap: wrap;
}
.stat-item { text-align: center; }
.stat-num {
