  .module-2::before { background: linear-gradient(90deg, #f472b6, #fbbf24); }
  .module-header { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 20px; }
  .module-num { font-size: 2rem; font-weight: 900; line-height: 1; }
  .m1-num { color: #7dd3fc; } .m2-num { color: #f472b6; }
  .module-meta { flex: 1; }
  .module-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
  .module-sub { font-size: 0.8rem; color: var(--text-dim); }
  .topic-list { list-style: none; }
  .topic-item {
    display: flex; align-items: flex-start; gap: 10px; padding: 9px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.85rem; color: var(--text-secondary);
  }
  .topic-item:last-child { border-bottom: none; }
  .topic-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; margin-top: 6px; }
  .t1 { background: #7dd3fc; } .t2 { background: #6366f1; } .t3 { background: #34d399; }
  .t4 { background: #fbbf24; } .t5 { background: #f472b6; } .t6 { background: #a78bfa; }
  .t7 { background: #22d3ee; } .t8 { background: #fb923c; } .t9 { background: #e879f9; }
  .topic-name { font-weight: 600; color: var(--text-primary); }
  .topic-detail { font-size: 0.77rem; color: var(--text-dim); margin-top: 2px; }

  /* ── CHARACTERISTICS WHEEL ── */
  .chars-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; margin-bottom: 36px; }
  .char-card {
    background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 14px;
    padding: 18px 20px; display: flex; gap: 14px; align-items: flex-start;
