<style>
:root {
    --sky-light: #e0f2fe;
    --sky-mid: #7dd3fc;
    --sky-deep: #0ea5e9;
    --space-blue: #0c1445;
    --space-deep: #060d2e;
    --nebula: #6366f1;
    --nebula-light: #a5b4fc;
    --cloud-white: rgba(255,255,255,0.92);
    --card-bg: rgba(255,255,255,0.07);
    --card-border: rgba(255,255,255,0.15);
    --text-primary: #f0f9ff;
    --text-secondary: rgba(224,242,254,0.75);
    --text-dim: rgba(186,230,253,0.55);
    --accent-aws: #FF9900;
    --accent-azure: #0078D4;
    --accent-gcp: #4285F4;
    --accent-green: #22d3ee;
    --accent-purple: #a78bfa;
    --accent-pink: #f472b6;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: linear-gradient(180deg,
      #87ceeb 0%,
      #5bb8f5 8%,
      #2196f3 18%,
      #1565c0 28%,
      #0d3b8a 38%,
      #0c1445 52%,
      #080f35 68%,
      #060d2e 85%,
      #040920 100%
    );
    background-attachment: fixed;
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    backdrop-filter: blur(20px);
    background: rgba(6,13,46,0.75);
    border-bottom: 1px solid var(--card-border);
    padding: 12px 32px;
    display: flex; align-items: center; gap: 32px; flex-wrap: wrap;
  }
  .nav-logo { font-weight: 800; font-size: 1.1rem; color: var(--sky-mid); letter-spacing: -0.5px; white-space: nowrap; }
  .nav-links { display: flex; gap: 4px; flex-wrap: wrap; }
  .nav-links a {
    color: var(--text-secondary); text-decoration: none; padding: 5px 12px;
    border-radius: 20px; font-size: 0.82rem; font-weight: 500; transition: all 0.2s; white-space: nowrap;
  }
  .nav-links a:hover { background: rgba(125,211,252,0.15); color: var(--sky-mid); }

  /* ── HERO ── */
  #hero {
    min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    position: relative; overflow: hidden; padding: 100px 24px 80px; text-align: center;
  }

  .stars-layer {
    position: absolute; inset: 0; pointer-events: none; opacity: 0;
    animation: fadeInStars 3s 1s forwards;
  }
  .stars-layer::before {
    content: ''; position: absolute; inset: 0;
    background-image: radial-gradient(1px 1px at 10% 20%, white 0%, transparent 100%),
      radial-gradient(1px 1px at 25% 40%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 50% 15%, white 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 30%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 85% 10%, white 0%, transparent 100%),
      radial-gradient(1px 1px at 15% 60%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 60% 50%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 55%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 35% 75%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 78% 70%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 5% 85%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 42% 88%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 93% 82%, white 0%, transparent 100%);
  }
  @keyframes fadeInStars { to { opacity: 1; } }

  .cloud-layer { position: absolute; inset: 0; pointer-events: none; }
  .cloud {
    position: absolute; background: white; border-radius: 50px; opacity: 0.85;
    animation: floatCloud linear infinite;
  }
  .cloud::before, .cloud::after { content: ''; position: absolute; background: white; border-radius: 50%; }
  .cloud-1 { width: 140px; height: 40px; top: 18%; left: -160px; animation-duration: 28s; }
  .cloud-1::before { width: 70px; height: 60px; top: -30px; left: 20px; }
  .cloud-1::after { width: 50px; height: 45px; top: -20px; left: 60px; }
  .cloud-2 { width: 100px; height: 30px; top: 28%; left: -120px; animation-duration: 22s; animation-delay: -8s; opacity: 0.65; }
  .cloud-2::before { width: 55px; height: 45px; top: -22px; left: 15px; }
  .cloud-2::after { width: 40px; height: 35px; top: -15px; left: 45px; }
  .cloud-3 { width: 180px; height: 50px; top: 12%; left: -200px; animation-duration: 35s; animation-delay: -15s; opacity: 0.7; }
  .cloud-3::before { width: 80px; height: 70px; top: -38px; left: 25px; }
  .cloud-3::after { width: 65px; height: 55px; top: -28px; left: 80px; }
  .cloud-4 { width: 90px; height: 28px; top: 38%; left: -110px; animation-duration: 19s; animation-delay: -4s; opacity: 0.55; }
  .cloud-4::before { width: 45px; height: 40px; top: -18px; left: 12px; }
  .cloud-4::after { width: 35px; height: 30px; top: -12px; left: 40px; }
  @keyframes floatCloud { from { transform: translateX(0); } to { transform: translateX(calc(100vw + 250px)); } }

  .particles-canvas { position: absolute; inset: 0; pointer-events: none; width: 100%; height: 100%; }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(125,211,252,0.15); border: 1px solid rgba(125,211,252,0.3);
    padding: 6px 16px; border-radius: 20px; font-size: 0.8rem; font-weight: 600;
    color: var(--sky-mid); letter-spacing: 1px; text-transform: uppercase;
    margin-bottom: 24px; animation: fadeUp 0.8s 0.2s both;
  }
  .hero-title {
    font-size: clamp(2.8rem, 7vw, 5.5rem); font-weight: 900; line-height: 1.05;
    letter-spacing: -2px; margin-bottom: 8px; animation: fadeUp 0.8s 0.35s both;
  }
  .hero-title .grad { background: linear-gradient(135deg, #7dd3fc, #a5b4fc, #f0abfc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.35rem); font-weight: 400;
    color: var(--text-secondary); max-width: 600px; margin: 0 auto 40px; line-height: 1.6;
    animation: fadeUp 0.8s 0.5s both;
  }
  .hero-visual { width: 100%; max-width: 700px; margin: 0 auto 40px; animation: fadeUp 0.8s 0.65s both; }
  .hero-stats { display: flex; gap: 40px; justify-content: center; flex-wrap: wrap; animation: fadeUp 0.8s 0.8s both; }
  .hero-stat .num { font-size: 2rem; font-weight: 800; color: var(--sky-mid); }
  .hero-stat .label { font-size: 0.78rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }

  /* ── SECTIONS ── */
  section { padding: 80px 24px; max-width: 1200px; margin: 0 auto; }
  .section-tag {
    display: inline-block; background: rgba(165,180,252,0.15); border: 1px solid rgba(165,180,252,0.3);
    color: var(--nebula-light); font-size: 0.75rem; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; padding: 4px 14px; border-radius: 20px; margin-bottom: 16px;
  }
  .section-title { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; letter-spacing: -1px; margin-bottom: 12px; line-height: 1.15; }
  .section-subtitle { color: var(--text-secondary); font-size: 1.05rem; max-width: 560px; line-height: 1.6; margin-bottom: 48px; }

  /* ── CONCEPT CARDS ── */
  .concepts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px; }
  .concept-card {
    background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 20px;
    padding: 28px; position: relative; overflow: hidden;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s; cursor: default;
  }
  .concept-card:hover { transform: translateY(-4px); border-color: rgba(125,211,252,0.4); box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 30px rgba(125,211,252,0.08); }
  .concept-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 20px 20px 0 0; }
  .card-c1::before { background: linear-gradient(90deg, #f472b6, #a78bfa); }
  .card-c2::before { background: linear-gradient(90deg, #22d3ee, #6366f1); }
  .card-c3::before { background: linear-gradient(90deg, #34d399, #22d3ee); }
  .card-c4::before { background: linear-gradient(90deg, #fbbf24, #f472b6); }
  .card-c5::before { background: linear-gradient(90deg, #60a5fa, #34d399); }
  .card-c6::before { background: linear-gradient(90deg, #a78bfa, #f472b6); }
  .concept-icon { font-size: 2rem; margin-bottom: 12px; }
  .concept-title { font-size: 1.15rem; font-weight: 700; margin-bottom: 6px; }
  .concept-analogy { font-size: 0.78rem; color: var(--accent-green); font-weight: 600; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
  .concept-desc { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.65; margin-bottom: 20px; }

  /* ── PROVIDER CARDS ── */
  .providers-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
  .provider-card {
    background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 20px;
    padding: 28px; transition: transform 0.3s, box-shadow 0.3s;
  }
  .provider-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
  .provider-logo { font-size: 2.5rem; margin-bottom: 12px; }
  .provider-name { font-size: 1.4rem; font-weight: 800; margin-bottom: 4px; }
  .provider-share { font-size: 0.8rem; color: var(--text-dim); margin-bottom: 16px; }
  .provider-bar { height: 6px; border-radius: 3px; margin-bottom: 20px; }
  .aws-bar { background: linear-gradient(90deg, #FF9900, #ffb347); width: 33%; }
  .azure-bar { background: linear-gradient(90deg, #0078D4, #50e6ff); width: 23%; }
  .gcp-bar { background: linear-gradient(90deg, #4285F4, #34a853); width: 12%; }
  .provider-strengths { list-style: none; margin-bottom: 20px; }
  .provider-strengths li { font-size: 0.85rem; color: var(--text-secondary); padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; gap: 8px; }
  .provider-strengths li::before { content: '✦'; font-size: 0.6rem; opacity: 0.6; flex-shrink: 0; }
  .provider-cert { background: rgba(255,255,255,0.06); border-radius: 10px; padding: 12px; }
  .cert-label { font-size: 0.72rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; font-weight: 600; }
  .cert-pills { display: flex; flex-wrap: wrap; gap: 6px; }
  .cert-pill { font-size: 0.72rem; padding: 3px 10px; border-radius: 12px; font-weight: 500; }
  .cert-found { background: rgba(255,153,0,0.2); color: #FF9900; }
  .cert-assoc { background: rgba(255,153,0,0.12); color: #ffb347; }
  .cert-pro { background: rgba(255,153,0,0.08); color: #ffd700; }
  .cert-az-found { background: rgba(0,120,212,0.25); color: #50e6ff; }
  .cert-az-assoc { background: rgba(0,120,212,0.15); color: #7dd3fc; }
  .cert-az-pro { background: rgba(0,120,212,0.08); color: #bae6fd; }
  .cert-gcp-found { background: rgba(66,133,244,0.25); color: #7baaf7; }
  .cert-gcp-assoc { background: rgba(66,133,244,0.15); color: #a8c7fa; }
  .cert-gcp-pro { background: rgba(66,133,244,0.08); color: #c5d8ff; }

  /* ── TABS ── */
  .tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; }
  .tab-btn {
    padding: 9px 20px; border-radius: 20px; border: 1px solid var(--card-border);
    background: var(--card-bg); color: var(--text-secondary); font-size: 0.88rem; font-weight: 600;
    cursor: pointer; transition: all 0.2s; font-family: inherit;
  }
  .tab-btn.active, .tab-btn:hover { background: rgba(125,211,252,0.18); border-color: rgba(125,211,252,0.4); color: var(--sky-mid); }
  .tab-content { display: none; }
  .tab-content.active { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .resource-card {
    background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 14px;
    padding: 18px; transition: all 0.2s; text-decoration: none; display: block; color: inherit;
  }
  .resource-card:hover { background: rgba(125,211,252,0.1); border-color: rgba(125,211,252,0.3); transform: translateY(-2px); }
  .resource-title { font-weight: 700; font-size: 0.9rem; margin-bottom: 6px; color: var(--text-primary); }
  .resource-why { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.5; margin-bottom: 10px; }
  .resource-tag { font-size: 0.7rem; padding: 2px 8px; border-radius: 8px; font-weight: 600; display: inline-block; }
  .tag-free { background: rgba(34,211,238,0.2); color: var(--accent-green); }
  .tag-paid { background: rgba(251,191,36,0.15); color: #fbbf24; }
  .tag-freemium { background: rgba(167,139,250,0.2); color: var(--accent-purple); }

  /* ── ROADMAP ── */
  .roadmap { position: relative; padding: 20px 0; }
  .roadmap-line {
    position: absolute; left: 28px; top: 40px; bottom: 40px; width: 2px;
    background: linear-gradient(180deg, #7dd3fc, #6366f1, #a78bfa); border-radius: 2px;
  }
  .roadmap-item { display: flex; gap: 24px; margin-bottom: 40px; position: relative; }
  .roadmap-dot {
    flex-shrink: 0; width: 58px; height: 58px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; border: 2px solid; position: relative; z-index: 1;
  }
  .dot-1 { background: rgba(125,211,252,0.2); border-color: #7dd3fc; }
  .dot-2 { background: rgba(99,102,241,0.2); border-color: #6366f1; }
  .dot-3 { background: rgba(167,139,250,0.2); border-color: #a78bfa; }
  .dot-4 { background: rgba(244,114,182,0.2); border-color: #f472b6; }
  .roadmap-content { flex: 1; padding-top: 8px; }
  .roadmap-level { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; margin-bottom: 4px; }
  .roadmap-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 6px; }
  .roadmap-time { font-size: 0.78rem; color: var(--accent-green); font-weight: 600; margin-bottom: 10px; }
  .roadmap-items { display: flex; flex-wrap: wrap; gap: 6px; }
  .roadmap-pill { font-size: 0.75rem; padding: 4px 12px; border-radius: 12px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); color: var(--text-secondary); }

  /* ── CHEAT SHEET ── */
  .cheat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; }
  .cheat-card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 12px; padding: 14px 16px; }
  .cheat-term { font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; font-weight: 600; color: var(--accent-green); margin-bottom: 4px; }
  .cheat-def { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.45; }

  /* ── DEMO ── */
  #demo { padding: 80px 24px; max-width: 1200px; margin: 0 auto; }
  .demo-wrapper { background: rgba(0,0,0,0.3); border: 1px solid var(--card-border); border-radius: 24px; padding: 36px; }
  .demo-layout { display: grid; grid-template-columns: 280px 1fr; gap: 32px; }
  @media(max-width: 740px) { .demo-layout { grid-template-columns: 1fr; } }
  .demo-components h3 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-dim); margin-bottom: 16px; font-weight: 700; }
  .comp-btn {
    width: 100%; display: flex; align-items: center; gap: 12px;
    background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 12px;
    padding: 12px 14px; margin-bottom: 8px; cursor: pointer; transition: all 0.2s;
    text-align: left; color: var(--text-primary); font-family: inherit;
  }
  .comp-btn:hover { border-color: rgba(125,211,252,0.4); background: rgba(125,211,252,0.08); }
  .comp-btn.active { border-color: var(--accent-green); background: rgba(34,211,238,0.1); }
  .comp-icon { font-size: 1.4rem; flex-shrink: 0; }
  .comp-info { flex: 1; }
  .comp-name { font-size: 0.88rem; font-weight: 600; display: block; }
  .comp-cost { font-size: 0.75rem; color: var(--text-dim); }
  .comp-check { width: 20px; height: 20px; border-radius: 50%; border: 2px solid var(--card-border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; transition: all 0.2s; }
  .comp-btn.active .comp-check { background: var(--accent-green); border-color: var(--accent-green); color: #000; }
  .demo-canvas { min-height: 300px; }
  .demo-arch-svg { width: 100%; border-radius: 12px; background: rgba(0,0,0,0.2); }
  .cost-panel { background: rgba(0,0,0,0.4); border: 1px solid var(--card-border); border-radius: 14px; padding: 20px; margin-top: 20px; }
  .cost-title { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-dim); margin-bottom: 12px; font-weight: 700; }
  .cost-items { margin-bottom: 14px; }
