          <!-- Cluster 2 boundary -->
          <ellipse cx="205" cy="67" rx="30" ry="24" fill="rgba(244,162,97,0.08)" stroke="rgba(244,162,97,0.4)" stroke-width="1.5" stroke-dasharray="4,3"/>
          <text x="205" y="108" text-anchor="middle" fill="#f4a261" font-size="9">Cluster B</text>

