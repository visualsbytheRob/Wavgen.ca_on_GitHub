          <text x="91" y="62" text-anchor="middle" fill="#52b788" font-size="10" font-weight="bold">TP</text>
          <!-- FN -->
          <rect x="112" y="42" width="38" height="30" rx="3" fill="rgba(255,143,163,0.2)" stroke="rgba(255,143,163,0.4)" stroke-width="1"/>
          <text x="131" y="62" text-anchor="middle" fill="#ff8fa3" font-size="10" font-weight="bold">FN</text>
          <!-- FP -->
          <rect x="72" y="74" width="38" height="30" rx="3" fill="rgba(255,143,163,0.2)" stroke="rgba(255,143,163,0.4)" stroke-width="1"/>
          <text x="91" y="94" text-anchor="middle" fill="#ff8fa3" font-size="10" font-weight="bold">FP</text>
          <!-- TN -->
          <rect x="112" y="74" width="38" height="30" rx="3" fill="rgba(82,183,136,0.15)" stroke="rgba(82,183,136,0.3)" stroke-width="1"/>
          <text x="131" y="94" text-anchor="middle" fill="#74c69d" font-size="10" font-weight="bold">TN</text>
          <!-- Divider -->
          <line x1="185" y1="20" x2="185" y2="145" stroke="rgba(82,183,136,0.2)" stroke-width="1"/>
          <!-- ROC Curve (right half) -->
          <text x="260" y="22" text-anchor="middle" fill="#52b788" font-size="9" font-weight="bold">ROC Curve</text>
          <!-- Axes -->
          <line x1="195" y1="130" x2="325" y2="130" stroke="#7a9e8a" stroke-width="1"/>
          <line x1="195" y1="130" x2="195" y2="28" stroke="#7a9e8a" stroke-width="1"/>
          <text x="260" y="145" text-anchor="middle" fill="#7a9e8a" font-size="7">FPR →</text>
          <text x="183" y="79" text-anchor="middle" fill="#7a9e8a" font-size="7" transform="rotate(-90,183,79)">TPR →</text>
          <!-- Random diagonal -->
          <line x1="195" y1="130" x2="325" y2="28" stroke="rgba(255,255,255,0.2)" stroke-width="1" stroke-dasharray="4,3"/>
          <text x="318" y="25" fill="rgba(255,255,255,0.35)" font-size="7">random</text>
          <!-- Good ROC curve -->
          <path d="M195,130 C210,90 220,50 240,38 S 290,30 325,28" stroke="#f4a261" stroke-width="2" fill="none"/>
