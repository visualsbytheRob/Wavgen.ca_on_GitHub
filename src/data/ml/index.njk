<section id="concepts-row2" style="padding-top:0;">
  <div class="concepts-grid">

    <!-- Card 4: Overfitting vs Underfitting -->
    <div class="concept-card fade-in">
      <div class="concept-icon">📉</div>
      <h3>Overfitting vs Underfitting</h3>
      <p>Overfitting memorises training noise and fails on new data. Underfitting is too simple to capture the signal. The sweet spot — the <em>bias–variance tradeoff</em> — balances both errors for best generalisation.</p>
      <div class="concept-diagram">
        <svg viewBox="0 0 340 160" xmlns="http://www.w3.org/2000/svg" style="background:rgba(0,0,0,0.3);border-radius:8px;">
          <defs>
            <marker id="bv-ax" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><path d="M0,0 L0,7 L7,3.5 z" fill="#7a9e8a"/></marker>
          </defs>
          <!-- Axes -->
          <line x1="30" y1="130" x2="320" y2="130" stroke="#7a9e8a" stroke-width="1.5" marker-end="url(#bv-ax)"/>
          <line x1="30" y1="130" x2="30" y2="15" stroke="#7a9e8a" stroke-width="1.5" marker-end="url(#bv-ax)"/>
          <text x="175" y="148" text-anchor="middle" fill="#7a9e8a" font-size="9">Model Complexity →</text>
          <text x="13" y="75" text-anchor="middle" fill="#7a9e8a" font-size="9" transform="rotate(-90,13,75)">Error →</text>
          <!-- Training error curve (monotonically decreasing) -->
          <path d="M 45,110 C 80,95 120,65 160,45 S 240,28 305,22" stroke="#52b788" stroke-width="2" fill="none"/>
          <text x="310" y="20" fill="#52b788" font-size="8">Train</text>
          <!-- Validation error curve (U-shape) -->
          <path d="M 45,108 C 75,85 110,60 148,48 S 200,48 240,65 S 280,92 305,112" stroke="#f4a261" stroke-width="2" fill="none"/>
          <text x="310" y="115" fill="#f4a261" font-size="8">Val</text>
          <!-- Sweet spot vertical -->
          <line x1="152" y1="15" x2="152" y2="130" stroke="rgba(255,255,255,0.25)" stroke-width="1" stroke-dasharray="4,3"/>
          <text x="152" y="12" text-anchor="middle" fill="#fff" font-size="8" font-weight="bold">Sweet Spot</text>
          <!-- Zone labels -->
          <text x="80" y="130" text-anchor="middle" fill="#c9a0ff" font-size="8" dy="-4">Underfitting</text>
          <text x="240" y="130" text-anchor="middle" fill="#ff8fa3" font-size="8" dy="-4">Overfitting</text>
          <!-- Bias/variance annotations -->
          <text x="75" y="85" fill="#c9a0ff" font-size="7.5">High Bias</text>
          <text x="215" y="40" fill="#ff8fa3" font-size="7.5">High Variance</text>
        </svg>
      </div>
    </div>

    <!-- Card 5: Feature Engineering -->
    <div class="concept-card fade-in">
      <div class="concept-icon">🔧</div>
      <h3>Feature Engineering</h3>
      <p>Transforming raw data into meaningful inputs that improve model performance. Often the most impactful step — a good feature can outperform a complex algorithm on poor features.</p>
      <div class="concept-diagram">
        <svg viewBox="0 0 340 160" xmlns="http://www.w3.org/2000/svg" style="background:rgba(0,0,0,0.3);border-radius:8px;">
          <defs>
            <marker id="fe-ar" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#52b788"/></marker>
          </defs>
          <!-- Raw Data box -->
          <rect x="8" y="55" width="68" height="50" rx="8" fill="rgba(82,183,136,0.1)" stroke="#2d6a4f" stroke-width="1.5"/>
          <text x="42" y="75" text-anchor="middle" fill="#7a9e8a" font-size="8" font-weight="bold">RAW DATA</text>
          <text x="42" y="88" text-anchor="middle" fill="#7a9e8a" font-size="7">age: 34</text>
          <text x="42" y="98" text-anchor="middle" fill="#7a9e8a" font-size="7">DOB: 1990</text>
          <!-- Arrow 1 -->
          <line x1="76" y1="80" x2="96" y2="80" stroke="#52b788" stroke-width="1.5" marker-end="url(#fe-ar)"/>
          <!-- Transform box -->
          <rect x="97" y="48" width="72" height="64" rx="8" fill="rgba(244,162,97,0.1)" stroke="rgba(244,162,97,0.4)" stroke-width="1.5"/>
          <text x="133" y="68" text-anchor="middle" fill="#f4a261" font-size="8" font-weight="bold">TRANSFORM</text>
          <text x="133" y="81" text-anchor="middle" fill="#f9c784" font-size="7">normalise</text>
          <text x="133" y="91" text-anchor="middle" fill="#f9c784" font-size="7">encode cat.</text>
          <text x="133" y="101" text-anchor="middle" fill="#f9c784" font-size="7">extract date</text>
          <!-- Arrow 2 -->
          <line x1="169" y1="80" x2="189" y2="80" stroke="#52b788" stroke-width="1.5" marker-end="url(#fe-ar)"/>
          <!-- Features box -->
          <rect x="190" y="48" width="72" height="64" rx="8" fill="rgba(82,183,136,0.15)" stroke="#52b788" stroke-width="1.5"/>
          <text x="226" y="68" text-anchor="middle" fill="#52b788" font-size="8" font-weight="bold">FEATURES</text>
