          <circle cx="95" cy="55" r="5" fill="#52b788" opacity="0.8"/>
          <circle cx="65" cy="60" r="5" fill="#52b788" opacity="0.8"/>
          <circle cx="88" cy="85" r="6" fill="#52b788" opacity="0.7"/>
          <circle cx="72" cy="80" r="4" fill="#74c69d" opacity="0.7"/>
