<section id="taxonomy">
  <div class="section-header fade-in">
    <div class="section-tag">Classification</div>
    <h2>The ML Taxonomy</h2>
    <p>Machine learning branches into distinct families based on how models learn from data.</p>
  </div>
  <div class="taxonomy-wrap fade-in">
    <div class="tax-tree">
      <!-- ROOT -->
      <div class="tax-root">
        <div class="tax-node root">🧠 Machine Learning</div>
        <div class="tax-connector-v"></div>
        <!-- horizontal bar -->
        <div style="display:flex;align-items:flex-start;gap:0;">
          <!-- branch lines drawn with CSS border tricks via flex -->
