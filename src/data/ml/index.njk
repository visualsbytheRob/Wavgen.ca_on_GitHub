<style>
:root {
    --bg-deep: #1a1a2e;
    --bg-mid: #16213e;
    --bg-card: #0f3460;
    --green-dark: #2d6a4f;
    --green-mid: #40916c;
    --green-light: #52b788;
    --green-pale: #74c69d;
    --gold: #f4a261;
    --gold-light: #f9c784;
    --text-primary: #e8f5e9;
    --text-secondary: #b7e4c7;
    --text-muted: #7a9e8a;
    --border: rgba(82,183,136,0.2);
    --card-bg: rgba(15,52,96,0.6);
    --card-hover: rgba(45,106,79,0.3);
    --shadow: 0 8px 32px rgba(0,0,0,0.4);
    --radius: 16px;
    --radius-sm: 8px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--bg-deep);
    color: var(--text-primary);
    line-height: 1.6;
    overflow-x: hidden;
  }
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--bg-deep); }
  ::-webkit-scrollbar-thumb { background: var(--green-dark); border-radius: 4px; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(26,26,46,0.95); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem; height: 60px;
    display: flex; align-items: center; gap: 0;
  }
  .nav-logo {
    font-size: 1.1rem; font-weight: 700; color: var(--green-light);
    margin-right: 2rem; white-space: nowrap;
    display: flex; align-items: center; gap: 8px;
  }
  .nav-logo span { color: var(--gold); }
  .nav-links { display: flex; list-style: none; overflow-x: auto; scrollbar-width: none; }
  .nav-links::-webkit-scrollbar { display: none; }
  .nav-links a {
    color: var(--text-secondary); text-decoration: none;
    padding: 0 1rem; height: 60px; display: flex; align-items: center;
    font-size: 0.85rem; font-weight: 500;
    border-bottom: 2px solid transparent; transition: all 0.25s; white-space: nowrap;
  }
  .nav-links a:hover {
    color: var(--green-light); border-bottom-color: var(--green-light);
    background: rgba(82,183,136,0.08);
  }

  /* LAYOUT */
  .world-main { padding-top: 60px; }
  section { padding: 80px 2rem; max-width: 1300px; margin: 0 auto; }
  .full-section { padding: 80px 0; }
  .full-section > .inner { max-width: 1300px; margin: 0 auto; padding: 0 2rem; }
  .section-header { text-align: center; margin-bottom: 60px; }
  .section-header h2 { font-size: 2.2rem; font-weight: 700; color: var(--green-light); margin-bottom: 12px; }
  .section-header p { color: var(--text-muted); font-size: 1.05rem; max-width: 600px; margin: 0 auto; }
  .section-tag {
    display: inline-block; background: rgba(82,183,136,0.15); color: var(--green-light);
    border: 1px solid var(--border); border-radius: 20px;
    padding: 4px 16px; font-size: 0.8rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 16px;
  }

  /* CARDS */
  .card {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 28px; transition: all 0.3s; backdrop-filter: blur(8px);
  }
  .card:hover {
    transform: translateY(-4px); border-color: var(--green-light);
    box-shadow: 0 16px 48px rgba(82,183,136,0.15); background: var(--card-hover);
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 28px; border-radius: 8px;
    font-size: 0.95rem; font-weight: 600; cursor: pointer; border: none;
    transition: all 0.25s; text-decoration: none;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--green-dark), var(--green-mid));
    color: #fff; box-shadow: 0 4px 16px rgba(45,106,79,0.4);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(45,106,79,0.5); }
  .btn-gold {
    background: linear-gradient(135deg, #e07b39, var(--gold));
    color: #fff; box-shadow: 0 4px 16px rgba(244,162,97,0.3);
  }
  .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(244,162,97,0.4); }

  /* HERO */
  #home {
    position: relative; min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 80px 2rem 60px; overflow: hidden;
    background: radial-gradient(ellipse at 30% 50%, rgba(45,106,79,0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 30%, rgba(244,162,97,0.08) 0%, transparent 50%),
                var(--bg-deep);
  }
  #hero-canvas { position: absolute; inset: 0; z-index: 0; opacity: 0.7; }
  .hero-content { position: relative; z-index: 1; max-width: 800px; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(82,183,136,0.15); border: 1px solid rgba(82,183,136,0.4);
    border-radius: 30px; padding: 8px 20px; font-size: 0.85rem;
    color: var(--green-pale); margin-bottom: 28px; animation: fadeInDown 0.6s ease;
  }
  .hero-badge::before {
    content: ''; width: 8px; height: 8px; background: var(--green-light);
    border-radius: 50%; animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.3)} }
  .hero-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 800; line-height: 1.15;
    margin-bottom: 20px; animation: fadeInUp 0.7s ease 0.1s both;
  }
  .hero-title .highlight {
    background: linear-gradient(135deg, var(--green-light), var(--gold));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .hero-subtitle {
    font-size: 1.15rem; color: var(--text-secondary); margin-bottom: 40px;
    animation: fadeInUp 0.7s ease 0.2s both; max-width: 600px; margin-left: auto; margin-right: auto;
  }
  .hero-stats {
    display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;
    margin-bottom: 40px; animation: fadeInUp 0.7s ease 0.3s both;
  }
  .hero-stat {
    background: rgba(82,183,136,0.1); border: 1px solid rgba(82,183,136,0.25);
    border-radius: 12px; padding: 16px 24px; text-align: center; min-width: 130px;
  }
  .hero-stat .stat-num { font-size: 1.8rem; font-weight: 800; color: var(--gold); display: block; line-height: 1; }
  .hero-stat .stat-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px; display: block; }
  .hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; animation: fadeInUp 0.7s ease 0.4s both; }
  @keyframes fadeInDown { from{opacity:0;transform:translateY(-20px)} to{opacity:1;transform:translateY(0)} }
  @keyframes fadeInUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }

  /* TAXONOMY */
  #taxonomy { background: rgba(15,40,80,0.3); }
  .taxonomy-wrap { overflow-x: auto; padding: 20px 0; }
  .tax-tree {
    display: flex; align-items: flex-start; gap: 0;
    min-width: 900px; justify-content: center; padding: 20px;
  }
  .tax-root {
    display: flex; flex-direction: column; align-items: center;
  }
  .tax-node {
    background: linear-gradient(135deg, var(--green-dark), var(--green-mid));
    color: #fff; border-radius: 10px; padding: 10px 18px;
    font-size: 0.85rem; font-weight: 700; text-align: center;
    box-shadow: 0 4px 16px rgba(45,106,79,0.4); white-space: nowrap;
    transition: all 0.25s; cursor: default;
  }
  .tax-node:hover { transform: scale(1.05); }
  .tax-node.root { font-size: 1rem; padding: 14px 28px; background: linear-gradient(135deg, #1a4a33, var(--green-dark)); }
  .tax-node.leaf {
    background: rgba(82,183,136,0.15); border: 1px solid rgba(82,183,136,0.3);
    color: var(--green-pale); font-size: 0.78rem; padding: 7px 14px;
  }
  .tax-node.leaf:hover { background: rgba(82,183,136,0.25); }
  .tax-connector-v { width: 2px; height: 24px; background: var(--green-dark); margin: 0 auto; }
  .tax-connector-h { height: 2px; background: var(--green-dark); }
  .tax-branches { display: flex; align-items: flex-start; }
  .tax-branch { display: flex; flex-direction: column; align-items: center; padding: 0 12px; }
  .tax-leaves { display: flex; flex-direction: column; gap: 8px; align-items: center; margin-top: 8px; }
  .tax-category {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--text-muted); text-align: center; margin-bottom: 6px;
  }

  /* CONCEPT CARDS */
  .concepts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(360px, 1fr)); gap: 28px; }
  .concept-card {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 32px; transition: all 0.3s; backdrop-filter: blur(8px);
  }
  .concept-card:hover {
    transform: translateY(-6px); border-color: var(--green-light);
    box-shadow: 0 20px 60px rgba(82,183,136,0.12);
  }
  .concept-icon {
    width: 48px; height: 48px;
    background: linear-gradient(135deg, var(--green-dark), var(--green-mid));
    border-radius: 12px; display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; margin-bottom: 16px;
  }
  .concept-card h3 { font-size: 1.2rem; font-weight: 700; color: var(--green-light); margin-bottom: 12px; }
  .concept-card p { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 20px; line-height: 1.7; }
  .concept-diagram { width: 100%; border-radius: 8px; overflow: hidden; margin-top: 8px; }

  /* ALGORITHM GALLERY */
  .algo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }
  .algo-card {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 24px; cursor: pointer;
    transition: all 0.3s; position: relative; overflow: hidden;
  }
  .algo-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--green-dark), var(--green-light), var(--gold));
    transform: scaleX(0); transition: transform 0.3s; transform-origin: left;
  }
  .algo-card:hover::before { transform: scaleX(1); }
  .algo-card:hover { transform: translateY(-5px); border-color: var(--green-light); box-shadow: 0 16px 48px rgba(82,183,136,0.15); }
  .algo-card h3 { font-size: 1rem; font-weight: 700; color: var(--green-pale); margin: 12px 0 8px; }
  .algo-card p { font-size: 0.82rem; color: var(--text-muted); line-height: 1.6; }
  .algo-type-badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
  .badge-supervised { background: rgba(82,183,136,0.2); color: var(--green-light); }
  .badge-unsupervised { background: rgba(244,162,97,0.2); color: var(--gold); }
  .badge-ensemble { background: rgba(116,198,157,0.2); color: var(--green-pale); }
  .badge-neural { background: rgba(128,216,164,0.2); color: #80d8a4; }

  /* USE CASES */
  .usecases-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }
  .usecase-card {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 28px; transition: all 0.3s;
  }
  .usecase-card:hover { transform: translateY(-4px); border-color: var(--gold); box-shadow: 0 16px 48px rgba(244,162,97,0.12); }
  .usecase-icon { font-size: 2.4rem; margin-bottom: 14px; display: block; }
  .usecase-card h3 { font-size: 1.05rem; font-weight: 700; color: var(--gold); margin-bottom: 8px; }
  .usecase-card p { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.65; margin-bottom: 12px; }
  .usecase-tag {
    display: inline-block; background: rgba(244,162,97,0.15); color: var(--gold-light);
    border: 1px solid rgba(244,162,97,0.2); border-radius: 20px;
    padding: 2px 10px; font-size: 0.72rem; font-weight: 600; margin: 2px;
  }

  /* DEMO */
  #demo { background: rgba(15,52,96,0.1); }
  .demo-container { display: grid; grid-template-columns: 1fr 340px; gap: 32px; align-items: start; }
  @media(max-width:900px){ .demo-container{grid-template-columns:1fr;} }
  #demo-canvas {
    width: 100%; height: 440px; background: rgba(8,16,32,0.9);
    border: 1px solid var(--border); border-radius: var(--radius);
    cursor: crosshair; display: block;
  }
  .demo-controls { display: flex; flex-direction: column; gap: 16px; }
  .demo-controls h3 { font-size: 1.2rem; font-weight: 700; color: var(--green-light); }
  .demo-controls p { font-size: 0.87rem; color: var(--text-muted); line-height: 1.6; }
  .class-selector { display: flex; gap: 10px; }
  .class-btn {
    flex: 1; padding: 10px; border-radius: 8px; border: 2px solid transparent;
    cursor: pointer; font-weight: 600; font-size: 0.85rem; transition: all 0.2s;
    background: rgba(255,255,255,0.05); color: var(--text-primary);
  }
  .class-btn.active-green { border-color: var(--green-light); background: rgba(82,183,136,0.2); color: var(--green-light); }
  .class-btn.active-red { border-color: #e07070; background: rgba(220,100,100,0.2); color: #e07070; }
  .demo-stats {
    background: rgba(0,0,0,0.3); border-radius: 8px; padding: 14px;
    font-size: 0.82rem; color: var(--text-muted); line-height: 1.8;
  }
  .demo-stats span { color: var(--green-light); font-weight: 600; }

  /* RESOURCES */
  .tabs {
    display: flex; gap: 4px; background: rgba(0,0,0,0.3);
    border-radius: 12px; padding: 4px; margin-bottom: 32px; flex-wrap: wrap;
  }
  .tab-btn {
    padding: 10px 20px; border: none; border-radius: 8px; background: transparent;
    color: var(--text-muted); font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all 0.25s;
  }
  .tab-btn.active { background: linear-gradient(135deg, var(--green-dark), var(--green-mid)); color: #fff; }
  .tab-btn:hover:not(.active) { color: var(--text-primary); background: rgba(255,255,255,0.05); }
  .tab-content { display: none; }
  .tab-content.active { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
  .resource-card {
    background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 20px; transition: all 0.25s; text-decoration: none; color: inherit; display: block;
  }
  .resource-card:hover { border-color: var(--green-light); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(82,183,136,0.12); }
  .resource-card h4 { color: var(--green-light); font-size: 0.95rem; margin-bottom: 6px; }
  .resource-card p { color: var(--text-muted); font-size: 0.82rem; }
  .resource-card .resource-link { color: var(--gold); font-size: 0.78rem; margin-top: 8px; display: block; }

  /* ROADMAP */
  .roadmap-path {
    display: flex; flex-direction: column; position: relative;
    max-width: 800px; margin: 0 auto;
  }
  .roadmap-path::before {
    content: ''; position: absolute; left: 40px; top: 0; bottom: 0; width: 2px;
    background: linear-gradient(to bottom, var(--green-dark), var(--green-light), var(--gold));
  }
  .roadmap-step { display: flex; gap: 28px; align-items: flex-start; padding: 28px 0; position: relative; }
  .step-circle {
    width: 80px; height: 80px; min-width: 80px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; position: relative; z-index: 1; border: 3px solid;
  }
  .step-circle.s1{background:rgba(45,106,79,.3);border-color:var(--green-dark);}
  .step-circle.s2{background:rgba(64,145,108,.3);border-color:var(--green-mid);}
  .step-circle.s3{background:rgba(82,183,136,.3);border-color:var(--green-light);}
  .step-circle.s4{background:rgba(116,198,157,.3);border-color:var(--green-pale);}
  .step-circle.s5{background:rgba(244,162,97,.3);border-color:var(--gold);}
  .step-circle.s6{background:rgba(249,199,132,.3);border-color:var(--gold-light);}
  .step-content { padding-top: 12px; }
  .step-content h3 { font-size: 1.15rem; font-weight: 700; color: var(--green-light); margin-bottom: 6px; }
  .step-content p { color: var(--text-secondary); font-size: 0.88rem; line-height: 1.65; }
  .step-topics { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
  .step-topic {
    background: rgba(82,183,136,0.12); border: 1px solid rgba(82,183,136,0.2);
    border-radius: 20px; padding: 3px 10px; font-size: 0.75rem; color: var(--green-pale);
  }

  /* CHEAT SHEET */
  .cheat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 16px; }
  .cheat-card {
    background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 18px; cursor: pointer; transition: all 0.25s; position: relative;
  }
  .cheat-card:hover { border-color: var(--green-light); background: var(--card-hover); }
  .cheat-card.copied { border-color: var(--gold); background: rgba(244,162,97,0.1); }
  .cheat-card h4 { font-size: 0.88rem; font-weight: 700; color: var(--gold); margin-bottom: 6px; font-family: 'Courier New', monospace; }
  .cheat-card p { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.55; }
  .copy-hint { position: absolute; top: 8px; right: 10px; font-size: 0.65rem; color: var(--text-muted); opacity: 0; transition: opacity 0.2s; }
  .cheat-card:hover .copy-hint { opacity: 1; }

  /* FOOTER */
  footer { background: rgba(10,15,30,0.8); border-top: 1px solid var(--border); text-align: center; padding: 40px 2rem; color: var(--text-muted); font-size: 0.85rem; }
  footer span { color: var(--green-light); }
  .section-divider { height: 1px; background: linear-gradient(90deg, transparent, var(--border), transparent); }
  .fade-in { opacity: 0; transform: translateY(20px); transition: all 0.6s ease; }
  .fade-in.visible { opacity: 1; transform: translateY(0); }
  @media(max-width:768px){ .concepts-grid{grid-template-columns:1fr;} section{padding:60px 1rem;} }

/* ── Wavgen back link inside world nav ── */
.nav-brand-group { display:flex; align-items:center; gap:0.9rem; }
