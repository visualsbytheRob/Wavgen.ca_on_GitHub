<!-- CONCEPT CARDS -->
<section id="concepts">
  <div class="section-header fade-in">
    <div class="section-tag">Foundations</div>
    <h2>Core ML Concepts</h2>
    <p>Six essential ideas every ML practitioner needs to understand deeply.</p>
  </div>
  <div class="concepts-grid">

    <!-- Card 1: Supervised Learning -->
    <div class="concept-card fade-in">
      <div class="concept-icon">📊</div>
      <h3>Supervised Learning</h3>
      <p>The model learns a mapping from inputs to outputs using labeled training examples. Each example is a (input, correct output) pair. The model minimizes the difference between its predictions and the true labels.</p>
      <div class="concept-diagram">
        <svg viewBox="0 0 340 160" xmlns="http://www.w3.org/2000/svg" style="background:rgba(0,0,0,0.3);border-radius:8px;">
          <!-- Data source -->
          <rect x="10" y="55" width="70" height="50" rx="8" fill="rgba(45,106,79,0.3)" stroke="#2d6a4f" stroke-width="1.5"/>
          <text x="45" y="76" text-anchor="middle" fill="#74c69d" font-size="10" font-weight="bold">Labeled</text>
          <text x="45" y="90" text-anchor="middle" fill="#74c69d" font-size="10">Data</text>
          <text x="45" y="104" text-anchor="middle" fill="#7a9e8a" font-size="9">(X, y)</text>
          <!-- Arrow 1 -->
          <path d="M82 80 L115 80" stroke="#52b788" stroke-width="2" marker-end="url(#ah)"/>
          <!-- Model box -->
          <rect x="118" y="50" width="80" height="60" rx="8" fill="rgba(64,145,108,0.25)" stroke="#40916c" stroke-width="1.5"/>
          <text x="158" y="76" text-anchor="middle" fill="#52b788" font-size="10" font-weight="bold">Model</text>
          <text x="158" y="90" text-anchor="middle" fill="#7a9e8a" font-size="9">Training</text>
          <text x="158" y="103" text-anchor="middle" fill="#7a9e8a" font-size="9">Loop</text>
          <!-- Arrow 2 -->
          <path d="M200 80 L233 80" stroke="#52b788" stroke-width="2" marker-end="url(#ah)"/>
          <!-- Output -->
          <rect x="236" y="55" width="80" height="50" rx="8" fill="rgba(244,162,97,0.2)" stroke="#f4a261" stroke-width="1.5"/>
          <text x="276" y="76" text-anchor="middle" fill="#f9c784" font-size="10" font-weight="bold">Predict</text>
          <text x="276" y="90" text-anchor="middle" fill="#f9c784" font-size="10">ŷ</text>
          <text x="276" y="104" text-anchor="middle" fill="#7a9e8a" font-size="9">output</text>
          <!-- Feedback arrow -->
          <path d="M276 107 Q276 140 158 140 Q40 140 45 107" stroke="#f4a261" stroke-width="1.5" fill="none" stroke-dasharray="4,3" marker-end="url(#ahg)"/>
