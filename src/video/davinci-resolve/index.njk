(function initPageNav() {
  const canvas = document.getElementById('isometric-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;

  const PAGE_DEFS = [
    { name:'Deliver',   col:'#dc2626', icon:'⬆', desc:'Export your project in any format — H.264, ProRes, IMF, DCP. Set render queues, custom presets, and burn-ins.', tools:['Render Queue','Custom Presets','IMF/DCP','Burn-Ins'], workflow:'Final step: configure delivery settings and submit to render.' },
    { name:'Fairlight', col:'#8b5cf6', icon:'♪', desc:'Professional DAW built into Resolve. ADR, noise reduction, Foley, mix bus processing, and Atmos support.', tools:['ADR','Noise Reduction','Mix Bus','Atmos'], workflow:'Step 5: audio finishing and dialogue cleanup.' },
    { name:'Color',     col:'#34d399', icon:'◑', desc:'The industry-standard color grading environment. Nodes, scopes, qualifiers, power windows, OpenFX.', tools:['Node Tree','Scopes','Qualifier','OpenFX'], workflow:'Step 4: primary and secondary color correction.' },
    { name:'Fusion',    col:'#3b82f6', icon:'✦', desc:'Node-based 2D/3D compositing, keying, tracking, particle effects, and motion graphics pipeline.', tools:['Compositor','3D Space','Keyer','Tracker'], workflow:'Step 3: VFX, compositing, and motion graphics.' },
    { name:'Edit',      col:'#d97706', icon:'✂', desc:'Full-featured timeline editor. Multicam, magnetic timeline, speed ramps, subtitle tools, and audio sync.', tools:['Timeline','Multicam','Speed Ramps','Subtitles'], workflow:'Step 2: assemble and refine your edit.' },
    { name:'Cut',       col:'#f59e0b', icon:'⚡', desc:'Streamlined fast-cut page with source tape, smart insert, sync bin, and DaVinci Neural Engine cut detection.', tools:['Smart Insert','Sync Bin','Source Tape','Cut Detection'], workflow:'Step 1: fast assembly and rough cut.' },
  ];

  const lfFloor = new LagFilter(0.5);
  const lfElevator = new LagFilter(0.6);
  let selectedFloor = null;
  let elevatorTarget = 0;
  let elevatorPos = 0;
  let hoverFloor = null;

  // Isometric floor dimensions
  const FLOOR_H = 52, GAP = 8;
  const ISO_W = 200, ISO_D = 60;
  const startX = W/2, startY = H - 30;

  function floorY(fi) {
    return startY - fi * (FLOOR_H + GAP);
  }

  function drawFloor(fi, floor, hover, selected) {
    const y = floorY(fi);
    const x = startX;
    const col = floor.col;
    const alpha = selected ? 1.0 : hover ? 0.85 : 0.65;

    // Parse col to rgba
    const r=parseInt(col.slice(1,3),16);
    const g=parseInt(col.slice(3,5),16);
    const b=parseInt(col.slice(5,7),16);

    // Top face
    ctx.beginPath();
    ctx.moveTo(x, y);
    ctx.lineTo(x+ISO_W/2, y-ISO_D/2);
    ctx.lineTo(x+ISO_W/2, y-ISO_D/2-FLOOR_H);
    ctx.lineTo(x, y-FLOOR_H);
    ctx.lineTo(x-ISO_W/2, y-ISO_D/2-FLOOR_H);
    ctx.lineTo(x-ISO_W/2, y-ISO_D/2);
    ctx.closePath();
    ctx.fillStyle=`rgba(${r},${g},${b},${alpha*0.4})`;
    ctx.strokeStyle=`rgba(${r},${g},${b},${alpha})`;
    ctx.lineWidth=1.5;
    if(selected){ctx.shadowColor=col;ctx.shadowBlur=16;}
    ctx.fill(); ctx.stroke(); ctx.shadowBlur=0;

    // Top face highlight
    ctx.beginPath();
    ctx.moveTo(x, y-FLOOR_H);
    ctx.lineTo(x+ISO_W/2, y-ISO_D/2-FLOOR_H);
    ctx.lineTo(x, y-ISO_D-FLOOR_H);
    ctx.lineTo(x-ISO_W/2, y-ISO_D/2-FLOOR_H);
    ctx.closePath();
    ctx.fillStyle=`rgba(${r},${g},${b},${alpha*0.6})`;
    ctx.fill();

    // Floor label
    ctx.fillStyle=`rgba(${r},${g},${b},1)`;
    ctx.font=`bold 10px monospace`;
    ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillText(floor.icon+' '+floor.name, x, y-FLOOR_H*0.5-ISO_D*0.15);

    // Right face
    ctx.beginPath();
    ctx.moveTo(x+ISO_W/2, y-ISO_D/2);
    ctx.lineTo(x+ISO_W/2, y-ISO_D/2-FLOOR_H);
    ctx.lineTo(x, y-FLOOR_H);
    ctx.lineTo(x, y);
    ctx.closePath();
    ctx.fillStyle=`rgba(${Math.floor(r*0.5)},${Math.floor(g*0.5)},${Math.floor(b*0.5)},${alpha*0.5})`;
    ctx.fill();
    ctx.strokeStyle=`rgba(${r},${g},${b},${alpha*0.5})`; ctx.lineWidth=0.5;
    ctx.stroke();

    // Left face
    ctx.beginPath();
    ctx.moveTo(x-ISO_W/2, y-ISO_D/2);
    ctx.lineTo(x-ISO_W/2, y-ISO_D/2-FLOOR_H);
    ctx.lineTo(x, y-FLOOR_H);
    ctx.lineTo(x, y);
    ctx.closePath();
    ctx.fillStyle=`rgba(${Math.floor(r*0.35)},${Math.floor(g*0.35)},${Math.floor(b*0.35)},${alpha*0.4})`;
    ctx.fill();
    ctx.strokeStyle=`rgba(${r},${g},${b},${alpha*0.3})`; ctx.lineWidth=0.5;
    ctx.stroke();
  }

  function drawElevator(pos) {
    const ep = lfElevator.update(elevatorTarget, 0.016);
    const x = startX + ISO_W*0.35;
    const y = floorY(ep) - FLOOR_H*0.4;
    ctx.beginPath(); ctx.arc(x, y, 5, 0, Math.PI*2);
    ctx.fillStyle='#d97706';
    ctx.shadowColor='#d97706'; ctx.shadowBlur=8;
    ctx.fill(); ctx.shadowBlur=0;
    // Shaft line
    ctx.strokeStyle='rgba(217,119,6,0.3)'; ctx.lineWidth=1;
    ctx.setLineDash([3,4]);
    ctx.beginPath(); ctx.moveTo(x, floorY(0)-10); ctx.lineTo(x, floorY(5)-FLOOR_H);
    ctx.stroke(); ctx.setLineDash([]);
  }

  canvas.addEventListener('click', e => {
    const rect=canvas.getBoundingClientRect();
    const mx=(e.clientX-rect.left)*(W/rect.width);
    const my=(e.clientY-rect.top)*(H/rect.height);
    for(let fi=0;fi<PAGE_DEFS.length;fi++){
      const fy=floorY(fi);
      // Hit test: rough bounding box
      if(my>fy-FLOOR_H-ISO_D&&my<fy&&Math.abs(mx-startX)<ISO_W/2+20){
        selectedFloor=fi;
        elevatorTarget=fi;
        const detail=document.getElementById('page-detail');
        if(detail){
          const pd=PAGE_DEFS[fi];
          detail.innerHTML=`
            <h3 style="color:${pd.col}">${pd.icon} ${pd.name} Page</h3>
            <p>${pd.desc}</p>
            <div style="font-size:11px;color:var(--dim);margin-bottom:8px;font-style:italic">${pd.workflow}</div>
            <div class="page-tools">${pd.tools.map(t=>`<span class="tool-tag">${t}</span>`).join('')}</div>`;
        }
        break;
      }
    }
  });

  canvas.addEventListener('mousemove', e => {
    const rect=canvas.getBoundingClientRect();
    const my=(e.clientY-rect.top)*(H/rect.height);
    const mx=(e.clientX-rect.left)*(W/rect.width);
    hoverFloor=null;
    for(let fi=0;fi<PAGE_DEFS.length;fi++){
      const fy=floorY(fi);
      if(my>fy-FLOOR_H-ISO_D&&my<fy&&Math.abs(mx-startX)<ISO_W/2+20){
        hoverFloor=fi; break;
      }
    }
    canvas.style.cursor=hoverFloor!==null?'pointer':'default';
  });

  let isoLastTime=null;
  function isoLoop(ts){
    if(!isoLastTime)isoLastTime=ts;
    const dt=Math.min((ts-isoLastTime)/1000,0.1);
    isoLastTime=ts;

    ctx.fillStyle='rgba(10,10,15,0.08)';
    ctx.fillRect(0,0,W,H);

    // Draw floors bottom to top
    for(let fi=0;fi<PAGE_DEFS.length;fi++){
      drawFloor(fi, PAGE_DEFS[fi], hoverFloor===fi, selectedFloor===fi);
    }

    drawElevator(elevatorTarget);

    // Base platform shadow
    ctx.beginPath();
    ctx.ellipse(startX, startY+8, ISO_W*0.6, 14, 0, 0, Math.PI*2);
    ctx.fillStyle='rgba(10,10,15,0.6)';
    ctx.fill();

    requestAnimationFrame(isoLoop);
  }
  requestAnimationFrame(isoLoop);
})();

// ============================================================
// INTERSECTION OBSERVER — REVEAL ANIMATIONS
// ============================================================
(function initReveal() {
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.10 });

  document.querySelectorAll('.hidden').forEach(el => observer.observe(el));
})();

// ============================================================
// NAV — ACTIVE LINK HIGHLIGHTING
// ============================================================
(function initNav() {
  const sections = document.querySelectorAll('[id]');
  const navLinks = document.querySelectorAll('.nav-links a');

  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          link.style.color = link.getAttribute('href') === '#'+id
            ? 'var(--accent)' : '';
        });
      }
    });
  }, { threshold: 0.3 });

  sections.forEach(s => obs.observe(s));
})();

