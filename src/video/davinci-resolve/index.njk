<script>
'use strict';

// ============================================================
// LAGFILTER — MANDATORY ON ALL ANIMATED PARAMETERS
// ============================================================
class LagFilter {
  constructor(tau) { this.tau = tau; this.value = null; }
  update(target, dt) {
    if (this.value === null) this.value = target;
    this.value += (1 - Math.exp(-dt / this.tau)) * (target - this.value);
    return this.value;
  }
}

// ============================================================
// UTILS
// ============================================================
function hsl2rgb(h, s, l) {
  s /= 100; l /= 100;
  const k = n => (n + h / 30) % 12;
  const a = s * Math.min(l, 1 - l);
  const f = n => l - a * Math.max(-1, Math.min(k(n) - 3, Math.min(9 - k(n), 1)));
  return [Math.round(f(0)*255), Math.round(f(8)*255), Math.round(f(4)*255)];
}

function rgb2hsl(r, g, b) {
  r /= 255; g /= 255; b /= 255;
  const max = Math.max(r,g,b), min = Math.min(r,g,b);
  let h, s, l = (max+min)/2;
  if (max === min) { h = s = 0; }
  else {
    const d = max - min;
    s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
    switch(max) {
      case r: h = ((g-b)/d + (g<b?6:0))/6; break;
      case g: h = ((b-r)/d + 2)/6; break;
      case b: h = ((r-g)/d + 4)/6; break;
    }
  }
  return [h*360, s*100, l*100];
}

function clamp(v,a,b){return Math.max(a,Math.min(b,v));}

// ============================================================
// SECTION 1 — HERO CANVAS (3 scopes side by side)
// ============================================================
(function initHero() {
  const canvas = document.getElementById('hero-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const third = W / 3;

  // LagFilters for hero animations
  const lfDrift = new LagFilter(2.0);
  const lfVecPhase = new LagFilter(1.5);
  const lfFilmScroll = new LagFilter(0.8);

  let driftTarget = 0;
  let vecPhaseTarget = 0;
  let filmScrollTarget = 0;
  let filmScrollPos = 0;
  let lastTime = null;
  let frameCount = 0;

  // Synthetic film frame colors for filmstrip section
  const filmGrades = [
    // [shadows rgb, mids rgb, highlights rgb, name]
    { s:[20,15,30], m:[180,140,90], h:[255,230,200], name:'Warm' },
    { s:[10,20,30], m:[80,120,160], h:[200,220,240], name:'Cool' },
    { s:[10,40,40], m:[80,160,140], h:[230,200,60], name:'Teal-Orng' },
    { s:[5,5,5],    m:[100,100,100], h:[220,220,220], name:'Noir' },
    { s:[20,22,18], m:[130,135,125], h:[240,242,235], name:'Natural' },
    { s:[30,25,10], m:[160,150,120], h:[220,210,180], name:'Bleach' },
  ];

  function drawHeroWaveform(t) {
    const x0 = 0, y0 = 0, w = third, h = H;
    ctx.save();
    ctx.beginPath(); ctx.rect(x0,y0,w,h); ctx.clip();
    ctx.fillStyle = 'rgba(10,10,15,0.05)';
    ctx.fillRect(x0,y0,w,h);

    // Grid lines
    ctx.strokeStyle = 'rgba(30,30,46,0.5)'; ctx.lineWidth = 0.5;
    for (let i=0;i<=4;i++) {
      const yy = y0 + (i/4)*h;
      ctx.beginPath(); ctx.moveTo(x0,yy); ctx.lineTo(x0+w,yy); ctx.stroke();
    }
    ctx.strokeStyle = 'rgba(30,30,46,0.3)'; ctx.lineWidth = 0.3;
    for (let i=0;i<=8;i++) {
      const xx = x0 + (i/8)*w;
      ctx.beginPath(); ctx.moveTo(xx,y0); ctx.lineTo(xx,y0+h); ctx.stroke();
    }

    // Labels
    ctx.fillStyle = 'rgba(107,107,138,0.6)'; ctx.font = '9px monospace';
    ctx.fillText('1023', x0+3, y0+11);
    ctx.fillText('512',  x0+3, y0+h/2+4);
    ctx.fillText('0',    x0+3, y0+h-3);
    ctx.fillText('WAVEFORM', x0+w/2-26, y0+h-3);

    // Drift value (LagFilter)
    const drift = lfDrift.update(driftTarget, 0.016) * 0.05;

    // Draw luminance trace — simulated film scene
    ctx.strokeStyle = '#d97706';
    ctx.lineWidth = 1.2;
    ctx.shadowColor = '#d97706';
    ctx.shadowBlur = 4;
    ctx.beginPath();
    const cols = Math.floor(w);
    for (let xi=0; xi<cols; xi++) {
      const px = xi/cols;
      // Simulate sky (top) / ground transition / skin zone
      let lum;
      if (px < 0.35) {
        // sky zone — high luminance with variation
        lum = 0.65 + 0.15*Math.sin(t*0.7 + px*8) + 0.05*Math.sin(t*1.3+px*14) + drift;
      } else if (px < 0.55) {
        // horizon transition
        lum = 0.45 + 0.1*Math.sin(t*0.5+px*6) + drift;
      } else if (px < 0.75) {
        // skin / subject zone
        lum = 0.55 + 0.08*Math.sin(t*0.9+px*10) + 0.03*Math.cos(t*2.1) + drift;
      } else {
        // shadow zone
        lum = 0.18 + 0.06*Math.sin(t*0.6+px*12) + drift;
      }
      lum = clamp(lum, 0.01, 0.99);
      const yy = y0 + h - lum * (h - 4) - 2;
      if (xi === 0) ctx.moveTo(x0+xi, yy);
      else ctx.lineTo(x0+xi, yy);
    }
    ctx.stroke();
    ctx.shadowBlur = 0;
    ctx.restore();
  }

  // Vectorscope color points orbiting
  const vecColors = [
    { name:'Skin', hue:25,  sat:0.45, orbit:0.03, speed:0.11 },
    { name:'Sky',  hue:210, sat:0.55, orbit:0.04, speed:0.07 },
    { name:'Shad', hue:260, sat:0.25, orbit:0.02, speed:0.13 },
    { name:'Foil', hue:120, sat:0.5,  orbit:0.05, speed:0.09 },
    { name:'Gold', hue:45,  sat:0.7,  orbit:0.035,speed:0.15 },
    { name:'Neon', hue:300, sat:0.6,  orbit:0.025,speed:0.12 },
  ];
  const vecLagFilters = vecColors.map(()=>({r:new LagFilter(0.4),a:new LagFilter(0.4)}));

  function drawHeroVectorscope(t) {
    const cx = third + third/2, cy = H/2;
    const radius = Math.min(third, H)/2 - 14;
    ctx.save();
    ctx.beginPath(); ctx.rect(third, 0, third, H); ctx.clip();
    ctx.fillStyle = 'rgba(10,10,15,0.05)';
    ctx.fillRect(third, 0, third, H);

    // Outer ring
    ctx.strokeStyle = 'rgba(30,30,46,0.7)'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.arc(cx, cy, radius, 0, Math.PI*2); ctx.stroke();
    // Inner rings
    [0.25,0.5,0.75].forEach(r=>{
      ctx.strokeStyle = 'rgba(30,30,46,0.4)';
      ctx.beginPath(); ctx.arc(cx,cy,radius*r,0,Math.PI*2); ctx.stroke();
    });

    // I/Q axis lines
    ctx.strokeStyle = 'rgba(107,107,138,0.4)'; ctx.lineWidth = 0.5;
    ctx.beginPath(); ctx.moveTo(third+4, cy); ctx.lineTo(third+third-4, cy); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(cx, 4); ctx.lineTo(cx, H-4); ctx.stroke();

    // Amber target boxes at standard color positions
    const targetAngles = [
      {a:-0.52, name:'R', col:'#dc2626'},
      {a:0.52,  name:'B', col:'#3b82f6'},
      {a:2.09,  name:'G', col:'#34d399'},
      {a:-1.57, name:'Mg',col:'#d97706'},
    ];
    targetAngles.forEach(({a,name,col})=>{
      const tx = cx + Math.cos(a)*radius*0.8;
      const ty = cy + Math.sin(a)*radius*0.8;
      ctx.strokeStyle = col; ctx.lineWidth = 1.2;
      ctx.strokeRect(tx-5, ty-5, 10, 10);
      ctx.fillStyle = col; ctx.font = '8px monospace';
      ctx.fillText(name, tx+7, ty+3);
    });

    // Skin tone line
    ctx.strokeStyle = 'rgba(217,119,6,0.4)'; ctx.lineWidth = 0.8;
    ctx.setLineDash([3,3]);
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + Math.cos(0.44)*radius, cy + Math.sin(0.44)*radius);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = 'rgba(217,119,6,0.5)'; ctx.font='8px monospace';
    ctx.fillText('SKIN', cx+Math.cos(0.44)*radius*0.9, cy+Math.sin(0.44)*radius*0.9+3);

    // Color dots orbiting with LagFilter
    const vecPhase = lfVecPhase.update(vecPhaseTarget, 0.016);
    vecColors.forEach((vc, i) => {
      const targetR = (0.2 + vc.sat * 0.7) * radius;
      const targetA = (vc.hue / 180) * Math.PI + t * vc.speed + vecPhase * 0.3 + vc.orbit * Math.sin(t*1.7+i);
      const r = vecLagFilters[i].r.update(targetR, 0.016);
      const a = vecLagFilters[i].a.update(targetA, 0.016);
      const dx = cx + Math.cos(a)*r;
      const dy = cy + Math.sin(a)*r;
      const [rr,gg,bb] = hsl2rgb(vc.hue, 80, 60);
      ctx.beginPath(); ctx.arc(dx, dy, 4, 0, Math.PI*2);
      ctx.fillStyle = `rgba(${rr},${gg},${bb},0.85)`;
      ctx.shadowColor = `rgb(${rr},${gg},${bb})`; ctx.shadowBlur = 6;
      ctx.fill(); ctx.shadowBlur = 0;
    });

    // Phosphor trail accumulation dots (ambient)
    for (let i=0;i<6;i++) {
      const ang = t*0.3 + i*1.047;
      const r2 = (0.1+Math.sin(t*0.5+i)*0.15)*radius;
      const dx = cx + Math.cos(ang)*r2;
      const dy = cy + Math.sin(ang)*r2;
      ctx.beginPath(); ctx.arc(dx, dy, 1.5, 0, Math.PI*2);
      ctx.fillStyle = 'rgba(52,211,153,0.3)';
      ctx.fill();
    }

    ctx.fillStyle = 'rgba(107,107,138,0.6)'; ctx.font='9px monospace';
    ctx.fillText('VECTORSCOPE', cx-30, H-3);
    ctx.restore();
  }

  let filmFrameCache = null;
  function getFilmFrameCache() {
    if (filmFrameCache) return filmFrameCache;
    filmFrameCache = filmGrades.map(grade => {
      const oc = document.createElement('canvas');
      oc.width=80; oc.height=50;
      const oc2 = oc.getContext('2d');
      // sky gradient
      const grad = oc2.createLinearGradient(0,0,0,30);
      grad.addColorStop(0,`rgb(${grade.h[0]},${grade.h[1]},${grade.h[2]})`);
      grad.addColorStop(1,`rgb(${grade.m[0]},${grade.m[1]},${grade.m[2]})`);
      oc2.fillStyle=grad; oc2.fillRect(0,0,80,30);
      // ground
      oc2.fillStyle=`rgb(${grade.s[0]},${grade.s[1]},${grade.s[2]})`;
      oc2.fillRect(0,30,80,20);
      // subject silhouette
      oc2.fillStyle=`rgba(${grade.m[0]},${grade.m[1]},${grade.m[2]},0.7)`;
      oc2.beginPath(); oc2.ellipse(40,22,10,18,0,0,Math.PI*2); oc2.fill();
      // label
      oc2.fillStyle='rgba(255,255,255,0.6)'; oc2.font='6px monospace';
      oc2.fillText(grade.name,2,48);
      return oc;
    });
    return filmFrameCache;
  }

  function drawHeroFilmstrip(t) {
    const x0 = third*2, y0 = 0, w = third, h = H;
    ctx.save();
    ctx.beginPath(); ctx.rect(x0,y0,w,h); ctx.clip();
    ctx.fillStyle='rgba(10,10,15,0.05)'; ctx.fillRect(x0,y0,w,h);

    // Film perforations
    const perfW=8, perfH=14, perfX=x0+6;
    ctx.fillStyle='rgba(30,30,46,0.8)';
    for(let yi=0;yi<Math.ceil(h/28)+1;yi++){
      const yp = ((yi*28 - filmScrollPos*0.5) % h + h) % h;
      ctx.fillRect(perfX, y0+yp, perfW, perfH);
      ctx.fillRect(x0+w-perfX-perfW, y0+yp, perfW, perfH);
    }

    // Frame thumbnails scrolling
    const frameH = 66, frameW = w - 36, fPad=4;
    const frames = getFilmFrameCache();
    const scrollY = filmScrollPos % (frameH + fPad);

    for(let fi=-1; fi<Math.ceil(h/frameH)+2; fi++) {
      const baseY = y0 + fi*(frameH+fPad) - scrollY;
      const fIdx = ((fi + Math.floor(filmScrollPos/(frameH+fPad))) % frames.length + frames.length) % frames.length;
      if (baseY > y0+h || baseY+frameH < y0) continue;
      ctx.drawImage(frames[fIdx], x0+18, baseY, frameW, frameH);
      // Frame border
      ctx.strokeStyle='rgba(217,119,6,0.4)'; ctx.lineWidth=0.8;
      ctx.strokeRect(x0+18, baseY, frameW, frameH);
    }

    // Scan line overlay
    const scanY = y0 + ((t*80) % h);
    ctx.strokeStyle='rgba(217,119,6,0.5)'; ctx.lineWidth=1.5;
    ctx.beginPath(); ctx.moveTo(x0+16,scanY); ctx.lineTo(x0+w-16,scanY); ctx.stroke();

    ctx.fillStyle='rgba(107,107,138,0.6)'; ctx.font='9px monospace';
    ctx.fillText('FILM STRIP', x0+w/2-24, y0+h-3);
    ctx.restore();
  }

  function heroDividers() {
    ctx.strokeStyle='rgba(30,30,46,0.8)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(third,0); ctx.lineTo(third,H); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(third*2,0); ctx.lineTo(third*2,H); ctx.stroke();
  }

  function heroLoop(ts) {
    if (!lastTime) lastTime = ts;
    const dt = Math.min((ts - lastTime)/1000, 0.1);
    lastTime = ts;
    frameCount++;
    const t = ts / 1000;

    // Update lag targets periodically
    if (frameCount % 120 === 0) driftTarget = (Math.random()-0.5)*0.3;
    if (frameCount % 80 === 0) vecPhaseTarget = (Math.random()-0.5)*0.5;

    filmScrollPos += lfFilmScroll.update(1.2, dt) * dt * 28;

    // Phosphor persistence
    ctx.fillStyle='rgba(10,10,15,0.05)';
    ctx.fillRect(0,0,W,H);

    drawHeroWaveform(t);
    drawHeroVectorscope(t);
    drawHeroFilmstrip(t);
    heroDividers();

    requestAnimationFrame(heroLoop);
  }

  requestAnimationFrame(heroLoop);
})();

// ============================================================
// SECTION 2 — SCOPES EXPLORER
// ============================================================
(function initScopes() {
  const sourceCanvas = document.getElementById('scope-source');
  const wfCanvas = document.getElementById('scope-waveform');
  const vcCanvas = document.getElementById('scope-vector');
  const prCanvas = document.getElementById('scope-parade');
  const hiCanvas = document.getElementById('scope-histogram');
  if (!sourceCanvas || !wfCanvas) return;

  const sCtx = sourceCanvas.getContext('2d');
  const wCtx = wfCanvas.getContext('2d');
  const vCtx = vcCanvas.getContext('2d');
  const pCtx = prCanvas.getContext('2d');
  const hCtx = hiCanvas.getContext('2d');

  // LagFilters for all scope parameters
  const lfExposure = new LagFilter(0.25);
  const lfTemp     = new LagFilter(0.25);
  const lfTint     = new LagFilter(0.25);
  const lfSat      = new LagFilter(0.25);

  let expTarget=0, tempTarget=0, tintTarget=0, satTarget=100;

  // Wire up sliders
  const sliders = [
    { el: document.getElementById('sc-exposure'), val: document.getElementById('sc-exposure-val'),
      onChange: v => { expTarget=parseFloat(v); } },
    { el: document.getElementById('sc-temp'), val: document.getElementById('sc-temp-val'),
      onChange: v => { tempTarget=parseFloat(v); } },
    { el: document.getElementById('sc-tint'), val: document.getElementById('sc-tint-val'),
      onChange: v => { tintTarget=parseFloat(v); } },
    { el: document.getElementById('sc-sat'), val: document.getElementById('sc-sat-val'),
      onChange: v => { satTarget=parseFloat(v); } },
  ];
  sliders.forEach(s => {
    if (!s.el) return;
    s.el.addEventListener('input', e => {
      s.onChange(e.target.value);
      if (s.val) s.val.textContent = parseFloat(e.target.value).toFixed(s.el.step && s.el.step<1?2:0);
    });
  });

  // Draw synthetic reference image into sourceCanvas
  function drawSource(exposure, temp, tint, sat) {
    const W = sourceCanvas.width, H = sourceCanvas.height;
    sCtx.clearRect(0,0,W,H);

    // Sky gradient
    const skyGrad = sCtx.createLinearGradient(0,0,0,H*0.45);
    skyGrad.addColorStop(0,'#1a4a80');
    skyGrad.addColorStop(1,'#4a90d9');
    sCtx.fillStyle = skyGrad; sCtx.fillRect(0,0,W,H*0.45);

    // Ground
    const gndGrad = sCtx.createLinearGradient(0,H*0.45,0,H);
    gndGrad.addColorStop(0,'#3a6b20');
    gndGrad.addColorStop(1,'#1a3a10');
    sCtx.fillStyle = gndGrad; sCtx.fillRect(0,H*0.45,W,H*0.55);

    // Skin zone rectangle
    sCtx.fillStyle = '#c87040';
    sCtx.fillRect(W*0.3, H*0.15, W*0.2, H*0.45);

    // Color patches row
    const patches = ['#dc2626','#d97706','#34d399','#3b82f6','#8b5cf6','#ec4899'];
    patches.forEach((c,i) => {
      sCtx.fillStyle = c;
      sCtx.fillRect(i*(W/6), H*0.7, W/6, H*0.3);
    });

    // White/gray/black chips
    sCtx.fillStyle='#ffffff'; sCtx.fillRect(W*0.7,H*0.15,W*0.07,H*0.2);
    sCtx.fillStyle='#808080'; sCtx.fillRect(W*0.79,H*0.15,W*0.07,H*0.2);
    sCtx.fillStyle='#101010'; sCtx.fillRect(W*0.88,H*0.15,W*0.07,H*0.2);

    // Apply adjustments via getImageData
    const id = sCtx.getImageData(0,0,W,H);
    const d = id.data;
    const expMul = Math.pow(2, exposure);
    const tMul = temp/200;
    const tiMul = tint/200;

    for (let i=0;i<d.length;i+=4) {
      let r=d[i]/255, g=d[i+1]/255, b=d[i+2]/255;
      // Exposure
      r*=expMul; g*=expMul; b*=expMul;
      // Temperature (warm/cool shift)
      r+=tMul*0.15; b-=tMul*0.15;
      // Tint (green/magenta)
      g+=tiMul*0.1; r-=tiMul*0.05; b-=tiMul*0.05;
      // Saturation
      const lum = 0.2126*r + 0.7152*g + 0.0722*b;
      const sf = sat/100;
      r = lum + (r-lum)*sf;
      g = lum + (g-lum)*sf;
      b = lum + (b-lum)*sf;
      d[i]=clamp(r*255,0,255);
      d[i+1]=clamp(g*255,0,255);
      d[i+2]=clamp(b*255,0,255);
    }
    sCtx.putImageData(id,0,0);
  }

  function drawWaveform(id, ctx) {
    const W=ctx.canvas.width, H=ctx.canvas.height;
    const sW=sourceCanvas.width, sH=sourceCanvas.height;
    ctx.fillStyle='#0a0a0f'; ctx.fillRect(0,0,W,H);
    // Grid
    ctx.strokeStyle='rgba(30,30,46,0.7)'; ctx.lineWidth=0.5;
    for(let i=0;i<=4;i++){const y=H-(i/4)*H;ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
    ctx.fillStyle='rgba(107,107,138,0.5)'; ctx.font='8px monospace';
    ['1023','768','512','256','0'].forEach((l,i)=>ctx.fillText(l,2,(i/4)*(H-4)+6));

    ctx.strokeStyle='#d97706'; ctx.lineWidth=1;
    ctx.shadowColor='#d97706'; ctx.shadowBlur=3;
    ctx.beginPath();
    const stride = Math.max(1, Math.floor(sW/W));
    for(let xi=0;xi<W;xi++){
      const sx=Math.floor(xi*sW/W);
      let sumLum=0, cnt=0;
      for(let sy=0;sy<sH;sy+=4){
        const idx=(sy*sW+sx)*4;
        const r=id.data[idx]/255,g=id.data[idx+1]/255,b=id.data[idx+2]/255;
        sumLum += 0.2126*r+0.7152*g+0.0722*b;
        cnt++;
      }
      const lum=sumLum/cnt;
      const y=H-lum*(H-4)-2;
      if(xi===0)ctx.moveTo(xi,y); else ctx.lineTo(xi,y);
    }
    ctx.stroke(); ctx.shadowBlur=0;
    ctx.fillStyle='rgba(107,107,138,0.4)'; ctx.font='8px monospace';
    ctx.fillText('WAVEFORM',2,H-2);
  }

  function drawVectorscope(id, ctx) {
    const W=ctx.canvas.width, H=ctx.canvas.height;
    const cx=W/2, cy=H/2, radius=Math.min(W,H)/2-12;
    ctx.fillStyle='#0a0a0f'; ctx.fillRect(0,0,W,H);
    // Rings
    [1,0.75,0.5,0.25].forEach(r=>{
      ctx.strokeStyle=r===1?'rgba(30,30,46,0.8)':'rgba(30,30,46,0.4)';
      ctx.lineWidth=r===1?1:0.5;
      ctx.beginPath(); ctx.arc(cx,cy,radius*r,0,Math.PI*2); ctx.stroke();
    });
    // Axes
    ctx.strokeStyle='rgba(107,107,138,0.4)'; ctx.lineWidth=0.5;
    ctx.beginPath();ctx.moveTo(cx-radius,cy);ctx.lineTo(cx+radius,cy);ctx.stroke();
    ctx.beginPath();ctx.moveTo(cx,cy-radius);ctx.lineTo(cx,cy+radius);ctx.stroke();
    // Skin tone line
    ctx.strokeStyle='rgba(217,119,6,0.5)'; ctx.lineWidth=0.8; ctx.setLineDash([3,3]);
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+Math.cos(0.44)*radius,cy+Math.sin(0.44)*radius);ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle='rgba(217,119,6,0.6)';ctx.font='7px monospace';
    ctx.fillText('SKIN',cx+Math.cos(0.44)*radius*0.88,cy+Math.sin(0.44)*radius*0.88+3);
    // Sky reference
    ctx.fillStyle='rgba(59,130,246,0.6)';
    ctx.fillText('SKY',cx+Math.cos(-1.2)*radius*0.6,cy+Math.sin(-1.2)*radius*0.6+3);

    // Plot color dots
    const sW=sourceCanvas.width, sH=sourceCanvas.height;
    const step=Math.max(4,Math.floor(sH/40));
    for(let sy=0;sy<sH;sy+=step){
      for(let sx=0;sx<sW;sx+=step){
        const idx=(sy*sW+sx)*4;
        const r=id.data[idx]/255,g=id.data[idx+1]/255,b=id.data[idx+2]/255;
        // RGB to YCbCr approximation
        const Y=0.299*r+0.587*g+0.114*b;
        const Cb=-0.169*r-0.331*g+0.5*b;
        const Cr=0.5*r-0.419*g-0.081*b;
        const px=cx+Cb*radius*1.6;
        const py=cy-Cr*radius*1.6;
        ctx.beginPath();ctx.arc(px,py,1.2,0,Math.PI*2);
        ctx.fillStyle=`rgba(${Math.round(r*255)},${Math.round(g*255)},${Math.round(b*255)},0.5)`;
        ctx.fill();
      }
    }
    ctx.fillStyle='rgba(107,107,138,0.4)';ctx.font='8px monospace';
    ctx.fillText('VECTORSCOPE',2,H-2);
  }

  function drawParade(id, ctx) {
    const W=ctx.canvas.width, H=ctx.canvas.height;
    ctx.fillStyle='#0a0a0f'; ctx.fillRect(0,0,W,H);
    const cW=Math.floor(W/3)-4;
    const sW=sourceCanvas.width, sH=sourceCanvas.height;
    const channels=[
      {name:'R',col:'#dc2626',off:0,idx:0},
      {name:'G',col:'#34d399',off:Math.floor(W/3)+2,idx:1},
      {name:'B',col:'#3b82f6',off:Math.floor(W*2/3)+4,idx:2},
    ];
    channels.forEach(ch=>{
      const x0=ch.off;
      ctx.strokeStyle='rgba(30,30,46,0.5)';ctx.lineWidth=0.5;
      for(let i=0;i<=4;i++){const y=H-(i/4)*(H-4)-2;ctx.beginPath();ctx.moveTo(x0,y);ctx.lineTo(x0+cW,y);ctx.stroke();}
      ctx.strokeStyle=ch.col;ctx.lineWidth=1;
      ctx.shadowColor=ch.col;ctx.shadowBlur=3;
      ctx.beginPath();
      for(let xi=0;xi<cW;xi++){
        const sx=Math.floor(xi*sW/cW);
        let sum=0,cnt=0;
        for(let sy=0;sy<sH;sy+=4){
          const i2=(sy*sW+sx)*4;
          sum+=id.data[i2+ch.idx]/255;cnt++;
        }
        const val=sum/cnt;
        const y=H-val*(H-4)-2;
        if(xi===0)ctx.moveTo(x0+xi,y);else ctx.lineTo(x0+xi,y);
      }
      ctx.stroke();ctx.shadowBlur=0;
      ctx.fillStyle=ch.col;ctx.font='8px monospace';
      ctx.fillText(ch.name,x0+2,H-2);
    });
    ctx.fillStyle='rgba(107,107,138,0.4)';ctx.font='8px monospace';
    ctx.fillText('PARADE',W/2-18,H-2);
  }

  function drawHistogram(id, ctx) {
    const W=ctx.canvas.width, H=ctx.canvas.height;
    ctx.fillStyle='#0a0a0f'; ctx.fillRect(0,0,W,H);
    const bins=new Array(256).fill(0);
    const sW=sourceCanvas.width, sH=sourceCanvas.height;
    for(let i=0;i<id.data.length;i+=4){
      const r=id.data[i],g=id.data[i+1],b=id.data[i+2];
      const lum=Math.round(0.2126*r+0.7152*g+0.0722*b);
      bins[lum]++;
    }
    const maxBin=Math.max(...bins)*1.05;
    // Gradient fill
    const grad=ctx.createLinearGradient(0,0,W,0);
    grad.addColorStop(0,'rgba(107,107,138,0.4)');
    grad.addColorStop(0.5,'rgba(217,119,6,0.5)');
    grad.addColorStop(1,'rgba(255,255,255,0.4)');
    ctx.fillStyle=grad;
    ctx.beginPath();ctx.moveTo(0,H);
    for(let i=0;i<256;i++){
      const x=(i/255)*W;
      const y=H-(bins[i]/maxBin)*(H-4)-2;
      ctx.lineTo(x,y);
    }
    ctx.lineTo(W,H);ctx.closePath();ctx.fill();
    // Outline
    ctx.strokeStyle='rgba(217,119,6,0.7)';ctx.lineWidth=1;
    ctx.beginPath();
    for(let i=0;i<256;i++){
      const x=(i/255)*W;
      const y=H-(bins[i]/maxBin)*(H-4)-2;
      if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);
    }
    ctx.stroke();
    // Grid
    ctx.strokeStyle='rgba(30,30,46,0.5)';ctx.lineWidth=0.5;
    [0.25,0.5,0.75].forEach(p=>{ctx.beginPath();ctx.moveTo(p*W,0);ctx.lineTo(p*W,H);ctx.stroke();});
    ctx.fillStyle='rgba(107,107,138,0.4)';ctx.font='8px monospace';
    ctx.fillText('HISTOGRAM',2,H-2);
    ['0','64','128','192','255'].forEach((l,i)=>ctx.fillText(l,i*(W-8)/4,H-10));
  }

  let scopeLastTime=null;
  function scopeLoop(ts) {
    if(!scopeLastTime)scopeLastTime=ts;
    const dt=Math.min((ts-scopeLastTime)/1000,0.1);
    scopeLastTime=ts;

    const exp=lfExposure.update(expTarget,dt);
    const tmp=lfTemp.update(tempTarget,dt);
    const ti=lfTint.update(tintTarget,dt);
    const sa=lfSat.update(satTarget,dt);

    drawSource(exp,tmp,ti,sa);
    const id=sCtx.getImageData(0,0,sourceCanvas.width,sourceCanvas.height);

    drawWaveform(id, wCtx);
    drawVectorscope(id, vCtx);
    drawParade(id, pCtx);
    drawHistogram(id, hCtx);

    requestAnimationFrame(scopeLoop);
  }
  requestAnimationFrame(scopeLoop);
})();

// ============================================================
// SECTION 3 — COLOR WHEEL COLORIST
// ============================================================
(function initWheels() {
  const wheels = [
    { id:'wheel-lift',  valId:'wheel-lift-val',  label:'Lift' },
    { id:'wheel-gamma', valId:'wheel-gamma-val', label:'Gamma' },
    { id:'wheel-gain',  valId:'wheel-gain-val',  label:'Gain' },
  ];

  // State for each wheel: hue (0-360), sat (0-1)
  const wState = wheels.map(() => ({
    hue:0, sat:0,
    lfHue: new LagFilter(0.3),
    lfSat: new LagFilter(0.3),
  }));

  const lfOffset = new LagFilter(0.3);
  let offsetTarget = 0;
  let showBefore = false;
  let currentLut = null;

  // LUT presets (applied to whole grade)
  const LUT_PRESETS = {
    'teal-orange': { lift:{h:180,s:0.5}, gamma:{h:0,s:0}, gain:{h:30,s:0.55} },
    'bleach':      { lift:{h:0,s:0}, gamma:{h:0,s:0}, gain:{h:0,s:0}, desat:0.4, contr:1.3 },
    'warm':        { lift:{h:30,s:0.3}, gamma:{h:35,s:0.2}, gain:{h:40,s:0.4} },
    'cool':        { lift:{h:220,s:0.4}, gamma:{h:210,s:0.2}, gain:{h:200,s:0.3} },
    'natural':     { lift:{h:0,s:0.05}, gamma:{h:0,s:0.05}, gain:{h:0,s:0.05} },
  };

  // Draw a single color wheel canvas
  function drawWheel(canvas, hue, sat) {
    const ctx = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    const cx = W/2, cy = H/2, R = Math.min(W,H)/2 - 6;
    ctx.clearRect(0,0,W,H);

    // Draw color ring
    for (let a=0; a<360; a+=1) {
      const rad = (a * Math.PI/180);
      const [r,g,b] = hsl2rgb(a, 100, 50);
      ctx.strokeStyle = `rgb(${r},${g},${b})`;
      ctx.lineWidth = 8;
      ctx.beginPath();
      ctx.arc(cx,cy,R-4, rad, rad+Math.PI/180*2);
      ctx.stroke();
    }

    // White center gradient
    const grad = ctx.createRadialGradient(cx,cy,0,cx,cy,R-4);
    grad.addColorStop(0,'rgba(255,255,255,1)');
    grad.addColorStop(0.6,'rgba(255,255,255,0.4)');
    grad.addColorStop(1,'rgba(255,255,255,0)');
    ctx.fillStyle = grad;
    ctx.beginPath(); ctx.arc(cx,cy,R-4,0,Math.PI*2); ctx.fill();

    // Dark overlay for depth
    const darkGrad = ctx.createRadialGradient(cx,cy,0,cx,cy,R-4);
    darkGrad.addColorStop(0,'rgba(10,10,15,0.0)');
    darkGrad.addColorStop(0.85,'rgba(10,10,15,0.0)');
    darkGrad.addColorStop(1,'rgba(10,10,15,0.5)');
    ctx.fillStyle = darkGrad;
    ctx.beginPath(); ctx.arc(cx,cy,R-4,0,Math.PI*2); ctx.fill();

    // Draw indicator dot
    const dotRad = (hue * Math.PI/180);
    const dotR = sat * (R - 10);
    const dx = cx + Math.cos(dotRad) * dotR;
    const dy = cy + Math.sin(dotRad) * dotR;
    ctx.beginPath(); ctx.arc(dx,dy,7,0,Math.PI*2);
    ctx.fillStyle = '#d97706';
    ctx.shadowColor='#d97706'; ctx.shadowBlur=8;
    ctx.fill(); ctx.shadowBlur=0;
    ctx.strokeStyle='#fff'; ctx.lineWidth=1.5;
    ctx.stroke();

    // Center neutral dot
    ctx.beginPath(); ctx.arc(cx,cy,4,0,Math.PI*2);
    ctx.fillStyle='rgba(255,255,255,0.4)'; ctx.fill();
  }

  // Wire up wheel interaction
  wheels.forEach((w, wi) => {
    const canvas = document.getElementById(w.id);
    if (!canvas) return;
    const valEl = document.getElementById(w.valId);
    let dragging = false;

    function updateFromPos(e) {
      const rect = canvas.getBoundingClientRect();
      const cx = canvas.width/2, cy = canvas.height/2;
      const R = Math.min(canvas.width,canvas.height)/2 - 6;
      const clientX = e.touches ? e.touches[0].clientX : e.clientX;
      const clientY = e.touches ? e.touches[0].clientY : e.clientY;
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;
      const mx = (clientX - rect.left) * scaleX - cx;
      const my = (clientY - rect.top) * scaleY - cy;
      const dist = Math.sqrt(mx*mx + my*my);
      const hue = ((Math.atan2(my,mx) * 180/Math.PI) + 360) % 360;
      const sat = clamp(dist / (R-10), 0, 1);
      wState[wi].hue = hue;
      wState[wi].sat = sat;
      if (valEl) valEl.textContent = `H:${Math.round(hue)} S:${Math.round(sat*100)}%`;
    }

    canvas.addEventListener('mousedown', e => { dragging=true; updateFromPos(e); });
    canvas.addEventListener('mousemove', e => { if(dragging) updateFromPos(e); });
    canvas.addEventListener('mouseup', () => dragging=false);
    canvas.addEventListener('mouseleave', () => dragging=false);
    canvas.addEventListener('touchstart', e => { e.preventDefault(); dragging=true; updateFromPos(e); }, {passive:false});
    canvas.addEventListener('touchmove', e => { e.preventDefault(); if(dragging)updateFromPos(e); }, {passive:false});
    canvas.addEventListener('touchend', () => dragging=false);
  });

  // Master offset slider
  const offsetSlider = document.getElementById('master-offset');
  const offsetVal = document.getElementById('master-offset-val');
  if (offsetSlider) {
    offsetSlider.addEventListener('input', e => {
      offsetTarget = parseFloat(e.target.value);
      if (offsetVal) offsetVal.textContent = offsetTarget.toFixed(2);
    });
  }

  // LUT preset buttons
  document.querySelectorAll('#wheels .lut-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const lk = btn.dataset.lut;
      document.querySelectorAll('#wheels .lut-btn').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      const preset = LUT_PRESETS[lk];
      if (preset) {
        wState[0].hue = preset.lift.h; wState[0].sat = preset.lift.s;
        wState[1].hue = preset.gamma.h; wState[1].sat = preset.gamma.s;
        wState[2].hue = preset.gain.h; wState[2].sat = preset.gain.s;
        currentLut = preset;
        ['lift','gamma','gain'].forEach((n,i)=>{
          const v=document.getElementById('wheel-'+n+'-val');
          if(v) v.textContent=`H:${Math.round(wState[i].hue)} S:${Math.round(wState[i].sat*100)}%`;
        });
      }
    });
  });

  // Before/After toggle
  const toggleBtn = document.getElementById('toggle-ba');
  const previewLabel = document.getElementById('preview-label');
  if (toggleBtn) {
    toggleBtn.addEventListener('click', () => {
      showBefore = !showBefore;
      if (previewLabel) previewLabel.textContent = showBefore ? 'BEFORE (ORIGINAL)' : 'GRADE PREVIEW';
    });
  }

  // Draw synthetic film scene
  function drawScene(ctx, W, H, liftH, liftS, gammaH, gammaS, gainH, gainS, offset) {
    ctx.clearRect(0,0,W,H);

    // Sky zone
    const skyGrad = ctx.createLinearGradient(0,0,0,H*0.5);
    skyGrad.addColorStop(0,'#1a3d6e');
    skyGrad.addColorStop(1,'#3a7fd4');
    ctx.fillStyle = skyGrad; ctx.fillRect(0,0,W,H*0.5);

    // Ground
    ctx.fillStyle = '#2a5a18'; ctx.fillRect(0,H*0.5,W,H*0.5);

    // Subject (skin) zone
    ctx.fillStyle = '#b86030'; ctx.fillRect(W*0.35,H*0.1,W*0.15,H*0.55);

    // Shadow area
    ctx.fillStyle = '#101820'; ctx.fillRect(W*0.8,H*0.1,W*0.18,H*0.65);

    // Gray card
    ctx.fillStyle = '#808080'; ctx.fillRect(W*0.02,H*0.1,W*0.1,H*0.2);

    // Apply color grade via image data
    const id = ctx.getImageData(0,0,W,H);
    const d = id.data;

    // Convert wheel hue/sat to RGB tint multipliers
    function wheelToRGB(h, s, label) {
      if (s < 0.01) return [1,1,1];
      const [r,g,b] = hsl2rgb(h, 80, 50);
      const base = 1 + s * 0.4;
      return [
        1 + (r/255 - 0.5) * s * 0.6,
        1 + (g/255 - 0.5) * s * 0.6,
        1 + (b/255 - 0.5) * s * 0.6,
      ];
    }

    const liftMul = wheelToRGB(liftH, liftS, 'lift');
    const gammaMul = wheelToRGB(gammaH, gammaS, 'gamma');
    const gainMul = wheelToRGB(gainH, gainS, 'gain');

    for (let i=0;i<d.length;i+=4) {
      let r=d[i]/255, g=d[i+1]/255, b=d[i+2]/255;
      const lum = 0.2126*r + 0.7152*g + 0.0722*b;

      // Lift affects shadows
      const liftW = Math.max(0, 1 - lum*2);
      r += (liftMul[0]-1)*liftW + 0.08*liftS*liftW;
      g += (liftMul[1]-1)*liftW + 0.08*liftS*liftW;
      b += (liftMul[2]-1)*liftW + 0.08*liftS*liftW;

      // Gamma affects midtones
      const gammaW = Math.max(0, 1 - Math.abs(lum-0.5)*2.5);
      r += (gammaMul[0]-1)*gammaW;
      g += (gammaMul[1]-1)*gammaW;
      b += (gammaMul[2]-1)*gammaW;

      // Gain affects highlights
      const gainW = Math.max(0, lum*2-1);
      r += (gainMul[0]-1)*gainW;
      g += (gainMul[1]-1)*gainW;
      b += (gainMul[2]-1)*gainW;

      // Master offset
      r+=offset; g+=offset; b+=offset;

      // Bleach bypass desaturation (if LUT has it)
      if (currentLut && currentLut.desat) {
        const gl = 0.2126*r+0.7152*g+0.0722*b;
        const ds = currentLut.desat;
        r=r*(1-ds)+gl*ds; g=g*(1-ds)+gl*ds; b=b*(1-ds)+gl*ds;
      }
      if (currentLut && currentLut.contr) {
        const c=currentLut.contr;
        r=(r-0.5)*c+0.5; g=(g-0.5)*c+0.5; b=(b-0.5)*c+0.5;
      }

      d[i]=clamp(r*255,0,255);
      d[i+1]=clamp(g*255,0,255);
      d[i+2]=clamp(b*255,0,255);
    }
    ctx.putImageData(id,0,0);
  }

  function drawGradeWaveform(src, ctx) {
    const W=ctx.canvas.width, H=ctx.canvas.height;
    ctx.fillStyle='#0a0a0f'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='rgba(30,30,46,0.5)';ctx.lineWidth=0.5;
    for(let i=0;i<=4;i++){const y=(i/4)*H;ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
    const sW=src.width, sH=src.height;
    const sCtx=src.getContext('2d');
    const id=sCtx.getImageData(0,0,sW,sH);
    ctx.strokeStyle='#d97706';ctx.lineWidth=1;
    ctx.shadowColor='#d97706';ctx.shadowBlur=3;
    ctx.beginPath();
    for(let xi=0;xi<W;xi++){
      const sx=Math.floor(xi*sW/W);
      let sum=0,cnt=0;
      for(let sy=0;sy<sH;sy+=3){
        const i2=(sy*sW+sx)*4;
        sum+=(0.2126*id.data[i2]+0.7152*id.data[i2+1]+0.0722*id.data[i2+2])/255;
        cnt++;
      }
      const y=H-(sum/cnt)*(H-4)-2;
      if(xi===0)ctx.moveTo(xi,y);else ctx.lineTo(xi,y);
    }
    ctx.stroke();ctx.shadowBlur=0;
  }

  const gradeCanvas = document.getElementById('grade-preview');
  const gradeWfCanvas = document.getElementById('grade-waveform');
  const offscreenGrade = document.createElement('canvas');
  offscreenGrade.width=540; offscreenGrade.height=270;
  const offscreenOrig = document.createElement('canvas');
  offscreenOrig.width=540; offscreenOrig.height=270;

  // Draw ungraded version once
  drawScene(offscreenOrig.getContext('2d'),540,270,0,0,0,0,0,0,0);

  let wheelLastTime=null;
  function wheelsLoop(ts) {
    if(!wheelLastTime)wheelLastTime=ts;
    const dt=Math.min((ts-wheelLastTime)/1000,0.1);
    wheelLastTime=ts;

    const offset = lfOffset.update(offsetTarget, dt);

    // Draw and smooth wheels
    wheels.forEach((w, wi) => {
      const canvas = document.getElementById(w.id);
      if(!canvas) return;
      const sh = wState[wi].hue;
      const ss = wState[wi].sat;
      const smoothH = wState[wi].lfHue.update(sh, dt);
      const smoothS = wState[wi].lfSat.update(ss, dt);
      drawWheel(canvas, smoothH, smoothS);
    });

    // Draw graded preview
    if (gradeCanvas) {
      const gCtx = gradeCanvas.getContext('2d');
      const W=gradeCanvas.width, H=gradeCanvas.height;
      const ls=wState[0], ms=wState[1], gs=wState[2];
      if (showBefore) {
        gCtx.drawImage(offscreenOrig,0,0,W,H);
      } else {
        drawScene(offscreenGrade.getContext('2d'),offscreenGrade.width,offscreenGrade.height,
          wState[0].lfHue.value||0, wState[0].lfSat.value||0,
          wState[1].lfHue.value||0, wState[1].lfSat.value||0,
          wState[2].lfHue.value||0, wState[2].lfSat.value||0,
          offset);
        gCtx.drawImage(offscreenGrade,0,0,W,H);
      }
    }

    if (gradeWfCanvas) {
      drawGradeWaveform(showBefore ? offscreenOrig : offscreenGrade, gradeWfCanvas.getContext('2d'));
    }

    requestAnimationFrame(wheelsLoop);
  }
  requestAnimationFrame(wheelsLoop);
})();

// ============================================================
// SECTION 4 — NODE GRAPH BUILDER
// ============================================================
(function initNodeGraph() {
  const canvas = document.getElementById('node-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const wrap = document.getElementById('node-canvas-wrap');

  const NODE_TYPES = {
    Serial:    { col:'#d97706', icon:'S', desc:'Serial correction node' },
    Parallel:  { col:'#3b82f6', icon:'P', desc:'Parallel blend node' },
    Layer:     { col:'#8b5cf6', icon:'L', desc:'Layer composite node' },
    Outside:   { col:'#dc2626', icon:'O', desc:'Outside/inverse node' },
    Corrector: { col:'#34d399', icon:'C', desc:'Basic grade corrector' },
  };

  const NODE_W = 100, NODE_H = 58;

  let nodes = [];
  let cables = [];
  let pendingPort = null; // {nodeIdx, type:'out'|'in'}
  let draggingNode = null; // {idx, offX, offY}
  let signalDots = []; // {cableIdx, t, speed}
  const lfDots = [];

  // Preset graphs
  const PRESETS = {
    basic: [
      {type:'Serial', x:60,  y:150, hue:0,  sat:0.3, label:'Primary'},
      {type:'Serial', x:220, y:150, hue:30, sat:0.4, label:'Contrast'},
      {type:'Serial', x:380, y:150, hue:210,sat:0.3, label:'Color'},
    ],
    power: [
      {type:'Serial',    x:60,  y:150, hue:0,   sat:0.2, label:'Primary'},
      {type:'Corrector', x:220, y:80,  hue:30,  sat:0.5, label:'Window'},
      {type:'Outside',   x:220, y:230, hue:210, sat:0.3, label:'Outside'},
      {type:'Serial',    x:400, y:150, hue:0,   sat:0.2, label:'Final'},
    ],
    log: [
      {type:'Corrector', x:60,  y:150, hue:35,  sat:0.2, label:'Log Input'},
      {type:'Layer',     x:220, y:150, hue:0,   sat:0.0, label:'LUT Apply'},
      {type:'Serial',    x:380, y:150, hue:25,  sat:0.4, label:'Trim'},
      {type:'Serial',    x:540, y:150, hue:0,   sat:0.1, label:'Output'},
    ],
    skin: [
      {type:'Serial',    x:60,  y:150, hue:0,   sat:0.2, label:'Primary'},
      {type:'Corrector', x:220, y:80,  hue:25,  sat:0.6, label:'Skin'},
      {type:'Corrector', x:220, y:230, hue:210, sat:0.5, label:'Sky'},
      {type:'Parallel',  x:400, y:150, hue:0,   sat:0.1, label:'Merge'},
      {type:'Serial',    x:560, y:150, hue:0,   sat:0.15, label:'Final'},
    ],
  };

  const PRESET_CABLES = {
    basic: [[0,1],[1,2]],
    power: [[0,1],[0,2],[1,3],[2,3]],
    log:   [[0,1],[1,2],[2,3]],
    skin:  [[0,1],[0,2],[1,3],[2,3],[3,4]],
  };

  function loadPreset(key) {
    const p = PRESETS[key];
    const c = PRESET_CABLES[key];
    if (!p) return;
    nodes = p.map((n,i) => ({
      ...n, idx:i,
      lfX: new LagFilter(0.5), lfY: new LagFilter(0.5),
      lfHue: new LagFilter(0.4), lfSat: new LagFilter(0.4),
    }));
    cables = (c||[]).map(([a,b]) => ({from:a, to:b, lfT: new LagFilter(0.3)}));
    signalDots = cables.map((_,i) => ({cableIdx:i, t:Math.random(), speed:0.15+Math.random()*0.1}));
    document.querySelectorAll('.graph-btn').forEach(b=>b.classList.remove('active'));
    const btn=document.querySelector(`.graph-btn[data-graph="${key}"]`);
    if(btn)btn.classList.add('active');
  }

  // Drag from palette
  document.querySelectorAll('.node-chip').forEach(chip => {
    chip.addEventListener('dragstart', e => {
      e.dataTransfer.setData('nodeType', chip.dataset.type);
    });
  });

  const wrapEl = document.getElementById('node-canvas-wrap');
  if (wrapEl) {
    wrapEl.addEventListener('dragover', e => e.preventDefault());
    wrapEl.addEventListener('drop', e => {
      e.preventDefault();
      const type = e.dataTransfer.getData('nodeType');
      if (!type) return;
      const rect = canvas.getBoundingClientRect();
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;
      const x = (e.clientX - rect.left) * scaleX - NODE_W/2;
      const y = (e.clientY - rect.top) * scaleY - NODE_H/2;
      nodes.push({
        type, x: clamp(x,10,canvas.width-NODE_W-10),
        y: clamp(y,10,canvas.height-NODE_H-10),
        hue: Math.random()*360, sat: 0.3+Math.random()*0.4,
        label: type, idx: nodes.length,
        lfX: new LagFilter(0.5), lfY: new LagFilter(0.5),
        lfHue: new LagFilter(0.4), lfSat: new LagFilter(0.4),
      });
    });
  }

  // Mouse interaction for node dragging and port clicking
  let mouseX=0, mouseY=0;
  canvas.addEventListener('mousedown', e => {
    const rect=canvas.getBoundingClientRect();
    const mx=(e.clientX-rect.left)*(canvas.width/rect.width);
    const my=(e.clientY-rect.top)*(canvas.height/rect.height);
    // Check ports first
    for(let i=0;i<nodes.length;i++){
      const n=nodes[i];
      const nx=n.lfX.value||n.x, ny=n.lfY.value||n.y;
      const outX=nx+NODE_W, outY=ny+NODE_H/2;
      const inX=nx, inY=ny+NODE_H/2;
      if(Math.hypot(mx-outX,my-outY)<8){
        pendingPort={nodeIdx:i,type:'out',x:outX,y:outY}; return;
      }
      if(Math.hypot(mx-inX,my-inY)<8 && pendingPort && pendingPort.type==='out' && pendingPort.nodeIdx!==i){
        cables.push({from:pendingPort.nodeIdx,to:i,lfT:new LagFilter(0.3)});
        signalDots.push({cableIdx:cables.length-1,t:Math.random(),speed:0.15+Math.random()*0.1});
        pendingPort=null; return;
      }
    }
    pendingPort=null;
    // Check node body drag
    for(let i=nodes.length-1;i>=0;i--){
      const n=nodes[i];
      const nx=n.lfX.value||n.x, ny=n.lfY.value||n.y;
      if(mx>=nx&&mx<=nx+NODE_W&&my>=ny&&my<=ny+NODE_H){
        draggingNode={idx:i,offX:mx-nx,offY:my-ny}; return;
      }
    }
  });
  canvas.addEventListener('mousemove', e => {
    const rect=canvas.getBoundingClientRect();
    mouseX=(e.clientX-rect.left)*(canvas.width/rect.width);
    mouseY=(e.clientY-rect.top)*(canvas.height/rect.height);
    if(draggingNode){
      nodes[draggingNode.idx].x=clamp(mouseX-draggingNode.offX,10,canvas.width-NODE_W-10);
      nodes[draggingNode.idx].y=clamp(mouseY-draggingNode.offY,10,canvas.height-NODE_H-10);
    }
  });
  canvas.addEventListener('mouseup', () => { draggingNode=null; });

  document.querySelectorAll('.graph-btn').forEach(btn => {
    btn.addEventListener('click', () => loadPreset(btn.dataset.graph));
  });

  // Draw cable between two points (bezier)
  function drawCable(x1,y1,x2,y2,col,alpha) {
    const dx=(x2-x1)*0.5;
    ctx.strokeStyle=`rgba(${col},${alpha})`;
    ctx.lineWidth=1.8;
    ctx.shadowColor=`rgba(${col},0.4)`;
    ctx.shadowBlur=4;
    ctx.beginPath();
    ctx.moveTo(x1,y1);
    ctx.bezierCurveTo(x1+dx,y1,x2-dx,y2,x2,y2);
    ctx.stroke();
    ctx.shadowBlur=0;
  }

  // Draw signal dot along cable
  function dotOnBezier(t,x1,y1,x2,y2) {
    const dx=(x2-x1)*0.5;
    const mt=1-t;
    const cx1=x1+dx, cx2=x2-dx;
    const x=mt*mt*mt*x1+3*mt*mt*t*cx1+3*mt*t*t*cx2+t*t*t*x2;
    const y=mt*mt*mt*y1+3*mt*mt*t*y1+3*mt*t*t*y2+t*t*t*y2;
    return {x,y};
  }

  function drawNode(n, dt) {
    const nx = n.lfX.update(n.x, dt);
    const ny = n.lfY.update(n.y, dt);
    const nh = n.lfHue.update(n.hue, dt);
    const ns = n.lfSat.update(n.sat, dt);
    const nt = NODE_TYPES[n.type];
    const [r,g,b] = hsl2rgb(nh, 70, 45);
    const colStr = `rgb(${r},${g},${b})`;

    // Node body
    ctx.fillStyle = '#111118';
    ctx.strokeStyle = colStr;
    ctx.lineWidth = 1.5;
    ctx.shadowColor = colStr; ctx.shadowBlur = ns*12;
    roundRect(ctx, nx, ny, NODE_W, NODE_H, 5);
    ctx.fill(); ctx.stroke(); ctx.shadowBlur=0;

    // Type icon circle
    ctx.fillStyle = colStr;
    ctx.beginPath(); ctx.arc(nx+14,ny+14,8,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#111'; ctx.font='bold 9px monospace';
    ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillText(nt.icon, nx+14, ny+14);

    // Label
    ctx.fillStyle='rgba(226,226,240,0.9)'; ctx.font='10px monospace';
    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.fillText(n.label||n.type, nx+26, ny+8);

    // Saturation bar
    ctx.fillStyle='rgba(30,30,46,0.8)';
    ctx.fillRect(nx+8, ny+36, NODE_W-16, 6);
    ctx.fillStyle=colStr;
    ctx.fillRect(nx+8, ny+36, (NODE_W-16)*ns, 6);

    // Out port (right)
    ctx.beginPath(); ctx.arc(nx+NODE_W, ny+NODE_H/2, 5, 0, Math.PI*2);
    ctx.fillStyle=colStr; ctx.strokeStyle='#111'; ctx.lineWidth=1.5;
    ctx.fill(); ctx.stroke();

    // In port (left)
    ctx.beginPath(); ctx.arc(nx, ny+NODE_H/2, 5, 0, Math.PI*2);
    ctx.fillStyle='#1e1e2e'; ctx.strokeStyle=colStr; ctx.lineWidth=1.5;
    ctx.fill(); ctx.stroke();
  }

  function roundRect(ctx,x,y,w,h,r){
    ctx.beginPath();
    ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.arcTo(x+w,y,x+w,y+r,r);
    ctx.lineTo(x+w,y+h-r);ctx.arcTo(x+w,y+h,x+w-r,y+h,r);
    ctx.lineTo(x+r,y+h);ctx.arcTo(x,y+h,x,y+h-r,r);
    ctx.lineTo(x,y+r);ctx.arcTo(x,y,x+r,y,r);ctx.closePath();
  }

  let nodeLastTime=null;
  function nodeLoop(ts) {
    if(!nodeLastTime)nodeLastTime=ts;
    const dt=Math.min((ts-nodeLastTime)/1000,0.1);
    nodeLastTime=ts;

    const W=canvas.width,H=canvas.height;
    ctx.fillStyle='rgba(10,10,15,0.15)';
    ctx.fillRect(0,0,W,H);

    // Grid
    ctx.strokeStyle='rgba(30,30,46,0.3)'; ctx.lineWidth=0.5;
    for(let xi=0;xi<W;xi+=40){ctx.beginPath();ctx.moveTo(xi,0);ctx.lineTo(xi,H);ctx.stroke();}
    for(let yi=0;yi<H;yi+=40){ctx.beginPath();ctx.moveTo(0,yi);ctx.lineTo(W,yi);ctx.stroke();}

    // Draw cables
    cables.forEach((cable,ci) => {
      const fn=nodes[cable.from],tn=nodes[cable.to];
      if(!fn||!tn)return;
      const x1=(fn.lfX.value||fn.x)+NODE_W, y1=(fn.lfY.value||fn.y)+NODE_H/2;
      const x2=(tn.lfX.value||tn.x),         y2=(tn.lfY.value||tn.y)+NODE_H/2;
      const nt=NODE_TYPES[fn.type];
      const [r,g,b]=hsl2rgb(fn.hue,70,45);
      drawCable(x1,y1,x2,y2,`${r},${g},${b}`,0.7);
    });

    // Signal dots along cables
    signalDots.forEach(dot => {
      const cable=cables[dot.cableIdx];
      if(!cable)return;
      const fn=nodes[cable.from],tn=nodes[cable.to];
      if(!fn||!tn)return;
      dot.t=(dot.t+dot.speed*dt)%1;
      const x1=(fn.lfX.value||fn.x)+NODE_W, y1=(fn.lfY.value||fn.y)+NODE_H/2;
      const x2=(tn.lfX.value||tn.x),         y2=(tn.lfY.value||tn.y)+NODE_H/2;
      const dx=(x2-x1)*0.5;
      const mt=1-dot.t,t=dot.t;
      const px=mt*mt*mt*x1+3*mt*mt*t*(x1+dx)+3*mt*t*t*(x2-dx)+t*t*t*x2;
      const py=mt*mt*mt*y1+3*mt*mt*t*y1+3*mt*t*t*y2+t*t*t*y2;
      const [r,g,b]=hsl2rgb(fn.hue,80,60);
      ctx.beginPath(); ctx.arc(px,py,3,0,Math.PI*2);
      ctx.fillStyle=`rgba(${r},${g},${b},0.9)`;
      ctx.shadowColor=`rgb(${r},${g},${b})`; ctx.shadowBlur=6;
      ctx.fill(); ctx.shadowBlur=0;
    });

    // Pending port wire
    if(pendingPort){
      const fn=nodes[pendingPort.nodeIdx];
      const x1=(fn.lfX.value||fn.x)+NODE_W,y1=(fn.lfY.value||fn.y)+NODE_H/2;
      drawCable(x1,y1,mouseX,mouseY,'217,119,6',0.5);
    }

    // Draw nodes
    ctx.textAlign='left'; ctx.textBaseline='top';
    nodes.forEach(n => drawNode(n, dt));

    // Empty state hint
    if(nodes.length===0){
      ctx.fillStyle='rgba(107,107,138,0.4)';
      ctx.font='13px monospace'; ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText('Drag node types here, or click a preset below',W/2,H/2);
    }

    requestAnimationFrame(nodeLoop);
  }

  loadPreset('basic');
  requestAnimationFrame(nodeLoop);
})();

