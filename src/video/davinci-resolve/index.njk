(function initLutMuseum() {
  const LUT_DEFS = [
    { name:'Kodak 2383',  fn: (r,g,b) => [r*0.95+0.02, g*0.9+0.03, b*0.8+0.04] },
    { name:'Fuji 3510',   fn: (r,g,b) => [r*1.05, g*0.98, b*0.88] },
    { name:'Teal & Orange', fn: (r,g,b) => {
        const l=0.2126*r+0.7152*g+0.0722*b;
        return [l>0.5?r+(r-l)*0.6:r*(0.8), g*0.88, l<0.5?b+(b-l)*0.5:b*0.9];
    }},
    { name:'Bleach Bypass', fn: (r,g,b) => {
        const l=0.2126*r+0.7152*g+0.0722*b;
        return [(r*0.3+l*0.7)*1.1-0.05, (g*0.3+l*0.7)*1.1-0.05, (b*0.3+l*0.7)*1.05-0.05];
    }},
    { name:'Tobacco',     fn: (r,g,b) => [r*1.1, g*0.95, b*0.7] },
    { name:'Day for Night', fn: (r,g,b) => [r*0.6, g*0.65, b*0.9] },
    { name:'Neon Noir',   fn: (r,g,b) => {
        const l=0.2126*r+0.7152*g+0.0722*b;
        return [l*0.3+r*0.4, l*0.2+g*0.3, l*0.6+b*0.8];
    }},
    { name:'Log Conversion', fn: (r,g,b) => {
        const lc = v => Math.pow(clamp(v,0,1),0.45)*1.1;
        return [lc(r), lc(g), lc(b)];
    }},
    { name:'Vintage Desat', fn: (r,g,b) => {
        const l=0.2126*r+0.7152*g+0.0722*b;
        return [r*0.5+l*0.5+0.03, g*0.5+l*0.5+0.01, b*0.4+l*0.6-0.02];
    }},
    { name:'Golden Hour', fn: (r,g,b) => [r*1.15+0.04, g*1.0+0.02, b*0.7] },
    { name:'Blue Steel',  fn: (r,g,b) => [r*0.8, g*0.88, b*1.15] },
    { name:'Horror Night', fn: (r,g,b) => {
        const l=0.2126*r+0.7152*g+0.0722*b;
        return [l*0.4+0.05, l*0.5, l*0.3+b*0.5];
    }},
  ];

  let selectedLut = 0;
  const lfIntensity = new LagFilter(0.3);
  let intensityTarget = 1.0;

  // Draw synthetic LOG source image
  function drawLogSource(ctx, W, H) {
    ctx.clearRect(0,0,W,H);
    // Flat LOG-style gradient
    const grad = ctx.createLinearGradient(0,0,W,0);
    grad.addColorStop(0,'#1a1a2a'); grad.addColorStop(0.3,'#3a5a4a');
    grad.addColorStop(0.6,'#5a4a3a'); grad.addColorStop(1,'#4a3a5a');
    ctx.fillStyle=grad; ctx.fillRect(0,0,W,H);
    // Sky
    ctx.fillStyle='#2a3a4a'; ctx.fillRect(0,0,W,H*0.4);
    // Ground
    ctx.fillStyle='#2a3a2a'; ctx.fillRect(0,H*0.4,W,H*0.6);
    // Subject silhouette
    ctx.fillStyle='#4a3a2a'; ctx.fillRect(W*0.35,H*0.1,W*0.15,H*0.6);
    // Patches
    const flatCols=['#3a2020','#3a3020','#203a20','#202a3a','#302040','#302030'];
    flatCols.forEach((c,i)=>{ctx.fillStyle=c;ctx.fillRect(i*(W/6),H*0.7,W/6,H*0.3);});
    // Chip row
    ctx.fillStyle='#505050'; ctx.fillRect(W*0.7,H*0.1,W*0.08,H*0.2);
    ctx.fillStyle='#303030'; ctx.fillRect(W*0.8,H*0.1,W*0.08,H*0.2);
    ctx.fillStyle='#181818'; ctx.fillRect(W*0.9,H*0.1,W*0.08,H*0.2);
  }

  function applyLut(srcCtx, dstCtx, W, H, lutFn, intensity) {
    const id = srcCtx.getImageData(0,0,W,H);
    const out = new ImageData(W,H);
    for(let i=0;i<id.data.length;i+=4){
      const r=id.data[i]/255,g=id.data[i+1]/255,b=id.data[i+2]/255;
      const [lr,lg,lb]=lutFn(r,g,b);
      out.data[i]   = clamp((r*(1-intensity)+clamp(lr,0,1)*intensity)*255,0,255);
      out.data[i+1] = clamp((g*(1-intensity)+clamp(lg,0,1)*intensity)*255,0,255);
      out.data[i+2] = clamp((b*(1-intensity)+clamp(lb,0,1)*intensity)*255,0,255);
      out.data[i+3] = 255;
    }
    dstCtx.putImageData(out,0,0);
  }

  // Build LUT grid
  const grid = document.getElementById('lut-grid');
  if (!grid) return;

  const srcOffscreen = document.createElement('canvas');
  srcOffscreen.width=160; srcOffscreen.height=90;
  drawLogSource(srcOffscreen.getContext('2d'),160,90);

  LUT_DEFS.forEach((lut,i) => {
    const card = document.createElement('div');
    card.className = 'lut-card' + (i===0?' selected':'');
    const thumbC = document.createElement('canvas');
    thumbC.width=160; thumbC.height=60;
    // Draw thumbnail
    const tc=thumbC.getContext('2d');
    const tsrc=document.createElement('canvas');
    tsrc.width=160;tsrc.height=60;
    drawLogSource(tsrc.getContext('2d'),160,60);
    applyLut(tsrc.getContext('2d'),tc,160,60,lut.fn,1.0);
    card.appendChild(thumbC);
    const label=document.createElement('div');
    label.className='lut-card-name'; label.textContent=lut.name;
    card.appendChild(label);
    card.addEventListener('click',()=>{
      selectedLut=i;
      document.querySelectorAll('.lut-card').forEach(c=>c.classList.remove('selected'));
      card.classList.add('selected');
    });
    grid.appendChild(card);
  });

  // Intensity slider
  const intSlider = document.getElementById('lut-intensity');
  const intVal = document.getElementById('lut-intensity-val');
  if (intSlider) {
    intSlider.addEventListener('input', e => {
      intensityTarget = parseInt(e.target.value)/100;
      if(intVal) intVal.textContent = e.target.value+'%';
    });
  }

  // Before/after canvases
  const beforeC = document.getElementById('lut-before');
  const afterC  = document.getElementById('lut-after');
  if (!beforeC||!afterC) return;

  // Draw source once into before canvas
  const bCtx=beforeC.getContext('2d');
  drawLogSource(bCtx,beforeC.width,beforeC.height);

  const srcBig=document.createElement('canvas');
  srcBig.width=500;srcBig.height=281;
  drawLogSource(srcBig.getContext('2d'),500,281);

  let lutLastTime=null;
  function lutLoop(ts){
    if(!lutLastTime)lutLastTime=ts;
    const dt=Math.min((ts-lutLastTime)/1000,0.1);
    lutLastTime=ts;
    const intensity=lfIntensity.update(intensityTarget,dt);
    const aCtx=afterC.getContext('2d');
    applyLut(srcBig.getContext('2d'),aCtx,afterC.width,afterC.height,LUT_DEFS[selectedLut].fn,intensity);
    requestAnimationFrame(lutLoop);
  }
  requestAnimationFrame(lutLoop);
})();

