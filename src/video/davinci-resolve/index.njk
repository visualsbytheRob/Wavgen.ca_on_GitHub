// ============================================================
(function initFilmLook() {
  const STEPS = [
    { id:'step-log',      name:'LOG Input',        desc:'Flat, desaturated camera original' },
    { id:'step-lut',      name:'LUT Conversion',   desc:'Apply log-to-display curve' },
    { id:'step-lift',     name:'Shadow Lift',       desc:'Raise blacks for film base' },
    { id:'step-rolloff',  name:'Highlight Rolloff', desc:'Compress highlights gracefully' },
    { id:'step-grain',    name:'Film Grain',        desc:'Procedural grain overlay' },
  ];

  const FILM_STOCKS = [
    { name:'Kodak Vision3', warm:0.08, sat:1.1,  contrast:1.05, lift:0.02, grain:0.04 },
    { name:'Fuji Velvia',   warm:0.04, sat:1.3,  contrast:1.1,  lift:0.01, grain:0.02 },
    { name:'Agfa Vista',    warm:0.06, sat:1.05, contrast:1.0,  lift:0.03, grain:0.05 },
    { name:'Ilford HP5',    warm:0.0,  sat:0.0,  contrast:1.15, lift:0.04, grain:0.07 },
    { name:'Polaroid',      warm:0.1,  sat:0.8,  contrast:0.9,  lift:0.08, grain:0.06 },
    { name:'Cinestill 800T',warm:-0.05,sat:1.0,  contrast:1.05, lift:0.03, grain:0.08 },
  ];

  // Step state
  const stepState = STEPS.map((s,i)=>({
    enabled: true,
    intensity: 1.0,
    lfIntensity: new LagFilter(0.3),
    target: 1.0,
  }));
  let currentStock = 0;

  // Build pipeline UI
  const pipeWrap = document.getElementById('pipeline-wrap');
  if (!pipeWrap) return;

  STEPS.forEach((step,i) => {
    if (i>0) {
      const arr=document.createElement('div');
      arr.className='pipeline-arrow'; arr.textContent='▶';
      pipeWrap.appendChild(arr);
    }
    const div=document.createElement('div');
    div.className='pipeline-step active';
    div.innerHTML=`
      <div class="step-num">Step ${i+1}</div>
      <div class="step-name">${step.name}</div>
      <div style="font-size:10px;color:var(--dim);margin-bottom:6px">${step.desc}</div>
      <div class="step-toggle">
        <input type="checkbox" id="${step.id}-chk" checked>
        <label for="${step.id}-chk">Active</label>
      </div>
      <div class="step-intensity">
        <label>Intensity</label>
        <input type="range" id="${step.id}-int" min="0" max="100" value="100">
      </div>`;
    pipeWrap.appendChild(div);

    const chk=div.querySelector(`#${step.id}-chk`);
    const inr=div.querySelector(`#${step.id}-int`);
    chk.addEventListener('change',()=>{
      stepState[i].enabled=chk.checked;
      div.classList.toggle('active',chk.checked);
      div.classList.toggle('disabled',!chk.checked);
    });
    inr.addEventListener('input',()=>{ stepState[i].target=parseInt(inr.value)/100; });
  });

  // Film stock buttons
  const stockWrap=document.getElementById('film-stocks');
  if(stockWrap){
    FILM_STOCKS.forEach((fs,i)=>{
      const btn=document.createElement('button');
      btn.className='stock-btn'+(i===0?' active':'');
      btn.textContent=fs.name;
      btn.addEventListener('click',()=>{
        currentStock=i;
        document.querySelectorAll('.stock-btn').forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
      });
      stockWrap.appendChild(btn);
    });
  }

  // Export button
  const exportBtn=document.getElementById('export-film-btn');
  const filmCanvas=document.getElementById('film-preview');
  if(exportBtn&&filmCanvas){
    exportBtn.addEventListener('click',()=>{
      const link=document.createElement('a');
      link.download='film_look.png';
      link.href=filmCanvas.toDataURL('image/png');
      link.click();
    });
  }

  if(!filmCanvas)return;
  const filmCtx=filmCanvas.getContext('2d');
  const W=filmCanvas.width,H=filmCanvas.height;

  // Source scene for film look
  function drawFilmSource(ctx,W,H){
    ctx.clearRect(0,0,W,H);
    const skyG=ctx.createLinearGradient(0,0,0,H*0.45);
    skyG.addColorStop(0,'#1a3560'); skyG.addColorStop(1,'#4890d0');
    ctx.fillStyle=skyG; ctx.fillRect(0,0,W,H*0.45);
    const gndG=ctx.createLinearGradient(0,H*0.45,0,H);
    gndG.addColorStop(0,'#2a5c18'); gndG.addColorStop(1,'#1a3a10');
    ctx.fillStyle=gndG; ctx.fillRect(0,H*0.45,W,H*0.55);
    // Subject
    ctx.fillStyle='#b06030'; ctx.fillRect(W*0.38,H*0.1,W*0.14,H*0.56);
    // Window lit area
    ctx.fillStyle='rgba(255,200,100,0.15)';
    ctx.fillRect(W*0.55,H*0.05,W*0.12,H*0.3);
    // Shadow
    ctx.fillStyle='#0a1018'; ctx.fillRect(W*0.78,H*0.08,W*0.18,H*0.68);
    // Color patches
    ['#c82020','#c87020','#20a840','#2060b8','#7030a0','#c03060'].forEach((c,i)=>{
      ctx.fillStyle=c; ctx.fillRect(i*(W/6),H*0.75,W/6,H*0.25);
    });
  }

  // LOG flatten
  function applyLogFlatten(id){
    const d=id.data;
    for(let i=0;i<d.length;i+=4){
      const r=d[i]/255,g=d[i+1]/255,b=d[i+2]/255;
      const fl=v=>clamp(0.2+v*0.55,0,1);
      d[i]=fl(r)*255; d[i+1]=fl(g)*255; d[i+2]=fl(b)*255;
    }
  }
  // LUT conversion (log curve)
  function applyLutConv(id,intensity){
    const d=id.data;
    for(let i=0;i<d.length;i+=4){
      const r=d[i]/255,g=d[i+1]/255,b=d[i+2]/255;
      const lc=v=>clamp(Math.pow(v,0.5)*1.1,0,1);
      d[i]=(r*(1-intensity)+lc(r)*intensity)*255;
      d[i+1]=(g*(1-intensity)+lc(g)*intensity)*255;
      d[i+2]=(b*(1-intensity)+lc(b)*intensity)*255;
    }
  }
  // Shadow lift
  function applyShadowLift(id,intensity,liftAmt){
    const d=id.data;
    const lift=liftAmt*intensity;
    for(let i=0;i<d.length;i+=4){
      const r=d[i]/255,g=d[i+1]/255,b=d[i+2]/255;
      const lum=0.2126*r+0.7152*g+0.0722*b;
      const w=Math.max(0,1-lum*3)*intensity;
      d[i]=clamp((r+lift*w)*255,0,255);
      d[i+1]=clamp((g+lift*w)*255,0,255);
      d[i+2]=clamp((b+lift*w)*255,0,255);
    }
  }
  // Highlight rolloff
  function applyRolloff(id,intensity){
    const d=id.data;
    for(let i=0;i<d.length;i+=4){
      const r=d[i]/255,g=d[i+1]/255,b=d[i+2]/255;
      const roll=v=>{const comp=1-v;return 1-Math.pow(comp,1/(1+intensity));};
      d[i]=clamp((r*(1-intensity)+roll(r)*intensity)*255,0,255);
      d[i+1]=clamp((g*(1-intensity)+roll(g)*intensity)*255,0,255);
      d[i+2]=clamp((b*(1-intensity)+roll(b)*intensity)*255,0,255);
    }
  }
  // Film grain
  let grainSeed=0;
  function applyGrain(id,intensity,grainAmount){
    const d=id.data;
    const amt=intensity*grainAmount*80;
    for(let i=0;i<d.length;i+=4){
      const noise=(Math.random()-0.5)*amt;
      d[i]=clamp(d[i]+noise,0,255);
      d[i+1]=clamp(d[i+1]+noise*0.9,0,255);
      d[i+2]=clamp(d[i+2]+noise*0.85,0,255);
    }
  }
  // Film stock color
  function applyStock(id,stock){
    const d=id.data;
    const s=FILM_STOCKS[stock];
    for(let i=0;i<d.length;i+=4){
      let r=d[i]/255,g=d[i+1]/255,b=d[i+2]/255;
      // Warmth
      r+=s.warm; b-=s.warm*0.5;
      // Saturation
      const lum=0.2126*r+0.7152*g+0.0722*b;
      r=lum+(r-lum)*s.sat; g=lum+(g-lum)*s.sat; b=lum+(b-lum)*s.sat;
      // Contrast
      r=(r-0.5)*s.contrast+0.5; g=(g-0.5)*s.contrast+0.5; b=(b-0.5)*s.contrast+0.5;
      d[i]=clamp(r*255,0,255); d[i+1]=clamp(g*255,0,255); d[i+2]=clamp(b*255,0,255);
    }
  }

  const srcOff=document.createElement('canvas');
  srcOff.width=W; srcOff.height=H;
  drawFilmSource(srcOff.getContext('2d'),W,H);

  let filmLastTime=null;
  function filmLoop(ts){
    if(!filmLastTime)filmLastTime=ts;
    const dt=Math.min((ts-filmLastTime)/1000,0.1);
    filmLastTime=ts;

    // Update intensities
    stepState.forEach(s=>{ s.intensity=s.lfIntensity.update(s.target,dt); });

    // Build composited image
    const tmp=document.createElement('canvas');
    tmp.width=W; tmp.height=H;
    const tCtx=tmp.getContext('2d');
    tCtx.drawImage(srcOff,0,0);
    const id=tCtx.getImageData(0,0,W,H);

    const stock=FILM_STOCKS[currentStock];
    if(stepState[0].enabled) applyLogFlatten(id);
    if(stepState[1].enabled) applyLutConv(id,stepState[1].intensity);
    if(stepState[2].enabled) applyShadowLift(id,stepState[2].intensity,stock.lift);
    if(stepState[3].enabled) applyRolloff(id,stepState[3].intensity*0.6);
    applyStock(id,currentStock);
    if(stepState[4].enabled) applyGrain(id,stepState[4].intensity,stock.grain);

    filmCtx.putImageData(id,0,0);

    // Vignette overlay
    const vig=filmCtx.createRadialGradient(W/2,H/2,H*0.2,W/2,H/2,H*0.7);
    vig.addColorStop(0,'rgba(0,0,0,0)');
    vig.addColorStop(1,'rgba(0,0,0,0.35)');
    filmCtx.fillStyle=vig; filmCtx.fillRect(0,0,W,H);

    requestAnimationFrame(filmLoop);
  }
  requestAnimationFrame(filmLoop);
})();

