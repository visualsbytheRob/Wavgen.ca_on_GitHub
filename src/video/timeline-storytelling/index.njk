<script>
// ── UTILITY: LagFilter ──────────────────────────────────────────────────────
class LagFilter {
  constructor(strength=0.08){this.v=null;this.s=strength}
  update(target){
    if(this.v===null)this.v=target;
    this.v+=(target-this.v)*this.s;
    return this.v;
  }
}

// ── UTILITY: NAV SCROLL ─────────────────────────────────────────────────────
function scrollTo(id){
  const el=document.getElementById(id);
  if(el)el.scrollIntoView({behavior:'smooth',block:'start'});
}

// ── UTILITY: IntersectionObserver scroll-reveal ─────────────────────────────
const revealObs=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting){e.target.classList.add('visible');}
  });
},{threshold:0.08});
document.querySelectorAll('section').forEach(s=>{
  if(s.id!=='hero')revealObs.observe(s);
  else s.classList.add('visible');
});

// ── NAV ACTIVE ──────────────────────────────────────────────────────────────
const navLinks=document.querySelectorAll('.nav-link');
const sectionIds=['hero','s2','s3','s4','s5','s6','s7','s8','s9'];
const sectionEls=sectionIds.map(id=>document.getElementById(id));
const navObs=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const idx=sectionEls.indexOf(e.target);
      navLinks.forEach((l,i)=>l.classList.toggle('active',i===idx));
    }
  });
},{threshold:0.3});
sectionEls.forEach(s=>{if(s)navObs.observe(s);});

// ── COLOR PALETTES ──────────────────────────────────────────────────────────
const EMOTION_COLORS=[
  {key:'joy',    color:'#f59e0b', label:'Joy/Hope'},
  {key:'sad',    color:'#3b82f6', label:'Sadness/Loss'},
  {key:'fear',   color:'#ef4444', label:'Fear/Tension'},
  {key:'anger',  color:'#f97316', label:'Anger/Conflict'},
  {key:'peace',  color:'#22c55e', label:'Peace/Resolution'},
  {key:'wonder', color:'#a855f7', label:'Mystery/Wonder'},
];
let activeEmotion=EMOTION_COLORS[0];

function buildColorStrip(containerId, onSelect){
  const c=document.getElementById(containerId);
  if(!c)return;
  EMOTION_COLORS.forEach((e,i)=>{
    const d=document.createElement('div');
    d.className='color-dot'+(i===0?' selected':'');
    d.style.background=e.color;
    d.title=e.label;
    d.onclick=()=>{
      c.querySelectorAll('.color-dot').forEach(x=>x.classList.remove('selected'));
      d.classList.add('selected');
      onSelect(e);
    };
    c.appendChild(d);
  });
}
buildColorStrip('emotionColors',(e)=>{activeEmotion=e;});
buildColorStrip('shotColors',(e)=>{activeShotColor=e;});

// ════════════════════════════════════════════════════════════════════════════
// SECTION 1 — HERO: Film Strip Canvas
// ════════════════════════════════════════════════════════════════════════════
(function(){
  const canvas=document.getElementById('heroCanvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;

  const BEATS=[
    {label:'INCITING\nINCIDENT', palette:['#f59e0b','#fcd34d','#fef3c7'], mood:'joy'},
    {label:'CALL TO\nADVENTURE', palette:['#3b82f6','#60a5fa','#1e3a5f'], mood:'wonder'},
    {label:'REFUSAL', palette:['#64748b','#94a3b8','#1e293b'], mood:'doubt'},
    {label:'CROSSING\nTHRESHOLD', palette:['#f59e0b','#ef4444','#7c2d12'], mood:'tension'},
    {label:'ORDEAL', palette:['#0a0a0f','#1e1e2e','#ef4444'], mood:'crisis'},
    {label:'DARK NIGHT', palette:['#1e1e2e','#0f172a','#3b82f6'], mood:'despair'},
    {label:'REVELATION', palette:['#a855f7','#7c3aed','#f59e0b'], mood:'wonder'},
    {label:'CLIMAX', palette:['#ef4444','#f97316','#fcd34d'], mood:'crisis'},
    {label:'RESOLUTION', palette:['#22c55e','#f59e0b','#fef3c7'], mood:'joy'},
    {label:'RETURN', palette:['#f59e0b','#fcd34d','#fffbeb'], mood:'hope'},
    {label:'CHANGED\nHERO', palette:['#22c55e','#86efac','#d1fae5'], mood:'peace'},
    {label:'FINAL\nIMAGE', palette:['#f59e0b','#92400e','#1c1917'], mood:'resolution'},
  ];

  const FRAME_W=96, FRAME_H=240, GAP=18, SPROCKET=8;
  const STRIP_H=FRAME_H+80, STRIP_Y=(H-STRIP_H)/2;
  const totalW=(FRAME_W+GAP)*BEATS.length;
  let offset=0;
  const offsetLag=new LagFilter(0.04);
  let targetOffset=0;
  const SCROLL_SPEED=0.4;

  function drawBeat(ctx,x,y,beat,idx){
    // Frame border
    ctx.save();
    ctx.strokeStyle='rgba(245,158,11,0.5)';
    ctx.lineWidth=1.5;
    ctx.strokeRect(x,y,FRAME_W,FRAME_H);

    // Background gradient
    const g=ctx.createLinearGradient(x,y,x+FRAME_W,y+FRAME_H);
    g.addColorStop(0,beat.palette[0]);
    g.addColorStop(0.5,beat.palette[1]);
    g.addColorStop(1,beat.palette[2]);
    ctx.fillStyle=g;
    ctx.fillRect(x+1,y+1,FRAME_W-2,FRAME_H-2);

    // Simple geometric composition per mood
    ctx.save();
    ctx.beginPath();
    ctx.rect(x+1,y+1,FRAME_W-2,FRAME_H-2);
    ctx.clip();
    if(beat.mood==='joy'||beat.mood==='hope'){
      // Rising sun shape
      ctx.fillStyle='rgba(255,255,255,0.15)';
      ctx.beginPath();
      ctx.arc(x+FRAME_W/2,y+FRAME_H*0.75,30,Math.PI,0);
      ctx.fill();
      for(let r=0;r<6;r++){
        const angle=-Math.PI+r*(Math.PI/5);
        ctx.strokeStyle='rgba(255,255,255,0.12)';
        ctx.lineWidth=1;
        ctx.beginPath();
        ctx.moveTo(x+FRAME_W/2,y+FRAME_H*0.75);
        ctx.lineTo(x+FRAME_W/2+Math.cos(angle)*50,y+FRAME_H*0.75+Math.sin(angle)*50);
        ctx.stroke();
      }
    } else if(beat.mood==='crisis'||beat.mood==='tension'){
      // Jagged diagonal lines
      ctx.strokeStyle='rgba(255,255,255,0.2)';
      ctx.lineWidth=2;
      for(let i=0;i<5;i++){
        const yy=y+FRAME_H*0.3+i*20;
        ctx.beginPath();
        ctx.moveTo(x+5,yy);
        ctx.lineTo(x+FRAME_W*0.4,yy-15);
        ctx.lineTo(x+FRAME_W*0.6,yy+15);
        ctx.lineTo(x+FRAME_W-5,yy-10);
        ctx.stroke();
      }
    } else if(beat.mood==='despair'||beat.mood==='doubt'){
      // Descending stairs
      ctx.fillStyle='rgba(255,255,255,0.08)';
      for(let i=0;i<5;i++){
        ctx.fillRect(x+5+i*16,y+FRAME_H*0.5+i*18,14,14);
      }
    } else if(beat.mood==='wonder'){
      // Concentric circles
      for(let r=10;r<50;r+=12){
        ctx.strokeStyle=`rgba(255,255,255,${0.2-r*0.003})`;
        ctx.lineWidth=1;
        ctx.beginPath();
        ctx.arc(x+FRAME_W/2,y+FRAME_H/2,r,0,Math.PI*2);
        ctx.stroke();
      }
    } else if(beat.mood==='peace'||beat.mood==='resolution'){
      // Horizontal calm lines
      ctx.strokeStyle='rgba(255,255,255,0.12)';
      ctx.lineWidth=1.5;
      for(let i=0;i<8;i++){
        const yy=y+FRAME_H*0.3+i*18;
        ctx.beginPath();
        ctx.moveTo(x+8,yy);
        ctx.lineTo(x+FRAME_W-8,yy);
        ctx.stroke();
      }
    }
    ctx.restore();

    // Beat label
    ctx.fillStyle='rgba(0,0,0,0.6)';
    ctx.fillRect(x+1,y+FRAME_H-36,FRAME_W-2,35);
    ctx.fillStyle='#f59e0b';
    ctx.font='bold 8px "Courier New"';
    ctx.textAlign='center';
    const lines=beat.label.split('\n');
    lines.forEach((ln,li)=>{
      ctx.fillText(ln,x+FRAME_W/2,y+FRAME_H-22+li*11);
    });
    ctx.restore();
  }

  function draw(ts){
    ctx.clearRect(0,0,W,H);

    // Background
    const bgG=ctx.createLinearGradient(0,0,0,H);
    bgG.addColorStop(0,'#050508');
    bgG.addColorStop(1,'#0d0d14');
    ctx.fillStyle=bgG;
    ctx.fillRect(0,0,W,H);

    // Auto scroll
    targetOffset+=SCROLL_SPEED;
    if(targetOffset>totalW) targetOffset=0;
    offset=offsetLag.update(targetOffset);

    const stripY=STRIP_Y+20;

    // Film strip body
    ctx.fillStyle='#0a0a12';
    ctx.fillRect(0,stripY-8,W,STRIP_H+16);
    ctx.strokeStyle='rgba(245,158,11,0.2)';
    ctx.lineWidth=1;
    ctx.strokeRect(0,stripY-8,W,STRIP_H+16);

    // Sprocket holes top and bottom
    for(let sx=-GAP;sx<W+GAP*2;sx+=GAP*2){
      const hx=sx-((offset%(GAP*2)));
      ctx.fillStyle='rgba(245,158,11,0.4)';
      // top
      ctx.beginPath();
      ctx.arc(hx,stripY-4,SPROCKET/2,0,Math.PI*2);
      ctx.fill();
      // bottom
      ctx.beginPath();
      ctx.arc(hx,stripY+STRIP_H+4,SPROCKET/2,0,Math.PI*2);
      ctx.fill();
    }

    // Draw frames
    ctx.save();
    ctx.beginPath();
    ctx.rect(0,stripY,W,STRIP_H);
    ctx.clip();
    for(let i=-1;i<Math.ceil(W/(FRAME_W+GAP))+2;i++){
      const baseX=i*(FRAME_W+GAP)-((offset)%(totalW))+10;
      const beatIdx=((i%(BEATS.length))+BEATS.length)%BEATS.length;
      drawBeat(ctx,baseX,stripY+20,BEATS[beatIdx],beatIdx);
    }
    ctx.restore();

    // Playhead line
    const phX=W/2;
    const grad=ctx.createLinearGradient(phX,0,phX,H);
    grad.addColorStop(0,'rgba(245,158,11,0)');
    grad.addColorStop(0.3,'rgba(245,158,11,0.8)');
    grad.addColorStop(0.7,'rgba(245,158,11,0.8)');
    grad.addColorStop(1,'rgba(245,158,11,0)');
    ctx.strokeStyle=grad;
    ctx.lineWidth=2;
    ctx.setLineDash([4,4]);
    ctx.beginPath();
    ctx.moveTo(phX,0);
    ctx.lineTo(phX,H);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle='#f59e0b';
    ctx.font='bold 9px "Courier New"';
    ctx.textAlign='center';
    ctx.fillText('◆ NOW',phX,16);

    // Title overlay (top)
    ctx.fillStyle='rgba(5,5,8,0.5)';
    ctx.fillRect(0,0,W,stripY-8);
    ctx.fillRect(0,stripY+STRIP_H+8,W,H-(stripY+STRIP_H+8));

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();

// ════════════════════════════════════════════════════════════════════════════
// SECTION 2 — STORY STRUCTURE ANALYZER
// SYSTEM: StoryArcVisualizer
// ════════════════════════════════════════════════════════════════════════════
(function(){
  const canvas=document.getElementById('structCanvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  let activeStruct=0;
  let userCurve=[];
  let isDrawing=false;

  // Structure definitions
  const STRUCTS=[
    {
      name:'Three-Act Structure',
      draw:drawThreeAct,
      color:'#f59e0b',
    },
    {
      name:"Hero's Journey",
      draw:drawHeroJourney,
      color:'#a855f7',
    },
    {
      name:'Kishōtenketsu',
      draw:drawKisho,
      color:'#22c55e',
    },
  ];

  function drawThreeAct(ctx,W,H){
    const pad=40, plotH=H-80;
    // Rising action: gentle slope up
    const pts=[
      {x:pad,y:plotH*0.85},
      {x:W*0.28,y:plotH*0.6},
      {x:W*0.5,y:plotH*0.3},
      {x:W*0.6,y:plotH*0.05}, // CLIMAX
      {x:W*0.7,y:plotH*0.35},
      {x:W-pad,y:plotH*0.2},
    ];
    ctx.strokeStyle=STRUCTS[0].color;
    ctx.lineWidth=3;
    ctx.shadowColor=STRUCTS[0].color;
    ctx.shadowBlur=8;
    drawCurve(ctx,pts);
    ctx.shadowBlur=0;

    // Labels
    const labels=[
      {x:pad,y:plotH+16,t:'SETUP'},
      {x:W*0.27,y:plotH*0.6-14,t:'RISING ACTION'},
      {x:W*0.6,y:plotH*0.05-14,t:'CLIMAX'},
      {x:W*0.82,y:plotH*0.22-14,t:'RESOLUTION'},
    ];
    ctx.fillStyle='rgba(245,158,11,0.7)';
    ctx.font='9px "Courier New"';
    ctx.textAlign='center';
    labels.forEach(l=>ctx.fillText(l.t,l.x,l.y));

    // Act dividers
    ctx.strokeStyle='rgba(245,158,11,0.2)';
    ctx.lineWidth=1;
    ctx.setLineDash([4,4]);
    [W*0.25,W*0.75].forEach(x=>{
      ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,plotH+30);ctx.stroke();
    });
    ctx.setLineDash([]);
    ctx.fillStyle='rgba(245,158,11,0.4)';
    ctx.font='8px "Courier New"';
    ctx.fillText('ACT I',W*0.12,plotH+30);
    ctx.fillText('ACT II',W*0.5,plotH+30);
    ctx.fillText('ACT III',W*0.875,plotH+30);
  }

  function drawHeroJourney(ctx,W,H){
    const cx=W/2, cy=(H-40)/2+10, rx=W*0.36, ry=(H-60)/2;
    const stages=[
      {pct:0,   label:'ORDINARY WORLD'},
      {pct:0.1, label:'CALL TO\nADVENTURE'},
      {pct:0.2, label:'REFUSAL'},
      {pct:0.3, label:'CROSSING'},
      {pct:0.42,label:'TESTS &\nALLIES'},
      {pct:0.5, label:'ORDEAL'},
      {pct:0.62,label:'REWARD'},
      {pct:0.73,label:'ROAD BACK'},
      {pct:0.82,label:'RESURRECTION'},
      {pct:0.92,label:'RETURN WITH\nELIXIR'},
    ];

    ctx.strokeStyle=STRUCTS[1].color;
    ctx.lineWidth=2;
    ctx.shadowColor=STRUCTS[1].color;
    ctx.shadowBlur=6;
    ctx.beginPath();
    ctx.ellipse(cx,cy,rx,ry,0,0,Math.PI*2);
    ctx.stroke();
    ctx.shadowBlur=0;

    stages.forEach((s,i)=>{
      const angle=-Math.PI/2+s.pct*Math.PI*2;
      const px=cx+Math.cos(angle)*rx;
      const py=cy+Math.sin(angle)*ry;
      ctx.fillStyle=STRUCTS[1].color;
      ctx.beginPath();
      ctx.arc(px,py,5,0,Math.PI*2);
      ctx.fill();
      const lx=cx+Math.cos(angle)*(rx+28);
      const ly=cy+Math.sin(angle)*(ry+28);
      ctx.fillStyle='rgba(168,85,247,0.8)';
      ctx.font='7px "Courier New"';
      ctx.textAlign='center';
      const lines=s.label.split('\n');
      lines.forEach((ln,li)=>ctx.fillText(ln,lx,ly-4+li*9));
    });
    ctx.fillStyle='rgba(168,85,247,0.15)';
    ctx.beginPath();
    ctx.ellipse(cx,cy,rx,ry,0,0,Math.PI*2);
    ctx.fill();
  }

  function drawKisho(ctx,W,H){
    const pad=40, plotH=H-80;
    const pts=[
      {x:pad,y:plotH*0.7},
      {x:W*0.18,y:plotH*0.55},
      {x:W*0.33,y:plotH*0.35}, // KI ends
      {x:W*0.35,y:plotH*0.35},
      {x:W*0.5,y:plotH*0.38}, // SHO plateau
      {x:W*0.6,y:plotH*0.35},
      {x:W*0.62,y:plotH*0.1},  // TEN — surprise twist UP
      {x:W*0.72,y:plotH*0.45}, // KETSU reconciliation
      {x:W*0.85,y:plotH*0.3},
      {x:W-pad,y:plotH*0.25},
    ];
    ctx.strokeStyle=STRUCTS[2].color;
    ctx.lineWidth=3;
    ctx.shadowColor=STRUCTS[2].color;
    ctx.shadowBlur=8;
    drawCurve(ctx,pts);
    ctx.shadowBlur=0;

    const labels=[
      {x:W*0.17,y:plotH+16,t:'KI (Intro)'},
      {x:W*0.43,y:plotH+16,t:'SHŌ (Development)'},
      {x:W*0.62,y:plotH*0.1-14,t:'TEN (Twist)'},
      {x:W*0.82,y:plotH+16,t:'KETSU (Reconcile)'},
    ];
    ctx.strokeStyle='rgba(34,197,94,0.15)';
    ctx.lineWidth=1;
    ctx.setLineDash([4,4]);
    [W*0.33,W*0.62,W*0.73].forEach(x=>{
      ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,plotH+30);ctx.stroke();
    });
    ctx.setLineDash([]);
    ctx.fillStyle='rgba(34,197,94,0.7)';
    ctx.font='9px "Courier New"';
    ctx.textAlign='center';
    labels.forEach(l=>ctx.fillText(l.t,l.x,l.y));
  }

  function drawCurve(ctx,pts){
    if(pts.length<2)return;
    ctx.beginPath();
    ctx.moveTo(pts[0].x,pts[0].y);
    for(let i=1;i<pts.length-1;i++){
      const mx=(pts[i].x+pts[i+1].x)/2;
      const my=(pts[i].y+pts[i+1].y)/2;
      ctx.quadraticCurveTo(pts[i].x,pts[i].y,mx,my);
    }
    ctx.lineTo(pts[pts.length-1].x,pts[pts.length-1].y);
    ctx.stroke();
  }

  function drawGrid(ctx,W,H){
    ctx.strokeStyle='rgba(30,30,46,0.8)';
    ctx.lineWidth=1;
    for(let y=0;y<H-40;y+=40){
      ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();
    }
    // Y axis label
    ctx.save();
    ctx.translate(12,(H-40)/2);
    ctx.rotate(-Math.PI/2);
    ctx.fillStyle='#64748b';
    ctx.font='9px "Courier New"';
    ctx.textAlign='center';
    ctx.fillText('TENSION →',0,0);
    ctx.restore();
    ctx.fillStyle='#64748b';
    ctx.font='9px "Courier New"';
    ctx.textAlign='center';
    ctx.fillText('STORY TIME (0% → 100%)',W/2,H-8);
  }

  function render(){
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#0d0d14';
    ctx.fillRect(0,0,W,H);
    drawGrid(ctx,W,H);
    STRUCTS[activeStruct].draw(ctx,W,H);

    // Draw user curve overlay
    if(userCurve.length>1){
      ctx.strokeStyle='rgba(255,255,255,0.5)';
      ctx.lineWidth=2;
      ctx.setLineDash([6,4]);
      ctx.beginPath();
      ctx.moveTo(userCurve[0].x,userCurve[0].y);
      userCurve.forEach(p=>ctx.lineTo(p.x,p.y));
      ctx.stroke();
      ctx.setLineDash([]);
    }
  }
  render();

  canvas.addEventListener('mousedown',(e)=>{
    isDrawing=true;
    userCurve=[];
    const r=canvas.getBoundingClientRect();
    const sx=canvas.width/r.width, sy=canvas.height/r.height;
    userCurve.push({x:(e.clientX-r.left)*sx,y:(e.clientY-r.top)*sy});
  });
  canvas.addEventListener('mousemove',(e)=>{
    if(!isDrawing)return;
    const r=canvas.getBoundingClientRect();
    const sx=canvas.width/r.width, sy=canvas.height/r.height;
    userCurve.push({x:(e.clientX-r.left)*sx,y:(e.clientY-r.top)*sy});
    render();
  });
  canvas.addEventListener('mouseup',()=>{isDrawing=false;});
  canvas.addEventListener('mouseleave',()=>{isDrawing=false;});

  window.setStruct=function(idx){
    activeStruct=idx;
    const btns=document.querySelectorAll('#structBtns .btn');
    btns.forEach((b,i)=>b.classList.toggle('active',i===idx));
    userCurve=[];
    render();
  };
})();

