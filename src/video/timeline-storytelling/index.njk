// SECTION 4 — BRANCHING TIMELINE BUILDER
// SYSTEM: BranchingTimelineBuilder
// ════════════════════════════════════════════════════════════════════════════
(function(){
  const canvas=document.getElementById('branchCanvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height;
  let branches=[];
  let dotPos=0;
  let dotAnimating=false;
  let dotPath=[];
  let dotPathIdx=0;
  let dotPauseTick=0;
  let animRAF=null;

  const SPINE_Y=H/2;
  const SPINE_X0=40, SPINE_X1=W-40;
  const BRANCH_AMP=80;

  const TIMELINE_PRESETS={
    rashomon:{
      label:'Rashomon — 4 Perspectives',
      branches:[
        {xPct:0.25,type:'parallel',label:'Bandit\'s Version'},
        {xPct:0.5,type:'parallel',label:'Wife\'s Version'},
        {xPct:0.75,type:'parallel',label:'Samurai\'s Ghost'},
      ]
    },
    lola:{
      label:'Run Lola Run — 3 Runs',
      branches:[
        {xPct:0.33,type:'reset',label:'Run 1 Ends'},
        {xPct:0.66,type:'reset',label:'Run 2 Ends'},
      ]
    },
    memento:{
      label:'Memento — Reversed',
      branches:[
        {xPct:0.15,type:'flashback',label:'Scene B'},
        {xPct:0.35,type:'flashback',label:'Scene C'},
        {xPct:0.55,type:'flashback',label:'Scene D'},
        {xPct:0.75,type:'flashback',label:'Scene E'},
      ]
    },
    sliding:{
      label:'Sliding Doors — Split at Decision',
      branches:[
        {xPct:0.2,type:'split',label:'Catches Train'},
      ]
    },
  };

  function getBranchColor(type){
    return type==='parallel'?'#06b6d4':
           type==='reset'?'#ef4444':
           type==='flashback'?'rgba(255,255,255,0.7)':
           type==='split'?'#a855f7':'#f59e0b';
  }

  function xFromPct(pct){return SPINE_X0+pct*(SPINE_X1-SPINE_X0);}

  function drawBranchCanvas(){
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#0d0d14';
    ctx.fillRect(0,0,W,H);

    // Time axis arrow
    ctx.strokeStyle='rgba(245,158,11,0.15)';
    ctx.lineWidth=1;
    ctx.setLineDash([4,8]);
    ctx.beginPath();ctx.moveTo(SPINE_X0,SPINE_Y);ctx.lineTo(SPINE_X1,SPINE_Y);ctx.stroke();
    ctx.setLineDash([]);

    // Main spine
    ctx.strokeStyle='#f59e0b';
    ctx.lineWidth=3;
    ctx.shadowColor='#f59e0b';
    ctx.shadowBlur=6;
    ctx.beginPath();
    ctx.moveTo(SPINE_X0,SPINE_Y);
    ctx.lineTo(SPINE_X1,SPINE_Y);
    ctx.stroke();
    ctx.shadowBlur=0;

    // Arrow head
    ctx.fillStyle='#f59e0b';
    ctx.beginPath();
    ctx.moveTo(SPINE_X1,SPINE_Y);
    ctx.lineTo(SPINE_X1-10,SPINE_Y-5);
    ctx.lineTo(SPINE_X1-10,SPINE_Y+5);
    ctx.fill();
    ctx.font='9px "Courier New"';
    ctx.fillStyle='rgba(245,158,11,0.6)';
    ctx.textAlign='left';
    ctx.fillText('START',SPINE_X0,SPINE_Y-14);
    ctx.textAlign='right';
    ctx.fillText('END',SPINE_X1,SPINE_Y-14);

    // Draw branches
    branches.forEach((b,i)=>{
      const bx=xFromPct(b.xPct);
      const col=getBranchColor(b.type);
      const dir=i%2===0?-1:1; // alternating above/below

      // Branch fork
      ctx.strokeStyle=col;
      ctx.lineWidth=2;
      ctx.shadowColor=col;
      ctx.shadowBlur=4;
      ctx.beginPath();
      ctx.moveTo(bx,SPINE_Y);
      ctx.quadraticCurveTo(bx+40,SPINE_Y+dir*BRANCH_AMP*0.5,bx+100,SPINE_Y+dir*BRANCH_AMP);
      ctx.stroke();
      ctx.shadowBlur=0;

      // Endpoint card
      ctx.fillStyle='rgba(13,13,20,0.9)';
      ctx.strokeStyle=col;
      ctx.lineWidth=1.5;
      const ex=bx+100, ey=SPINE_Y+dir*BRANCH_AMP;
      ctx.beginPath();
      ctx.roundRect(ex-36,ey-14,72,28,4);
      ctx.fill();ctx.stroke();

      ctx.fillStyle=col;
      ctx.font='bold 9px "Courier New"';
      ctx.textAlign='center';
      ctx.fillText(b.label||`PATH ${i+1}`,ex,ey+4);

      // Fork dot
      ctx.fillStyle=col;
      ctx.beginPath();
      ctx.arc(bx,SPINE_Y,6,0,Math.PI*2);
      ctx.fill();
    });

    // Animated dot
    if(dotPos>0){
      ctx.fillStyle='#ffffff';
      ctx.shadowColor='#ffffff';
      ctx.shadowBlur=10;
      ctx.beginPath();
      ctx.arc(dotPos,SPINE_Y,7,0,Math.PI*2);
      ctx.fill();
      ctx.shadowBlur=0;
    }

    ctx.fillStyle='#64748b';
    ctx.font='9px "Courier New"';
    ctx.textAlign='center';
    ctx.fillText('AMBER = main · CYAN = alternative · WHITE = flashback · DIM = not taken',W/2,H-8);
  }
  drawBranchCanvas();

  function animateDot(){
    if(!dotAnimating){dotPos=0;drawBranchCanvas();return;}
    if(dotPos<SPINE_X0){dotPos=SPINE_X0;}
    if(dotPauseTick>0){
      dotPauseTick--;
      drawBranchCanvas();
      animRAF=requestAnimationFrame(animateDot);
      return;
    }
    dotPos+=2.5;
    // Check branch points
    branches.forEach(b=>{
      const bx=xFromPct(b.xPct);
      if(Math.abs(dotPos-bx)<3 && dotPauseTick===0){
        dotPauseTick=30; // pause 30 frames
      }
    });
    if(dotPos>=SPINE_X1){
      dotAnimating=false;
      dotPos=0;
    }
    drawBranchCanvas();
    if(dotAnimating) animRAF=requestAnimationFrame(animateDot);
  }

  window.addBranch=function(){
    const xPct=0.2+Math.random()*0.6;
    const types=['parallel','split','flashback','reset'];
    branches.push({xPct,type:types[Math.floor(Math.random()*types.length)],label:`FORK ${branches.length+1}`});
    branches.sort((a,b)=>a.xPct-b.xPct);
    drawBranchCanvas();
  };
  window.clearBranches=function(){branches=[];dotPos=0;dotAnimating=false;if(animRAF)cancelAnimationFrame(animRAF);drawBranchCanvas();};
  window.playTimeline=function(){
    dotAnimating=true;dotPos=SPINE_X0;dotPauseTick=0;
    if(animRAF)cancelAnimationFrame(animRAF);
    animRAF=requestAnimationFrame(animateDot);
  };
  window.loadTimelinePreset=function(){
    const key=document.getElementById('filmTimeline').value;
    if(!key)return;
    const p=TIMELINE_PRESETS[key];
    if(!p)return;
    branches=p.branches.map(b=>({...b}));
    drawBranchCanvas();
    document.getElementById('filmTimeline').value='';
  };
})();

// ════════════════════════════════════════════════════════════════════════════
// SECTION 5 — MONTAGE PACING STUDIO
// SYSTEM: MontagePacingStudio
// ════════════════════════════════════════════════════════════════════════════
(function(){
  const canvas=document.getElementById('pacingCanvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height;

  let shots=[];
  let selectedShot=-1;
  let dragging=null;
  let activeShotColorLocal=EMOTION_COLORS[0];
  let dragStartX=0;

  // expose to color strip
  window.activeShotColor=EMOTION_COLORS[0];

  const TRACK_Y=60, TRACK_H=120, PIE_CY=220, PIE_R=30;
  const MIN_W=8;

  const PACING_PRESETS={
    breathless:[
      ...Array.from({length:24},(_,i)=>({dur:0.5+Math.random()*1.5,color:EMOTION_COLORS[Math.floor(Math.random()*6)].color}))
    ],
    '2001':[
      {dur:18,color:'#3b82f6'},{dur:12,color:'#64748b'},{dur:24,color:'#3b82f6'},
      {dur:8,color:'#f59e0b'},{dur:30,color:'#0a0a0f'},{dur:16,color:'#3b82f6'},
    ],
    fury:[
      ...Array.from({length:40},(_,i)=>({dur:0.2+Math.random()*0.8,color:EMOTION_COLORS[Math.floor(Math.random()*3)].color}))
    ],
  };

  function getTotalDur(){return shots.reduce((s,sh)=>s+sh.dur,0);}

  function shotsToPixels(){
    const total=getTotalDur()||1;
    const usableW=W-20;
    let x=10;
    return shots.map(sh=>{
      const w=Math.max(MIN_W,(sh.dur/total)*usableW);
      const r={x,w,sh};
      x+=w+2;
      return r;
    });
  }

  function updateStats(){
    const n=shots.length;
    const total=getTotalDur();
    const avg=n?total/n:0;
    const cpm=total?Math.round((n/total)*60):0;
    let assessment='—';
    if(n>0){
      if(avg<1.5)assessment='FRANTIC';
      else if(avg<4)assessment='DYNAMIC';
      else assessment='SLOW BURN';
    }
    document.getElementById('statShots').textContent=n;
    document.getElementById('statAvg').textContent=avg.toFixed(1)+'s';
    document.getElementById('statCPM').textContent=cpm;
    document.getElementById('statPacing').textContent=assessment;
  }

  function drawPacing(){
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#0d0d14';
    ctx.fillRect(0,0,W,H);

    // Track background
    ctx.fillStyle='rgba(30,30,46,0.4)';
    ctx.beginPath();
    ctx.roundRect(10,TRACK_Y,W-20,TRACK_H,6);
    ctx.fill();
    ctx.strokeStyle='rgba(30,30,46,0.8)';
    ctx.lineWidth=1;
    ctx.stroke();

    // Draw shots
    const mapped=shotsToPixels();
    mapped.forEach((m,i)=>{
      const isSelected=(i===selectedShot);
      ctx.fillStyle=m.sh.color||'#f59e0b';
      ctx.globalAlpha=isSelected?1:0.8;
      ctx.beginPath();
      ctx.roundRect(m.x,TRACK_Y+4,m.w,TRACK_H-8,3);
      ctx.fill();
      ctx.globalAlpha=1;
      if(isSelected){
        ctx.strokeStyle='#ffffff';
        ctx.lineWidth=2;
        ctx.beginPath();
        ctx.roundRect(m.x,TRACK_Y+4,m.w,TRACK_H-8,3);
        ctx.stroke();
      }
      // Duration label if wide enough
      if(m.w>28){
        ctx.fillStyle='rgba(0,0,0,0.7)';
        ctx.font='8px "Courier New"';
        ctx.textAlign='center';
        ctx.fillText(m.sh.dur.toFixed(1)+'s',m.x+m.w/2,TRACK_Y+TRACK_H/2+4);
      }
      // Resize handle on right edge
      ctx.fillStyle='rgba(255,255,255,0.2)';
      ctx.fillRect(m.x+m.w-3,TRACK_Y+4,3,TRACK_H-8);
    });

    // Timeline ruler
    ctx.fillStyle='#64748b';
    ctx.font='9px "Courier New"';
    ctx.textAlign='center';
    const total=getTotalDur();
    for(let t=0;t<=total;t+=Math.max(1,Math.round(total/8))){
      const px=10+(t/Math.max(total,1))*(W-20);
      ctx.fillText(t+'s',px,TRACK_Y-6);
      ctx.strokeStyle='rgba(100,116,139,0.2)';
      ctx.lineWidth=1;
      ctx.beginPath();ctx.moveTo(px,TRACK_Y);ctx.lineTo(px,TRACK_Y+TRACK_H);ctx.stroke();
    }

    // Emotional distribution pie
    if(shots.length>0){
      const counts={};
      shots.forEach(sh=>{counts[sh.color]=(counts[sh.color]||0)+sh.dur;});
      const entries=Object.entries(counts);
      let startAngle=0;
      const total2=getTotalDur();
      const PIE_X=W-PIE_R-16;
      entries.forEach(([col,dur])=>{
        const sweep=(dur/total2)*Math.PI*2;
        ctx.fillStyle=col;
        ctx.beginPath();
        ctx.moveTo(PIE_X,PIE_CY);
        ctx.arc(PIE_X,PIE_CY,PIE_R,startAngle,startAngle+sweep);
        ctx.fill();
        startAngle+=sweep;
      });
      ctx.fillStyle='#64748b';
      ctx.font='8px "Courier New"';
      ctx.textAlign='center';
      ctx.fillText('EMOTION',PIE_X,PIE_CY+PIE_R+12);
    }

    ctx.fillStyle='#64748b';
    ctx.font='9px "Courier New"';
    ctx.textAlign='left';
    ctx.fillText('Click shots to select · Drag right edge to resize',12,H-8);
    updateStats();
  }
  drawPacing();

  canvas.addEventListener('click',(e)=>{
    const r=canvas.getBoundingClientRect();
    const sx=canvas.width/r.width;
    const cx=(e.clientX-r.left)*sx;
    const cy_=(e.clientY-r.top)*(canvas.height/r.height);
    if(cy_<TRACK_Y||cy_>TRACK_Y+TRACK_H)return;
    const mapped=shotsToPixels();
    let hit=-1;
    for(let i=0;i<mapped.length;i++){
      if(cx>=mapped[i].x&&cx<=mapped[i].x+mapped[i].w){hit=i;break;}
    }
    selectedShot=hit;
    drawPacing();
  });

  canvas.addEventListener('mousedown',(e)=>{
    const r=canvas.getBoundingClientRect();
    const sx=canvas.width/r.width;
    const cx=(e.clientX-r.left)*sx;
    const cy_=(e.clientY-r.top)*(canvas.height/r.height);
    if(cy_<TRACK_Y||cy_>TRACK_Y+TRACK_H)return;
    const mapped=shotsToPixels();
    for(let i=0;i<mapped.length;i++){
      const m=mapped[i];
      if(cx>=m.x+m.w-8&&cx<=m.x+m.w+4){
        dragging={shotIdx:i,startX:cx,startDur:m.sh.dur,totalDur:getTotalDur()};
        break;
      }
    }
  });
  canvas.addEventListener('mousemove',(e)=>{
    if(!dragging)return;
    const r=canvas.getBoundingClientRect();
    const sx=canvas.width/r.width;
    const cx=(e.clientX-r.left)*sx;
    const delta=cx-dragging.startX;
    const pxPerSec=(W-20)/Math.max(dragging.totalDur,1);
    const newDur=Math.max(0.1,dragging.startDur+delta/pxPerSec);
    shots[dragging.shotIdx].dur=parseFloat(newDur.toFixed(1));
    drawPacing();
  });
  canvas.addEventListener('mouseup',()=>{dragging=null;});
  canvas.addEventListener('mouseleave',()=>{dragging=null;});

  window.addShot=function(){
    shots.push({dur:2,color:window.activeShotColor.color||'#f59e0b'});
    drawPacing();
  };
  window.deleteSelectedShot=function(){
    if(selectedShot>=0&&selectedShot<shots.length){
      shots.splice(selectedShot,1);
      selectedShot=-1;
      drawPacing();
    }
  };
  window.loadPacingPreset=function(){
    const key=document.getElementById('filmPacing').value;
    if(!key)return;
    shots=PACING_PRESETS[key].map(s=>({...s}));
    selectedShot=-1;
    drawPacing();
    document.getElementById('filmPacing').value='';
  };

  // Re-render when shot color changes
  const origColorStrip=buildColorStrip;
  document.getElementById('shotColors')&&buildColorStrip('shotColors',(e)=>{
    window.activeShotColor=e;
    if(selectedShot>=0&&selectedShot<shots.length){
      shots[selectedShot].color=e.color;
      drawPacing();
    }
  });
})();

// ════════════════════════════════════════════════════════════════════════════
// SECTION 6 — NARRATIVE SPACE MAP
// SYSTEM: NarrativeSpaceMap
// ════════════════════════════════════════════════════════════════════════════
(function(){
  const canvas=document.getElementById('mapCanvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height;
  let locations=[];
  let paths=[];
  let mapMode='place';
  let connectStart=-1;
  let journeyDot=null;
  let journeyStep=0;
  let journeyT=0;
  let journeyAnimRAF=null;

  const MAP_PRESETS={
    wizard:{
      label:'The Wizard of Oz',
      locations:[
        {x:90,y:300,label:'Kansas'},
        {x:200,y:180,label:'Munchkinland'},
        {x:320,y:260,label:'Yellow\nBrick Road'},
        {x:480,y:160,label:'Emerald City'},
        {x:580,y:280,label:"Witch's Castle"},
        {x:90,y:300,label:'Kansas (Return)'},
      ],
      paths:[
        {from:0,to:1,emotion:'joy',label:'Tornado'},
        {from:1,to:2,emotion:'wonder',label:'Follow the road'},
        {from:2,to:3,emotion:'joy',label:'Enter the city'},
        {from:3,to:4,emotion:'fear',label:'Save Toto'},
        {from:4,to:5,emotion:'peace',label:'Click heels'},
      ],
    },
    odyssey:{
      label:'The Odyssey',
      locations:[
        {x:100,y:200,label:'Troy'},
        {x:200,y:120,label:'Cicones'},
        {x:290,y:80,label:"Cyclops'sIsland"},
        {x:400,y:100,label:'Aeolia'},
        {x:490,y:180,label:"Circe's Isle"},
        {x:540,y:280,label:'Underworld'},
        {x:460,y:340,label:'Sirens'},
        {x:350,y:320,label:'Scylla &\nCharybdis'},
        {x:240,y:340,label:'Helios\' Isle'},
        {x:110,y:360,label:'Ithaca'},
      ],
      paths:[
        {from:0,to:1,emotion:'anger'},{from:1,to:2,emotion:'fear'},
        {from:2,to:3,emotion:'wonder'},{from:3,to:4,emotion:'wonder'},
        {from:4,to:5,emotion:'fear'},{from:5,to:6,emotion:'fear'},
        {from:6,to:7,emotion:'fear'},{from:7,to:8,emotion:'anger'},
        {from:8,to:9,emotion:'joy'},
      ],
    },
    shining:{
      label:'The Shining — Overlook Hotel',
      locations:[
        {x:320,y:200,label:'Lobby'},
        {x:180,y:200,label:'Room 237'},
        {x:460,y:200,label:'Ballroom'},
        {x:320,y:100,label:'Hedge Maze\nEntrance'},
        {x:320,y:320,label:'Boiler Room'},
        {x:200,y:100,label:'Hedge Maze\nDeep'},
      ],
      paths:[
        {from:0,to:1,emotion:'fear'},{from:0,to:2,emotion:'wonder'},
        {from:0,to:3,emotion:'fear'},{from:0,to:4,emotion:'anger'},
        {from:3,to:5,emotion:'fear'},
      ],
    },
  };

  function getEmotionColor(emo){
    const e=EMOTION_COLORS.find(x=>x.key===emo);
    return e?e.color:'#f59e0b';
  }

  function drawMap(){
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#0d0d14';
    ctx.fillRect(0,0,W,H);

    // Subtle grid
    ctx.strokeStyle='rgba(30,30,46,0.5)';
    ctx.lineWidth=1;
    for(let x=0;x<W;x+=40){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
    for(let y=0;y<H;y+=40){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}

    // Draw paths
    paths.forEach((p,i)=>{
      const from=locations[p.from], to=locations[p.to];
      if(!from||!to)return;
      const col=getEmotionColor(p.emotion);
      ctx.strokeStyle=col;
      ctx.lineWidth=2;
      ctx.shadowColor=col;
      ctx.shadowBlur=4;
      ctx.beginPath();
      ctx.moveTo(from.x,from.y);
      const mx=(from.x+to.x)/2, my=(from.y+to.y)/2-30;
      ctx.quadraticCurveTo(mx,my,to.x,to.y);
      ctx.stroke();
      ctx.shadowBlur=0;
      // Arrowhead
      const angle=Math.atan2(to.y-my,to.x-mx);
      ctx.fillStyle=col;
      ctx.beginPath();
      ctx.moveTo(to.x,to.y);
      ctx.lineTo(to.x-10*Math.cos(angle-0.4),to.y-10*Math.sin(angle-0.4));
      ctx.lineTo(to.x-10*Math.cos(angle+0.4),to.y-10*Math.sin(angle+0.4));
      ctx.fill();
      // Label
      if(p.label){
        ctx.fillStyle=col;
        ctx.font='8px "Courier New"';
        ctx.textAlign='center';
        ctx.fillText(p.label,mx,my-4);
      }
    });

    // Draw location nodes
    locations.forEach((loc,i)=>{
      ctx.beginPath();
      ctx.arc(loc.x,loc.y,16,0,Math.PI*2);
      const grad=ctx.createRadialGradient(loc.x,loc.y,4,loc.x,loc.y,16);
      grad.addColorStop(0,'rgba(245,158,11,0.3)');
      grad.addColorStop(1,'rgba(245,158,11,0.05)');
      ctx.fillStyle=grad;
      ctx.fill();
      ctx.strokeStyle=(connectStart===i)?'#ffffff':'rgba(245,158,11,0.7)';
      ctx.lineWidth=(connectStart===i)?2.5:1.5;
      ctx.stroke();
      // Label
      const lines=loc.label.split('\n');
      ctx.fillStyle='#f59e0b';
      ctx.font='bold 9px "Courier New"';
      ctx.textAlign='center';
      lines.forEach((ln,li)=>ctx.fillText(ln,loc.x,loc.y+24+li*11));
      // Index
      ctx.fillStyle='rgba(245,158,11,0.6)';
      ctx.font='8px "Courier New"';
      ctx.textAlign='center';
      ctx.fillText(i+1,loc.x,loc.y+4);
    });

    // Journey dot
    if(journeyDot){
      ctx.fillStyle='#ffffff';
      ctx.shadowColor='#ffffff';
      ctx.shadowBlur=12;
      ctx.beginPath();
      ctx.arc(journeyDot.x,journeyDot.y,8,0,Math.PI*2);
      ctx.fill();
      ctx.shadowBlur=0;
    }

    ctx.fillStyle='#64748b';
    ctx.font='9px "Courier New"';
    ctx.textAlign='left';
    ctx.fillText(`MODE: ${mapMode.toUpperCase()} · ${locations.length} locations · ${paths.length} paths`,8,H-8);
  }
  drawMap();

  canvas.addEventListener('click',(e)=>{
    const r=canvas.getBoundingClientRect();
    const sx=canvas.width/r.width, sy=canvas.height/r.height;
    const cx=(e.clientX-r.left)*sx;
    const cy=(e.clientY-r.top)*sy;

    if(mapMode==='place'){
      const hit=locations.findIndex(l=>Math.hypot(l.x-cx,l.y-cy)<20);
      if(hit===-1){
        locations.push({x:Math.round(cx),y:Math.round(cy),label:`LOC ${locations.length+1}`});
      }
      drawMap();
    } else if(mapMode==='connect'){
      const hit=locations.findIndex(l=>Math.hypot(l.x-cx,l.y-cy)<22);
      if(hit===-1)return;
      if(connectStart===-1){
        connectStart=hit;
      } else {
        if(connectStart!==hit){
          paths.push({from:connectStart,to:hit,emotion:activeEmotion.key,label:''});
        }
        connectStart=-1;
      }
      drawMap();
    }
  });

  function animateJourney(){
    if(!paths.length||!locations.length)return;
    const p=paths[journeyStep];
    const from=locations[p.from], to=locations[p.to];
    if(!from||!to)return;
    journeyT+=0.02;
    if(journeyT>=1){
      journeyT=0;
      journeyStep=(journeyStep+1)%paths.length;
    }
    // Quadratic bezier interpolation
    const mx=(from.x+to.x)/2, my=(from.y+to.y)/2-30;
    const t=journeyT;
    const x=(1-t)*(1-t)*from.x+2*(1-t)*t*mx+t*t*to.x;
    const y=(1-t)*(1-t)*from.y+2*(1-t)*t*my+t*t*to.y;
    journeyDot={x,y};
    drawMap();
    journeyAnimRAF=requestAnimationFrame(animateJourney);
  }

  window.setMapMode=function(m){
    mapMode=m;
    connectStart=-1;
    document.getElementById('modePlace').classList.toggle('active',m==='place');
    document.getElementById('modeConnect').classList.toggle('active',m==='connect');
    drawMap();
  };
  window.clearMap=function(){locations=[];paths=[];connectStart=-1;journeyDot=null;if(journeyAnimRAF)cancelAnimationFrame(journeyAnimRAF);drawMap();};
  window.playMapJourney=function(){
    if(!paths.length)return;
    journeyStep=0;journeyT=0;
    if(journeyAnimRAF)cancelAnimationFrame(journeyAnimRAF);
    journeyAnimRAF=requestAnimationFrame(animateJourney);
  };
  window.loadMapPreset=function(){
    const key=document.getElementById('mapPreset').value;
    if(!key)return;
    const p=MAP_PRESETS[key];
    if(!p)return;
    locations=p.locations.map(l=>({...l}));
    paths=p.paths.map(p2=>({...p2}));
    journeyDot=null;
    drawMap();
    document.getElementById('mapPreset').value='';
  };
})();

// ════════════════════════════════════════════════════════════════════════════
// SECTION 7 — TIME MANIPULATION TOOLS
// ════════════════════════════════════════════════════════════════════════════

// — Flashback Machine —
(function(){
  const canvas=document.getElementById('flashCanvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height;
  let blend=0; // 0=present, 1=past

  function drawFlash(b){
    ctx.clearRect(0,0,W,H);
    // Present scene (cool, sharp, neutral)
    const presentBg=ctx.createLinearGradient(0,0,W,H);
    presentBg.addColorStop(0,'#0d1a2e');
    presentBg.addColorStop(1,'#1e2d44');
    // Past scene (warm, vignetted, soft)
    const pastBg=ctx.createLinearGradient(0,0,W,H);
    pastBg.addColorStop(0,'#2a1a0a');
    pastBg.addColorStop(1,'#4a2e0e');

    // Draw blended background
    ctx.globalAlpha=1-b;
    ctx.fillStyle=presentBg;
    ctx.fillRect(0,0,W,H);
    ctx.globalAlpha=b;
    ctx.fillStyle=pastBg;
    ctx.fillRect(0,0,W,H);
    ctx.globalAlpha=1;

    // Present scene elements (geometric, sharp)
    ctx.save();
    ctx.globalAlpha=Math.max(0,1-b*1.5);
    // City buildings silhouette
    const bldgs=[[30,160,50,80],[90,140,40,100],[140,120,60,120],[210,150,45,90],[265,130,55,110],[330,155,40,85]];
    ctx.fillStyle='#0a1525';
    bldgs.forEach(([x,y,w,h])=>ctx.fillRect(x,y,w,h));
    // Windows
    ctx.fillStyle='#3b82f6';
    bldgs.forEach(([x,y,w,h])=>{
      for(let wy=y+10;wy<y+h-10;wy+=15){
        for(let wx=x+8;wx<x+w-8;wx+=14){
          if(Math.random()>0.4)ctx.fillRect(wx,wy,6,8);
        }
      }
    });
    ctx.fillStyle='#60a5fa';
    ctx.font='bold 11px "Courier New"';
    ctx.textAlign='center';
    ctx.fillText('PRESENT',W/2,H-16);
    ctx.restore();

    // Past scene elements (soft, warm)
    ctx.save();
    ctx.globalAlpha=Math.max(0,b*1.5-0.3);
    // Soft landscape
    const hillGrad=ctx.createLinearGradient(0,H*0.5,0,H);
    hillGrad.addColorStop(0,'#5c3a0a');
    hillGrad.addColorStop(1,'#2a1a05');
    ctx.fillStyle=hillGrad;
    ctx.beginPath();
    ctx.moveTo(0,H);
    ctx.lineTo(0,H*0.65);
    ctx.quadraticCurveTo(W*0.3,H*0.45,W*0.5,H*0.6);
    ctx.quadraticCurveTo(W*0.7,H*0.75,W,H*0.55);
    ctx.lineTo(W,H);
    ctx.fill();
    // Warm sun
    const sunG=ctx.createRadialGradient(W*0.75,H*0.25,5,W*0.75,H*0.25,40);
    sunG.addColorStop(0,'rgba(253,200,100,0.9)');
    sunG.addColorStop(1,'rgba(253,200,100,0)');
    ctx.fillStyle=sunG;
    ctx.beginPath();ctx.arc(W*0.75,H*0.25,40,0,Math.PI*2);ctx.fill();
    // Vignette
    const vig=ctx.createRadialGradient(W/2,H/2,H*0.2,W/2,H/2,H*0.7);
    vig.addColorStop(0,'rgba(0,0,0,0)');
    vig.addColorStop(1,'rgba(20,8,0,0.8)');
    ctx.fillStyle=vig;ctx.fillRect(0,0,W,H);
    ctx.fillStyle='rgba(253,200,100,0.7)';
    ctx.font='bold 11px "Courier New"';
    ctx.textAlign='center';
    ctx.fillText('PAST — MEMORY',W/2,H-16);
    ctx.restore();

    // Soft-edge blur simulation overlay when past
    if(b>0.2){
      ctx.globalAlpha=b*0.3;
      ctx.fillStyle='rgba(180,100,30,0.15)';
      ctx.fillRect(0,0,W,H);
      ctx.globalAlpha=1;
    }

    // Label
    ctx.fillStyle='rgba(245,158,11,0.6)';
    ctx.font='9px "Courier New"';
    ctx.textAlign='left';
    ctx.fillText(`BLEND: ${Math.round(b*100)}% PAST`,8,18);
  }
  drawFlash(0);

  window.updateFlash=function(val){
    blend=(100-parseInt(val))/100;
    drawFlash(blend);
  };
})();

// — Parallel Timeline Viewer —
(function(){
  const canvas=document.getElementById('parallelCanvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height;
  let convergePct=0.7;
  let tick=0;

  const TRACKS=[
    {label:'LAND — 1 WEEK',color:'#f59e0b',speed:1,y:H*0.28},
    {label:'SEA — 1 DAY',color:'#06b6d4',speed:2.5,y:H*0.55},
    {label:'AIR — 1 HOUR',color:'#a855f7',speed:6,y:H*0.78},
  ];
  const TRACK_H=28;
  const PAD_X=10;

  function drawParallel(){
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#0d0d14';
    ctx.fillRect(0,0,W,H);

    const convX=PAD_X+(W-PAD_X*2)*convergePct;

    TRACKS.forEach((tr,ti)=>{
      const trackW=convX-PAD_X;
      // Track background
      ctx.fillStyle='rgba(30,30,46,0.4)';
      ctx.beginPath();
      ctx.roundRect(PAD_X,tr.y-TRACK_H/2,trackW,TRACK_H,3);
      ctx.fill();
      ctx.strokeStyle=tr.color;
      ctx.lineWidth=1;
      ctx.beginPath();
      ctx.roundRect(PAD_X,tr.y-TRACK_H/2,trackW,TRACK_H,3);
      ctx.stroke();

      // Animated progress dot
      const dotX=PAD_X+((tick*tr.speed*0.4)%(trackW));
      ctx.fillStyle=tr.color;
      ctx.shadowColor=tr.color;
      ctx.shadowBlur=8;
      ctx.beginPath();
      ctx.arc(Math.min(dotX,trackW),tr.y,7,0,Math.PI*2);
      ctx.fill();
      ctx.shadowBlur=0;

      // Label
      ctx.fillStyle=tr.color;
      ctx.font='bold 9px "Courier New"';
      ctx.textAlign='left';
      ctx.fillText(tr.label,PAD_X+4,tr.y-TRACK_H/2-4);
    });

    // Convergence zone - tracks merge
    const mergeGrad=ctx.createLinearGradient(convX-30,0,convX+50,0);
    mergeGrad.addColorStop(0,'rgba(245,158,11,0)');
    mergeGrad.addColorStop(0.5,'rgba(245,158,11,0.2)');
    mergeGrad.addColorStop(1,'rgba(245,158,11,0)');
    ctx.fillStyle=mergeGrad;
    ctx.fillRect(convX-30,TRACKS[0].y-20,80,TRACKS[TRACKS.length-1].y+20-TRACKS[0].y+20);

    // Convergence line
    ctx.strokeStyle='rgba(245,158,11,0.6)';
    ctx.lineWidth=2;
    ctx.setLineDash([4,4]);
    ctx.beginPath();
    ctx.moveTo(convX,0);
    ctx.lineTo(convX,H-20);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle='#f59e0b';
    ctx.font='bold 8px "Courier New"';
    ctx.textAlign='center';
    ctx.fillText('CONVERGENCE',convX,H-8);

    // After convergence: single merged track
    ctx.fillStyle='rgba(245,158,11,0.15)';
    ctx.beginPath();
    ctx.roundRect(convX,H/2-14,W-convX-PAD_X,28,3);
    ctx.fill();
    ctx.strokeStyle='rgba(245,158,11,0.4)';
    ctx.lineWidth=1.5;
    ctx.stroke();
    ctx.fillStyle='rgba(245,158,11,0.7)';
    ctx.font='8px "Courier New"';
    ctx.textAlign='center';
    ctx.fillText('MERGED STORY',convX+(W-convX-PAD_X)/2,H/2+4);

    tick++;
    requestAnimationFrame(drawParallel);
  }
  drawParallel();

  window.updateConvergence=function(val){convergePct=parseInt(val)/100;};
})();

// — Time Compression/Expansion —
(function(){
  const canvas=document.getElementById('timeCanvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height;
  let speed=1;
  let sunAngle=0;
  let tick=0;

  const SPEEDS=[0.1,0.25,0.5,1,2,5,10,25,50,100];

  function drawTimeCanvas(){
    ctx.clearRect(0,0,W,H);

    // Sky gradient based on sun position
    const dayPct=(sunAngle%(Math.PI*2))/(Math.PI*2);
    const isDawn=dayPct<0.3;
    const isDay=dayPct>=0.15&&dayPct<0.6;
    const isDusk=dayPct>=0.55&&dayPct<0.75;
    const isNight=dayPct>=0.72||dayPct<0.05;

    let skyTop, skyBot;
    if(isNight){skyTop='#020208';skyBot='#0a0510';}
    else if(isDawn){skyTop='#1a0510';skyBot='#7c3a1a';}
    else if(isDay){skyTop='#1a3a6a';skyBot='#3a6a9a';}
    else{skyTop='#2a0a10';skyBot='#6a2a0a';}

    const skyG=ctx.createLinearGradient(0,0,0,H*0.75);
    skyG.addColorStop(0,skyTop);
    skyG.addColorStop(1,skyBot);
    ctx.fillStyle=skyG;
    ctx.fillRect(0,0,W,H*0.75);

    // Ground
    const groundG=ctx.createLinearGradient(0,H*0.75,0,H);
    groundG.addColorStop(0,'#1a2a0a');
    groundG.addColorStop(1,'#0a1505');
    ctx.fillStyle=groundG;
    ctx.fillRect(0,H*0.75,W,H*0.25);

    // Horizon line
    ctx.strokeStyle='rgba(255,255,255,0.05)';
    ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(0,H*0.75);ctx.lineTo(W,H*0.75);ctx.stroke();

    // Sun/Moon path
    const cx=W*0.5;
    const cy_=H*0.75;
    const radius=H*0.6;
    // Sun follows arc below horizon on night side
    const sunX=cx+Math.sin(sunAngle-Math.PI/2)*radius*1.2;
    const sunY=cy_-Math.cos(sunAngle-Math.PI/2)*radius;

    if(sunY<H*0.75+20){
      // Draw sun
      const sunCol=isNight?'#c0c0e0':(isDawn||isDusk?'#f97316':'#fcd34d');
      const sunR=isNight?12:18;
      const sunGrad=ctx.createRadialGradient(sunX,sunY,2,sunX,sunY,sunR*3);
      sunGrad.addColorStop(0,sunCol);
      sunGrad.addColorStop(0.3,sunCol+'80');
      sunGrad.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=sunGrad;
      ctx.beginPath();ctx.arc(sunX,sunY,sunR*3,0,Math.PI*2);ctx.fill();
      ctx.fillStyle=sunCol;
      ctx.beginPath();ctx.arc(sunX,sunY,sunR,0,Math.PI*2);ctx.fill();
    }

    // Stars when night
    if(isNight||dayPct<0.1){
      ctx.fillStyle='rgba(255,255,255,0.6)';
      for(let i=0;i<30;i++){
        const sx=(i*137.5)%W;
        const sy=(i*73.3)%(H*0.7);
        const flicker=Math.sin(tick*0.05+i)*0.4+0.6;
        ctx.globalAlpha=flicker*0.8;
        ctx.beginPath();ctx.arc(sx,sy,1.2,0,Math.PI*2);ctx.fill();
      }
      ctx.globalAlpha=1;
    }

    // Time display
    const hours=Math.floor(dayPct*24);
    const mins=Math.floor((dayPct*24-hours)*60);
    const timeStr=`${String(hours).padStart(2,'0')}:${String(mins).padStart(2,'0')}`;
    ctx.fillStyle='rgba(0,0,0,0.5)';
    ctx.fillRect(W-120,8,112,44);
    ctx.strokeStyle='rgba(245,158,11,0.3)';
    ctx.lineWidth=1;
    ctx.strokeRect(W-120,8,112,44);
    ctx.fillStyle='#f59e0b';
    ctx.font='bold 20px "Courier New"';
    ctx.textAlign='center';
    ctx.fillText(timeStr,W-64,34);
    ctx.fillStyle='rgba(245,158,11,0.5)';
    ctx.font='8px "Courier New"';
    ctx.fillText(speed+'× speed',W-64,46);

    // Speed tape at bottom
    ctx.fillStyle='rgba(5,5,8,0.8)';
    ctx.fillRect(0,H-36,W,36);
    const labelSpeeds=['0.1×','0.25×','0.5×','1×','2×','5×','10×','25×','50×','100×'];
    labelSpeeds.forEach((lbl,i)=>{
      const lx=60+i*(W-120)/9;
      const isActive=(SPEEDS[i]===speed);
      ctx.fillStyle=isActive?'#f59e0b':'#64748b';
      ctx.font=isActive?'bold 9px "Courier New"':'8px "Courier New"';
      ctx.textAlign='center';
      ctx.fillText(lbl,lx,H-12);
      if(isActive){
        ctx.fillStyle='#f59e0b';
        ctx.beginPath();ctx.arc(lx,H-28,3,0,Math.PI*2);ctx.fill();
      }
    });

    sunAngle+=speed*0.002;
    tick++;
    requestAnimationFrame(drawTimeCanvas);
  }
  drawTimeCanvas();

  window.updateSpeed=function(val){
    const pct=parseInt(val)/100;
    const idx=Math.min(SPEEDS.length-1,Math.floor(pct*(SPEEDS.length)));
    speed=SPEEDS[idx];
    document.getElementById('speedLabel').textContent=speed+'×';
  };
})();

