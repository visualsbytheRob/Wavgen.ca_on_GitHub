// SECTION 3 — EMOTIONAL ARC DESIGNER
// SYSTEM: EmotionalArcDesigner
// ════════════════════════════════════════════════════════════════════════════
(function(){
  const canvas=document.getElementById('arcCanvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height;
  let nodes=[];
  const PAD=50;

  const FILM_PRESETS={
    laLaLand:[
      {xPct:0.0,yPct:0.4,emotion:'joy',label:'Dreaming in LA'},
      {xPct:0.15,yPct:0.55,emotion:'joy',label:'They Meet'},
      {xPct:0.28,yPct:0.2,emotion:'joy',label:'Falling in Love'},
      {xPct:0.45,yPct:0.3,emotion:'joy',label:'First Success'},
      {xPct:0.6,yPct:0.5,emotion:'sad',label:'Compromise'},
      {xPct:0.75,yPct:0.7,emotion:'sad',label:'Breakup'},
      {xPct:0.88,yPct:0.15,emotion:'wonder',label:'Success Alone'},
      {xPct:1.0,yPct:0.85,emotion:'sad',label:'What Could\'ve Been'},
    ],
    up:[
      {xPct:0.0,yPct:0.2,emotion:'joy',label:'Childhood Wonder'},
      {xPct:0.08,yPct:0.05,emotion:'joy',label:'Ellie & Carl'},
      {xPct:0.15,yPct:0.85,emotion:'sad',label:'Ellie Dies'},
      {xPct:0.25,yPct:0.7,emotion:'sad',label:'Alone'},
      {xPct:0.38,yPct:0.45,emotion:'anger',label:'Adventure Begins'},
      {xPct:0.55,yPct:0.5,emotion:'fear',label:'Muntz Revealed'},
      {xPct:0.7,yPct:0.3,emotion:'wonder',label:'Floating House'},
      {xPct:0.85,yPct:0.15,emotion:'peace',label:'New Family'},
      {xPct:1.0,yPct:0.2,emotion:'joy',label:'Acceptance'},
    ],
    ncfom:[
      {xPct:0.0,yPct:0.6,emotion:'fear',label:'Money Found'},
      {xPct:0.2,yPct:0.7,emotion:'fear',label:'Chigurh Pursues'},
      {xPct:0.4,yPct:0.75,emotion:'fear',label:'Cat & Mouse'},
      {xPct:0.55,yPct:0.8,emotion:'fear',label:'Motel Massacre'},
      {xPct:0.7,yPct:0.85,emotion:'sad',label:'Carla Jean Dies (off-screen)'},
      {xPct:0.85,yPct:0.8,emotion:'sad',label:'Moss Dies (off-screen)'},
      {xPct:1.0,yPct:0.75,emotion:'sad',label:'Bell Retires — No Resolution'},
    ],
    parasite:[
      {xPct:0.0,yPct:0.8,emotion:'sad',label:'Basement Poverty'},
      {xPct:0.15,yPct:0.6,emotion:'wonder',label:'Enter the Park House'},
      {xPct:0.3,yPct:0.4,emotion:'joy',label:'All Installed'},
      {xPct:0.45,yPct:0.3,emotion:'joy',label:'The Good Life'},
      {xPct:0.52,yPct:0.6,emotion:'fear',label:'Rain — The Party'},
      {xPct:0.65,yPct:0.2,emotion:'anger',label:'Basement Truth'},
      {xPct:0.78,yPct:0.05,emotion:'fear',label:'The Massacre'},
      {xPct:0.88,yPct:0.85,emotion:'sad',label:'Aftermath'},
      {xPct:1.0,yPct:0.9,emotion:'sad',label:'Impossible Dream'},
    ],
    esotsm:[
      {xPct:0.0,yPct:0.5,emotion:'wonder',label:'Valentine\'s Day (disoriented)'},
      {xPct:0.15,yPct:0.4,emotion:'sad',label:'Clementine Erased'},
      {xPct:0.3,yPct:0.6,emotion:'sad',label:'Memories Dissolving'},
      {xPct:0.45,yPct:0.3,emotion:'joy',label:'Hidden Good Memories'},
      {xPct:0.6,yPct:0.5,emotion:'fear',label:'Joel Fights Erasure'},
      {xPct:0.72,yPct:0.2,emotion:'joy',label:'Montauk Memory'},
      {xPct:0.85,yPct:0.55,emotion:'wonder',label:'They Meet Again'},
      {xPct:1.0,yPct:0.35,emotion:'peace',label:'\'Okay\''},
    ],
  };

  function xToCanvas(xPct){return PAD+(W-PAD*2)*xPct;}
  function yToCanvas(yPct){return PAD+(H-PAD*2)*yPct;}

  function drawArcCanvas(){
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#0d0d14';
    ctx.fillRect(0,0,W,H);

    // Grid
    ctx.strokeStyle='rgba(30,30,46,0.7)';
    ctx.lineWidth=1;
    for(let i=0;i<=10;i++){
      const x=PAD+(W-PAD*2)*i/10;
      const y=PAD+(H-PAD*2)*i/10;
      ctx.beginPath();ctx.moveTo(x,PAD);ctx.lineTo(x,H-PAD);ctx.stroke();
      ctx.beginPath();ctx.moveTo(PAD,y);ctx.lineTo(W-PAD,y);ctx.stroke();
    }

    // Axes labels
    ctx.fillStyle='#64748b';
    ctx.font='9px "Courier New"';
    ctx.textAlign='center';
    ctx.fillText('OPENING',PAD,H-8);
    ctx.fillText('ENDING',W-PAD,H-8);
    ctx.textAlign='left';
    ctx.fillText('EUPHORIA',6,PAD+4);
    ctx.fillText('DESPAIR',6,H-PAD);

    // Y axis emotional intensity marker (dashed midline)
    ctx.strokeStyle='rgba(245,158,11,0.1)';
    ctx.setLineDash([4,6]);
    ctx.beginPath();ctx.moveTo(PAD,(H)/2);ctx.lineTo(W-PAD,(H)/2);ctx.stroke();
    ctx.setLineDash([]);

    // Draw Bézier curve through nodes
    if(nodes.length>=2){
      ctx.save();
      ctx.shadowColor='rgba(255,255,255,0.4)';
      ctx.shadowBlur=6;
      ctx.strokeStyle='rgba(255,255,255,0.5)';
      ctx.lineWidth=2;
      ctx.beginPath();
      const pts=nodes.map(n=>({x:xToCanvas(n.xPct),y:yToCanvas(n.yPct)}));
      ctx.moveTo(pts[0].x,pts[0].y);
      if(pts.length===2){
        ctx.lineTo(pts[1].x,pts[1].y);
      } else {
        for(let i=0;i<pts.length-1;i++){
          const cp1x=(pts[i].x+pts[i+1].x)/2;
          const cp1y=pts[i].y;
          const cp2x=(pts[i].x+pts[i+1].x)/2;
          const cp2y=pts[i+1].y;
          ctx.bezierCurveTo(cp1x,cp1y,cp2x,cp2y,pts[i+1].x,pts[i+1].y);
        }
      }
      ctx.stroke();
      ctx.restore();

      // Filled area under curve
      ctx.save();
      ctx.beginPath();
      const pp=nodes.map(n=>({x:xToCanvas(n.xPct),y:yToCanvas(n.yPct)}));
      ctx.moveTo(pp[0].x,H-PAD);
      ctx.lineTo(pp[0].x,pp[0].y);
      if(pp.length===2){
        ctx.lineTo(pp[1].x,pp[1].y);
      } else {
        for(let i=0;i<pp.length-1;i++){
          const cp1x=(pp[i].x+pp[i+1].x)/2;
          const cp1y=pp[i].y;
          const cp2x=(pp[i].x+pp[i+1].x)/2;
          const cp2y=pp[i+1].y;
          ctx.bezierCurveTo(cp1x,cp1y,cp2x,cp2y,pp[i+1].x,pp[i+1].y);
        }
      }
      ctx.lineTo(pp[pp.length-1].x,H-PAD);
      ctx.closePath();
      const fillG=ctx.createLinearGradient(0,PAD,0,H-PAD);
      fillG.addColorStop(0,'rgba(245,158,11,0.12)');
      fillG.addColorStop(1,'rgba(245,158,11,0.02)');
      ctx.fillStyle=fillG;
      ctx.fill();
      ctx.restore();
    }

    // Draw nodes
    nodes.forEach((n,i)=>{
      const px=xToCanvas(n.xPct);
      const py=yToCanvas(n.yPct);
      const ec=EMOTION_COLORS.find(e=>e.key===n.emotion)||EMOTION_COLORS[0];
      ctx.beginPath();
      ctx.arc(px,py,8,0,Math.PI*2);
      ctx.fillStyle=ec.color;
      ctx.fill();
      ctx.strokeStyle='rgba(255,255,255,0.4)';
      ctx.lineWidth=1.5;
      ctx.stroke();
      // Label
      if(n.label){
        ctx.fillStyle=ec.color;
        ctx.font='8px "Courier New"';
        ctx.textAlign='center';
        ctx.fillText(n.label,px,py-14);
      }
    });
  }
  drawArcCanvas();

  canvas.addEventListener('click',(e)=>{
    const r=canvas.getBoundingClientRect();
    const sx=canvas.width/r.width, sy=canvas.height/r.height;
    const cx=(e.clientX-r.left)*sx;
    const cy=(e.clientY-r.top)*sy;
    const xPct=Math.max(0,Math.min(1,(cx-PAD)/(W-PAD*2)));
    const yPct=Math.max(0,Math.min(1,(cy-PAD)/(H-PAD*2)));
    nodes.push({xPct,yPct,emotion:activeEmotion.key,label:''});
    nodes.sort((a,b)=>a.xPct-b.xPct);
    drawArcCanvas();
  });

  window.loadFilmPreset=function(){
    const key=document.getElementById('filmPreset').value;
    if(!key)return;
    nodes=FILM_PRESETS[key].map(n=>({...n}));
    drawArcCanvas();
    document.getElementById('filmPreset').value='';
  };
  window.clearArc=function(){nodes=[];drawArcCanvas();};
})();

