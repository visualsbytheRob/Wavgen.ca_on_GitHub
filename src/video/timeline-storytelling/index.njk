// SECTION 9 — GLOSSARY
// ════════════════════════════════════════════════════════════════════════════
const GLOSSARY=[
  {term:'Act Break',def:'A major structural turning point that shifts the story into a new phase or direction.'},
  {term:'Antagonist',def:'The force — person, system, or internal conflict — that opposes the protagonist\'s goal.'},
  {term:'Backstory',def:'Events that occurred before the story begins that shaped the characters and situation.'},
  {term:'Beat',def:'The smallest unit of dramatic action — a moment of change in a scene or relationship.'},
  {term:'Catalyst',def:'The inciting incident that disrupts the status quo and sets the story in motion.'},
  {term:'Character Arc',def:'The internal transformation a character undergoes across the story\'s timeline.'},
  {term:'Climax',def:'The moment of highest tension where the central conflict reaches its crisis point.'},
  {term:'Denouement',def:'The resolution phase after the climax where loose ends are tied up and a new equilibrium forms.'},
  {term:'Exposition',def:'Information delivered to orient the audience — character background, world rules, prior events.'},
  {term:'Flashback',def:'A narrative device that interrupts the present timeline to show events from the past.'},
  {term:'Flashforward',def:'A scene that jumps ahead in time to show future events before the story reaches them.'},
  {term:'Inciting Incident',def:'The event that disrupts normal life and launches the protagonist into the central conflict.'},
  {term:'Kishōtenketsu',def:'A Japanese 4-act structure: introduction (ki), development (shō), twist (ten), reconciliation (ketsu).'},
  {term:'MacGuffin',def:'An object or goal that motivates characters but has no intrinsic narrative significance itself.'},
  {term:'Midpoint',def:'The structural center of a story — a false peak or false defeat that raises the stakes.'},
  {term:'Montage',def:'A sequence of images or shots edited together to compress time or convey a theme through juxtaposition.'},
  {term:'Non-Linear Narrative',def:'A story told out of chronological order — using flashbacks, parallel timelines, or fragmented structure.'},
  {term:'Plot Point',def:'A significant event that spins the story in a new direction, changing what must happen next.'},
  {term:'Protagonist',def:'The central character whose goal and internal need drive the story forward.'},
  {term:'Rising Action',def:'The escalating series of events and complications that build tension toward the climax.'},
  {term:'Subtext',def:'The underlying meaning beneath dialogue or action — what characters mean but don\'t say directly.'},
  {term:'Three-Act Structure',def:'The Western narrative framework dividing a story into Setup, Confrontation, and Resolution.'},
];

const glossGrid=document.getElementById('glossGrid');
if(glossGrid){
  GLOSSARY.forEach(g=>{
    const item=document.createElement('div');
    item.className='gloss-item';
    item.innerHTML=`<div class="gloss-term">${g.term}</div><div class="gloss-def">${g.def}</div>`;
    glossGrid.appendChild(item);
  });
}

