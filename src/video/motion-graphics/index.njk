<script>
// ===== SECTION 2 — KINETIC TYPOGRAPHY =====
(function(){
  var canvas=document.getElementById('typoCanvas');
  var ctx=canvas.getContext('2d');
  var W,H,letters=[],preset='cascade',triggered=false,trigT=0;
  var lastT=0;

  function resize(){
    W=canvas.parentElement.offsetWidth||800;
    H=260;
    canvas.width=W;
    canvas.height=H;
  }

  window.setTypoPreset=function(p){
    preset=p;
    document.querySelectorAll('#typo-section .btn').forEach(function(b){b.classList.remove('active')});
    event.target.classList.add('active');
    triggerTypo();
  };

  window.triggerTypo=function(){
    var text=document.getElementById('typoInput').value||'MOTION';
    var fs=parseInt(document.getElementById('typoSize').value)||52;
    var sp=parseInt(document.getElementById('typoSpacing').value)||4;
    var speed=parseFloat(document.getElementById('typoSpeed').value)||5;
    var tau=0.22-(speed-1)*0.018;
    ctx.font='bold '+fs+'px Courier New,monospace';
    letters=[];
    var chars=text.split('');
    var totalW=0;
    for(var i=0;i<chars.length;i++){totalW+=ctx.measureText(chars[i]).width+sp;}
    var sx=W/2-totalW/2, cy=H/2+fs*0.35;
    for(var i=0;i<chars.length;i++){
      var cw=ctx.measureText(chars[i]).width+sp;
      var tx=sx, ty=cy;
      var startX=tx, startY=ty-H;
      var delay=i*0.08;
      if(preset==='shatter'){startX=tx+(Math.random()-0.5)*W;startY=ty+(Math.random()-0.5)*H*2;}
      else if(preset==='blur'){startX=tx-W*0.3;startY=ty;}
      else if(preset==='typewriter'){startX=tx;startY=ty;delay=i*0.12;}
      else if(preset==='elastic'){startX=tx;startY=ty-H*1.2;tau=0.08;}
      else if(preset==='glitch'){startX=tx+(Math.random()-0.5)*60;startY=ty+(Math.random()-0.5)*60;}
      letters.push({
        ch:chars[i],tx:tx,ty:ty,fs:fs,
        lag:new VectorLag(startX,startY,tau),
        alpha:new LagFilter(preset==='typewriter'?0:0,0.2),
        rot:new LagFilter(preset==='shatter'?(Math.random()-0.5)*Math.PI:0,0.15),
        blur:new LagFilter(preset==='blur'?1:0,0.18),
        glitch:new LagFilter(preset==='glitch'?1:0,0.12),
        delay:delay, started:false, sp:sp
      });
      sx+=cw;
    }
    triggered=true; trigT=0;
  };

  function loop(t){
    var dt=Math.min((t-lastT)*0.001,0.05); lastT=t;
    if(triggered) trigT+=dt;
    // Phosphor decay
    ctx.globalAlpha=0.12; ctx.fillStyle='#040200'; ctx.fillRect(0,0,W,H); ctx.globalAlpha=1;

    for(var i=0;i<letters.length;i++){
      var l=letters[i];
      if(trigT>=l.delay&&!l.started){
        l.started=true;
        l.lag.set(l.tx,l.ty);
        l.alpha.set(1); l.blur.set(0); l.glitch.set(0); l.rot.set(0);
      }
      if(!l.started&&preset!=='typewriter') continue;
      if(preset==='typewriter'&&trigT>=l.delay) l.alpha.set(1);
      l.lag.update(dt); l.alpha.update(dt); l.rot.update(dt); l.blur.update(dt); l.glitch.update(dt);
      var lx=l.lag.x.value, ly=l.lag.y.value;
      if(l.alpha.value<0.01) continue;
      ctx.save();
      if(l.blur.value>0.01){ctx.filter='blur('+(l.blur.value*12)+'px)';}
      if(l.glitch.value>0.01){
        ctx.globalAlpha=l.alpha.value*0.4; ctx.fillStyle='#ef4444';
        ctx.font='bold '+l.fs+'px Courier New,monospace';
        ctx.fillText(l.ch,lx+(Math.random()-0.5)*l.glitch.value*8,ly+(Math.random()-0.5)*l.glitch.value*4);
        ctx.fillStyle='#60a5fa';
        ctx.fillText(l.ch,lx-(Math.random()-0.5)*l.glitch.value*8,ly);
      }
      ctx.globalAlpha=l.alpha.value;
      ctx.shadowBlur=8; ctx.shadowColor='#f97316';
      ctx.fillStyle='#fbbf24';
      ctx.font='bold '+l.fs+'px Courier New,monospace';
      ctx.translate(lx,ly); ctx.rotate(l.rot.value);
      ctx.fillText(l.ch,0,0);
      ctx.shadowBlur=0; ctx.restore();
    }
    requestAnimationFrame(loop);
  }

  resize();
  window.addEventListener('resize',resize);
  triggerTypo();
  requestAnimationFrame(loop);
  document.getElementById('typoInput').addEventListener('input',function(){setTimeout(triggerTypo,300);});
})();

// ===== SECTION 3 — MOTION CURVE EDITOR =====
(function(){
  var canvas=document.getElementById('curveCanvas');
  var ctx=canvas.getContext('2d');
  var ball=document.getElementById('ballCanvas');
  var bctx=ball.getContext('2d');
  var W=500,H=300,BW,BH=80;
  var pad=40;
  // Bezier control points (normalized 0-1)
  var CP=[{x:0.25,y:0.1},{x:0.25,y:1.0}]; // h1, h2
  var dragging=-1, mouseX=0, mouseY=0;
  var lastT=0, ballT=0, ballDir=1;
  var ballX=new LagFilter(0,0.1);

  var PRESETS={
    linear:[[0.0,0.0],[1.0,1.0]],
    easeIn:[[0.42,0.0],[1.0,1.0]],
    easeOut:[[0.0,0.0],[0.58,1.0]],
    easeInOut:[[0.25,0.1],[0.25,1.0]],
    overshoot:[[0.34,1.56],[0.64,1.0]],
    anticipate:[[-0.3,-0.2],[0.7,1.0]],
    bounce:[[0.0,0.9],[0.7,1.0]]
  };

  window.applyCurvePreset=function(name){
    var p=PRESETS[name];
    if(p){CP[0]={x:p[0][0],y:p[0][1]};CP[1]={x:p[1][0],y:p[1][1]};}
    updateEqLabel();
  };

  function updateEqLabel(){
    var el=document.getElementById('curveEq');
    if(el) el.textContent='cubic-bezier('+CP[0].x.toFixed(2)+', '+CP[0].y.toFixed(2)+', '+CP[1].x.toFixed(2)+', '+CP[1].y.toFixed(2)+')';
  }

  function normToCanvas(nx,ny){return {x:pad+nx*(W-pad*2), y:H-pad-ny*(H-pad*2)};}
  function canvasToNorm(cx,cy){return {x:(cx-pad)/(W-pad*2), y:(H-pad-cy)/(H-pad*2)};}

  function evalCubicBezier(t){
    // Evaluate CSS cubic-bezier(x1,y1,x2,y2) at parameter t (0-1 time)
    var x1=CP[0].x,y1=CP[0].y,x2=CP[1].x,y2=CP[1].y;
    // Newton's method to find u such that Bx(u)=t
    var u=t;
    for(var i=0;i<8;i++){
      var bx=3*u*(1-u)*(1-u)*x1+3*u*u*(1-u)*x2+u*u*u-t;
      var bxd=3*(1-u)*(1-u)*x1+6*u*(1-u)*(x2-x1)+3*u*u*(1-2*x1+x2-1+1);
      if(Math.abs(bxd)<1e-6)break;
      u-=bx/Math.max(Math.abs(bxd),0.001)*Math.sign(bxd);
      u=Math.max(0,Math.min(1,u));
    }
    return 3*u*(1-u)*(1-u)*y1+3*u*u*(1-u)*y2+u*u*u;
  }

  function draw(){
    ctx.clearRect(0,0,W,H);
    // Background
    ctx.fillStyle='#0e0800'; ctx.fillRect(0,0,W,H);
    // Grid
    ctx.strokeStyle='rgba(249,115,22,0.08)'; ctx.lineWidth=0.5;
    for(var gi=0;gi<=4;gi++){
      var gx=normToCanvas(gi/4,0).x; ctx.beginPath();ctx.moveTo(gx,pad);ctx.lineTo(gx,H-pad);ctx.stroke();
      var gy=normToCanvas(0,gi/4).y; ctx.beginPath();ctx.moveTo(pad,gy);ctx.lineTo(W-pad,gy);ctx.stroke();
    }
    // Diagonal reference
    ctx.strokeStyle='rgba(249,115,22,0.15)'; ctx.lineWidth=1; ctx.setLineDash([4,4]);
    var p0=normToCanvas(0,0),p1=normToCanvas(1,1);
    ctx.beginPath();ctx.moveTo(p0.x,p0.y);ctx.lineTo(p1.x,p1.y);ctx.stroke();
    ctx.setLineDash([]);
    // Draw curve
    ctx.beginPath();
    var start=normToCanvas(0,0);
    ctx.moveTo(start.x,start.y);
    ctx.strokeStyle='#f97316'; ctx.lineWidth=2;
    ctx.shadowBlur=8; ctx.shadowColor='#f97316';
    var h1=normToCanvas(CP[0].x,CP[0].y), h2=normToCanvas(CP[1].x,CP[1].y), end=normToCanvas(1,1);
    ctx.bezierCurveTo(h1.x,h1.y,h2.x,h2.y,end.x,end.y);
    ctx.stroke(); ctx.shadowBlur=0;
    // Handle lines
    ctx.strokeStyle='rgba(249,115,22,0.35)'; ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(start.x,start.y);ctx.lineTo(h1.x,h1.y);ctx.stroke();
    ctx.beginPath();ctx.moveTo(end.x,end.y);ctx.lineTo(h2.x,h2.y);ctx.stroke();
    // Handles
    var handles=[h1,h2];
    for(var i=0;i<handles.length;i++){
      ctx.beginPath();ctx.arc(handles[i].x,handles[i].y,7,0,Math.PI*2);
      ctx.fillStyle=dragging===i?'#fbbf24':'#f97316'; ctx.fill();
      ctx.strokeStyle='#fbbf24'; ctx.lineWidth=1.5; ctx.stroke();
    }
    // Endpoints
    ctx.beginPath();ctx.arc(start.x,start.y,4,0,Math.PI*2);ctx.fillStyle='#c0c0c8';ctx.fill();
    ctx.beginPath();ctx.arc(end.x,end.y,4,0,Math.PI*2);ctx.fillStyle='#c0c0c8';ctx.fill();
    // Axes labels
    ctx.fillStyle='rgba(128,96,80,0.6)'; ctx.font='10px Courier New,monospace';
    ctx.fillText('TIME',W/2-16,H-8); ctx.fillText('VALUE',4,H/2);
  }

  function drawBall(t){
    BW=ball.parentElement.offsetWidth||400;
    ball.width=BW; ball.height=BH;
    bctx.clearRect(0,0,BW,BH);
    bctx.fillStyle='#0e0800'; bctx.fillRect(0,0,BW,BH);
    // Track
    bctx.strokeStyle='rgba(249,115,22,0.2)'; bctx.lineWidth=1;
    bctx.beginPath();bctx.moveTo(20,BH/2);bctx.lineTo(BW-20,BH/2);bctx.stroke();
    // Ball position
    var val=evalCubicBezier(t);
    var bx=20+val*(BW-40);
    // Trail
    for(var ti=0;ti<8;ti++){
      var tv=evalCubicBezier(Math.max(0,t-ti*0.04));
      var tx2=20+tv*(BW-40);
      bctx.beginPath();bctx.arc(tx2,BH/2,6*(1-ti/8),0,Math.PI*2);
      bctx.fillStyle='rgba(249,115,22,'+(0.3*(1-ti/8))+')'; bctx.fill();
    }
    bctx.beginPath();bctx.arc(bx,BH/2,8,0,Math.PI*2);
    bctx.shadowBlur=12;bctx.shadowColor='#f97316';
    bctx.fillStyle='#fbbf24'; bctx.fill(); bctx.shadowBlur=0;
  }

  function loop(t){
    var dt=Math.min((t-lastT)*0.001,0.05); lastT=t;
    ballT+=dt*0.5*ballDir;
    if(ballT>=1){ballT=1;ballDir=-1;}
    if(ballT<=0){ballT=0;ballDir=1;}
    draw();
    drawBall(ballT);
    requestAnimationFrame(loop);
  }

  canvas.addEventListener('mousedown',function(e){
    var rect=canvas.getBoundingClientRect();
    var scaleX=W/rect.width, scaleY=H/rect.height;
    var mx=(e.clientX-rect.left)*scaleX, my=(e.clientY-rect.top)*scaleY;
    var h1=normToCanvas(CP[0].x,CP[0].y), h2=normToCanvas(CP[1].x,CP[1].y);
    if(Math.hypot(mx-h1.x,my-h1.y)<14){dragging=0;}
    else if(Math.hypot(mx-h2.x,my-h2.y)<14){dragging=1;}
  });
  canvas.addEventListener('mousemove',function(e){
    if(dragging<0)return;
    var rect=canvas.getBoundingClientRect();
    var scaleX=W/rect.width, scaleY=H/rect.height;
    var nx=(e.clientX-rect.left)*scaleX, ny=(e.clientY-rect.top)*scaleY;
    var n=canvasToNorm(nx,ny);
    CP[dragging]={x:Math.max(-0.5,Math.min(1.5,n.x)),y:Math.max(-0.5,Math.min(1.5,n.y))};
    updateEqLabel();
  });
  canvas.addEventListener('mouseup',function(){dragging=-1;});
  canvas.addEventListener('mouseleave',function(){dragging=-1;});

  // Touch support
  canvas.addEventListener('touchstart',function(e){
    e.preventDefault();
    var touch=e.touches[0];
    var rect=canvas.getBoundingClientRect();
    var scaleX=W/rect.width, scaleY=H/rect.height;
    var mx=(touch.clientX-rect.left)*scaleX, my=(touch.clientY-rect.top)*scaleY;
    var h1=normToCanvas(CP[0].x,CP[0].y), h2=normToCanvas(CP[1].x,CP[1].y);
    if(Math.hypot(mx-h1.x,my-h1.y)<20){dragging=0;}
    else if(Math.hypot(mx-h2.x,my-h2.y)<20){dragging=1;}
  },{passive:false});
  canvas.addEventListener('touchmove',function(e){
    if(dragging<0)return; e.preventDefault();
    var touch=e.touches[0];
    var rect=canvas.getBoundingClientRect();
    var scaleX=W/rect.width, scaleY=H/rect.height;
    var nx=(touch.clientX-rect.left)*scaleX, ny=(touch.clientY-rect.top)*scaleY;
    var n=canvasToNorm(nx,ny);
    CP[dragging]={x:Math.max(-0.5,Math.min(1.5,n.x)),y:Math.max(-0.5,Math.min(1.5,n.y))};
    updateEqLabel();
  },{passive:false});
  canvas.addEventListener('touchend',function(){dragging=-1;});

  applyCurvePreset('easeInOut');
  requestAnimationFrame(loop);
})();
</script>
<!-- SECTION 4 — EASING VISUALIZER -->
<section id="easing-section">
<span class="section-label hidden stagger-1">04 / Easing Functions</span>
<h2 class="section-title hidden stagger-2">Easing Visualizer</h2>
<p class="section-desc hidden stagger-3">Eight easing functions running simultaneously. Watch how each one feels different in motion. Hit Race to see them compete.</p>
<div class="ctrl-row hidden stagger-3">
<button class="btn btn-solid" onclick="startEasingRace()">RACE</button>
<button class="btn" onclick="resetEasingRace()">LOOP</button>
<label>SPEED</label><input id="easingSpeed" max="3" min="0.3" step="0.1" type="range" value="1"/>
</div>
