<script>
// ===== WAVGEN CORE =====
class LagFilter {
  constructor(initial,tau){this.value=initial||0;this.target=initial||0;this.tau=tau||0.15}
  update(dt){var a=1-Math.exp(-dt/Math.max(this.tau,0.001));this.value+=(this.target-this.value)*a;return this.value}
  set(t){this.target=t}
  snap(v){this.value=this.target=v}
}
class VectorLag {
  constructor(x,y,tau){this.x=new LagFilter(x,tau);this.y=new LagFilter(y,tau)}
  set(x,y){this.x.set(x);this.y.set(y)}
  snap(x,y){this.x.snap(x);this.y.snap(y)}
  update(dt){this.x.update(dt);this.y.update(dt)}
}
class BPMEngine {
  constructor(bpm){this.bpm=bpm||120;this._start=null;this._beat=0;this._rafId=null;this.running=false;this._subs=new Map()}
  start(){this.running=true;this._start=performance.now();this._beat=0;this._tick()}
  stop(){this.running=false;if(this._rafId)cancelAnimationFrame(this._rafId)}
  setBPM(b){this.bpm=Math.max(40,Math.min(240,b));if(this.running){this.stop();this.start()}}
  _tick(){
    if(!this.running)return;
    var now=performance.now(),el=now-this._start,mpb=60000/this.bpm,exp=Math.floor(el/mpb);
    while(this._beat<=exp){this._fire(this._beat++);}
    this._rafId=requestAnimationFrame(this._tick.bind(this));
  }
  _fire(n){
    var ph=n%16,isQ=ph%4===0,isD=ph===0;
    try{document.dispatchEvent(new CustomEvent('wavgen:beat',{detail:{beat:n,phase:ph,isQ:isQ,isD:isD,bpm:this.bpm}}))}catch(e){}
    this._subs.forEach(function(fn){fn({beat:n,phase:ph,isQ:isQ,isD:isD})});
  }
  subscribe(id,fn){this._subs.set(id,fn)}
}

// ===== SECTION 1 — HERO KINETIC LETTERS =====
(function(){
  var canvas=document.getElementById('heroCanvas');
  var ctx=canvas.getContext('2d');
  var W,H,letters=[],phase='fly-in',phaseT=0;
  var BPM=120;
  var bpmEngine=new BPMEngine(BPM);
  var FULL_TEXT='MOTION GRAPHICS WORLD';
  var beatFlash=new LagFilter(0,0.06);
  var lastT=0,elapsed=0;

  document.addEventListener('wavgen:beat',function(e){
    if(e.detail.isQ)beatFlash.set(1);
  });

  function resize(){
    W=canvas.parentElement.offsetWidth||window.innerWidth;
    H=440;
    canvas.width=W;
    canvas.height=H;
    initLetters();
  }

  function initLetters(){
    letters=[];
    var fs=Math.min(Math.max(W*0.055,28),72);
    ctx.font='bold '+fs+'px Courier New,monospace';
    var chars=FULL_TEXT.split('');
    var cx=W/2, cy=H/2+fs*0.35;
    // measure total
    var totalW=0;
    var cwidths=[];
    for(var i=0;i<chars.length;i++){
      var cw=(chars[i]===' ')?(fs*0.4):(ctx.measureText(chars[i]).width+2);
      cwidths.push(cw);
      totalW+=cw;
    }
    var sx0=cx-totalW/2;
    for(var i=0;i<chars.length;i++){
      if(chars[i]===' '){sx0+=cwidths[i];continue;}
      var tx=sx0, ty=cy;
      var angle=Math.random()*Math.PI*2;
      var dist=Math.max(W,H)*0.9;
      var startX=W/2+Math.cos(angle)*dist;
      var startY=H/2+Math.sin(angle)*dist;
      letters.push({
        ch:chars[i], tx:tx, ty:ty, fs:fs,
        ex:tx+(Math.random()-0.5)*W*1.6,
        ey:ty+(Math.random()-0.5)*H*2.2,
        lag:new VectorLag(startX,startY,0.12),
        alpha:new LagFilter(0,0.15),
        rot:new LagFilter((Math.random()-0.5)*Math.PI*0.9,0.18),
        trail:[]
      });
      sx0+=cwidths[i];
    }
  }

  function loop(t){
    var dt=Math.min((t-lastT)*0.001,0.05);
    lastT=t; elapsed+=dt; phaseT+=dt;
    beatFlash.update(dt);

    var SETTLE=1.4,HOLD=1.8,EXPLODE=0.9,REFORM=1.3;
    if(phase==='fly-in'){
      for(var i=0;i<letters.length;i++){var l=letters[i];l.lag.set(l.tx,l.ty);l.alpha.set(1);l.rot.set(0);}
      if(phaseT>SETTLE){phase='hold';phaseT=0;}
    } else if(phase==='hold'){
      if(phaseT>HOLD){phase='explode';phaseT=0;}
    } else if(phase==='explode'){
      for(var i=0;i<letters.length;i++){var l=letters[i];l.lag.set(l.ex,l.ey);l.alpha.set(0);l.rot.set((Math.random()-0.5)*Math.PI*2);}
      if(phaseT>EXPLODE){phase='reform';phaseT=0;for(var i=0;i<letters.length;i++){var l=letters[i];l.lag.snap(l.ex,l.ey);}}
    } else if(phase==='reform'){
      for(var i=0;i<letters.length;i++){var l=letters[i];l.lag.set(l.tx,l.ty);l.alpha.set(1);l.rot.set(0);}
      if(phaseT>REFORM){phase='hold';phaseT=0;}
    }

    for(var i=0;i<letters.length;i++){
      var l=letters[i];
      var px=l.lag.x.value, py=l.lag.y.value;
      l.lag.update(dt); l.alpha.update(dt); l.rot.update(dt);
      var spd=Math.hypot(l.lag.x.value-px,l.lag.y.value-py);
      l.trail.unshift({x:px,y:py,a:Math.min(spd*0.09,0.4)});
      if(l.trail.length>9)l.trail.pop();
    }

    draw();
    requestAnimationFrame(loop);
  }

  function draw(){
    ctx.globalAlpha=0.08; ctx.fillStyle='#040200'; ctx.fillRect(0,0,W,H); ctx.globalAlpha=1;
    // Grid
    ctx.save(); ctx.globalAlpha=0.04+beatFlash.value*0.05; ctx.strokeStyle='#f97316'; ctx.lineWidth=0.5;
    for(var gx=0;gx<W;gx+=40){ctx.beginPath();ctx.moveTo(gx,0);ctx.lineTo(gx,H);ctx.stroke();}
    for(var gy=0;gy<H;gy+=40){ctx.beginPath();ctx.moveTo(0,gy);ctx.lineTo(W,gy);ctx.stroke();}
    ctx.restore();
    // Beat ring
    if(beatFlash.value>0.01){
      ctx.save(); ctx.globalAlpha=beatFlash.value*0.2; ctx.strokeStyle='#f97316'; ctx.lineWidth=1.5;
      ctx.beginPath(); ctx.arc(W/2,H/2,Math.max(W,H)*beatFlash.value,0,Math.PI*2); ctx.stroke(); ctx.restore();
    }
    // Letters
    for(var i=0;i<letters.length;i++){
      var l=letters[i];
      var lx=l.lag.x.value, ly=l.lag.y.value;
      var fstr='bold '+l.fs+'px Courier New,monospace';
      // Trail
      for(var ti=l.trail.length-1;ti>=0;ti--){
        var tr=l.trail[ti];
        ctx.save(); ctx.globalAlpha=tr.a*(1-ti/l.trail.length)*l.alpha.value;
        ctx.fillStyle='#f97316'; ctx.font=fstr;
        ctx.translate(tr.x,tr.y); ctx.rotate(l.rot.value*(ti/l.trail.length));
        ctx.fillText(l.ch,0,0); ctx.restore();
      }
      // Main
      if(l.alpha.value>0.01){
        ctx.save(); ctx.globalAlpha=l.alpha.value;
        ctx.shadowBlur=14+beatFlash.value*22; ctx.shadowColor='#f97316';
        ctx.fillStyle='#fbbf24'; ctx.font=fstr;
        ctx.translate(lx,ly); ctx.rotate(l.rot.value);
        ctx.fillText(l.ch,0,0); ctx.shadowBlur=0; ctx.restore();
      }
    }
    // Footer label
    ctx.save(); ctx.globalAlpha=0.45; ctx.fillStyle='#f97316';
    ctx.font=(Math.max(10,Math.round(W*0.012)))+'px Courier New,monospace';
    ctx.fillText('BPM '+BPM+' · MOTION DESIGN STUDIO · WAVGEN',W*0.04,H-16);
    ctx.restore();
    // Scanlines
    ctx.save(); ctx.globalAlpha=0.04; ctx.fillStyle='rgba(0,0,0,1)';
    for(var sy=0;sy<H;sy+=2){ctx.fillRect(0,sy,W,1);} ctx.restore();
  }

  resize();
  window.addEventListener('resize',resize);
  bpmEngine.start();
  window.wavgenBPM=bpmEngine;
  requestAnimationFrame(loop);
})();
</script>
