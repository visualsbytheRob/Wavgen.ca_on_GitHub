<canvas height="360" id="titleCanvas"></canvas>
</div>
<p class="motion-quote">"Build the feeling before you build the frame."</p>
</section>
<script>
// ===== SECTION 4 — EASING VISUALIZER =====
(function(){
  var canvas=document.getElementById('easingCanvas');
  var ctx=canvas.getContext('2d');
  var W,H=420,lastT=0,raceMode=false,raceT=0,loopT=0;
  var speed=1;

  var EASINGS=[
    {name:'Linear',   fn:function(t){return t;}, color:'#c0c0c8'},
    {name:'Ease',     fn:function(t){return t<0.5?2*t*t:(4-2*t)*t-1;}, color:'#f97316'},
    {name:'EaseIn',   fn:function(t){return t*t*t;}, color:'#fbbf24'},
    {name:'EaseOut',  fn:function(t){var t2=t-1;return t2*t2*t2+1;}, color:'#fb923c'},
    {name:'EaseInOut',fn:function(t){return t<0.5?4*t*t*t:(t-1)*(2*t-2)*(2*t-2)+1;}, color:'#fdba74'},
    {name:'Bounce',   fn:function(t){
      if(t<1/2.75)return 7.5625*t*t;
      if(t<2/2.75){t-=1.5/2.75;return 7.5625*t*t+0.75;}
      if(t<2.5/2.75){t-=2.25/2.75;return 7.5625*t*t+0.9375;}
      t-=2.625/2.75; return 7.5625*t*t+0.984375;
    }, color:'#34d399'},
    {name:'Elastic',  fn:function(t){
      if(t===0||t===1)return t;
      return -Math.pow(2,10*t-10)*Math.sin((t*10-10.75)*(2*Math.PI/3));
    }, color:'#60a5fa'},
    {name:'Back',     fn:function(t){var c=1.70158;return t*t*((c+1)*t-c);}, color:'#c084fc'}
  ];

  var ROW_H,PAD_L=90,PAD_R=20,PAD_T=20,BOX_H=30;
  var squares=EASINGS.map(function(e){return {x:new LagFilter(0,0.1),alpha:new LagFilter(1,0.08)};});

  window.startEasingRace=function(){raceMode=true;raceT=0;loopT=0;for(var i=0;i<squares.length;i++){squares[i].x.snap(0);}};
  window.resetEasingRace=function(){raceMode=false;raceT=0;loopT=0;for(var i=0;i<squares.length;i++){squares[i].x.snap(0);}};

  function resize(){
    W=canvas.parentElement.offsetWidth||900;
    canvas.width=W;
    canvas.height=H;
    ROW_H=(H-PAD_T*2)/EASINGS.length;
  }

  function loop(t){
    var dt=Math.min((t-lastT)*0.001,0.05); lastT=t;
    speed=parseFloat(document.getElementById('easingSpeed').value)||1;

    ctx.globalAlpha=0.18; ctx.fillStyle='#040200'; ctx.fillRect(0,0,W,H); ctx.globalAlpha=1;

    var trackW=W-PAD_L-PAD_R;

    if(raceMode){
      raceT+=dt*speed;
      for(var i=0;i<EASINGS.length;i++){
        var t01=Math.min(raceT,1);
        var val=EASINGS[i].fn(t01);
        squares[i].x.set(Math.max(0,Math.min(1,val)));
        squares[i].x.update(dt);
      }
      if(raceT>=2){raceT=0;for(var i=0;i<squares.length;i++){squares[i].x.snap(0);}}
    } else {
      loopT+=dt*speed*0.5;
      for(var i=0;i<EASINGS.length;i++){
        var tl=(loopT%2);
        var t01=tl<1?tl:2-tl;
        var val=EASINGS[i].fn(Math.max(0,Math.min(1,t01)));
        squares[i].x.set(Math.max(0,Math.min(1,val)));
        squares[i].x.update(dt);
      }
    }

    for(var i=0;i<EASINGS.length;i++){
      var e=EASINGS[i];
      var y=PAD_T+i*ROW_H+ROW_H/2;
      // Track
      ctx.strokeStyle='rgba(249,115,22,0.12)'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.moveTo(PAD_L,y); ctx.lineTo(W-PAD_R,y); ctx.stroke();
      // End markers
      ctx.strokeStyle='rgba(249,115,22,0.25)'; ctx.lineWidth=0.5;
      ctx.beginPath();ctx.moveTo(PAD_L,y-BOX_H/2-2);ctx.lineTo(PAD_L,y+BOX_H/2+2);ctx.stroke();
      ctx.beginPath();ctx.moveTo(W-PAD_R,y-BOX_H/2-2);ctx.lineTo(W-PAD_R,y+BOX_H/2+2);ctx.stroke();
      // Label
      ctx.fillStyle=e.color; ctx.font='11px Courier New,monospace';
      ctx.fillText(e.name,4,y+4);
      // Square
      var sx=PAD_L+squares[i].x.value*trackW;
      ctx.save();
      ctx.shadowBlur=10; ctx.shadowColor=e.color;
      ctx.fillStyle=e.color;
      ctx.fillRect(sx-BOX_H/2,y-BOX_H/2,BOX_H,BOX_H);
      ctx.shadowBlur=0; ctx.restore();
    }
    // Header
    ctx.fillStyle='rgba(249,115,22,0.4)'; ctx.font='10px Courier New,monospace';
    ctx.fillText('START',PAD_L,H-6);
    ctx.fillText('END',W-PAD_R-24,H-6);
    requestAnimationFrame(loop);
  }

  resize();
  window.addEventListener('resize',resize);
  requestAnimationFrame(loop);
})();

// ===== SECTION 5 — TITLE SEQUENCE BUILDER =====
(function(){
  var canvas=document.getElementById('titleCanvas');
  var ctx=canvas.getContext('2d');
  var W,H=360,lastT=0;
  var playing=false,seqT=0,curScene=0,alpha=new LagFilter(0,0.12);
  var transAlpha=new LagFilter(1,0.1);
  var fill=document.getElementById('sceneFill');

  var SCENES=[
    {id:0,label:'OPEN',draw:drawScene0},
    {id:1,label:'WORD',draw:drawScene1},
    {id:2,label:'TITLE + LINE',draw:drawScene2},
    {id:3,label:'TAGLINE',draw:drawScene3},
    {id:4,label:'LOGO',draw:drawScene4}
  ];

  var letters1=['M'],letters2=['M','O','T','I','O','N'],title='MOTION GRAPHICS',tagline='Where time becomes art.';
  var letterLags=[];
  var lineLag=new LagFilter(0,0.15);
  var tagLag=new LagFilter(0,0.18);
  var logoRot=new LagFilter(0,0.2);

  window.playTitleSeq=function(){playing=true;seqT=0;curScene=0;alpha.snap(0);transAlpha.snap(0);initScene(0);};
  window.stopTitleSeq=function(){playing=false;};

  function initScene(s){
    letterLags=[];
    lineLag.snap(0); tagLag.snap(0); logoRot.snap(0);
    if(s===0){alpha.snap(0);alpha.set(1);}
    if(s===1){
      for(var i=0;i<letters2.length;i++){
        var l=new LagFilter(0,0.14+i*0.02);
        l.snap(0); letterLags.push(l);
        setTimeout((function(lag){return function(){lag.set(1);};})(l),i*120);
      }
    }
    if(s===2){lineLag.snap(0);lineLag.set(1);}
    if(s===3){tagLag.snap(0);tagLag.set(1);}
    if(s===4){logoRot.set(1);}
    transAlpha.snap(0); transAlpha.set(1);
  }

  function drawScene0(fs){
    ctx.save();
    ctx.globalAlpha=alpha.value;
    ctx.fillStyle='#f97316';
    ctx.font='bold '+fs*2+'px Courier New,monospace';
    ctx.textAlign='center';
    ctx.shadowBlur=30; ctx.shadowColor='#f97316';
    ctx.fillText('M',W/2,H/2+fs*0.7);
    ctx.shadowBlur=0; ctx.restore();
  }
  function drawScene1(fs){
    ctx.save(); ctx.textAlign='center';
    var cw=fs*0.65, totalW=letters2.length*cw;
    var sx=W/2-totalW/2;
    for(var i=0;i<letters2.length;i++){
      var lag=letterLags[i];
      if(!lag)continue;
      var a=lag.value;
      ctx.globalAlpha=a;
      ctx.fillStyle='#fbbf24'; ctx.font='bold '+fs+'px Courier New,monospace';
      ctx.shadowBlur=12; ctx.shadowColor='#f97316';
      ctx.fillText(letters2[i],sx+i*cw+cw/2,H/2+fs*0.35);
    }
    ctx.shadowBlur=0; ctx.restore();
  }
  function drawScene2(fs){
    ctx.save(); ctx.textAlign='center';
    ctx.globalAlpha=1;
    ctx.fillStyle='#fbbf24'; ctx.font='bold '+fs+'px Courier New,monospace';
    ctx.shadowBlur=14; ctx.shadowColor='#f97316';
    ctx.fillText(title,W/2,H/2);
    ctx.shadowBlur=0;
    // Line sweep
    var lineW=lineLag.value*(W*0.7);
    ctx.fillStyle='#f97316'; ctx.globalAlpha=0.8;
    ctx.fillRect(W/2-lineW/2,H/2+fs*0.5+8,lineW,2);
    ctx.restore();
  }
  function drawScene3(fs){
    ctx.save(); ctx.textAlign='center';
    ctx.globalAlpha=1;
    ctx.fillStyle='#fbbf24'; ctx.font='bold '+fs+'px Courier New,monospace';
    ctx.fillText(title,W/2,H/2-20);
    ctx.fillStyle='#f97316'; ctx.globalAlpha=0.8;
    ctx.fillRect(W/2-W*0.35,H/2+10,W*0.7,2);
    ctx.globalAlpha=tagLag.value;
    ctx.fillStyle='#c0c0c8'; ctx.font=(fs*0.4)+'px Georgia,serif'; ctx.fontStyle='italic';
    ctx.fillText(tagline,W/2,H/2+50);
    ctx.restore();
  }
  function drawScene4(fs){
    ctx.save(); ctx.translate(W/2,H/2); ctx.rotate(logoRot.value*Math.PI*2);
    ctx.beginPath();
    for(var vi=0;vi<6;vi++){
      var ang=vi*Math.PI*2/6-Math.PI/2;
      var r=Math.min(W,H)*0.18;
      if(vi===0)ctx.moveTo(Math.cos(ang)*r,Math.sin(ang)*r);
      else ctx.lineTo(Math.cos(ang)*r,Math.sin(ang)*r);
    }
    ctx.closePath();
    ctx.strokeStyle='#f97316'; ctx.lineWidth=2;
    ctx.shadowBlur=20; ctx.shadowColor='#f97316'; ctx.stroke(); ctx.shadowBlur=0;
    // Inner
    ctx.beginPath();
    for(var vi=0;vi<3;vi++){
      var ang=vi*Math.PI*2/3+Math.PI/6;
      var r2=Math.min(W,H)*0.09;
      if(vi===0)ctx.moveTo(Math.cos(ang)*r2,Math.sin(ang)*r2);
      else ctx.lineTo(Math.cos(ang)*r2,Math.sin(ang)*r2);
    }
    ctx.closePath(); ctx.fillStyle='#fbbf24'; ctx.fill();
    ctx.restore();
  }

  function resize(){
    W=canvas.parentElement.offsetWidth||900; canvas.width=W; canvas.height=H;
  }

  function loop(t){
    var dt=Math.min((t-lastT)*0.001,0.05); lastT=t;
    var dur=parseFloat(document.getElementById('sceneDur').value)||1.5;
    var fs=parseInt(document.getElementById('titleSize').value)||42;
    var trans=document.getElementById('titleTrans').value;

    if(playing){
      seqT+=dt;
      var totalDur=SCENES.length*dur;
      var pct=seqT/totalDur;
      if(fill)fill.style.width=(Math.min(pct,1)*100)+'%';
      var newScene=Math.min(Math.floor(seqT/dur),SCENES.length-1);
      if(newScene!==curScene){curScene=newScene;initScene(curScene);}
      if(seqT>=totalDur){playing=false;}
    }

    // Phosphor
    ctx.globalAlpha=0.1; ctx.fillStyle='#040200'; ctx.fillRect(0,0,W,H); ctx.globalAlpha=1;

    // Transition overlay
    if(trans==='blur'||trans==='dissolve'){
      ctx.globalAlpha=1-transAlpha.value;
      ctx.fillStyle='#040200'; ctx.fillRect(0,0,W,H); ctx.globalAlpha=1;
    }

    SCENES[curScene].draw.call(null,fs);

    // Update lags
    alpha.update(dt); transAlpha.update(dt); lineLag.update(dt); tagLag.update(dt); logoRot.update(dt);
    for(var i=0;i<letterLags.length;i++)letterLags[i].update(dt);

    // Scanlines
    ctx.globalAlpha=0.04; ctx.fillStyle='rgba(0,0,0,1)';
    for(var sy=0;sy<H;sy+=2){ctx.fillRect(0,sy,W,1);}
    ctx.globalAlpha=1;

    // Scene label
    if(playing){
      ctx.fillStyle='rgba(249,115,22,0.4)'; ctx.font='10px Courier New,monospace';
      ctx.textAlign='left';
      ctx.fillText('SCENE '+(curScene+1)+' / '+SCENES.length+' — '+SCENES[curScene].label,12,H-10);
    }

    requestAnimationFrame(loop);
  }

  resize();
  window.addEventListener('resize',resize);
  requestAnimationFrame(loop);
  // Auto-play once
  setTimeout(playTitleSeq,800);
})();
</script>
