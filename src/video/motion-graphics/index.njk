<script>
// ===== SECTION 6 — COMPOSITING =====
(function(){
  var canvas=document.getElementById('compCanvas');
  var ctx=canvas.getContext('2d');
  var W,H=380,lastT=0,elapsed=0;
  var selLayer=3;
  var anims=[false,true,true,true]; // layer anim on/off
  var offsets=[
    {x:new LagFilter(0,0.15),y:new LagFilter(0,0.15)},
    {x:new LagFilter(0,0.15),y:new LagFilter(0,0.15)},
    {x:new LagFilter(0,0.15),y:new LagFilter(0,0.15)},
    {x:new LagFilter(0,0,15),y:new LagFilter(0,0.15)}
  ];
  var offXLag=new LagFilter(0,0.12), offYLag=new LagFilter(0,0.12);

  window.selectLayer=function(n){
    selLayer=n;
    document.querySelectorAll('.layer-row').forEach(function(r){
      r.classList.toggle('selected',parseInt(r.dataset.layer)===n);
    });
  };
  window.toggleAnim=function(n){anims[n]=!anims[n];};
  window.updateLayer=function(){};

  // Particle pool for layer 2
  var particles=Array.from({length:60},function(){return {
    x:Math.random(),y:Math.random(),vx:(Math.random()-.5)*0.0008,vy:(Math.random()-.5)*0.0008,r:Math.random()*2+1
  };});

  function resize(){W=canvas.parentElement.offsetWidth||900;canvas.width=W;canvas.height=H;}

  function getOp(i){return (parseFloat(document.getElementById('op'+i).value)||100)/100;}
  function getBM(i){
    var v=document.getElementById('bm'+i).value;
    if(v==='add')return 'lighter';
    if(v==='normal')return 'source-over';
    return v;
  }

  function loop(t){
    var dt=Math.min((t-lastT)*0.001,0.05); lastT=t; elapsed+=dt;
    offXLag.set(parseFloat(document.getElementById('offX').value)||0);
    offYLag.set(parseFloat(document.getElementById('offY').value)||0);
    offXLag.update(dt); offYLag.update(dt);
    for(var i=0;i<offsets.length;i++){offsets[i].x.update(dt);offsets[i].y.update(dt);}

    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#040200'; ctx.fillRect(0,0,W,H);

    // Layer 4 (bg) — animated gradient
    ctx.save();
    ctx.globalCompositeOperation=getBM(3);
    ctx.globalAlpha=getOp(3);
    var cx=(selLayer===3?offXLag.value:0), cy2=(selLayer===3?offYLag.value:0);
    if(anims[3]){
      var gr=ctx.createRadialGradient(W/2+Math.sin(elapsed*0.3)*80+cx,H/2+Math.cos(elapsed*0.2)*50+cy2,10,W/2+cx,H/2+cy2,Math.max(W,H)*0.7);
      gr.addColorStop(0,'rgba(249,115,22,0.18)');
      gr.addColorStop(0.5,'rgba(26,12,0,0.8)');
      gr.addColorStop(1,'rgba(4,2,0,1)');
    } else {
      var gr=ctx.createRadialGradient(W/2+cx,H/2+cy2,10,W/2+cx,H/2+cy2,Math.max(W,H)*0.7);
      gr.addColorStop(0,'rgba(249,115,22,0.12)');
      gr.addColorStop(1,'rgba(4,2,0,1)');
    }
    ctx.fillStyle=gr; ctx.fillRect(0,0,W,H);
    if(selLayer===3){ctx.strokeStyle='rgba(249,115,22,0.5)';ctx.lineWidth=2;ctx.strokeRect(2,2,W-4,H-4);}
    ctx.restore();

    // Layer 3 (particles)
    ctx.save();
    ctx.globalCompositeOperation=getBM(2);
    ctx.globalAlpha=getOp(2);
    var pox=(selLayer===2?offXLag.value:0), poy=(selLayer===2?offYLag.value:0);
    for(var i=0;i<particles.length;i++){
      var p=particles[i];
      if(anims[2]){p.x+=p.vx; p.y+=p.vy; if(p.x<0||p.x>1)p.vx*=-1; if(p.y<0||p.y>1)p.vy*=-1;}
      ctx.beginPath();
      ctx.arc(p.x*W+pox,p.y*H+poy,p.r,0,Math.PI*2);
      ctx.fillStyle='rgba(251,191,36,0.55)'; ctx.fill();
    }
    if(selLayer===2){ctx.strokeStyle='rgba(249,115,22,0.5)';ctx.lineWidth=2;ctx.strokeRect(2,2,W-4,H-4);}
    ctx.restore();

    // Layer 2 (rotating polygon)
    ctx.save();
    ctx.globalCompositeOperation=getBM(1);
    ctx.globalAlpha=getOp(1);
    var sox=(selLayer===1?offXLag.value:0), soy=(selLayer===1?offYLag.value:0);
    var sides=6, r3=Math.min(W,H)*0.22;
    var rot=anims[1]?elapsed*0.4:0;
    ctx.translate(W/2+sox,H/2+soy); ctx.rotate(rot);
    ctx.beginPath();
    for(var vi=0;vi<sides;vi++){
      var ang=vi*Math.PI*2/sides-Math.PI/2;
      if(vi===0)ctx.moveTo(Math.cos(ang)*r3,Math.sin(ang)*r3);
      else ctx.lineTo(Math.cos(ang)*r3,Math.sin(ang)*r3);
    }
    ctx.closePath();
    ctx.strokeStyle='#f97316'; ctx.lineWidth=2;
    ctx.shadowBlur=18; ctx.shadowColor='#f97316'; ctx.stroke(); ctx.shadowBlur=0;
    // Inner ring
    ctx.beginPath(); ctx.arc(0,0,r3*0.45,0,Math.PI*2);
    ctx.strokeStyle='rgba(251,191,36,0.6)'; ctx.lineWidth=1; ctx.stroke();
    ctx.restore();
    if(selLayer===1){ctx.save();ctx.strokeStyle='rgba(249,115,22,0.5)';ctx.lineWidth=2;ctx.strokeRect(2,2,W-4,H-4);ctx.restore();}

    // Layer 1 (text)
    ctx.save();
    ctx.globalCompositeOperation=getBM(0);
    ctx.globalAlpha=getOp(0);
    var tox=(selLayer===0?offXLag.value:0), toy=(selLayer===0?offYLag.value:0);
    var tfs=Math.min(Math.max(W*0.06,22),56);
    ctx.font='bold '+tfs+'px Courier New,monospace';
    ctx.textAlign='center';
    ctx.fillStyle='#fbbf24';
    ctx.shadowBlur=20; ctx.shadowColor='#f97316';
    if(anims[0]){
      ctx.fillText('COMPOSITE',W/2+tox+Math.sin(elapsed*0.8)*8,H/2+toy+Math.cos(elapsed*0.5)*5);
    } else {
      ctx.fillText('COMPOSITE',W/2+tox,H/2+toy);
    }
    ctx.shadowBlur=0; ctx.restore();
    if(selLayer===0){ctx.save();ctx.strokeStyle='rgba(249,115,22,0.5)';ctx.lineWidth=2;ctx.strokeRect(2,2,W-4,H-4);ctx.restore();}

    // Scanlines
    ctx.globalAlpha=0.04; ctx.fillStyle='rgba(0,0,0,1)';
    for(var sy=0;sy<H;sy+=2){ctx.fillRect(0,sy,W,1);}
    ctx.globalAlpha=1;

    requestAnimationFrame(loop);
  }

  resize(); window.addEventListener('resize',resize);
  requestAnimationFrame(loop);
})();

// ===== SECTION 7 — AV MOTION SYNC =====
(function(){
  var canvas=document.getElementById('avCanvas');
  var ctx=canvas.getContext('2d');
  var W,H=380,lastT=0,elapsed=0;

  // Simulated frequency bands
  var BANDS=[
    {name:'BASS',  color:'#f97316',tau:0.08,freq:0.7,phase:0},
    {name:'LOW-MID',color:'#fbbf24',tau:0.10,freq:1.3,phase:Math.PI*0.5},
    {name:'HI-MID', color:'#fb923c',tau:0.07,freq:2.1,phase:Math.PI},
    {name:'TREBLE', color:'#fdba74',tau:0.06,freq:3.8,phase:Math.PI*1.5}
  ];
  var bands=BANDS.map(function(b){return new LagFilter(0,b.tau);});

  var SHAPES=['circle','square','triangle','hexagon'];
  var shapeScales=BANDS.map(function(){return new LagFilter(1,0.1);});
  var shapeRots=BANDS.map(function(){return new LagFilter(0,0.2);});
  var shapeTx=BANDS.map(function(){return new LagFilter(0,0.15);});
  var shapeTy=BANDS.map(function(){return new LagFilter(0,0.15);});

  function resize(){W=canvas.parentElement.offsetWidth||900;canvas.width=W;canvas.height=H;}

  function drawWave(bpmVal){
    var wH=H*0.32, wY=H*0.18;
    ctx.save();
    ctx.strokeStyle='rgba(249,115,22,0.5)'; ctx.lineWidth=1.5;
    ctx.beginPath();
    for(var xi=0;xi<W;xi+=2){
      var xn=xi/W;
      var y=wY+Math.sin(xn*Math.PI*8+elapsed*bpmVal*0.05)*bands[0].value*wH*0.5
            +Math.sin(xn*Math.PI*14+elapsed*bpmVal*0.08)*bands[1].value*wH*0.3
            +Math.sin(xn*Math.PI*24+elapsed*bpmVal*0.14)*bands[2].value*wH*0.2
            +Math.sin(xn*Math.PI*40+elapsed*bpmVal*0.22)*bands[3].value*wH*0.1;
      if(xi===0)ctx.moveTo(xi,y); else ctx.lineTo(xi,y);
    }
    ctx.stroke();
    // RMS envelope
    var envH=bands[0].value*wH*0.4;
    ctx.globalAlpha=0.12;
    ctx.fillStyle='#f97316';
    ctx.fillRect(0,wY-envH,W,envH*2);
    ctx.globalAlpha=1;
    ctx.restore();
  }

  function drawShape(i,cx,cy,maxR,bval,style){
    var scale=shapeScales[i].value;
    var rot=shapeRots[i].value;
    var tx2=shapeTx[i].value;
    var ty2=shapeTy[i].value;
    var r=maxR*scale;
    var col=BANDS[i].color;
    ctx.save();
    ctx.translate(cx+tx2,cy+ty2);
    ctx.rotate(rot);
    ctx.shadowBlur=bval*30+4;
    ctx.shadowColor=col;
    ctx.strokeStyle=col; ctx.lineWidth=2;
    ctx.fillStyle=col.replace(')',',0.15)').replace('rgb','rgba').replace('#','rgba(').replace(/,/g,',');
    // simpler: just use globalAlpha
    ctx.globalAlpha=0.15+bval*0.3;
    ctx.beginPath();
    if(SHAPES[i]==='circle'){
      ctx.arc(0,0,r,0,Math.PI*2);
    } else if(SHAPES[i]==='square'){
      ctx.rect(-r,-r,r*2,r*2);
    } else if(SHAPES[i]==='triangle'){
      for(var vi=0;vi<3;vi++){var a=vi*Math.PI*2/3-Math.PI/2;vi===0?ctx.moveTo(Math.cos(a)*r,Math.sin(a)*r):ctx.lineTo(Math.cos(a)*r,Math.sin(a)*r);}
      ctx.closePath();
    } else {
      for(var vi=0;vi<6;vi++){var a=vi*Math.PI*2/6-Math.PI/2;vi===0?ctx.moveTo(Math.cos(a)*r,Math.sin(a)*r):ctx.lineTo(Math.cos(a)*r,Math.sin(a)*r);}
      ctx.closePath();
    }
    ctx.fill();
    ctx.globalAlpha=0.7+bval*0.3;
    ctx.stroke();
    ctx.shadowBlur=0;
    // Label
    ctx.globalAlpha=0.5;
    ctx.fillStyle=col;
    ctx.font='10px Courier New,monospace';
    ctx.textAlign='center';
    ctx.fillText(BANDS[i].name,0,r+18);
    ctx.restore();
  }

  function loop(t){
    var dt=Math.min((t-lastT)*0.001,0.05); lastT=t; elapsed+=dt;
    var bpmVal=parseFloat(document.getElementById('avBPM').value)||120;
    var intensity=(parseFloat(document.getElementById('avIntensity').value)||70)/100;
    var style=document.getElementById('avStyle').value;
    document.getElementById('bpmDisplay').textContent=Math.round(bpmVal);
    var styleScale={subtle:0.4,medium:0.7,reactive:1.0,explosive:1.5}[style]||0.7;
    var amp=intensity*styleScale;

    // Simulate band signals
    var beat=elapsed*bpmVal/60;
    for(var i=0;i<4;i++){
      var b=BANDS[i];
      var raw=(Math.sin(beat*b.freq*Math.PI+b.phase)*0.5+0.5);
      raw=Math.pow(raw,1.5)*amp;
      if(i===0)raw=Math.pow(Math.max(0,Math.sin(beat*Math.PI)),4)*amp*1.2;
      bands[i].set(raw); bands[i].update(dt);
    }

    // Update shape transforms
    for(var i=0;i<4;i++){
      var bv=bands[i].value;
      shapeScales[i].set(1+bv*amp*(i===0?0.5:0.3));
      shapeScales[i].update(dt);
      shapeRots[i].set(elapsed*(i+1)*0.15*amp);
      shapeRots[i].update(dt);
      if(i===3){shapeTx[i].set(Math.sin(elapsed*2.2)*bv*40*amp);shapeTx[i].update(dt);}
      if(i===2){shapeTy[i].set(Math.sin(elapsed*1.8)*bv*30*amp);shapeTy[i].update(dt);}
    }

    // Draw
    ctx.globalAlpha=0.1; ctx.fillStyle='#040200'; ctx.fillRect(0,0,W,H); ctx.globalAlpha=1;
    drawWave(bpmVal);

    // Divider
    ctx.save(); ctx.strokeStyle='rgba(249,115,22,0.15)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(0,H*0.42); ctx.lineTo(W,H*0.42); ctx.stroke(); ctx.restore();

    // Draw 4 shapes in bottom half
    var shapeY=H*0.7, colW=W/4;
    for(var i=0;i<4;i++){
      var cx=colW*i+colW/2;
      drawShape(i,cx,shapeY,colW*0.28,bands[i].value,style);
    }

    // Scanlines
    ctx.globalAlpha=0.04; ctx.fillStyle='rgba(0,0,0,1)';
    for(var sy=0;sy<H;sy+=2){ctx.fillRect(0,sy,W,1);} ctx.globalAlpha=1;
    requestAnimationFrame(loop);
  }

  resize(); window.addEventListener('resize',resize);
  requestAnimationFrame(loop);
})();
</script>
<!-- SECTION 8 — ARTISTS -->
<section id="artists-section">
<span class="section-label hidden stagger-1">08 / Notable Artists</span>
<h2 class="section-title hidden stagger-2">Motion Graphics Artists &amp; Studios</h2>
<p class="section-desc hidden stagger-3">The designers and studios who defined the discipline — from Saul Bass's foundational title sequences to today's digital studios.</p>
<div class="artists-grid hidden stagger-4">
<div class="artist-card">
<div class="artist-name">Saul Bass</div>
<div class="artist-era">1920 – 1996 · Pioneer</div>
<div class="artist-style">The grandfather of motion graphics. Proved that opening credits could set an entire film's emotional tone through kinetic design. Every letterform had intention.</div>
<div class="artist-work">Psycho · Vertigo · Anatomy of a Murder · West Side Story</div>
</div>
<div class="artist-card">
<div class="artist-name">Kyle Cooper</div>
<div class="artist-era">b. 1962 · Prologue Films</div>
<div class="artist-style">Established the "damaged" aesthetic of 1990s title design. Se7en's scratched film, reversed type, and cut-up collage defined a decade of gritty motion design.</div>
<div class="artist-work">Se7en · Spider-Man · The Walking Dead</div>
</div>
<div class="artist-card">
<div class="artist-name">Imaginary Forces</div>
<div class="artist-era">est. 1996 · LA / NYC</div>
<div class="artist-style">Co-founded by Kyle Cooper. Pioneered the commercial title sequence renaissance. Complex narrative motion design with cinematic ambition.</div>
<div class="artist-work">Mad Men · True Detective S2 · Captain America</div>
</div>
<div class="artist-card">
<div class="artist-name">Buck Design</div>
<div class="artist-era">est. 2004 · LA / NY / Sydney</div>
<div class="artist-style">The defining contemporary motion studio. Bold graphic sensibility, sophisticated brand storytelling, and technical mastery. The benchmark of professional motion output.</div>
<div class="artist-work">Google · Apple · Nike · MTV Brand</div>
</div>
<div class="artist-card">
<div class="artist-name">ManvsMachine</div>
<div class="artist-era">est. 2007 · London</div>
<div class="artist-style">Luxury brand motion and product visualization. Technically exceptional, aesthetically cool. Known for precise mechanical motion and immaculate finish quality.</div>
<div class="artist-work">Nike · Jaguar · Google hardware campaigns</div>
</div>
<div class="artist-card">
<div class="artist-name">Gmunk</div>
<div class="artist-era">Bradley G. Munkowitz · SF</div>
<div class="artist-style">UI motion as cinema. Fantasy interfaces that became the visual language of an era. Dense information aesthetics and neon-lit atmosphere with real craft underneath.</div>
<div class="artist-work">Tron: Legacy · Oblivion · Ghost in the Shell</div>
</div>
<div class="artist-card">
<div class="artist-name">Matt Pyke / Universal Everything</div>
<div class="artist-era">est. 2004 · Sheffield</div>
<div class="artist-style">Studio at the edge of motion, installation, and digital art. Generative aesthetics, evolutionary form, and works that blur commercial and gallery contexts.</div>
<div class="artist-work">Nike Flyknit · Audi · Installation commissions</div>
</div>
<div class="artist-card">
<div class="artist-name">Ash Thorp</div>
<div class="artist-era">Contemporary · Multi-disciplinary</div>
<div class="artist-style">Concept artist, designer, and director. Complex layered compositions, dark atmospheric palettes, and motion design with genuine artistic depth beyond commercial work.</div>
<div class="artist-work">Ghost in the Shell · Total Recall · RAMA project</div>
</div>
</div>
</section>
<!-- SECTION 9 — GLOSSARY -->
<section id="glossary-section">
<span class="section-label hidden stagger-1">09 / Glossary</span>
<h2 class="section-title hidden stagger-2">Motion Graphics Glossary</h2>
<p class="section-desc hidden stagger-3">The vocabulary of motion design — from the 12 principles to the graph editor. Twenty-two terms every practitioner should know.</p>
<div class="glossary-grid hidden stagger-4">
<div class="gloss-item">
<span class="gloss-term">ARC</span>
<div class="gloss-def">Natural motion follows curved trajectories, not straight lines. Objects that move in pure linear paths feel mechanical and lifeless. The arc is nature's default movement path.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">ANTICIPATION</span>
<div class="gloss-def">A preparatory motion in the opposite direction before the main action. Increases impact and readability. The wind-up before the throw — one of Disney's 12 principles.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">BEZIER CURVE</span>
<div class="gloss-def">A parametric curve defined by anchor points and control handles. The mathematical foundation of motion paths, easing curves, and vector shapes in every major motion tool.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">BLEND MODE</span>
<div class="gloss-def">How a layer combines with layers below it. Screen (brightens), Multiply (darkens), Overlay (contrast), Add (luminosity). Compositing's fundamental grammar of light interaction.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">COMPOSITING</span>
<div class="gloss-def">The process of layering multiple visual elements to create a unified image. From background plates to particle effects — compositing is the assembly phase of motion design.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">EASING (SLOW IN/OUT)</span>
<div class="gloss-def">The acceleration and deceleration of motion over time. Ease in = accelerates from rest. Ease out = decelerates to rest. Ease in-out = both. Linear motion always looks mechanical.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">EXPRESSIONS</span>
<div class="gloss-def">JavaScript-based code in After Effects that procedurally controls property values. wiggle(), loopOut(), thisComp.layer() — expressions unlock fully generative animation behavior.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">FOLLOW-THROUGH</span>
<div class="gloss-def">Parts of an object continue moving after the main body has stopped. A character's hair keeps swinging after they halt. Communicates weight, physics, and organic system behavior.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">FRAME RATE</span>
<div class="gloss-def">Frames per second (fps). 24fps = cinematic. 30fps = broadcast. 60fps = gaming/UI. Higher rates feel smoother but less "filmic." Motion blur compensates at lower frame rates.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">INTERPOLATION</span>
<div class="gloss-def">The calculation of in-between values between keyframes. Linear interpolation = constant rate. Bezier interpolation = custom velocity curve. Hold interpolation = no change between keys.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">KEYFRAME</span>
<div class="gloss-def">A marker at a specific time that defines a property's value. The software interpolates between keyframes to generate motion. The fundamental unit of timeline-based animation.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">KINETIC TYPOGRAPHY</span>
<div class="gloss-def">Text that moves — letterforms animated to amplify meaning, emotion, or rhythm. The motion becomes inseparable from the message. From Saul Bass to contemporary title design.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">LAYER</span>
<div class="gloss-def">A single element in a composition — footage, shape, text, solid, camera, light, or null. Layers stack in the timeline and composite in the viewport. The atom of compositing.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">MOTION BLUR</span>
<div class="gloss-def">The blurring of fast-moving objects across frames, simulating camera shutter exposure time. Essential for natural-feeling motion — without it, fast movement appears strobed and harsh.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">NULL OBJECT</span>
<div class="gloss-def">An invisible layer used as a parent control. Animate the null, and all children follow. Used for camera rigs, grouped layer control, and expression targets in complex compositions.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">OVERSHOOT</span>
<div class="gloss-def">Motion that goes past its target before settling back. Communicates energy and elasticity. The classic "bounce settle" that makes UI motion feel alive rather than mechanical.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">PRECOMP</span>
<div class="gloss-def">Pre-composition: collapsing multiple layers into a single composition layer. Organizes complexity, enables effects on groups, and is essential architecture for any complex motion piece.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">SECONDARY MOTION</span>
<div class="gloss-def">Additional motion generated by the primary action — a tail following its body, fabric rippling after a gesture. Adds depth and believability to every element in the frame.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">SPACING</span>
<div class="gloss-def">The distance between consecutive animation frames. Close spacing = slow motion. Wide spacing = fast motion. Spacing IS the velocity — adjusting it is how animators control perceived speed.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">SQUASH AND STRETCH</span>
<div class="gloss-def">Deforming an object at the extremes of its motion to communicate weight and elasticity. The most powerful of Disney's 12 principles — it makes everything feel physically real.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">STAGING</span>
<div class="gloss-def">Presenting an idea clearly so it is unmistakable. In motion, staging means silhouette, timing, and composition all work together to direct attention to exactly one thing at a time.</div>
</div>
<div class="gloss-item">
<span class="gloss-term">TIMING</span>
<div class="gloss-def">How long an action takes to complete. Slow timing = weight, drama, importance. Fast timing = lightness, comedy, energy. Timing is the single most expressive variable in animation.</div>
</div>
</div>
</section>
