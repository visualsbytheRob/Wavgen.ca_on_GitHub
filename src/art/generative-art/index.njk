/* ═══════════════════════════════════════════
   SECTION 9 — GLOSSARY
═══════════════════════════════════════════ */
(function buildGlossary(){
  const TERMS=[
    {w:'Agent',d:'An autonomous entity in a simulation that perceives its environment and acts on rules, producing emergent collective behavior.'},
    {w:'Attractor',d:'A set of values toward which a dynamic system tends to evolve. Strange attractors have fractal structure and never repeat.'},
    {w:'Bifurcation',d:'A sudden qualitative change in a system\'s behavior as a parameter crosses a critical threshold. The onset of chaos.'},
    {w:'Chaos Theory',d:'The study of systems that are deterministic yet sensitively dependent on initial conditions — small changes, vast differences.'},
    {w:'Emergent',d:'Properties or patterns that arise from simple rules interacting, which could not be predicted from individual components alone.'},
    {w:'Evolution',d:'Iterative variation and selection applied to generative parameters or "genomes," producing increasingly fit or complex outputs.'},
    {w:'Feed/Kill Rate',d:'Parameters in reaction-diffusion models controlling how fast chemicals are supplied (F) and removed (K), shaping pattern type.'},
    {w:'Fitness Function',d:'A measure of how well an organism or solution solves a problem, driving selection in evolutionary algorithms.'},
    {w:'Flow Field',d:'A vector field assigning a direction to every point in space. Particles following it trace paths that reveal invisible structure.'},
    {w:'Fractal Dimension',d:'A non-integer dimension measuring self-similarity across scales. A coastline may have dimension 1.25 — between line and plane.'},
    {w:'Gene',d:'A single parameter in a generative genome. Genes encode shape, color, motion, or behavior and are inherited through breeding.'},
    {w:'Gray-Scott',d:'A reaction-diffusion model of two chemicals U and V producing Turing patterns: spots, stripes, mazes, and complex forms.'},
    {w:'L-System',d:'A parallel rewriting system invented by Lindenmayer to model plant growth. Simple rules iterated produce complex fractal forms.'},
    {w:'Lorenz',d:'A system of differential equations exhibiting chaos, visualized as a butterfly-shaped strange attractor in 3D phase space.'},
    {w:'Mutation',d:'Random change in a genome parameter, introducing novelty into an evolutionary population and preventing premature convergence.'},
    {w:'Perlin Noise',d:'Gradient noise invented by Ken Perlin (Tron, 1982). Smooth, coherent randomness used for terrain, clouds, and texture.'},
    {w:'Phenotype',d:'The observable visual form that a genome produces when expressed — the artwork itself, as opposed to its genetic encoding.'},
    {w:'Production Rule',d:'In L-systems, a rule replacing one symbol with a string: F → F+F-F-F+F. Applied in parallel at each iteration step.'},
    {w:'Reaction-Diffusion',d:'A system modeling two chemicals diffusing through space and reacting with each other, producing Turing-like biological patterns.'},
    {w:'Self-Organization',d:'The spontaneous emergence of order from initially disordered states, driven by local interactions rather than central control.'},
    {w:'Strange Attractor',d:'An attractor with fractal structure. Trajectories are confined to it but never repeat — deterministic chaos made visible.'},
    {w:'Turtle Graphics',d:'A drawing system where a "turtle" moves forward and turns, tracing paths. L-systems are interpreted via turtle graphics.'}
  ];
  const grid=document.getElementById('glossary-grid');
  TERMS.forEach(t=>{
    const d=document.createElement('div');d.className='gterm';
    d.innerHTML=`<div class="gword">${t.w}</div><div class="gdef">${t.d}</div>`;
    grid.appendChild(d);
  });
})();

/* ═══════════════════════════════════════════
   INTERSECTION OBSERVER — SCROLL REVEALS
═══════════════════════════════════════════ */
(function scrollReveal(){
  const io=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting)e.target.classList.replace('hidden','visible');});
  },{threshold:.10});
  document.querySelectorAll('.hidden').forEach(el=>io.observe(el));
})();

</script>
