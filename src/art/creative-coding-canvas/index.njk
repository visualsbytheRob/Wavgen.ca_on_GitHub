// draw(ctx, w, h, frame, t) — runs every frame
function draw(ctx, w, h, frame, t) {
  ctx.fillStyle = 'rgba(10,10,15,0.04)';
  ctx.fillRect(0, 0, w, h);
  const cx = w / 2, cy = h / 2;
  const R = Math.min(w, h) * 0.42;
  const a = 3, b = 2, delta = t * 0.4;
  ctx.beginPath();
  for (let i = 0; i &lt;= 628; i++) {
    const theta = i * 0.01;
    const x = cx + R * Math.sin(a * theta + delta);
    const y = cy + R * Math.sin(b * theta);
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  }
  ctx.strokeStyle = '#f59e0b';
  ctx.lineWidth = 1.5;
  ctx.stroke();
}</textarea>
