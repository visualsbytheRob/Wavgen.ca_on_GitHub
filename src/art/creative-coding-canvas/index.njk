// SECTION 3 — GENERATIVE BRUSH
// ============================================================
(function initBrush() {
  const canvas = document.getElementById('brush-canvas');
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() {
    const img = ctx.getImageData(0, 0, W || 1, H || 1);
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight || 450;
    ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0, 0, W, H);
    if (img.width > 1) ctx.putImageData(img, 0, 0);
  }
  resize();
  new ResizeObserver(resize).observe(canvas);

  let brushType = 'noise';
  let isDrawing = false, mx = 0, my = 0, pmx = 0, pmy = 0;
  let wormX = 200, wormY = 200, wormAngle = 0;
  let lissPhase = 0;

  function getColor() { return document.getElementById('brush-color').value; }
  function getSize() { return +document.getElementById('brush-size').value; }
  function getOpacity() { return +document.getElementById('brush-opacity').value / 100; }

  function hexToRgb(hex) {
    const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
    return `${r},${g},${b}`;
  }

  function applyBrush(x, y) {
    const size = getSize(), op = getOpacity(), col = getColor(), rgb = hexToRgb(col);
    ctx.save();

    if (brushType === 'noise') {
      const n = Math.floor(size * 3);
      for (let i = 0; i < n; i++) {
        const angle = Math.random() * Math.PI * 2;
        const r = Math.random() * size * (0.5 + fbm(i * 0.3) * 0.5);
        const px = x + Math.cos(angle) * r;
        const py = y + Math.sin(angle) * r;
        ctx.beginPath();
        ctx.arc(px, py, Math.random() * 2 + 0.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${rgb},${op * (0.3 + Math.random() * 0.7)})`;
        ctx.fill();
      }
    } else if (brushType === 'splitter') {
      function splitLine(x1, y1, len, angle, depth) {
        if (depth > 5 || len < 2) return;
        const x2 = x1 + Math.cos(angle) * len;
        const y2 = y1 + Math.sin(angle) * len;
        ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2);
        ctx.strokeStyle = `rgba(${rgb},${op * (1 - depth * 0.15)})`;
        ctx.lineWidth = Math.max(3 - depth * 0.5, 0.5);
        ctx.stroke();
        const spread = 0.5 + Math.random() * 0.3;
        splitLine(x2, y2, len * 0.65, angle - spread, depth + 1);
        splitLine(x2, y2, len * 0.65, angle + spread, depth + 1);
      }
      splitLine(x, y, size, -Math.PI / 2 + (Math.random() - 0.5) * 0.8, 0);
    } else if (brushType === 'echo') {
      const echoes = 6;
      for (let e = 0; e < echoes; e++) {
        const ef = e / echoes;
        const ex = x + (pmx - x) * ef * 0.6;
        const ey = y + (pmy - y) * ef * 0.6;
        ctx.beginPath();
        ctx.arc(ex, ey, size * (1 - ef * 0.6), 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(${rgb},${op * (1 - ef) * 0.4})`;
        ctx.lineWidth = 1.5;
        ctx.stroke();
      }
      ctx.beginPath(); ctx.arc(x, y, size * 0.15, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${rgb},${op})`; ctx.fill();
    } else if (brushType === 'scatter') {
      const count = Math.floor(size * 2);
      for (let i = 0; i < count; i++) {
        const angle = Math.random() * Math.PI * 2;
        const r = Math.pow(Math.random(), 0.5) * size * 1.5;
        const px = x + Math.cos(angle) * r;
        const py = y + Math.sin(angle) * r;
        ctx.beginPath();
        ctx.arc(px, py, Math.random() * 3 + 0.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${rgb},${op * Math.random()})`;
        ctx.fill();
      }
    } else if (brushType === 'lisspen') {
      lissPhase += 0.08;
      const R = size * 0.8;
      ctx.beginPath();
      for (let i = 0; i <= 60; i++) {
        const theta = i * 0.1;
        const px = x + R * Math.sin(3 * theta + lissPhase);
        const py = y + R * Math.sin(2 * theta);
        i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
      }
      ctx.strokeStyle = `rgba(${rgb},${op * 0.6})`;
      ctx.lineWidth = 1.2;
      ctx.stroke();
    } else if (brushType === 'worm') {
      const steps = 8;
      for (let i = 0; i < steps; i++) {
        wormAngle += (Math.random() - 0.5) * 0.5;
        const dx = x - wormX, dy = y - wormY;
        wormAngle += Math.atan2(dy, dx) * 0.04;
        wormX += Math.cos(wormAngle) * size * 0.18;
        wormY += Math.sin(wormAngle) * size * 0.18;
        ctx.beginPath();
        ctx.arc(wormX, wormY, size * 0.12 + Math.random() * 2, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${rgb},${op * 0.5})`;
        ctx.fill();
      }
    }
    ctx.restore();
    pmx = x; pmy = y;
  }

  function evtPos(e) {
    const r = canvas.getBoundingClientRect();
    const src = e.touches ? e.touches[0] : e;
    return { x: (src.clientX - r.left) * (W / r.width), y: (src.clientY - r.top) * (H / r.height) };
  }

  canvas.addEventListener('mousedown', e => { isDrawing = true; const p = evtPos(e); mx=p.x; my=p.y; pmx=mx; pmy=my; wormX=mx; wormY=my; });
  canvas.addEventListener('mousemove', e => { if (!isDrawing) return; const p = evtPos(e); mx=p.x; my=p.y; applyBrush(mx, my); });
  canvas.addEventListener('mouseup', () => isDrawing = false);
  canvas.addEventListener('mouseleave', () => isDrawing = false);
  canvas.addEventListener('touchstart', e => { e.preventDefault(); isDrawing = true; const p = evtPos(e); mx=p.x; my=p.y; pmx=mx; pmy=my; wormX=mx; wormY=my; }, { passive: false });
  canvas.addEventListener('touchmove', e => { e.preventDefault(); if (!isDrawing) return; const p = evtPos(e); mx=p.x; my=p.y; applyBrush(mx, my); }, { passive: false });
  canvas.addEventListener('touchend', () => isDrawing = false);

  document.querySelectorAll('[data-brush]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-brush]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      brushType = btn.dataset.brush;
    });
  });
  document.getElementById('brush-clear').addEventListener('click', () => {
    ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0, 0, W, H);
  });
})();

