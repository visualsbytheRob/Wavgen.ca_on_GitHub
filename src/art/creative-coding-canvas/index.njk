// --- Phyllotaxis ---
(function initPhyllo() {
  const canvas = document.getElementById('phyllo-canvas');
  const ctx = canvas.getContext('2d');
  const nLabel = document.getElementById('phyllo-n');
  let W, H, n = 0, last = null;
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight || 260; }
  resize(); new ResizeObserver(resize).observe(canvas);
  const golden = 2.399963;
  const speedSlider = document.getElementById('phyllo-speed');
  const nFilter = new LagFilter(0.5);

  function frame(ts) {
    if (!last) last = ts;
    const dt = Math.min((ts - last) / 1000, 0.05); last = ts;
    const speed = +speedSlider.value;
    n = Math.min(n + speed, 1200);
    const nSmooth = nFilter.update(n, dt);
    nLabel.textContent = Math.floor(nSmooth);

    ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0, 0, W, H);
    const cx = W / 2, cy = H / 2;
    const maxR = Math.min(W, H) * 0.47;
    const count = Math.floor(nSmooth);
    for (let i = 0; i < count; i++) {
      const r = Math.sqrt(i / count) * maxR;
      const theta = i * golden;
      const x = cx + r * Math.cos(theta);
      const y = cy + r * Math.sin(theta);
      const hue = (i / count) * 60 + 20;
      const dotR = Math.sqrt(i) * 0.28 + 1.2;
      ctx.beginPath(); ctx.arc(x, y, dotR, 0, Math.PI * 2);
      ctx.fillStyle = `hsl(${hue},90%,60%)`; ctx.fill();
    }
    if (n >= 1200) n = 0;
    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();

// --- Polar Rose ---
(function initRose() {
  const canvas = document.getElementById('rose-canvas');
  const ctx = canvas.getContext('2d');
  const kSlider = document.getElementById('rose-k');
  const kVal = document.getElementById('rose-kval');
  let W, H, theta = 0, last = null;
  const kFilter = new LagFilter(1.2);
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight || 260; }
  resize(); new ResizeObserver(resize).observe(canvas);
  kSlider.addEventListener('input', () => kVal.textContent = kSlider.value);

  function frame(ts) {
    if (!last) last = ts;
    const dt = Math.min((ts - last) / 1000, 0.05); last = ts;
    const k = kFilter.update(+kSlider.value, dt);

    ctx.fillStyle = 'rgba(10,10,15,0.08)'; ctx.fillRect(0, 0, W, H);
    const R = Math.min(W, H) * 0.44;
    const cx = W / 2, cy = H / 2;
    const step = 0.025;
    const total = Math.PI * (Number.isInteger(k) ? (k % 2 === 0 ? 2 : 1) : 2) * 12;

    ctx.beginPath();
    const t0 = theta;
    for (let i = 0; i <= 80; i++) {
      const th = t0 + i * step;
      const r = R * Math.cos(k * th);
      const x = cx + r * Math.cos(th);
      const y = cy + r * Math.sin(th);
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.strokeStyle = '#a78bfa'; ctx.lineWidth = 1.5; ctx.stroke();
    theta += step * 4;
    if (theta > total) {
      theta = 0;
      ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0, 0, W, H);
    }
    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();

// --- Galaxy Spiral ---
(function initGalaxy() {
  const canvas = document.getElementById('galaxy-canvas');
  const ctx = canvas.getContext('2d');
  const armsSlider = document.getElementById('galaxy-arms');
  const aVal = document.getElementById('galaxy-aval');
  let W, H, last = null, t = 0;
  const armsFilter = new LagFilter(1.5);
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight || 260; }
  resize(); new ResizeObserver(resize).observe(canvas);
  armsSlider.addEventListener('input', () => aVal.textContent = armsSlider.value);

  // Star particles
  const N = 400;
  const stars = Array.from({length: N}, (_, i) => ({
    arm: i % 6,
    t: Math.random(),
    spread: (Math.random() - 0.5) * 0.4,
    brightness: 0.4 + Math.random() * 0.6,
    size: Math.random() * 1.8 + 0.3
  }));

  function frame(ts) {
    if (!last) last = ts;
    const dt = Math.min((ts - last) / 1000, 0.05); last = ts;
    t += dt * 0.08;
    const arms = Math.round(armsFilter.update(+armsSlider.value, dt));

    ctx.fillStyle = 'rgba(10,10,15,0.12)'; ctx.fillRect(0, 0, W, H);
    const cx = W / 2, cy = H / 2;
    const maxR = Math.min(W, H) * 0.44;

    stars.forEach(s => {
      if (s.arm >= arms) return;
      const armAngle = (s.arm / arms) * Math.PI * 2 + t;
      const r = s.t * maxR;
      const twist = r * 0.018;
      const angle = armAngle + twist + s.spread * (1 - s.t);
      const x = cx + r * Math.cos(angle);
      const y = cy + r * Math.sin(angle);
      const hue = 200 + s.arm * 30;
      ctx.beginPath(); ctx.arc(x, y, s.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(180,210,255,${s.brightness * (0.4 + s.t * 0.6)})`; ctx.fill();
    });

    // Core glow
    const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, maxR * 0.18);
    g.addColorStop(0, 'rgba(245,200,100,0.25)');
    g.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = g; ctx.fillRect(0, 0, W, H);

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();

