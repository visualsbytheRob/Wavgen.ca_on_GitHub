      draw:function(cv,cx){ cx.fillStyle='#f5f5f0'; cx.fillRect(0,0,200,155); var lines=[[0,55,200,55],[0,110,200,110],[70,0,70,155],[130,0,130,155]]; cx.strokeStyle='#111'; cx.lineWidth=4; lines.forEach(function(l){ cx.beginPath(); cx.moveTo(l[0],l[1]); cx.lineTo(l[2],l[3]); cx.stroke(); }); [{x:0,y:0,w:70,h:55,c:'#ef4444'},{x:130,y:55,w:70,h:55,c:'#3b82f6'},{x:0,y:110,w:70,h:45,c:'#f59e0b'},{x:130,y:0,w:70,h:55,c:'#111'}].forEach(function(f){ cx.fillStyle=f.c; cx.fillRect(f.x+2,f.y+2,f.w-4,f.h-4); }); }
