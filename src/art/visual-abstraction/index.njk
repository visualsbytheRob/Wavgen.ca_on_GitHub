<script>
(function() {
  var cv = document.getElementById('geoCanvas');
  var cx = cv.getContext('2d');
  var W = 680, H = 440;
  var mode = 'stijl';

  // LagFilters for color transitions
  function LF(v, tau) { return new LagFilter(v, tau); }

  // Dividing lines (normalized 0-1)
  var hLines = [0.38, 0.72];  // horizontal
  var vLines = [0.28, 0.60];  // vertical
  var allLines = [];

  function buildLines() {
    allLines = [];
    hLines.forEach(function(y,i){ allLines.push({type:'h', pos:y, idx:i, lf: new LagFilter(y, 0.18)}); });
    vLines.forEach(function(x,i){ allLines.push({type:'v', pos:x, idx:i, lf: new LagFilter(x, 0.18)}); });
  }
  buildLines();

  // Stijl colors
  var STIJL_COLORS = ['#ef4444','#3b82f6','#f59e0b','#111111','#f5f5f0','#f5f5f0','#f5f5f0','#f5f5f0','#f5f5f0'];
  var cellColors = [];
  var cellColorTargets = [];
  // LagFilters for each cell color channel
  var cellR = [], cellG = [], cellB = [];

  function hexToRgb(h) {
    var r=parseInt(h.slice(1,3),16), g=parseInt(h.slice(3,5),16), b=parseInt(h.slice(5,7),16);
    return [r,g,b];
  }
  function rgbToHex(r,g,b) {
    return '#'+[r,g,b].map(function(v){ return Math.round(Math.max(0,Math.min(255,v))).toString(16).padStart(2,'0'); }).join('');
  }

  function initCells() {
    var n = (hLines.length+1)*(vLines.length+1);
    cellColors = []; cellColorTargets = []; cellR = []; cellG = []; cellB = [];
    for (var i=0;i<n;i++) {
      var c = STIJL_COLORS[Math.min(i, STIJL_COLORS.length-1)];
      var rgb = hexToRgb(c);
      cellColors.push(c); cellColorTargets.push(c);
      cellR.push(new LagFilter(rgb[0], 0.25));  // LagFilter per cell R
      cellG.push(new LagFilter(rgb[1], 0.25));  // LagFilter per cell G
      cellB.push(new LagFilter(rgb[2], 0.25));  // LagFilter per cell B
    }
  }
  initCells();

  function randomizeStijl() {
    var n = cellColors.length;
    var reds=0, blues=0, yellows=0;
    for (var i=0;i<n;i++) {
      var r = Math.random();
      var c;
      if (r < 0.12 && reds < 2) { c='#ef4444'; reds++; }
      else if (r < 0.22 && blues < 2) { c='#3b82f6'; blues++; }
      else if (r < 0.30 && yellows < 1) { c='#f59e0b'; yellows++; }
      else if (r < 0.36) { c='#111111'; }
      else { c='#f5f5f0'; }
      cellColorTargets[i] = c;
    }
  }

  function cycleCell(idx) {
    var cycle;
    if (mode === 'stijl') cycle = ['#f5f5f0','#ef4444','#3b82f6','#f59e0b','#111111'];
    else if (mode === 'kand') cycle = ['#7c3aed','#f59e0b','#ef4444','#22c55e','#3b82f6','#ec4899','#f5f5f0'];
    else cycle = ['#fff','#111','#fff','#fff','#888'];
    var cur = cellColorTargets[idx];
    var ci = cycle.indexOf(cur);
    cellColorTargets[idx] = cycle[(ci+1)%cycle.length];
  }

  // Drag state
  var drag = null;
  var GRAB = 10;

  function pxToNorm(px,py) { return {x:px/W, y:py/H}; }
  function normToPx(nx,ny) { return {x:nx*W, y:ny*H}; }

  function findLine(px,py) {
    for (var i=0;i<allLines.length;i++) {
      var l = allLines[i];
      if (l.type==='h') { if (Math.abs(py - l.pos*H) < GRAB) return i; }
      else { if (Math.abs(px - l.pos*W) < GRAB) return i; }
    }
    return -1;
  }

  function cellIndexAt(px,py) {
    var xs = [0].concat(vLines.map(function(v){ return v*W; })).concat([W]);
    var ys = [0].concat(hLines.map(function(h){ return h*H; })).concat([H]);
    var ci = -1, ri = -1;
    for (var i=0;i<xs.length-1;i++) { if (px>=xs[i] && px<xs[i+1]) { ci=i; break; } }
    for (var j=0;j<ys.length-1;j++) { if (py>=ys[j] && py<ys[j+1]) { ri=j; break; } }
    if (ci<0||ri<0) return -1;
    return ri*(vLines.length+1)+ci;
  }

  cv.addEventListener('mousedown', function(e) {
    var r=cv.getBoundingClientRect(), px=(e.clientX-r.left)*(W/r.width), py=(e.clientY-r.top)*(H/r.height);
    var li = findLine(px,py);
    if (li>=0) { drag={li:li}; cv.style.cursor='grabbing'; }
    else {
      var ci = cellIndexAt(px,py);
      if (ci>=0) cycleCell(ci);
    }
  });
  window.addEventListener('mousemove', function(e) {
    if (!drag) { var r=cv.getBoundingClientRect(), px=(e.clientX-r.left)*(W/r.width), py=(e.clientY-r.top)*(H/r.height); cv.style.cursor = findLine(px,py)>=0 ? (allLines[findLine(px,py)].type==='h'?'ns-resize':'ew-resize') : 'crosshair'; return; }
    var r=cv.getBoundingClientRect(), px=(e.clientX-r.left)*(W/r.width), py=(e.clientY-r.top)*(H/r.height);
    var l = allLines[drag.li];
    var margin = 0.08;
    if (l.type==='h') {
      var neighbors = [0].concat(hLines).concat([1]);
      var prev = neighbors[l.idx], next = neighbors[l.idx+2];
      l.pos = Math.max(prev+margin, Math.min(next-margin, py/H));
      hLines[l.idx] = l.pos;
    } else {
      var neighbors2 = [0].concat(vLines).concat([1]);
      var prev2 = neighbors2[l.idx], next2 = neighbors2[l.idx+2];
      l.pos = Math.max(prev2+margin, Math.min(next2-margin, px/W));
      vLines[l.idx] = l.pos;
    }
  });
  window.addEventListener('mouseup', function() { drag=null; cv.style.cursor='crosshair'; });

  // Kandinsky overlays: circles, arcs, diagonal lines
  var kandShapes = [];
  function buildKand() {
    kandShapes = [];
    for (var i=0;i<12;i++) {
      kandShapes.push({
        type:['circle','arc','line'][i%3],
        x: 0.1+Math.random()*0.8, y:0.1+Math.random()*0.8,
        r: 0.04+Math.random()*0.1,
        a1: Math.random()*Math.PI*2, a2: Math.random()*Math.PI*2,
        c:['#7c3aed','#f59e0b','#ef4444','#3b82f6','#22c55e'][i%5],
        lx: new LagFilter(0.1+Math.random()*0.8, 0.5),
        ly: new LagFilter(0.1+Math.random()*0.8, 0.5),
      });
    }
  }
  buildKand();

  // Malevich shapes
  var malShapes = [];
  function buildMal() {
    malShapes = [];
    var forms = ['rect','circle','rect','rect','line','rect'];
    var cols = ['#111','#111','#ef4444','#111','#111','#888888'];
    var sizes = [[0.3,0.3],[0.18,0.18],[0.5,0.12],[0.15,0.4],[0,0],[0.2,0.08]];
    for (var i=0;i<forms.length;i++) {
      malShapes.push({
        type:forms[i], c:cols[i],
        x: 0.15+Math.random()*0.6, y: 0.15+Math.random()*0.6,
        w:sizes[i][0], h:sizes[i][1],
        rot: (Math.random()-0.5)*0.6,
        lx: new LagFilter(0.15+Math.random()*0.6, 0.4),
        ly: new LagFilter(0.15+Math.random()*0.6, 0.4),
      });
    }
  }
  buildMal();

  var last = performance.now();
  function draw(now) {
    requestAnimationFrame(draw);
    var dt = Math.min((now-last)/1000, 0.05); last=now;
    var t = now*0.001;

    cx.clearRect(0,0,W,H);

    // Draw base cells with LagFiltered colors
    var xs = [0].concat(vLines.map(function(v){ return v*W; })).concat([W]);
    var ys = [0].concat(hLines.map(function(h){ return h*H; })).concat([H]);
    var ci = 0;
    for (var row=0;row<ys.length-1;row++) {
      for (var col=0;col<xs.length-1;col++) {
        var target = cellColorTargets[ci] || '#f5f5f0';
        var trgb = hexToRgb(target);
        cellR[ci].update(trgb[0], dt);
        cellG[ci].update(trgb[1], dt);
        cellB[ci].update(trgb[2], dt);
        cx.fillStyle = rgbToHex(cellR[ci].val, cellG[ci].val, cellB[ci].val);
        cx.fillRect(xs[col], ys[row], xs[col+1]-xs[col], ys[row+1]-ys[row]);
        ci++;
      }
    }

    // Draw grid lines (Stijl & Kand modes)
    if (mode !== 'mal') {
      cx.strokeStyle = '#111'; cx.lineWidth = mode==='stijl'?5:2;
      hLines.forEach(function(y) { cx.beginPath(); cx.moveTo(0,y*H); cx.lineTo(W,y*H); cx.stroke(); });
      vLines.forEach(function(x) { cx.beginPath(); cx.moveTo(x*W,0); cx.lineTo(x*W,H); cx.stroke(); });
    }

    // Kandinsky overlay
    if (mode === 'kand') {
      kandShapes.forEach(function(s,i) {
        s.lx.update(s.x + 0.04*Math.sin(t*0.4+i), dt);
        s.ly.update(s.y + 0.04*Math.cos(t*0.35+i), dt);
        var px=s.lx.val*W, py=s.ly.val*H, r=s.r*Math.min(W,H);
        cx.strokeStyle=s.c; cx.lineWidth=2.5; cx.globalAlpha=0.75;
        if (s.type==='circle') { cx.beginPath(); cx.arc(px,py,r,0,Math.PI*2); cx.stroke(); }
        else if (s.type==='arc') { cx.beginPath(); cx.arc(px,py,r,s.a1,s.a2); cx.stroke(); }
        else { cx.beginPath(); cx.moveTo(px-r,py-r); cx.lineTo(px+r,py+r); cx.stroke(); }
        cx.globalAlpha=1;
      });
    }

    // Malevich overlay
    if (mode === 'mal') {
      cx.fillStyle='#f5f5f0'; cx.fillRect(0,0,W,H);
      malShapes.forEach(function(s,i) {
        s.lx.update(s.x, dt); s.ly.update(s.y, dt);
        var px=s.lx.val*W, py=s.ly.val*H;
        cx.save(); cx.translate(px,py); cx.rotate(s.rot); cx.fillStyle=s.c;
        if (s.type==='rect') { cx.fillRect(-s.w*W/2,-s.h*H/2,s.w*W,s.h*H); }
        else if (s.type==='circle') { cx.beginPath(); cx.arc(0,0,s.w*Math.min(W,H)/2,0,Math.PI*2); cx.fill(); }
        else { cx.strokeStyle=s.c; cx.lineWidth=3; cx.beginPath(); cx.moveTo(-s.w*W,0); cx.lineTo(s.w*W,0); cx.stroke(); }
        cx.restore();
      });
    }
  }
  draw(performance.now());

  // Button handlers
  document.getElementById('geoModeStijl').addEventListener('click', function() {
    mode='stijl'; updateBtns(); resetToStijl();
  });
  document.getElementById('geoModeKand').addEventListener('click', function() {
    mode='kand'; updateBtns(); buildKand();
    for(var i=0;i<cellColorTargets.length;i++) cellColorTargets[i]='#f5f5f0';
  });
  document.getElementById('geoModeMal').addEventListener('click', function() {
    mode='mal'; updateBtns(); buildMal();
  });
  document.getElementById('geoRandom').addEventListener('click', function() {
    if (mode==='stijl'||mode==='kand') { randomizeStijl(); }
    else { buildMal(); }
    vLines[0]=0.15+Math.random()*0.2; vLines[1]=0.55+Math.random()*0.2;
    hLines[0]=0.2+Math.random()*0.2; hLines[1]=0.6+Math.random()*0.15;
    buildLines();
  });
  document.getElementById('geoReset').addEventListener('click', function() {
    hLines=[0.38,0.72]; vLines=[0.28,0.60]; buildLines(); resetToStijl(); mode='stijl'; updateBtns();
  });
  document.getElementById('geoExport').addEventListener('click', function() {
    var link=document.createElement('a'); link.download='abstraction.png'; link.href=cv.toDataURL(); link.click();
  });

  function resetToStijl() {
    initCells(); randomizeStijl();
  }
  function updateBtns() {
    ['geoModeStijl','geoModeKand','geoModeMal'].forEach(function(id,i){
      document.getElementById(id).classList.toggle('act', ['stijl','kand','mal'][i]===mode);
    });
  }

  resetToStijl();
})();
</script>
<!-- ══════════════════════════════════════
     SECTION 4 — OP ART & PERCEPTUAL EFFECTS
══════════════════════════════════════ -->
<section id="op-art">
<div class="section-inner hidden">
<div class="sec-label">Visual Phenomena &amp; Perceptual Illusion</div>
<h2>Op Art &amp; Perceptual Effects</h2>
<p>Six interactive optical generators — each exploits a different quirk of human visual perception. Adjust sliders to push each illusion to its limit.</p>
<div class="op-grid">
<!-- 1: Riley Waves -->
<div class="op-card">
<h3>Bridget Riley Waves</h3>
<canvas height="180" id="opRiley" width="260"></canvas>
<div class="ctrl"><label>Frequency</label><input id="rFreq" max="30" min="1" step="0.5" type="range" value="12"/><span class="val-d" id="rFreqV">12</span></div>
<div class="ctrl"><label>Amplitude</label><input id="rAmp" max="40" min="1" step="0.5" type="range" value="10"/><span class="val-d" id="rAmpV">10</span></div>
<div class="ctrl"><label>Phase Shift</label><input id="rPhase" max="6.28" min="0" step="0.01" type="range" value="0"/><span class="val-d" id="rPhaseV">0</span></div>
</div>
<!-- 2: Vasarely Grid -->
<div class="op-card">
<h3>Vasarely Depth Grid</h3>
<canvas height="180" id="opVas" width="260"></canvas>
<div class="ctrl"><label>Grid Size</label><input id="vGrid" max="16" min="4" step="1" type="range" value="9"/><span class="val-d" id="vGridV">9</span></div>
<div class="ctrl"><label>Depth</label><input id="vDepth" max="2.5" min="0.1" step="0.05" type="range" value="1"/><span class="val-d" id="vDepthV">1.0</span></div>
</div>
<!-- 3: Cafe Wall -->
<div class="op-card">
<h3>Cafe Wall Illusion</h3>
<canvas height="180" id="opCafe" width="260"></canvas>
<div class="ctrl"><label>Offset</label><input id="cOff" max="30" min="0" step="0.5" type="range" value="14"/><span class="val-d" id="cOffV">14</span></div>
<div class="ctrl"><label>Grout Width</label><input id="cGrout" max="10" min="1" step="0.5" type="range" value="3"/><span class="val-d" id="cGroutV">3</span></div>
<div class="ctrl"><label>Grout Color</label><input id="cGCol" max="255" min="0" step="1" type="range" value="128"/><span class="val-d" id="cGColV">128</span></div>
</div>
<!-- 4: Spiral Illusion -->
<div class="op-card">
<h3>Rotating Spiral Illusion</h3>
<canvas height="180" id="opSpiral" width="260"></canvas>
<div class="ctrl"><label>Turns</label><input id="sTurns" max="20" min="2" step="1" type="range" value="9"/><span class="val-d" id="sTurnsV">9</span></div>
<div class="ctrl"><label>Speed</label><input id="sSpeed" max="3" min="0" step="0.05" type="range" value="0.8"/><span class="val-d" id="sSpeedV">0.8</span></div>
</div>
<!-- 5: Neon Color Spreading -->
<div class="op-card">
<h3>Neon Color Spreading</h3>
<canvas height="180" id="opNeon" width="260"></canvas>
<div class="ctrl"><label>Line Density</label><input id="nDens" max="18" min="2" step="1" type="range" value="8"/><span class="val-d" id="nDensV">8</span></div>
<div class="ctrl"><label>Hue</label><input id="nHue" max="360" min="0" step="1" type="range" value="270"/><span class="val-d" id="nHueV">270</span></div>
</div>
<!-- 6: Moire Patterns -->
<div class="op-card">
<h3>Moiré Patterns</h3>
<canvas height="180" id="opMoire" width="260"></canvas>
<div class="ctrl"><label>Angle Offset</label><input id="mAngle" max="15" min="0" step="0.1" type="range" value="3"/><span class="val-d" id="mAngleV">3.0</span></div>
<div class="ctrl"><label>Grid Spacing</label><input id="mSpace" max="20" min="4" step="0.5" type="range" value="8"/><span class="val-d" id="mSpaceV">8</span></div>
</div>
</div>
</div>
</section>
<script>
(function() {
  // LagFilters for all 6 Op Art generators
  var riley = {
    freq:  new LagFilter(12, 0.25),
    amp:   new LagFilter(10, 0.25),
    phase: new LagFilter(0,  0.25),
    tFreq: 12, tAmp: 10, tPhase: 0
  };
  var vasarely = {
    grid:  new LagFilter(9,  0.3),
    depth: new LagFilter(1,  0.3),
    tGrid: 9, tDepth: 1
  };
  var cafe = {
    off:   new LagFilter(14, 0.22),
    grout: new LagFilter(3,  0.22),
    gcol:  new LagFilter(128,0.22),
    tOff: 14, tGrout: 3, tGcol: 128
  };
  var spiral = {
    turns: new LagFilter(9, 0.3),
    speed: new LagFilter(0.8, 0.25),
    angle: 0,
    tTurns: 9, tSpeed: 0.8
  };
  var neon = {
    dens: new LagFilter(8, 0.28),
    hue:  new LagFilter(270, 0.28),
    tDens: 8, tHue: 270
  };
  var moire = {
    angle: new LagFilter(3, 0.22),
    space: new LagFilter(8, 0.22),
    tAngle: 3, tSpace: 8
  };

  function wire(id, valId, obj, key, fmt) {
    var sl = document.getElementById(id);
    var vd = document.getElementById(valId);
    sl.addEventListener('input', function() {
      obj[key] = +sl.value;
      vd.textContent = fmt ? (+sl.value).toFixed(fmt) : sl.value;
    });
  }
  wire('rFreq','rFreqV', riley,'tFreq',0);
  wire('rAmp','rAmpV',   riley,'tAmp',0);
  wire('rPhase','rPhaseV',riley,'tPhase',2);
  wire('vGrid','vGridV', vasarely,'tGrid',0);
  wire('vDepth','vDepthV',vasarely,'tDepth',1);
  wire('cOff','cOffV',   cafe,'tOff',0);
  wire('cGrout','cGroutV',cafe,'tGrout',0);
  wire('cGCol','cGColV', cafe,'tGcol',0);
  wire('sTurns','sTurnsV',spiral,'tTurns',0);
  wire('sSpeed','sSpeedV',spiral,'tSpeed',2);
  wire('nDens','nDensV', neon,'tDens',0);
  wire('nHue','nHueV',   neon,'tHue',0);
  wire('mAngle','mAngleV',moire,'tAngle',1);
  wire('mSpace','mSpaceV',moire,'tSpace',0);

  var cvR=document.getElementById('opRiley'), cxR=cvR.getContext('2d');
  var cvV=document.getElementById('opVas'),   cxV=cvV.getContext('2d');
  var cvC=document.getElementById('opCafe'),  cxC=cvC.getContext('2d');
  var cvS=document.getElementById('opSpiral'),cxS=cvS.getContext('2d');
  var cvN=document.getElementById('opNeon'),  cxN=cvN.getContext('2d');
  var cvM=document.getElementById('opMoire'), cxM=cvM.getContext('2d');

  var last = performance.now();

  function drawRiley(dt) {
    riley.freq.update(riley.tFreq, dt);
    riley.amp.update(riley.tAmp, dt);
    riley.phase.update(riley.tPhase, dt);
    var W=260,H=180, freq=riley.freq.val, amp=riley.amp.val, ph=riley.phase.val;
    cxR.fillStyle='#fff'; cxR.fillRect(0,0,W,H);
    var spacing = H / Math.max(1,freq);
    for (var row=0; row<freq+2; row++) {
      var yBase = row*spacing;
      cxR.beginPath(); cxR.strokeStyle=row%2===0?'#111':'#fff'; cxR.lineWidth=spacing*0.82;
      for (var x=0;x<=W;x++) {
        var y = yBase + amp*Math.sin((x/W)*Math.PI*3 + row*0.5 + ph);
        if (x===0) cxR.moveTo(x,y); else cxR.lineTo(x,y);
      }
      cxR.stroke();
    }
  }

  function drawVasarely(dt) {
    vasarely.grid.update(vasarely.tGrid, dt);
    vasarely.depth.update(vasarely.tDepth, dt);
    var W=260,H=180, n=Math.round(vasarely.grid.val), dep=vasarely.depth.val;
    cxV.fillStyle='#111'; cxV.fillRect(0,0,W,H);
    var cw=W/n, ch=H/n, cx2=W/2, cy2=H/2;
    for (var r=0;r<n;r++) {
      for (var c=0;c<n;c++) {
        var x=c*cw+cw/2, y=r*ch+ch/2;
        var dx=(x-cx2)/cx2, dy=(y-cy2)/cy2;
        var dist=Math.sqrt(dx*dx+dy*dy);
        var rad=Math.min(cw,ch)*0.45*(1-dist*0.4*dep);
        if (rad<=0) continue;
        var bright=Math.floor(220*(1-dist*0.5*dep));
        cxV.fillStyle='rgb('+bright+','+bright+','+bright+')';
        cxV.beginPath(); cxV.arc(x,y,rad,0,Math.PI*2); cxV.fill();
      }
    }
  }

  function drawCafe(dt) {
    cafe.off.update(cafe.tOff, dt);
    cafe.grout.update(cafe.tGrout, dt);
    cafe.gcol.update(cafe.tGcol, dt);
    var W=260,H=180, off=cafe.off.val, gw=cafe.grout.val, gc=Math.round(cafe.gcol.val);
    var rowH = 22, tileW = 40;
    var rows = Math.ceil(H/rowH)+1;
    var gcStr='rgb('+gc+','+gc+','+gc+')';
    cxC.fillStyle=gcStr; cxC.fillRect(0,0,W,H);
    for (var r=0;r<rows;r++) {
      var y=r*rowH, shift=(r%2)*off;
      var cols2=Math.ceil(W/tileW)+2;
      for (var c=-1;c<cols2;c++) {
        var x=c*tileW+shift-tileW;
        cxC.fillStyle=c%2===0?'#111':'#f5f5f0';
        cxC.fillRect(x+gw/2, y+gw/2, tileW-gw, rowH-gw);
      }
    }
  }

  function drawSpiral(dt) {
    spiral.turns.update(spiral.tTurns, dt);
    spiral.speed.update(spiral.tSpeed, dt);
    spiral.angle += spiral.speed.val * dt;
    var W=260,H=180, turns=spiral.turns.val, ang=spiral.angle;
    var cx2=W/2, cy2=H/2, maxR=Math.min(W,H)*0.47;
    cxS.fillStyle='#111'; cxS.fillRect(0,0,W,H);
    var steps=800;
    cxS.beginPath();
    for (var i=0;i<=steps;i++) {
      var t=i/steps;
      var a=t*turns*Math.PI*2+ang;
      var r=t*maxR;
      var x=cx2+r*Math.cos(a), y=cy2+r*Math.sin(a);
      if (i===0) cxS.moveTo(x,y); else cxS.lineTo(x,y);
    }
    cxS.strokeStyle='#fff'; cxS.lineWidth=2.5; cxS.stroke();
    // Second arm
    cxS.beginPath();
    for (var i=0;i<=steps;i++) {
      var t=i/steps;
      var a=t*turns*Math.PI*2+ang+Math.PI;
      var r=t*maxR;
      var x=cx2+r*Math.cos(a), y=cy2+r*Math.sin(a);
      if (i===0) cxS.moveTo(x,y); else cxS.lineTo(x,y);
    }
    cxS.strokeStyle='#a78bfa'; cxS.lineWidth=1.5; cxS.stroke();
  }

  function drawNeon(dt) {
    neon.dens.update(neon.tDens, dt);
    neon.hue.update(neon.tHue, dt);
    var W=260,H=180, n=Math.round(neon.dens.val), h=neon.hue.val;
    cxN.fillStyle='#0a0a0a'; cxN.fillRect(0,0,W,H);
    // Black grid lines
    var step=W/(n+1);
    cxN.strokeStyle='#111'; cxN.lineWidth=2;
    for (var i=1;i<=n;i++) { cxN.beginPath(); cxN.moveTo(i*step,0); cxN.lineTo(i*step,H); cxN.stroke(); }
    for (var i=1;i<=n;i++) { var sy=i*(H/(n+1)); cxN.beginPath(); cxN.moveTo(0,sy); cxN.lineTo(W,sy); cxN.stroke(); }
    // Colored segments in center cross — neon glow illusion
    cxN.strokeStyle='hsl('+h+',100%,65%)'; cxN.lineWidth=3;
    cxN.shadowColor='hsl('+h+',100%,65%)'; cxN.shadowBlur=12;
    var mid=Math.round(n/2);
    cxN.beginPath(); cxN.moveTo((mid+0.5)*step,0); cxN.lineTo((mid+0.5)*step,H); cxN.stroke();
    cxN.beginPath(); cxN.moveTo(0,(mid+0.5)*(H/(n+1))); cxN.lineTo(W,(mid+0.5)*(H/(n+1))); cxN.stroke();
    cxN.shadowBlur=0;
    // Apparent glow at intersection
    var gx=(mid+0.5)*step, gy=(mid+0.5)*(H/(n+1));
    var grad=cxN.createRadialGradient(gx,gy,0,gx,gy,30);
    grad.addColorStop(0,'hsla('+h+',100%,75%,0.45)');
    grad.addColorStop(1,'transparent');
    cxN.fillStyle=grad; cxN.fillRect(gx-35,gy-35,70,70);
  }

  function drawMoire(dt) {
    moire.angle.update(moire.tAngle, dt);
    moire.space.update(moire.tSpace, dt);
    var W=260,H=180, ang=moire.angle.val*Math.PI/180, sp=moire.space.val;
    cxM.fillStyle='#fff'; cxM.fillRect(0,0,W,H);
    cxM.strokeStyle='#111'; cxM.lineWidth=0.8;
    // Grid 1: straight
    for (var x=0;x<W;x+=sp) { cxM.beginPath(); cxM.moveTo(x,0); cxM.lineTo(x,H); cxM.stroke(); }
    // Grid 2: rotated
    cxM.save();
    cxM.translate(W/2,H/2); cxM.rotate(ang);
    cxM.strokeStyle='rgba(0,0,0,0.6)';
    for (var x=-W;x<W*2;x+=sp) { cxM.beginPath(); cxM.moveTo(x,-H); cxM.lineTo(x,H*2); cxM.stroke(); }
    cxM.restore();
  }

  function loop(now) {
    requestAnimationFrame(loop);
    var dt=Math.min((now-last)/1000,0.05); last=now;
    drawRiley(dt); drawVasarely(dt); drawCafe(dt);
    drawSpiral(dt); drawNeon(dt); drawMoire(dt);
  }
  loop(performance.now());
})();
</script>
<!-- ══════════════════════════════════════
     SECTION 5 — COLOR FIELD & MINIMALISM
══════════════════════════════════════ -->
<section id="color-field">
<div class="section-inner hidden">
<div class="sec-label">Chromatic Immersion &amp; Systematic Order</div>
<h2>Color Field &amp; Minimalism</h2>
<p>Two poles of 1950s–60s abstraction: Rothko's luminous color-saturated fields versus LeWitt's instruction-based geometric systems.</p>
<div class="cf-layout">
<div class="cf-panel">
<h3>Rothko Generator</h3>
<canvas height="280" id="rothkoCanvas" style="width:100%;border-radius:8px;display:block;margin-bottom:0.75rem;" width="320"></canvas>
<div class="ctrl"><label>Zone 1 Hue</label><input id="rH1" max="360" min="0" type="range" value="270"/><span class="val-d" id="rH1V">270</span></div>
<div class="ctrl"><label>Zone 2 Hue</label><input id="rH2" max="360" min="0" type="range" value="20"/><span class="val-d" id="rH2V">20</span></div>
<div class="ctrl"><label>Zone 3 Hue</label><input id="rH3" max="360" min="0" type="range" value="200"/><span class="val-d" id="rH3V">200</span></div>
<div class="ctrl"><label>Edge Softness</label><input id="rSoft" max="80" min="5" type="range" value="38"/><span class="val-d" id="rSoftV">38</span></div>
<div class="toolbar" style="margin-top:0.5rem;">
<button class="btn" id="rothkoNew">New Palette</button>
</div>
</div>
<div class="cf-panel">
<h3>LeWitt Grid System</h3>
<canvas height="280" id="lewittCanvas" style="width:100%;border-radius:8px;display:block;margin-bottom:0.75rem;background:#fff;" width="320"></canvas>
<div class="ctrl"><label>Grid Size</label><input id="lwGrid" max="12" min="1" step="1" type="range" value="6"/><span class="val-d" id="lwGridV">6</span></div>
<div class="ctrl"><label>Line Dir</label><input id="lwDir" max="3" min="0" step="1" type="range" value="1"/><span class="val-d" id="lwDirV">H</span></div>
<div class="ctrl"><label>Density</label><input id="lwDens" max="10" min="1" type="range" value="4"/><span class="val-d" id="lwDensV">4</span></div>
<div id="lwInstruction" style="font-size:0.72rem;color:var(--text-muted);margin-top:0.5rem;"></div>
</div>
</div>
</div>
</section>
<script>
(function() {
  // ── ROTHKO ──────────────────────────────────────
  var rcv = document.getElementById('rothkoCanvas');
  var rcx = rcv.getContext('2d');
  var W=320, H=280;
  var rH1=new LagFilter(270,0.6), rH2=new LagFilter(20,0.6), rH3=new LagFilter(200,0.6);
  var rSoft=new LagFilter(38,0.5);
  var breathe1=new LagFilter(50,1.8), breathe2=new LagFilter(50,1.8);
  var tH1=270, tH2=20, tH3=200, tSoft=38;
  // Breathe targets
  var bTgt1=50, bTgt2=50;

  function wire(id,valId,cb,fmt) {
    var sl=document.getElementById(id), vd=document.getElementById(valId);
    sl.addEventListener('input', function(){ cb(+sl.value); vd.textContent=fmt?((+sl.value).toFixed(fmt)):sl.value; });
  }
  wire('rH1','rH1V', function(v){tH1=v;});
  wire('rH2','rH2V', function(v){tH2=v;});
  wire('rH3','rH3V', function(v){tH3=v;});
  wire('rSoft','rSoftV', function(v){tSoft=v;});

  document.getElementById('rothkoNew').addEventListener('click', function() {
    tH1=Math.random()*360; tH2=Math.random()*360; tH3=Math.random()*360;
    document.getElementById('rH1').value=Math.round(tH1); document.getElementById('rH1V').textContent=Math.round(tH1);
    document.getElementById('rH2').value=Math.round(tH2); document.getElementById('rH2V').textContent=Math.round(tH2);
    document.getElementById('rH3').value=Math.round(tH3); document.getElementById('rH3V').textContent=Math.round(tH3);
  });

  function drawRothko(dt) {
    rH1.update(tH1,dt); rH2.update(tH2,dt); rH3.update(tH3,dt); rSoft.update(tSoft,dt);
    // Breathe
    bTgt1=50+35*Math.sin(Date.now()*0.0004); bTgt2=50+35*Math.cos(Date.now()*0.00035);
    breathe1.update(bTgt1,dt); breathe2.update(bTgt2,dt);
    var h1=rH1.val, h2=rH2.val, h3=rH3.val, soft=rSoft.val;
    var s1=Math.round(breathe1.val), s2=Math.round(breathe2.val);
    // Background
    rcx.fillStyle='hsl('+h1+',55%,22%)'; rcx.fillRect(0,0,W,H);
    // Zone 1 — top rectangle
    var g1=rcx.createLinearGradient(0,10,0,H*0.42);
    g1.addColorStop(0,'hsla('+h1+',60%,45%,0)');
    g1.addColorStop(soft/100,'hsla('+h2+','+s1+'%,52%,0.9)');
    g1.addColorStop(1-soft/100,'hsla('+h2+','+s1+'%,52%,0.9)');
    g1.addColorStop(1,'hsla('+h1+',60%,45%,0)');
    rcx.fillStyle=g1; rcx.fillRect(0,0,W,H*0.45);
    // Zone 2 — bottom rectangle
    var g2=rcx.createLinearGradient(0,H*0.55,0,H-10);
    g2.addColorStop(0,'hsla('+h3+',65%,40%,0)');
    g2.addColorStop(soft/100,'hsla('+h3+','+s2+'%,48%,0.88)');
    g2.addColorStop(1-soft/100,'hsla('+h3+','+s2+'%,48%,0.88)');
    g2.addColorStop(1,'hsla('+h3+',65%,40%,0)');
    rcx.fillStyle=g2; rcx.fillRect(0,H*0.52,W,H*0.48);
    // Luminous inner glow
    var glow=rcx.createRadialGradient(W/2,H/2,0,W/2,H/2,W*0.45);
    glow.addColorStop(0,'hsla('+h2+',80%,70%,0.12)');
    glow.addColorStop(1,'transparent');
    rcx.fillStyle=glow; rcx.fillRect(0,0,W,H);
  }

  // ── LEWITT ──────────────────────────────────────
  var lcv=document.getElementById('lewittCanvas'), lcx=lcv.getContext('2d');
  var LW=320,LH=280;
  var lwGrid=new LagFilter(6,0.3), lwDens=new LagFilter(4,0.3);
  var tLwGrid=6, tLwDir=1, tLwDens=4;
  var DIRS=['Vertical','Horizontal','Diagonal','Cross'];

  wire('lwGrid','lwGridV', function(v){tLwGrid=v;});
  wire('lwDens','lwDensV', function(v){tLwDens=v;});
  document.getElementById('lwDir').addEventListener('input', function() {
    tLwDir=+this.value;
    document.getElementById('lwDirV').textContent=['V','H','D','X'][tLwDir];
    updateInstruction();
  });

  function updateInstruction() {
    var g=Math.round(tLwGrid), d=DIRS[tLwDir], dens=Math.round(tLwDens);
    document.getElementById('lwInstruction').innerHTML =
      '<em>Instruction:</em> Draw a '+g+'x'+g+' grid. In each cell draw '+dens+' '+d.toLowerCase()+' lines evenly spaced within the cell boundary.';
  }
  updateInstruction();

  function drawLeWitt(dt) {
    lwGrid.update(tLwGrid,dt); lwDens.update(tLwDens,dt);
    var n=Math.max(1,Math.round(lwGrid.val)), d=Math.max(1,Math.round(lwDens.val));
    lcx.fillStyle='#f5f5f0'; lcx.fillRect(0,0,LW,LH);
    var cw=LW/n, ch=LH/n;
    lcx.strokeStyle='#1e1b4b'; lcx.lineWidth=0.9;
    for (var r=0;r<n;r++) {
      for (var c=0;c<n;c++) {
        var x0=c*cw, y0=r*ch;
        // Cell border
        lcx.strokeStyle='#ccc'; lcx.lineWidth=0.5;
        lcx.strokeRect(x0,y0,cw,ch);
        lcx.strokeStyle='#1e1b4b'; lcx.lineWidth=0.9;
        // Lines inside cell
        for (var i=1;i<=d;i++) {
          var frac=i/(d+1);
          if (tLwDir===0) { // vertical
            lcx.beginPath(); lcx.moveTo(x0+cw*frac,y0+1); lcx.lineTo(x0+cw*frac,y0+ch-1); lcx.stroke();
          } else if (tLwDir===1) { // horizontal
            lcx.beginPath(); lcx.moveTo(x0+1,y0+ch*frac); lcx.lineTo(x0+cw-1,y0+ch*frac); lcx.stroke();
          } else if (tLwDir===2) { // diagonal
            lcx.beginPath(); lcx.moveTo(x0+cw*frac,y0); lcx.lineTo(x0+cw*(frac-0.5)+cw,y0+ch); lcx.stroke();
          } else { // cross
            lcx.beginPath(); lcx.moveTo(x0+cw*frac,y0+1); lcx.lineTo(x0+cw*frac,y0+ch-1); lcx.stroke();
            lcx.beginPath(); lcx.moveTo(x0+1,y0+ch*frac); lcx.lineTo(x0+cw-1,y0+ch*frac); lcx.stroke();
          }
        }
      }
    }
  }

  var last=performance.now();
  function loop(now) {
    requestAnimationFrame(loop);
    var dt=Math.min((now-last)/1000,0.05); last=now;
    drawRothko(dt); drawLeWitt(dt);
  }
  loop(performance.now());
})();
</script>
<!-- ══════════════════════════════════════
     SECTION 6 — ABSTRACT EXPRESSIONISM TOOLS
══════════════════════════════════════ -->
<section id="abstract-expressionism">
<div class="section-inner hidden">
<div class="sec-label">Expressive Mark-Making</div>
<h2>Abstract Expressionism Tools</h2>
<p>Three expressive tools drawn from the New York School — drip painting, gestural brushwork, and soft color washes. Select a tool and paint directly on the canvas.</p>
<div class="ae-toolbar">
<button class="btn act" id="aeDrip">Drip / Pollock</button>
<button class="btn" id="aeBrush">Gestural / de Kooning</button>
<button class="btn" id="aeWash">Color Wash / Rothko</button>
<button class="btn" id="aeReset">Clear Canvas</button>
</div>
<canvas height="420" id="aeCanvas" width="780"></canvas>
<p style="margin-top:0.5rem;font-size:0.78rem;"><em>Drip:</em> click-drag fast to fling paint. <em>Gestural:</em> drag — fast=thin, slow=thick bristles. <em>Wash:</em> click to pour a soft color zone.</p>
</div>
</section>
<script>
(function() {
  var cv=document.getElementById('aeCanvas'), cx=cv.getContext('2d');
  var W=780,H=420;
  cx.fillStyle='#f5f5f0'; cx.fillRect(0,0,W,H);

  var tool='drip';
  var painting=false, lastX=0, lastY=0, lastT=0;
  var pressure=new LagFilter(8,0.12);  // LagFilter for brush pressure
  var vx=new LagFilter(0,0.08), vy=new LagFilter(0,0.08); // velocity smoothing
  var drip_hue=new LagFilter(0,0.5);   // LagFilter for drip hue cycling

  var DRIP_PALETTE=['#f59e0b','#ef4444','#7c3aed','#3b82f6','#22c55e','#ec4899','#111111','#f97316'];
  var EXP_PALETTE=['#7c3aed','#f59e0b','#ef4444','#3b82f6','#22c55e','#f97316','#ec4899','#14b8a6'];
  var currentColor=DRIP_PALETTE[0];
  var colorIdx=0;
  var washHue=new LagFilter(270,0.8); // LagFilter for wash hue
  var tWashHue=270;

  function getPos(e) {
    var r=cv.getBoundingClientRect();
    var src=e.touches?e.touches[0]:e;
    return {x:(src.clientX-r.left)*(W/r.width), y:(src.clientY-r.top)*(H/r.height)};
  }

  function startPaint(e) {
    e.preventDefault(); painting=true;
    var p=getPos(e); lastX=p.x; lastY=p.y; lastT=performance.now();
    colorIdx=(colorIdx+1)%DRIP_PALETTE.length;
    if (tool==='drip') currentColor=DRIP_PALETTE[colorIdx];
    else if (tool==='brush') currentColor=EXP_PALETTE[colorIdx];
    else {
      tWashHue=(tWashHue+47)%360;
      doWash(p.x,p.y);
    }
  }
  function doPaint(e) {
    if (!painting||tool==='wash') return;
    e.preventDefault();
    var p=getPos(e); var now=performance.now();
    var dt=(now-lastT)/1000; lastT=now;
    var dvx=(p.x-lastX)/(dt+0.001), dvy=(p.y-lastY)/(dt+0.001);
    vx.update(dvx,dt); vy.update(dvy,dt);
    var speed=Math.sqrt(vx.val*vx.val+vy.val*vy.val);

    if (tool==='drip') {
      doDrip(p.x,p.y,speed,dvx,dvy);
    } else if (tool==='brush') {
      doGesture(lastX,lastY,p.x,p.y,speed,dt);
    }
    lastX=p.x; lastY=p.y;
  }
  function stopPaint() { painting=false; }

  cv.addEventListener('mousedown', startPaint);
  cv.addEventListener('mousemove', doPaint);
  window.addEventListener('mouseup', stopPaint);
  cv.addEventListener('touchstart', startPaint, {passive:false});
  cv.addEventListener('touchmove', doPaint, {passive:false});
  cv.addEventListener('touchend', stopPaint);

  function doDrip(x,y,speed,dvx,dvy) {
    // Main drop
    cx.beginPath();
    cx.arc(x,y,2+Math.random()*3,0,Math.PI*2);
    cx.fillStyle=currentColor;
    cx.globalAlpha=0.85+Math.random()*0.15;
    cx.fill();
    // Splatter at high speed
    if (speed>200) {
      var splats=Math.floor(speed/120);
      for (var i=0;i<splats;i++) {
        var ang=Math.atan2(dvy,dvx)+(Math.random()-0.5)*1.2;
        var dist=20+Math.random()*speed*0.04;
        cx.beginPath();
        cx.arc(x+Math.cos(ang)*dist, y+Math.sin(ang)*dist, 0.8+Math.random()*2.5, 0, Math.PI*2);
        cx.globalAlpha=0.5+Math.random()*0.4;
        cx.fill();
      }
    }
    // Drip line
    cx.beginPath(); cx.moveTo(x,y);
    cx.lineTo(x+(dvx/(speed+1))*15, y+(dvy/(speed+1))*15);
    cx.strokeStyle=currentColor; cx.lineWidth=1.5+Math.random()*2;
    cx.globalAlpha=0.6; cx.stroke();
    cx.globalAlpha=1;
  }

  function doGesture(x1,y1,x2,y2,speed,dt) {
    // LagFiltered pressure: fast=thin, slow=thick
    var targetW=Math.max(2, 28-(speed/60));
    pressure.update(targetW, dt);
    var bristles=Math.ceil(pressure.val/3);
    cx.globalAlpha=0.72;
    for (var i=0;i<bristles;i++) {
      var off=(i-bristles/2)*(pressure.val/bristles)*0.9;
      var perpX=-(y2-y1)/(Math.sqrt((x2-x1)*(x2-x1)+(y2-y1)*(y2-y1))+0.01);
      var perpY=(x2-x1)/(Math.sqrt((x2-x1)*(x2-x1)+(y2-y1)*(y2-y1))+0.01);
      cx.beginPath();
      cx.moveTo(x1+perpX*off, y1+perpY*off);
      cx.lineTo(x2+perpX*off+Math.random()*2-1, y2+perpY*off+Math.random()*2-1);
      cx.strokeStyle=currentColor;
      cx.lineWidth=Math.max(0.5, pressure.val/bristles*0.8);
      cx.lineCap='round'; cx.stroke();
    }
    cx.globalAlpha=1;
  }

  var washHueAnim=new LagFilter(270,0.6);
  function doWash(x,y) {
    washHue.update(tWashHue, 0.3);
    var h=tWashHue;
    var r=80+Math.random()*60;
    var g=cx.createRadialGradient(x,y,0,x,y,r);
    g.addColorStop(0,'hsla('+h+',70%,55%,0.55)');
    g.addColorStop(0.5,'hsla('+h+',60%,45%,0.3)');
    g.addColorStop(1,'transparent');
    cx.globalCompositeOperation='multiply';
    cx.fillStyle=g; cx.fillRect(x-r,y-r,r*2,r*2);
    cx.globalCompositeOperation='source-over';
  }

  document.getElementById('aeDrip').addEventListener('click', function(){ tool='drip'; updateAeBtns(); });
  document.getElementById('aeBrush').addEventListener('click', function(){ tool='brush'; updateAeBtns(); });
  document.getElementById('aeWash').addEventListener('click', function(){ tool='wash'; updateAeBtns(); });
  document.getElementById('aeReset').addEventListener('click', function(){
    cx.fillStyle='#f5f5f0'; cx.fillRect(0,0,W,H);
  });
  function updateAeBtns() {
    [['aeDrip','drip'],['aeBrush','brush'],['aeWash','wash']].forEach(function(p){
      document.getElementById(p[0]).classList.toggle('act',tool===p[1]);
    });
  }
})();
</script>
<!-- ══════════════════════════════════════
     SECTION 7 — GENERATIVE ABSTRACTION
══════════════════════════════════════ -->
<section id="generative">
<div class="section-inner hidden">
<div class="sec-label">Algorithmic &amp; Systematic Art</div>
<h2>Generative Abstraction</h2>
<p>Three algorithmic systems that generate abstract compositions through rules, mathematics, and recursive logic.</p>
<div class="gen-tabs">
<button class="btn act" id="genT0">Rule-Based</button>
<button class="btn" id="genT1">Strange Attractors</button>
<button class="btn" id="genT2">Recursive Subdivision</button>
</div>
<!-- Panel 0: Rule-Based -->
<div class="gen-panel act" id="genP0">
<canvas height="360" id="genRuleCanvas" style="width:100%;border-radius:8px;border:1px solid rgba(167,139,250,0.3);display:block;" width="700"></canvas>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem 2rem;margin-top:0.75rem;">
<div class="ctrl"><label>N Circles</label><input id="grCircles" max="60" min="0" type="range" value="30"/><span class="val-d" id="grCirclesV">30</span></div>
<div class="ctrl"><label>Connect Nth</label><input id="grConnect" max="30" min="0" type="range" value="8"/><span class="val-d" id="grConnectV">8</span></div>
<div class="ctrl"><label>Subdivide Thresh</label><input id="grSubdiv" max="50000" min="500" type="range" value="12000"/><span class="val-d" id="grSubdivV">12000</span></div>
<div class="ctrl"><label>Color Spread</label><input id="grSpread" max="360" min="10" type="range" value="120"/><span class="val-d" id="grSpreadV">120</span></div>
</div>
<button class="btn" id="grRegen" style="margin-top:0.5rem;">Regenerate</button>
</div>
<!-- Panel 1: Strange Attractors -->
<div class="gen-panel" id="genP1">
<canvas height="380" id="genAttrCanvas" style="width:100%;border-radius:8px;border:1px solid rgba(167,139,250,0.3);display:block;" width="700"></canvas>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem 2rem;margin-top:0.75rem;">
<div class="ctrl"><label>a</label><input id="gaA" max="3" min="-3" step="0.01" type="range" value="-1.7"/><span class="val-d" id="gaAV">-1.7</span></div>
<div class="ctrl"><label>b</label><input id="gaB" max="3" min="-3" step="0.01" type="range" value="1.3"/><span class="val-d" id="gaBV">1.3</span></div>
<div class="ctrl"><label>c</label><input id="gaC" max="3" min="-3" step="0.01" type="range" value="0.5"/><span class="val-d" id="gaCV">0.5</span></div>
<div class="ctrl"><label>d</label><input id="gaD" max="3" min="-3" step="0.01" type="range" value="-1.2"/><span class="val-d" id="gaDV">-1.2</span></div>
</div>
<div class="toolbar" style="margin-top:0.5rem;">
<button class="btn act" id="gaClifford">Clifford</button>
<button class="btn" id="gaPeterDeJong">Peter de Jong</button>
</div>
</div>
<!-- Panel 2: Recursive Subdivision -->
<div class="gen-panel" id="genP2">
<canvas height="380" id="genRecCanvas" style="width:100%;border-radius:8px;border:1px solid rgba(167,139,250,0.3);display:block;" width="700"></canvas>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem 2rem;margin-top:0.75rem;">
<div class="ctrl"><label>Depth</label><input id="grDepth" max="8" min="1" step="1" type="range" value="4"/><span class="val-d" id="grDepthV">4</span></div>
<div class="ctrl"><label>Base Hue</label><input id="grHue" max="360" min="0" type="range" value="270"/><span class="val-d" id="grHueV">270</span></div>
</div>
<button class="btn" id="grRecRegen" style="margin-top:0.5rem;">Regenerate</button>
</div>
</div>
</section>
<script>
(function() {
  var panels=['genP0','genP1','genP2'], tabs=['genT0','genT1','genT2'];
  tabs.forEach(function(tid,i) {
    document.getElementById(tid).addEventListener('click', function() {
      panels.forEach(function(pid,j){ document.getElementById(pid).classList.toggle('act',j===i); });
      tabs.forEach(function(t,j){ document.getElementById(t).classList.toggle('act',j===i); });
    });
  });

  // ── PANEL 0: RULE-BASED ─────────────────────────
  var rcv=document.getElementById('genRuleCanvas'), rcx=rcv.getContext('2d');
  var RW=700,RH=360;
  var rCircles=new LagFilter(30,0.4), rConnect=new LagFilter(8,0.4);
  var rSubdiv=new LagFilter(12000,0.4), rSpread=new LagFilter(120,0.4);
  var tRCircles=30, tRConnect=8, tRSubdiv=12000, tRSpread=120;

  function wireG(id,valId,setter,fmt) {
    var sl=document.getElementById(id), vd=document.getElementById(valId);
    sl.addEventListener('input', function(){ setter(+sl.value); vd.textContent=fmt?(+sl.value).toFixed(fmt):sl.value; });
  }
  wireG('grCircles','grCirclesV',function(v){tRCircles=v;});
  wireG('grConnect','grConnectV',function(v){tRConnect=v;});
  wireG('grSubdiv','grSubdivV',function(v){tRSubdiv=v;});
  wireG('grSpread','grSpreadV',function(v){tRSpread=v;});

  var rulePoints=[];
  function regenRule() {
    rulePoints=[];
    var n=Math.round(tRCircles);
    for (var i=0;i<n;i++) {
      rulePoints.push({x:40+Math.random()*(RW-80), y:40+Math.random()*(RH-80), r:8+Math.random()*30});
    }
  }
  regenRule();
  document.getElementById('grRegen').addEventListener('click', regenRule);

  var lastR=performance.now();
  function drawRule(now) {
    if (document.getElementById('genP0').classList.contains('act')) requestAnimationFrame(drawRule);
    var dt=Math.min((now-lastR)/1000,0.05); lastR=now;
    rCircles.update(tRCircles,dt); rConnect.update(tRConnect,dt);
    rSubdiv.update(tRSubdiv,dt); rSpread.update(tRSpread,dt);
    rcx.fillStyle='#1e1b4b'; rcx.fillRect(0,0,RW,RH);
    var n=Math.min(rulePoints.length, Math.round(rCircles.val));
    var hueBase=270, spread=rSpread.val;
    // Rule 1: Draw N circles
    for (var i=0;i<n;i++) {
      var p=rulePoints[i], hue=(hueBase+i/n*spread)%360;
      rcx.beginPath(); rcx.arc(p.x,p.y,p.r,0,Math.PI*2);
      rcx.strokeStyle='hsl('+hue+',80%,65%)'; rcx.lineWidth=1.2; rcx.globalAlpha=0.6; rcx.stroke();
      rcx.globalAlpha=0.1; rcx.fillStyle='hsl('+hue+',60%,50%)'; rcx.fill(); rcx.globalAlpha=1;
    }
    // Rule 2: Connect every Nth point
    var step=Math.max(1,Math.round(rConnect.val));
    rcx.strokeStyle='rgba(167,139,250,0.35)'; rcx.lineWidth=0.8;
    for (var i=0;i<n-step;i+=step) {
      rcx.beginPath(); rcx.moveTo(rulePoints[i].x,rulePoints[i].y);
      rcx.lineTo(rulePoints[i+step].x,rulePoints[i+step].y); rcx.stroke();
    }
    // Rule 3: Subdivide rects with area > threshold
    var thresh=rSubdiv.val;
    rcx.strokeStyle='rgba(245,158,11,0.2)'; rcx.lineWidth=0.6;
    function subdivide(x,y,w,h,depth) {
      if (depth>4||w*h<thresh) return;
      var phi=0.618;
      if (w>h) {
        var sp=w*phi; rcx.beginPath(); rcx.moveTo(x+sp,y); rcx.lineTo(x+sp,y+h); rcx.stroke();
        subdivide(x,y,sp,h,depth+1); subdivide(x+sp,y,w-sp,h,depth+1);
      } else {
        var sp=h*phi; rcx.beginPath(); rcx.moveTo(x,y+sp); rcx.lineTo(x+w,y+sp); rcx.stroke();
        subdivide(x,y,w,sp,depth+1); subdivide(x,y+sp,w,h-sp,depth+1);
      }
    }
    subdivide(0,0,RW,RH,0);
  }
  drawRule(performance.now());

  // ── PANEL 1: STRANGE ATTRACTORS ─────────────────
  var acv=document.getElementById('genAttrCanvas'), acx=acv.getContext('2d');
  var AW=700,AH=380;
  var aA=new LagFilter(-1.7,0.6), aB=new LagFilter(1.3,0.6);
  var aC=new LagFilter(0.5,0.6), aD=new LagFilter(-1.2,0.6);
  var tA=-1.7, tB=1.3, tC=0.5, tD=-1.2;
  var attrType='clifford';
  wireG('gaA','gaAV',function(v){tA=v;},2);
  wireG('gaB','gaBV',function(v){tB=v;},2);
  wireG('gaC','gaCV',function(v){tC=v;},2);
  wireG('gaD','gaDV',function(v){tD=v;},2);
  document.getElementById('gaClifford').addEventListener('click',function(){attrType='clifford'; this.classList.add('act'); document.getElementById('gaPeterDeJong').classList.remove('act');});
  document.getElementById('gaPeterDeJong').addEventListener('click',function(){attrType='pdj'; this.classList.add('act'); document.getElementById('gaClifford').classList.remove('act');});

  // Off-screen for accumulation
  var offscr=document.createElement('canvas'); offscr.width=AW; offscr.height=AH;
  var offcx=offscr.getContext('2d');
  offcx.fillStyle='#0a0814'; offcx.fillRect(0,0,AW,AH);
  var ax=0.1, ay=0.1;
  var lastPrms={a:tA,b:tB,c:tC,d:tD,type:attrType};

  function resetAttractor() {
    offcx.fillStyle='#0a0814'; offcx.fillRect(0,0,AW,AH);
    ax=0.1; ay=0.1;
  }

  var lastA=performance.now();
  function drawAttractor(now) {
    if (document.getElementById('genP1').classList.contains('act')) requestAnimationFrame(drawAttractor);
    else { lastA=now; return; }
    var dt=Math.min((now-lastA)/1000,0.05); lastA=now;
    var ca=aA.update(tA,dt), cb=aB.update(tB,dt), cc=aC.update(tC,dt), cd=aD.update(tD,dt);
    if (lastPrms.a!==tA||lastPrms.b!==tB||lastPrms.c!==tC||lastPrms.d!==tD||lastPrms.type!==attrType) {
      resetAttractor(); lastPrms={a:tA,b:tB,c:tC,d:tD,type:attrType};
    }
    var steps=8000;
    offcx.globalAlpha=0.55;
    for (var i=0;i<steps;i++) {
      var nx,ny;
      if (attrType==='clifford') {
        nx=Math.sin(ca*ay)+cc*Math.cos(ca*ax);
        ny=Math.sin(cb*ax)+cd*Math.cos(cb*ay);
      } else {
        nx=Math.sin(ca*ay)-Math.cos(cb*ax);
        ny=Math.sin(cc*ax)-Math.cos(cd*ay);
      }
      ax=nx; ay=ny;
      var px=Math.round((ax+3)/6*AW), py=Math.round((ay+3)/6*AH);
      if (px<0||px>=AW||py<0||py>=AH) continue;
      var hue=(i/steps*360)%360;
      offcx.fillStyle='hsl('+hue+',85%,65%)';
      offcx.fillRect(px,py,1,1);
    }
    offcx.globalAlpha=1;
    acx.drawImage(offscr,0,0);
  }
  document.getElementById('genT1').addEventListener('click', function() { drawAttractor(performance.now()); });
  // Auto-start if tab is active
  setTimeout(function(){ if(document.getElementById('genP1').classList.contains('act')) drawAttractor(performance.now()); }, 100);

  // ── PANEL 2: RECURSIVE SUBDIVISION ──────────────
  var rrcv=document.getElementById('genRecCanvas'), rrcx=rrcv.getContext('2d');
  var RRW=700,RRH=380;
  var rrDepth=new LagFilter(4,0.4), rrHue=new LagFilter(270,0.4);
  var tRRDepth=4, tRRHue=270;
  wireG('grDepth','grDepthV',function(v){tRRDepth=v;});
  wireG('grHue','grHueV',function(v){tRRHue=v;});

  var recSeed=Math.random();
  document.getElementById('grRecRegen').addEventListener('click',function(){recSeed=Math.random(); drawRecursive();});

  function seededRand(seed) {
    var x=Math.sin(seed+1)*10000; return x-Math.floor(x);
  }

  function drawRecursive() {
    rrDepth.update(tRRDepth,0.3); rrHue.update(tRRHue,0.3);
    rrcx.fillStyle='#1e1b4b'; rrcx.fillRect(0,0,RRW,RRH);
    var maxDepth=Math.round(rrDepth.val), baseHue=rrHue.val;
    var counter={n:0};
    function subDiv(x,y,w,h,depth,hueOffset) {
      if (depth>=maxDepth||w<4||h<4) {
        var hue=(baseHue+hueOffset)%360;
        var light=35+depth*7;
        rrcx.fillStyle='hsl('+hue+',65%,'+light+'%)';
        rrcx.fillRect(x+1,y+1,w-2,h-2);
        return;
      }
      var phi=0.618;
      var sr=seededRand(recSeed*100+counter.n++);
      if (w>h) {
        var sp=sr<0.5?(w*phi):(w*(1-phi));
        subDiv(x,y,sp,h,depth+1,hueOffset+15);
        subDiv(x+sp,y,w-sp,h,depth+1,hueOffset+35);
      } else {
        var sp=sr<0.5?(h*phi):(h*(1-phi));
        subDiv(x,y,w,sp,depth+1,hueOffset+25);
        subDiv(x,y+sp,w,h-sp,depth+1,hueOffset+10);
      }
      rrcx.strokeStyle='rgba(30,27,75,0.7)'; rrcx.lineWidth=1;
      rrcx.strokeRect(x,y,w,h);
    }
    subDiv(0,0,RRW,RRH,0,0);
  }
  drawRecursive();

  document.getElementById('genT2').addEventListener('click', drawRecursive);
  document.getElementById('grDepth').addEventListener('input', drawRecursive);
  document.getElementById('grHue').addEventListener('input', drawRecursive);

  // Resume rule-based anim on tab switch
  document.getElementById('genT0').addEventListener('click', function() { drawRule(performance.now()); });
})();
</script>
