        for(var i=0;i<200;i++){var ang=i*2.399+t*0.1;var r=Math.sqrt(i)*15;var x=250+r*Math.cos(ang);var y=140+r*Math.sin(ang)*0.7;if(x<0||x>500||y<0||y>280)continue;var hue=(i*11+t*20)%360;cx.fillStyle='hsl('+hue+',80%,65%)';cx.fillRect(x-2,y-2,4,4);}
        // Squares with noise
        cx.strokeStyle='rgba(167,139,250,0.4)'; cx.lineWidth=1;
        for(var i=0;i<12;i++){var s=20+i*18;var noise=5*Math.sin(t+i);cx.strokeRect(250-s/2+noise,140-s*0.36+noise,s,s*0.72);}
      }
    }
  ];

  var grid=document.getElementById('artistsGrid');
  var modal=document.getElementById('artistModal');
  var modalTitle=document.getElementById('modalTitle');
  var modalDesc=document.getElementById('modalDesc');
  var modalCanvas=document.getElementById('modalCanvas');
  var modalApproach=document.getElementById('modalApproach');
  var mcx=modalCanvas.getContext('2d');
  var demoRaf=null;

  ARTISTS.forEach(function(a,i) {
    // Create avatar canvas
    var ac=document.createElement('canvas'); ac.width=76; ac.height=76; ac.className='artist-avatar';
    var actx=ac.getContext('2d'); a.avatar(ac,actx);

    var card=document.createElement('div'); card.className='artist-card';
    card.innerHTML='<div class="a-name">'+a.name+'</div><div class="a-era">'+a.era+'</div><div class="a-move">'+a.move+'</div><div class="a-works">'+a.works+'</div><button class="btn demo-btn" data-idx="'+i+'" style="margin-top:0.7rem;font-size:0.72rem;">View Technique Demo</button>';
    card.insertBefore(ac, card.firstChild);
    grid.appendChild(card);
  });

  grid.addEventListener('click', function(e) {
    var btn=e.target.closest('[data-idx]');
    if (!btn) return;
    var a=ARTISTS[+btn.dataset.idx];
    modalTitle.textContent=a.name;
    modalDesc.textContent=a.era+' · '+a.move;
    modalApproach.textContent=a.approach;
    modal.classList.add('open');
    if (demoRaf) cancelAnimationFrame(demoRaf);
    function runDemo() { a.demo(modalCanvas,mcx); demoRaf=requestAnimationFrame(runDemo); }
    runDemo();
  });

  document.getElementById('modalClose').addEventListener('click', function() {
    modal.classList.remove('open');
    if (demoRaf) { cancelAnimationFrame(demoRaf); demoRaf=null; }
  });
  modal.addEventListener('click', function(e) {
    if (e.target===modal) { modal.classList.remove('open'); if(demoRaf){cancelAnimationFrame(demoRaf);demoRaf=null;} }
  });
})();
</script>
<!-- ══════════════════════════════════════
     SECTION 9 — GLOSSARY
══════════════════════════════════════ -->
<section id="glossary">
<div class="section-inner hidden">
<div class="sec-label">Key Terms &amp; Concepts</div>
<h2>Glossary of Abstraction</h2>
<p>Core vocabulary for understanding non-representational art — from formal elements to philosophical underpinnings.</p>
<div class="gloss-grid">
<div class="g-item"><div class="g-term">Abstraction</div><p class="g-def">The process of departing from literal representation toward pure form, color, and line — reducing or eliminating reference to the visible world.</p></div>
<div class="g-item"><div class="g-term">Color Field</div><p class="g-def">A style in which large areas of flat, resonant color fill the canvas to create immersive chromatic experience. Associated with Rothko, Newman, Frankenthaler.</p></div>
<div class="g-item"><div class="g-term">Composition</div><p class="g-def">The deliberate arrangement of visual elements — shape, color, line, space — within the picture plane to create unity and meaning.</p></div>
<div class="g-item"><div class="g-term">Concrete Art</div><p class="g-def">Art composed entirely of invented visual elements with no reference to natural forms, coined by Theo van Doesburg. Max Bill was its foremost practitioner.</p></div>
<div class="g-item"><div class="g-term">De Stijl</div><p class="g-def">Dutch movement (1917–1931) led by Mondrian and Van Doesburg, restricting visual language to horizontal/vertical lines and primary colors plus black and white.</p></div>
<div class="g-item"><div class="g-term">Expressionism</div><p class="g-def">Art that prioritizes subjective emotional response over objective depiction, using distortion, heightened color, and gestural marks to convey inner states.</p></div>
<div class="g-item"><div class="g-term">Form</div><p class="g-def">A bounded area or three-dimensional shape within a composition. In abstraction, form is the primary carrier of meaning independent of any object it might resemble.</p></div>
<div class="g-item"><div class="g-term">Gestural</div><p class="g-def">Mark-making that preserves the physical evidence of the artist's movement — brushstroke speed, pressure, and direction remain visible as expressive content.</p></div>
<div class="g-item"><div class="g-term">Geometric</div><p class="g-def">Abstraction using precise mathematical forms — circles, squares, triangles, lines — often derived from tools rather than hand gesture. De Stijl, Suprematism, Op Art.</p></div>
<div class="g-item"><div class="g-term">Ground</div><p class="g-def">The background surface upon which marks are made. In abstract painting, the relationship between figure and ground can be intentionally ambiguous or reversed.</p></div>
<div class="g-item"><div class="g-term">Hue</div><p class="g-def">The pure spectral color (red, blue, yellow, violet) before modification by value or saturation. In color theory, hue is the first dimension of color identity.</p></div>
<div class="g-item"><div class="g-term">Kinetic Art</div><p class="g-def">Art incorporating actual or apparent movement. Op Art creates visual movement without physical motion through carefully calibrated optical conflicts.</p></div>
<div class="g-item"><div class="g-term">Luminosity</div><p class="g-def">The quality of appearing to emit light from within. Rothko achieved luminosity through translucent paint layers; color field artists pursued it as primary goal.</p></div>
<div class="g-item"><div class="g-term">Minimalism</div><p class="g-def">Reduction to the absolute essentials of form and material, eliminating personal expression. Judd, Andre, Flavin used industrial materials in serial arrangements.</p></div>
<div class="g-item"><div class="g-term">Moiré</div><p class="g-def">An interference pattern created when two repetitive grids or patterns overlap at a slight angle, producing a larger-scale emergent optical pattern.</p></div>
<div class="g-item"><div class="g-term">Non-Objective</div><p class="g-def">Art with no reference to observable reality whatsoever — stricter than "abstract," which may retain some naturalistic origin. Malevich's Suprematism was fully non-objective.</p></div>
<div class="g-item"><div class="g-term">Op Art</div><p class="g-def">Short for Optical Art — work that exploits visual perception to create apparent motion, three-dimensionality, or vibration through precise geometric patterning.</p></div>
<div class="g-item"><div class="g-term">Pictorial Space</div><p class="g-def">The illusion of depth or three-dimensional space within a two-dimensional work. Abstract artists may flatten, deny, or paradoxically intensify pictorial space.</p></div>
<div class="g-item"><div class="g-term">Plane</div><p class="g-def">A flat, two-dimensional surface element within a composition. Paul Cezanne's "passage" of interlocking planes was foundational for abstract art's development.</p></div>
<div class="g-item"><div class="g-term">Pure Abstraction</div><p class="g-def">Art in which visual elements function autonomously without reference to external reality — form and color as the sole subject matter and content.</p></div>
<div class="g-item"><div class="g-term">Saturation</div><p class="g-def">The intensity or purity of a hue — how far it is from gray. High saturation produces vivid, intense color; low saturation approaches neutral gray.</p></div>
<div class="g-item"><div class="g-term">Suprematism</div><p class="g-def">Movement founded by Malevich in 1915 reducing painting to pure geometric sensation — squares, circles, lines floating in white space with no narrative or object.</p></div>
<div class="g-item"><div class="g-term">Texture</div><p class="g-def">The surface quality of a work — actual physical texture from thick paint (impasto) or implied visual texture through mark density and variation.</p></div>
<div class="g-item"><div class="g-term">Value</div><p class="g-def">The lightness or darkness of a color. Value contrast creates form; in abstract art, value relationships are often more structurally important than hue choices.</p></div>
</div>
</div>
</section>
