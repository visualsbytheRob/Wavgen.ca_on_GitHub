  function showEra(idx) {
    if (activeIdx === idx) {
      detail.classList.remove('act');
      nodes.forEach(function(n){ n.classList.remove('act'); });
      activeIdx = -1;
      if (miniRaf) { cancelAnimationFrame(miniRaf); miniRaf = null; }
