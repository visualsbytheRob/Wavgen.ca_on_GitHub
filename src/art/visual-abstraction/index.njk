<section id="hero">
<canvas id="heroCanvas"></canvas>
<div class="hero-overlay">
<h1>Visual Abstraction</h1>
<p>Form liberated from representation</p>
</div>
</section>
<script>
// ── Global LagFilter class (used throughout) ──────
class LagFilter {
  constructor(init, tau) { this.val = init; this.tau = tau; }
  update(target, dt) {
    this.val += (1 - Math.exp(-dt / this.tau)) * (target - this.val);
    return this.val;
  }
}

// ── HERO ──────────────────────────────────────────
(function() {
  const cv = document.getElementById('heroCanvas');
  const cx = cv.getContext('2d');
  let W, H;
  const resize = () => { W = cv.width = cv.offsetWidth; H = cv.height = cv.offsetHeight; };
  resize();
  window.addEventListener('resize', resize);

  let mx = 200, my = 200;
  cv.addEventListener('mousemove', e => {
    const r = cv.getBoundingClientRect();
    mx = e.clientX - r.left; my = e.clientY - r.top;
  });

  const PAIRS = [
    ['#7c3aed','#f59e0b'],['#3b82f6','#f97316'],
    ['#ef4444','#22c55e'],['#a78bfa','#fde68a'],
    ['#ec4899','#10b981'],['#8b5cf6','#fbbf24']
  ];
  const TYPES = ['circle','triangle','arc','line','rect','diamond'];
  const rnd = (a,b) => a + Math.random()*(b-a);
  const pick = arr => arr[Math.floor(Math.random()*arr.length)];

  // 24 shapes, each with 5 LagFilter instances = 120 total, well over 15
  const shapes = Array.from({length: 24}, (_, i) => {
    const pair = pick(PAIRS);
    const sz = rnd(22, 68);
    return {
      type: pick(TYPES),
      x: rnd(0.04, 0.96), y: rnd(0.04, 0.96),
      vx: rnd(-7e-5, 7e-5), vy: rnd(-7e-5, 7e-5),
      sz, rot: rnd(0, Math.PI*2), rotV: rnd(-0.005, 0.005),
      color: pair[Math.floor(Math.random()*2)],
      alpha: rnd(0.38, 0.82),
      dispX: new LagFilter(0, 0.28),      // LagFilter #1 per shape
      dispY: new LagFilter(0, 0.28),      // LagFilter #2 per shape
      lSz:   new LagFilter(sz, 0.9),      // LagFilter #3 per shape
      lAlpha:new LagFilter(rnd(0.38,0.82), 1.1), // LagFilter #4
      lPulse:new LagFilter(0.5, 1.5),    // LagFilter #5
    };
  });

  function drawShape(s) {
    const x = s.x*W + s.dispX.val, y = s.y*H + s.dispY.val;
    const sz = Math.max(2, s.lSz.val);
    const al = Math.max(0, Math.min(1, s.lAlpha.val));
    cx.save();
    cx.globalAlpha = al;
    cx.strokeStyle = s.color; cx.fillStyle = s.color; cx.lineWidth = 2.2;
    cx.translate(x, y); cx.rotate(s.rot);
    if (s.type === 'circle') {
      cx.beginPath(); cx.arc(0,0,sz/2,0,Math.PI*2);
      cx.globalAlpha = al*0.22; cx.fill(); cx.globalAlpha = al; cx.stroke();
    } else if (s.type === 'triangle') {
      cx.beginPath(); cx.moveTo(0,-sz/2); cx.lineTo(sz/2,sz/2); cx.lineTo(-sz/2,sz/2); cx.closePath();
      cx.globalAlpha = al*0.2; cx.fill(); cx.globalAlpha = al; cx.stroke();
    } else if (s.type === 'arc') {
      cx.lineWidth = 2.5;
      cx.beginPath(); cx.arc(0,0,sz/2,0.2,Math.PI*1.5); cx.stroke();
      cx.beginPath(); cx.arc(0,0,sz/3.2,Math.PI*0.7,Math.PI*2.2); cx.stroke();
    } else if (s.type === 'line') {
      cx.lineWidth = 3;
      cx.beginPath(); cx.moveTo(-sz/2,0); cx.lineTo(sz/2,0); cx.stroke();
      cx.beginPath(); cx.moveTo(0,-sz*0.4); cx.lineTo(0,sz*0.4); cx.stroke();
      cx.lineWidth = 1.5;
      cx.beginPath(); cx.moveTo(-sz*0.3,-sz*0.3); cx.lineTo(sz*0.3,sz*0.3); cx.stroke();
    } else if (s.type === 'rect') {
      const w = sz, h = sz*0.62;
      cx.strokeRect(-w/2,-h/2,w,h);
      cx.globalAlpha = al*0.12; cx.fillRect(-w/2,-h/2,w,h);
    } else {
      cx.beginPath(); cx.moveTo(0,-sz/2); cx.lineTo(sz/2.4,0); cx.lineTo(0,sz/2); cx.lineTo(-sz/2.4,0); cx.closePath();
      cx.globalAlpha = al*0.18; cx.fill(); cx.globalAlpha = al; cx.stroke();
    }
    cx.restore();
  }

  let last = performance.now();
  function animate(now) {
    requestAnimationFrame(animate);
    const dt = Math.min((now-last)/1000, 0.05);
    last = now;
    // Phosphor persistence
    cx.fillStyle = 'rgba(5,5,12,0.04)';
    cx.fillRect(0,0,W,H);
    const t = now*0.001;
    shapes.forEach((s,i) => {
      s.x += s.vx; s.y += s.vy;
      if (s.x < 0) s.x=1; if (s.x>1) s.x=0;
      if (s.y < 0) s.y=1; if (s.y>1) s.y=0;
      s.rot += s.rotV;
      const sx=s.x*W, sy=s.y*H;
      const ddx=sx-mx, ddy=sy-my;
      const dist=Math.sqrt(ddx*ddx+ddy*ddy)+0.1;
      const rep = dist<140 ? (140-dist)/140 : 0;
      s.dispX.update(rep*(ddx/dist)*48, dt);
      s.dispY.update(rep*(ddy/dist)*48, dt);
      s.lSz.update(s.sz*(1+0.14*Math.sin(t+i*1.3)), dt);
      s.lAlpha.update(s.alpha*(0.78+0.22*Math.cos(t*0.9+i*0.7)), dt);
      s.lPulse.update(0.5+0.5*Math.sin(t*0.4+i), dt);
      drawShape(s);
    });
  }
  animate(performance.now());
})();
</script>
