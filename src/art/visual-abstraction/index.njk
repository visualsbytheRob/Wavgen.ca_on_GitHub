      draw:function(cv,cx){ var g=cx.createLinearGradient(0,0,200,0); g.addColorStop(0,'#7c3aed'); g.addColorStop(0.5,'#ec4899'); g.addColorStop(1,'#f59e0b'); cx.fillStyle=g; cx.fillRect(0,0,200,155); [{x:80,y:60,r:70,c:'#3b82f688'},{x:140,y:100,r:60,c:'#22c55e66'},{x:50,y:90,r:55,c:'#fde68a55'}].forEach(function(z){ var rg=cx.createRadialGradient(z.x,z.y,0,z.x,z.y,z.r); rg.addColorStop(0,z.c); rg.addColorStop(1,'transparent'); cx.fillStyle=rg; cx.fillRect(0,0,200,155); }); cx.strokeStyle='#fff'; cx.lineWidth=3; cx.beginPath(); cx.moveTo(105,0); cx.lineTo(105,155); cx.stroke(); }
    },
