      works:'Martin: Untitled #3 (1974). Richter: Abstract Painting 809-1 (1994). Basquiat: Horn Players (1983).',
      draw:function(cv,cx){ cx.fillStyle='#f8f8f5'; cx.fillRect(0,0,200,155); cx.strokeStyle='#ddd'; cx.lineWidth=0.7; for(var x=0;x<200;x+=8){ cx.beginPath(); cx.moveTo(x,0); cx.lineTo(x,155); cx.stroke(); } for(var y=0;y<155;y+=8){ cx.beginPath(); cx.moveTo(0,y); cx.lineTo(200,y); cx.stroke(); } [['#7c3aed99',0],['#f59e0b99',60],['#ef444499',120]].forEach(function(sc){ cx.fillStyle=sc[0]; cx.beginPath(); cx.moveTo(sc[1],20); cx.bezierCurveTo(sc[1]+50,50,sc[1]+40,90,sc[1]+70,125); cx.lineTo(sc[1]+90,115); cx.bezierCurveTo(sc[1]+60,82,sc[1]+70,42,sc[1]+22,18); cx.closePath(); cx.fill(); }); }
    },
    { title:'1990s+ — Generative & Algorithmic Art',
      body:'Vera Molnar pioneered computer-generated abstraction from the 1960s using FORTRAN loops. Casey Reas and Ben Fry created Processing, democratizing algorithmic art-making. The NFT boom of 2021 mainstreamed generative art: Tyler Hobbs\'s Fidenza, Dmitri Cherniak\'s Ringers, and the Art Blocks platform created new markets for code-as-art with each piece unique.',
      works:'Molnar: Interruptions (1968). Hobbs: Fidenza (2021). Cherniak: Ringers (2021). Reas: Process series.',
      draw:function(cv,cx){ var t=Date.now()*0.001; cx.fillStyle='#1e1b4b'; cx.fillRect(0,0,200,155); for(var i=0;i<80;i++){ var ang=i*2.399; var r=Math.sqrt(i)*11; var x=100+r*Math.cos(ang); var y=77+r*Math.sin(ang)*0.7; if(x<0||x>200||y<0||y>155) continue; var hue=(i*13+t*30)%360; cx.fillStyle='hsl('+hue+',75%,62%)'; cx.beginPath(); cx.arc(x,y,2.2,0,Math.PI*2); cx.fill(); } }
