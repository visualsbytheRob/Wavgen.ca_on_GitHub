<script>
// ===== HISTORY SECTION =====
(function() {
  const items = [
    {
      year: '1960s', title: 'Happenings', subtitle: 'Allan Kaprow & the unscripted event',
      body: `Kaprow coined "Happenings" — ephemeral, unscripted events where audience members became performers. <em>18 Happenings in 6 Parts</em> (1959) required visitors to move between rooms on instruction, erasing the passive viewer entirely.`,
      artists: ['Allan Kaprow', 'Jim Dine', 'Carolee Schneemann'],
      works: ['18 Happenings in 6 Parts', 'Car Crash', 'Eye Body'],
      tags: ['performance', 'participation', 'ephemeral'],
      demoFn: drawHappenings,
    },
    {
      year: 'c.1960', title: 'Fluxus', subtitle: 'Anti-art, instruction-based, participatory',
      body: `Fluxus rejected the art object entirely. Works were instructions — the participant's action <em>was</em> the art. Yoko Ono's <em>Grapefruit</em> book gave readers instructions: "Make a hole. Place your eye against it."`,
      artists: ['George Maciunas', 'Yoko Ono', 'Nam June Paik', 'Joseph Beuys'],
      works: ['Grapefruit (Ono)', 'Piano Activities (Corner)', 'Water Yam (Brecht)'],
      tags: ['instruction', 'anti-art', 'scores'],
      demoFn: drawFluxus,
    },
    {
      year: '1970s', title: 'Mail Art', subtitle: 'Network-based, distributed participation',
      body: `Mail Art used postal systems as a distributed gallery. Anyone could participate by sending work to a network address. Ray Johnson's New York Correspondence School made connectivity itself the medium — decades before the internet.`,
      artists: ['Ray Johnson', 'Robert Filliou', 'Ulises Carrión'],
      works: ['New York Correspondence School', 'The Eternal Network', 'Mail Art Shows'],
      tags: ['network', 'distribution', 'post'],
      demoFn: drawMailArt,
    },
    {
      year: '1974', title: 'Video Art', subtitle: 'Nam June Paik — viewer activates the work',
      body: `Paik's closed-circuit installations placed cameras and monitors so visitors saw themselves in real time, transformed. <em>TV Buddha</em> looped a Buddha statue watching its own image — presence and representation collapsing together.`,
      artists: ['Nam June Paik', 'Vito Acconci', 'Peter Campus'],
      works: ['TV Buddha', 'Participation TV', 'Mem'],
      tags: ['video', 'feedback', 'closed-circuit'],
      demoFn: drawVideoArt,
    },
    {
      year: '1980–90s', title: 'Interactive Installations', subtitle: 'Computer-based, sensor-responsive',
      body: `Artists began using infrared sensors, cameras, and microcomputers to create environments that responded to visitors. Myron Krueger's <em>VIDEOPLACE</em> mapped body silhouettes into synthetic interaction spaces — the first "responsive environments."`,
      artists: ['Myron Krueger', 'Jeffrey Shaw', 'David Rokeby'],
      works: ['VIDEOPLACE', 'The Legible City', 'Very Nervous System'],
      tags: ['sensors', 'computer', 'real-time'],
      demoFn: drawInteractive,
    },
    {
      year: '1990s', title: 'Net Art', subtitle: 'Internet as medium, distributed participation',
      body: `Net art turned the browser into a gallery and the network into the canvas. Works like Olia Lialina's <em>My Boyfriend Came Back from the War</em> existed only as web navigation — the viewer's clicks wrote the story.`,
      artists: ['Olia Lialina', 'JODI', 'Vuk Ćosić'],
      works: ['My Boyfriend Came Back...', 'wwwwwwwww.jodi.org', 'ASCII History of Moving Images'],
      tags: ['internet', 'hypertext', 'browser'],
      demoFn: drawNetArt,
    },
    {
      year: '2000s', title: 'Social Practice', subtitle: 'Community-based, art as social action',
      body: `Social Practice artists dissolved the studio into public space. Tino Sehgal's constructed situations hired "interpreters" to engage visitors in philosophical dialogue — no objects, no documentation. The interaction was everything.`,
      artists: ['Tino Sehgal', 'Rirkrit Tiravanija', 'Thomas Hirschhorn'],
      works: ['This is So Contemporary', 'Untitled (Free)', 'Gramsci Monument'],
      tags: ['community', 'relational', 'social'],
      demoFn: drawSocial,
    },
    {
      year: '2010s', title: 'AR/VR Art', subtitle: 'Embodied digital participation',
      body: `Virtual and augmented reality placed audiences fully inside the artwork. teamLab's digital art museums required visitors to walk through, become surrounded by, and alter living visual ecosystems — presence literally changed the work in real time.`,
      artists: ['teamLab', 'Marshmallow Laser Feast', 'Chris Milk'],
      works: ['Crystal Universe', 'In the Eyes of the Animal', 'Clouds over Sidra'],
      tags: ['VR', 'AR', 'immersive', 'embodied'],
      demoFn: drawARVR,
    },
  ];

  // Mini canvas demo functions
  function drawHappenings(ctx, w, h, t) {
    ctx.clearRect(0,0,w,h);
    ctx.fillStyle='#050505'; ctx.fillRect(0,0,w,h);
    const n = 6;
    for(let i=0;i<n;i++){
      const a = (i/n)*Math.PI*2 + t*0.5;
      const x = w/2 + Math.cos(a)*40;
      const y = h/2 + Math.sin(a)*30;
      ctx.beginPath(); ctx.arc(x,y,5,0,Math.PI*2);
      ctx.fillStyle='#FF2D78'; ctx.globalAlpha=0.7+0.3*Math.sin(t+i); ctx.fill();
    }
    ctx.globalAlpha=1;
    ctx.fillStyle='rgba(255,255,255,0.15)';
    ctx.fillRect(w/2-25,h/2-15,50,30);
    ctx.fillStyle='#FFF'; ctx.font='7px sans-serif'; ctx.textAlign='center';
    ctx.fillText('HAPPENINGS', w/2, h/2+4);
  }
  function drawFluxus(ctx, w, h, t) {
    ctx.fillStyle='rgba(5,5,5,0.15)'; ctx.fillRect(0,0,w,h);
    const words = ['MAKE','DO','PLAY','ACT','OPEN','FOLD'];
    const i = Math.floor(t*0.7) % words.length;
    ctx.font=`${12+Math.sin(t)*3}px monospace`; ctx.textAlign='center';
    ctx.fillStyle='#FF2D78'; ctx.globalAlpha=0.6+Math.sin(t*2)*0.3;
    ctx.fillText(words[i], w/2, h/2+4);
    ctx.globalAlpha=1;
  }
  function drawMailArt(ctx, w, h, t) {
    ctx.fillStyle='rgba(5,5,5,0.1)'; ctx.fillRect(0,0,w,h);
    for(let i=0;i<4;i++){
      const x = 10+Math.sin(t*0.4+i)*w*0.3;
      const y = 10+Math.cos(t*0.3+i*1.3)*h*0.3;
      ctx.strokeStyle='rgba(255,45,120,0.5)'; ctx.lineWidth=0.8;
      ctx.strokeRect(x,y,40,28);
      ctx.beginPath(); ctx.moveTo(x,y); ctx.lineTo(x+40,y+14); ctx.lineTo(x,y+28);
      ctx.stroke();
    }
  }
  function drawVideoArt(ctx, w, h, t) {
    ctx.fillStyle='rgba(5,5,5,0.18)'; ctx.fillRect(0,0,w,h);
    ctx.strokeStyle='rgba(255,45,120,0.6)'; ctx.lineWidth=1;
    ctx.strokeRect(w*0.15,h*0.15,w*0.7,h*0.7);
    // Feedback echo
    for(let i=0;i<3;i++){
      const s = 0.6 - i*0.15;
      ctx.globalAlpha=0.3-i*0.08;
      ctx.strokeRect(w*(0.5-s*0.35)+Math.sin(t+i)*3, h*(0.5-s*0.35)+Math.cos(t+i)*3, w*s*0.7, h*s*0.7);
    }
    ctx.globalAlpha=1;
    ctx.beginPath(); ctx.arc(w/2,h/2,8,0,Math.PI*2);
    ctx.fillStyle='#FF8EC8'; ctx.fill();
  }
  function drawInteractive(ctx, w, h, t) {
    ctx.fillStyle='rgba(5,5,5,0.12)'; ctx.fillRect(0,0,w,h);
    const cx=w/2+Math.sin(t*0.6)*20, cy=h/2+Math.cos(t*0.4)*15;
    const rings = 4;
    for(let i=0;i<rings;i++){
      ctx.beginPath(); ctx.arc(cx,cy,(i+1)*16,0,Math.PI*2);
      ctx.strokeStyle=`rgba(255,45,120,${0.5-i*0.1})`; ctx.lineWidth=1; ctx.stroke();
    }
    ctx.fillStyle='#FFFFFF'; ctx.beginPath(); ctx.arc(cx,cy,5,0,Math.PI*2); ctx.fill();
  }
  function drawNetArt(ctx, w, h, t) {
    ctx.fillStyle='rgba(5,5,5,0.1)'; ctx.fillRect(0,0,w,h);
    const pts = [[w*0.2,h*0.3],[w*0.5,h*0.15],[w*0.8,h*0.3],[w*0.7,h*0.7],[w*0.3,h*0.7]];
    pts.forEach((p,i) => {
      pts.forEach((q,j) => {
        if(i>=j) return;
        const pulse = 0.3+0.3*Math.sin(t*1.2+i+j);
        ctx.strokeStyle=`rgba(255,45,120,${pulse})`; ctx.lineWidth=0.8;
        ctx.beginPath(); ctx.moveTo(p[0],p[1]); ctx.lineTo(q[0],q[1]); ctx.stroke();
      });
      ctx.beginPath(); ctx.arc(p[0],p[1],3,0,Math.PI*2);
      ctx.fillStyle='#FFFFFF'; ctx.fill();
    });
  }
  function drawSocial(ctx, w, h, t) {
    ctx.fillStyle='rgba(5,5,5,0.12)'; ctx.fillRect(0,0,w,h);
    const people = 5;
    for(let i=0;i<people;i++){
      const a = (i/people)*Math.PI*2 + t*0.15;
      const x = w/2+Math.cos(a)*38, y=h/2+Math.sin(a)*28;
      ctx.beginPath(); ctx.arc(x,y,5,0,Math.PI*2);
      ctx.fillStyle='#FF8EC8'; ctx.fill();
      ctx.beginPath(); ctx.moveTo(x,y+5); ctx.lineTo(x,y+18);
      ctx.strokeStyle='#FF8EC8'; ctx.lineWidth=1.5; ctx.stroke();
    }
  }
  function drawARVR(ctx, w, h, t) {
    ctx.fillStyle='rgba(5,5,5,0.1)'; ctx.fillRect(0,0,w,h);
    const hue = (t * 40) % 360;
    const grd = ctx.createRadialGradient(w/2,h/2,0,w/2,h/2,50);
    grd.addColorStop(0, `hsla(${hue},100%,65%,0.4)`);
    grd.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = grd; ctx.fillRect(0,0,w,h);
    for(let i=0;i<6;i++){
      const a = (i/6)*Math.PI*2+t*0.3;
      const r = 20+i*8;
      ctx.strokeStyle=`rgba(255,255,255,${0.15+i*0.05})`;
      ctx.beginPath(); ctx.arc(w/2,h/2,r,a,a+Math.PI*0.5); ctx.stroke();
    }
  }

  const demoFns = [drawHappenings,drawFluxus,drawMailArt,drawVideoArt,drawInteractive,drawNetArt,drawSocial,drawARVR];
  const demoCtxs = [];

  const root = document.getElementById('timeline-root');
  items.forEach((item, idx) => {
    const div = document.createElement('div');
    div.className = 'timeline-item';
    div.innerHTML = `
      <div class="timeline-header">
        <span class="timeline-year">${item.year}</span>
        <span class="timeline-title">${item.title}</span>
      </div>
      <div class="timeline-body">
        <div class="timeline-body-inner">
          <div>
            <p style="margin:0 0 0.5rem">${item.body}</p>
            <div style="margin-bottom:0.35rem"><strong style="font-size:0.7rem;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.08em">Artists:</strong>
              <span style="font-size:0.75rem;color:#FF8EC8"> ${item.artists.join(', ')}</span></div>
            <div style="margin-bottom:0.5rem"><strong style="font-size:0.7rem;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.08em">Key Works:</strong>
              <span style="font-size:0.75rem;color:rgba(255,255,255,0.6)"> ${item.works.join(' · ')}</span></div>
            <div>${item.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div>
          </div>
          <canvas class="timeline-mini-canvas" id="mini-${idx}" width="180" height="120"></canvas>
        </div>
      </div>`;
    root.appendChild(div);
    div.querySelector('.timeline-header').addEventListener('click', () => {
      const isOpen = div.classList.contains('open');
      root.querySelectorAll('.timeline-item').forEach(el => el.classList.remove('open'));
      if (!isOpen) div.classList.add('open');
    });
  });

  // Animate mini canvases
  let t0 = performance.now();
  function animateMinis(ts) {
    const t = (ts - t0) / 1000;
    items.forEach((item, idx) => {
      const c = document.getElementById(`mini-${idx}`);
      if (!c) return;
      const ctx = c.getContext('2d');
      item.demoFn(ctx, 180, 120, t);
    });
    requestAnimationFrame(animateMinis);
  }
  requestAnimationFrame(animateMinis);
})();

// ===== SENSOR LAB =====
(function() {
  const SENSOR_SIZE = 200;
  const sensors = [
    { id: 'presence', name: 'Presence Sensor', desc: 'cursor in zone = presence', val: '0%' },
    { id: 'distance', name: 'Distance Sensor', desc: 'distance from center', val: '0.0' },
    { id: 'velocity', name: 'Velocity Sensor', desc: 'mouse speed → visual', val: '0 px/s' },
    { id: 'direction', name: 'Direction Sensor', desc: 'movement angle steers element', val: '0°' },
    { id: 'dwell', name: 'Dwell Sensor', desc: 'stillness triggers event', val: '0%' },
    { id: 'multipresence', name: 'Multi-Presence', desc: 'click = body in space', val: '0 bodies' },
  ];

  const grid = document.getElementById('sensors-grid');
  sensors.forEach(s => {
    const card = document.createElement('div');
    card.className = 'sensor-card';
    card.innerHTML = `
      <canvas class="sensor-canvas" id="sc-${s.id}" width="${SENSOR_SIZE}" height="${SENSOR_SIZE}"></canvas>
      <div class="sensor-info">
        <div class="sensor-name">${s.name}</div>
        <div class="sensor-val" id="sv-${s.id}">${s.desc}</div>
      </div>`;
    grid.appendChild(card);
  });

  // Global mouse tracking for sensors
  let gmx = 0, gmy = 0, gpx = 0, gpy = 0;
  let gvx = 0, gvy = 0, gspeed = 0, gspeedSmooth = 0;
  let gangle = 0, gangleSmooth = 0;
  let gLastT = performance.now();

  window.addEventListener('mousemove', e => { gmx = e.clientX; gmy = e.clientY; });

  // Multi-presence bodies
  const bodies = [];
  const mpCanvas = document.getElementById('sc-multipresence');
  if (mpCanvas) {
    mpCanvas.addEventListener('click', e => {
      const r = mpCanvas.getBoundingClientRect();
      const x = e.clientX - r.left, y = e.clientY - r.top;
      if (bodies.length >= 8) bodies.shift();
      bodies.push({ x, y, life: 1, smoothX: x, smoothY: y });
    });
  }

  // Dwell state
  let dwellTimer = 0, dwellSmooth = 0, dwellTriggered = false;
  let prevDwellX = gmx, prevDwellY = gmy;

  // Per-sensor lag state
  let presenceSmooth = 0;
  let distSmooth = 0;
  let velSmooth = 0;
  let dirSmooth = 0;
  let chainActive = false;

  function sensorLoop(ts) {
    const dt = Math.min((ts - gLastT) / 1000, 0.05);
    gLastT = ts;

    const rawVx = (gmx - gpx) / (dt + 0.001);
    const rawVy = (gmy - gpy) / (dt + 0.001);
    // LagFilter 11 & 12: sensor velocity
    gvx += (1 - Math.exp(-dt / 0.07)) * (rawVx - gvx);
    gvy += (1 - Math.exp(-dt / 0.07)) * (rawVy - gvy);
    gspeed = Math.sqrt(gvx*gvx + gvy*gvy);
    // LagFilter 13: smooth speed
    gspeedSmooth += (1 - Math.exp(-dt / 0.2)) * (gspeed - gspeedSmooth);

    const rawAngle = Math.atan2(gvy, gvx) * 180 / Math.PI;
    // LagFilter 14: smooth angle
    gangleSmooth += (1 - Math.exp(-dt / 0.15)) * (rawAngle - gangleSmooth);

    gpx = gmx; gpy = gmy;

    // ---- Presence sensor ----
    const pc = document.getElementById('sc-presence');
    if (pc) {
      const r = pc.getBoundingClientRect();
      const lx = gmx - r.left, ly = gmy - r.top;
      const inZone = lx > 40 && lx < 160 && ly > 40 && ly < 160 ? 1 : 0;
      // LagFilter 15: smooth presence
      presenceSmooth += (1 - Math.exp(-dt / 0.15)) * (inZone - presenceSmooth);

      const ctx = pc.getContext('2d');
      ctx.fillStyle = 'rgba(5,5,5,0.2)'; ctx.fillRect(0,0,200,200);
      // Zone rect
      const zc = `rgba(255,45,120,${0.12 + presenceSmooth * 0.25})`;
      ctx.fillStyle = zc; ctx.fillRect(40,40,120,120);
      ctx.strokeStyle = `rgba(255,45,120,${0.4 + presenceSmooth * 0.5})`;
      ctx.lineWidth = 1.5; ctx.strokeRect(40,40,120,120);
      // Pulse ring when present
      if (presenceSmooth > 0.5) {
        const ring = (ts % 1200) / 1200;
        ctx.beginPath(); ctx.arc(100,100,20+ring*50,0,Math.PI*2);
        ctx.strokeStyle = `rgba(255,45,120,${(1-ring)*0.6})`; ctx.lineWidth=1; ctx.stroke();
      }
      ctx.fillStyle = '#FFFFFF'; ctx.font = '10px monospace'; ctx.textAlign = 'center';
      ctx.fillText(inZone ? 'DETECTED' : 'EMPTY', 100, 180);
      document.getElementById('sv-presence').textContent = `${Math.round(presenceSmooth*100)}% presence`;
      if (chainActive) { document.getElementById('cd0').classList.toggle('active', presenceSmooth > 0.5); }
    }

    // ---- Distance sensor ----
    const dc = document.getElementById('sc-distance');
    if (dc) {
      const r = dc.getBoundingClientRect();
      const lx = gmx - r.left - 100, ly = gmy - r.top - 100;
      const rawDist = Math.sqrt(lx*lx + ly*ly);
      const norm = Math.min(rawDist / 100, 1);
      distSmooth += (1 - Math.exp(-dt / 0.18)) * (norm - distSmooth);
      const ctx = dc.getContext('2d');
      ctx.fillStyle = 'rgba(5,5,5,0.2)'; ctx.fillRect(0,0,200,200);
      for (let i = 4; i >= 1; i--) {
        ctx.beginPath(); ctx.arc(100,100,i*22,0,Math.PI*2);
        ctx.strokeStyle = `rgba(255,45,120,${0.15+i*0.06})`; ctx.lineWidth=1; ctx.stroke();
      }
      const bright = 0.3 + (1-distSmooth) * 0.7;
      ctx.beginPath(); ctx.arc(100,100,6,0,Math.PI*2);
      ctx.fillStyle = `rgba(255,45,120,${bright})`; ctx.fill();
      const dotX = 100 + Math.min(lx, 95), dotY = 100 + Math.min(ly, 95);
      ctx.beginPath(); ctx.arc(Math.min(Math.max(dotX,5),195), Math.min(Math.max(dotY,5),195), 4,0,Math.PI*2);
      ctx.fillStyle='#FF8EC8'; ctx.fill();
      document.getElementById('sv-distance').textContent = `dist: ${rawDist.toFixed(0)}px | ${(distSmooth*100).toFixed(0)}%`;
      if (chainActive) document.getElementById('cd1').classList.toggle('active', distSmooth > 0.5);
    }

    // ---- Velocity sensor ----
    const vc = document.getElementById('sc-velocity');
    if (vc) {
      const ctx = vc.getContext('2d');
      ctx.fillStyle = 'rgba(5,5,5,0.15)'; ctx.fillRect(0,0,200,200);
      const barH = Math.min(gspeedSmooth / 8, 1) * 160;
      const barColor = `rgba(255,${Math.round(45 + (1-Math.min(gspeedSmooth/800,1))*130)},120,0.85)`;
      ctx.fillStyle = barColor;
      ctx.fillRect(80, 200-barH, 40, barH);
      ctx.strokeStyle = 'rgba(255,45,120,0.3)'; ctx.lineWidth=1;
      ctx.strokeRect(80,40,40,160);
      // Speed bands
      [0.25,0.5,0.75].forEach(f => {
        ctx.strokeStyle='rgba(255,255,255,0.1)'; ctx.lineWidth=0.5;
        ctx.beginPath(); ctx.moveTo(70, 200-f*160); ctx.lineTo(130, 200-f*160); ctx.stroke();
      });
      document.getElementById('sv-velocity').textContent = `${gspeedSmooth.toFixed(0)} px/s`;
      if (chainActive) document.getElementById('cd2').classList.toggle('active', gspeedSmooth > 200);
    }

    // ---- Direction sensor ----
    const dirc = document.getElementById('sc-direction');
    if (dirc) {
      const ctx = dirc.getContext('2d');
      ctx.fillStyle = 'rgba(5,5,5,0.18)'; ctx.fillRect(0,0,200,200);
      ctx.strokeStyle = 'rgba(255,45,120,0.2)'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.arc(100,100,60,0,Math.PI*2); ctx.stroke();
      ctx.beginPath(); ctx.arc(100,100,30,0,Math.PI*2); ctx.stroke();
      // Direction arrow
      const rad = gangleSmooth * Math.PI / 180;
      const ax = 100 + Math.cos(rad)*55, ay = 100 + Math.sin(rad)*55;
      ctx.beginPath(); ctx.moveTo(100,100); ctx.lineTo(ax,ay);
      ctx.strokeStyle='#FF2D78'; ctx.lineWidth=2; ctx.stroke();
      ctx.beginPath(); ctx.arc(ax,ay,4,0,Math.PI*2); ctx.fillStyle='#FF2D78'; ctx.fill();
      // N/S/E/W labels
      [['N',100,28],['S',100,178],['E',178,104],['W',22,104]].forEach(([l,x,y]) => {
        ctx.fillStyle='rgba(255,255,255,0.25)'; ctx.font='9px sans-serif'; ctx.textAlign='center'; ctx.fillText(l,x,y);
      });
      document.getElementById('sv-direction').textContent = `${gangleSmooth.toFixed(1)}°`;
      if (chainActive) document.getElementById('cd3').classList.toggle('active', gspeed > 50);
    }

    // ---- Dwell sensor ----
    const dwc = document.getElementById('sc-dwell');
    if (dwc) {
      const moveDist = Math.sqrt((gmx-prevDwellX)**2+(gmy-prevDwellY)**2);
      if (moveDist > 8) { dwellTimer = 0; dwellTriggered = false; }
      else { dwellTimer = Math.min(dwellTimer + dt, 2); }
      prevDwellX = gmx; prevDwellY = gmy;
      const dwellFrac = dwellTimer / 2;
      dwellSmooth += (1 - Math.exp(-dt / 0.1)) * (dwellFrac - dwellSmooth);
      if (dwellFrac >= 1 && !dwellTriggered) dwellTriggered = true;

      const ctx = dwc.getContext('2d');
      ctx.fillStyle = 'rgba(5,5,5,0.2)'; ctx.fillRect(0,0,200,200);
      ctx.strokeStyle='rgba(255,255,255,0.1)'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.arc(100,100,60,0,Math.PI*2); ctx.stroke();
      // Fill arc
      ctx.beginPath(); ctx.moveTo(100,100);
      ctx.arc(100,100,60,-Math.PI/2,-Math.PI/2+dwellSmooth*Math.PI*2);
      ctx.fillStyle=`rgba(255,45,120,${0.2+dwellSmooth*0.5})`; ctx.fill();
      if (dwellTriggered) {
        ctx.beginPath(); ctx.arc(100,100,10,0,Math.PI*2);
        ctx.fillStyle='#FF2D78'; ctx.fill();
      }
      ctx.fillStyle='rgba(255,255,255,0.5)'; ctx.font='9px monospace'; ctx.textAlign='center';
      ctx.fillText(`${(dwellSmooth*100).toFixed(0)}%`, 100, 104);
      document.getElementById('sv-dwell').textContent = `dwell: ${(dwellSmooth*2).toFixed(2)}s`;
      if (chainActive) document.getElementById('cd4').classList.toggle('active', dwellSmooth > 0.8);
    }

    // ---- Multi-presence sensor ----
    const mpc = document.getElementById('sc-multipresence');
    if (mpc) {
      const ctx = mpc.getContext('2d');
      ctx.fillStyle = 'rgba(5,5,5,0.25)'; ctx.fillRect(0,0,200,200);
      ctx.strokeStyle='rgba(255,45,120,0.12)'; ctx.lineWidth=0.5;
      for(let x=0;x<=200;x+=25) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,200); ctx.stroke(); }
      for(let y=0;y<=200;y+=25) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(200,y); ctx.stroke(); }
      bodies.forEach((b,i) => {
        b.life = Math.max(0, b.life - dt * 0.15);
        ctx.globalAlpha = 0.4 + b.life * 0.5;
        ctx.beginPath(); ctx.arc(b.x, b.y, 8+i*2, 0, Math.PI*2);
        ctx.strokeStyle='#FF2D78'; ctx.lineWidth=1; ctx.stroke();
        ctx.beginPath(); ctx.arc(b.x, b.y, 4, 0, Math.PI*2);
        ctx.fillStyle='#FF8EC8'; ctx.fill();
      });
      ctx.globalAlpha=1;
      document.getElementById('sv-multipresence').textContent = `${bodies.length} bodies`;
      if (chainActive) document.getElementById('cd5').classList.toggle('active', bodies.length >= 3);
    }

    requestAnimationFrame(sensorLoop);
  }
  requestAnimationFrame(sensorLoop);

  document.getElementById('chain-btn').addEventListener('click', function() {
    chainActive = !chainActive;
    this.textContent = chainActive ? 'Unchain Sensors' : 'Chain Sensors';
    this.classList.toggle('active', chainActive);
  });
})();
</script>
<!-- SECTION 4: RESPONSIVE ENVIRONMENT BUILDER -->
<section id="environment">
