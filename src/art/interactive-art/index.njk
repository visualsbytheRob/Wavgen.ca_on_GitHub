<script>
// ===== INSTALLATIONS =====
(function() {
  let lastT = performance.now();

  // ---- Light Installation ----
  const lc = document.getElementById('inst-light');
  const lctx = lc.getContext('2d');
  const lW = lc.width, lH = lc.height;
  let lmx = lW/2, lmy = lH/2;
  let lmxS = lW/2, lmyS = lH/2;
  let lLastT = performance.now();
  lc.addEventListener('mousemove', e => { const r=lc.getBoundingClientRect(); lmx=e.clientX-r.left; lmy=e.clientY-r.top; });
  function lightLoop(ts) {
    const dt=Math.min((ts-lLastT)/1000,0.05); lLastT=ts;
    // LagFilter light position
    lmxS += (1 - Math.exp(-dt/0.12)) * (lmx - lmxS);
    lmyS += (1 - Math.exp(-dt/0.12)) * (lmy - lmyS);
    lctx.fillStyle='rgba(5,5,5,0.25)'; lctx.fillRect(0,0,lW,lH);
    const sources = [
      {x:lmxS, y:lmyS, r:255, g:45, b:120},
      {x:lW-lmxS*0.5, y:lmyS*0.5, r:45, g:180, b:255},
      {x:lmxS*0.4, y:lH-lmyS*0.6, r:255, g:255, b:100},
    ];
    sources.forEach(s => {
      const grd = lctx.createRadialGradient(s.x,s.y,0,s.x,s.y,100);
      grd.addColorStop(0,`rgba(${s.r},${s.g},${s.b},0.45)`);
      grd.addColorStop(1,'rgba(0,0,0,0)');
      lctx.globalCompositeOperation='screen';
      lctx.fillStyle=grd; lctx.fillRect(0,0,lW,lH);
    });
    lctx.globalCompositeOperation='source-over';
    requestAnimationFrame(lightLoop);
  }
  requestAnimationFrame(lightLoop);

  // ---- Sound Installation ----
  const sc = document.getElementById('inst-sound');
  const sctx = sc.getContext('2d');
  const sW = sc.width, sH = sc.height;
  const soundSources = [];
  let sLastT = performance.now();
  sc.addEventListener('click', e => {
    const r=sc.getBoundingClientRect();
    if (soundSources.length >= 5) soundSources.shift();
    soundSources.push({x:e.clientX-r.left, y:e.clientY-r.top, born:performance.now()});
  });
  function soundLoop(ts) {
    const dt=Math.min((ts-sLastT)/1000,0.05); sLastT=ts;
    sctx.fillStyle='rgba(5,5,5,0.18)'; sctx.fillRect(0,0,sW,sH);
    soundSources.forEach((s,si) => {
      const age = (ts - s.born) / 1000;
      for (let i=0;i<8;i++) {
        const ring = (age * 40 + i * 22) % 160;
        const alpha = Math.max(0, 0.5 - ring/160) * 0.7;
        sctx.beginPath(); sctx.arc(s.x,s.y,ring,0,Math.PI*2);
        sctx.strokeStyle=`rgba(255,45,120,${alpha})`; sctx.lineWidth=1; sctx.stroke();
      }
      sctx.beginPath(); sctx.arc(s.x,s.y,4,0,Math.PI*2);
      sctx.fillStyle='#FF2D78'; sctx.fill();
    });
    if (soundSources.length === 0) {
      sctx.fillStyle='rgba(255,255,255,0.15)'; sctx.font='11px sans-serif'; sctx.textAlign='center';
      sctx.fillText('Click to place sound sources', sW/2, sH/2);
    }
    requestAnimationFrame(soundLoop);
  }
  requestAnimationFrame(soundLoop);

  // ---- Environmental/Thermal ----
  const ec = document.getElementById('inst-env');
  const ectx = ec.getContext('2d');
  const eW = ec.width, eH = ec.height;
  const heatmap = new Float32Array(eW * eH);
  let emx = eW/2, emy = eH/2;
  let eLastT = performance.now();
  ec.addEventListener('mousemove', e => {
    const r=ec.getBoundingClientRect();
    emx=(e.clientX-r.left)*(eW/r.width)|0;
    emy=(e.clientY-r.top)*(eH/r.height)|0;
  });
  function envThermal(ts) {
    const dt=Math.min((ts-eLastT)/1000,0.05); eLastT=ts;
    // Add heat at cursor
    for(let dy=-12;dy<=12;dy++) for(let dx=-12;dx<=12;dx++) {
      const d=Math.sqrt(dx*dx+dy*dy); if(d>12) continue;
      const ix=(emx+dx)|0, iy=(emy+dy)|0;
      if(ix<0||ix>=eW||iy<0||iy>=eH) continue;
      heatmap[iy*eW+ix] = Math.min(heatmap[iy*eW+ix] + dt*(1-d/12)*0.8, 1);
    }
    // Cool down
    for(let i=0;i<heatmap.length;i++) heatmap[i]*=0.998;

    const imgData = ectx.createImageData(eW, eH);
    for(let i=0;i<heatmap.length;i++){
      const v=heatmap[i];
      imgData.data[i*4]   = Math.round(v*255);
      imgData.data[i*4+1] = Math.round(v*45);
      imgData.data[i*4+2] = Math.round(v*120);
      imgData.data[i*4+3] = Math.round(30+v*200);
    }
    ectx.fillStyle='#050505'; ectx.fillRect(0,0,eW,eH);
    ectx.putImageData(imgData, 0, 0);
    requestAnimationFrame(envThermal);
  }
  requestAnimationFrame(envThermal);

  // ---- Data Installation ----
  const dc = document.getElementById('inst-data');
  const dctx = dc.getContext('2d');
  const dW = dc.width, dH = dc.height;
  let dLastT = performance.now();
  let dVisitors = 0; let dVisitorTimer = 0;
  let dHeartPhase = 0;
  // Lag state for data sculpture
  let dHeartSmooth = 0, dVisSmooth = 0, dTimeSmooth = 0;
  function dataLoop(ts) {
    const dt=Math.min((ts-dLastT)/1000,0.05); dLastT=ts;
    const t = ts/1000;
    dHeartPhase += dt * 1.1;
    dVisitorTimer += dt;
    if(dVisitorTimer > 3.7) { dVisitors = (dVisitors+1)%42; dVisitorTimer=0; }

    const heartbeat = 0.5 + 0.5*Math.sin(dHeartPhase * Math.PI * 2);
    const timeFrac = ((t % 60) / 60);
    // LagFilter data values
    dHeartSmooth += (1 - Math.exp(-dt/0.15)) * (heartbeat - dHeartSmooth);
    dVisSmooth += (1 - Math.exp(-dt/0.6)) * (dVisitors/42 - dVisSmooth);
    dTimeSmooth += (1 - Math.exp(-dt/1.2)) * (timeFrac - dTimeSmooth);

    dctx.fillStyle='rgba(5,5,5,0.22)'; dctx.fillRect(0,0,dW,dH);

    // Data bars
    const bars = [
      { label:'HEART', val:dHeartSmooth, color:'#FF2D78', x:30 },
      { label:'VISIT', val:dVisSmooth, color:'#FF8EC8', x:90 },
      { label:'TIME', val:dTimeSmooth, color:'#FFFFFF', x:150 },
    ];
    bars.forEach(b => {
      const bh = b.val * 100;
      dctx.fillStyle=b.color; dctx.globalAlpha=0.8;
      dctx.fillRect(b.x, dH-20-bh, 30, bh);
      dctx.globalAlpha=1;
      dctx.fillStyle='rgba(255,255,255,0.3)'; dctx.font='7px monospace'; dctx.textAlign='center';
      dctx.fillText(b.label, b.x+15, dH-8);
    });

    // Ikeda-style data stream
    dctx.fillStyle='rgba(255,45,120,0.5)'; dctx.font='7px monospace'; dctx.textAlign='left';
    for(let row=0;row<10;row++){
      const str = Array.from({length:20},()=>Math.random()>0.5?'1':'0').join('');
      const fade = (row/10)*0.6;
      dctx.globalAlpha = 0.04 + (1-fade)*dHeartSmooth*0.25;
      dctx.fillText(str, 200, 16 + row*12);
    }
    dctx.globalAlpha=1;

    // Sculpture spiral
    const cx=220, cy=dH/2;
    for(let i=0;i<40;i++){
      const a=(i/40)*Math.PI*2+t*0.3;
      const r=20 + i*2 * dVisSmooth;
      const x=cx+Math.cos(a)*r, y=cy+Math.sin(a)*r*(0.5+dHeartSmooth*0.5);
      dctx.beginPath(); dctx.arc(x,y,1.5,0,Math.PI*2);
      dctx.fillStyle=`rgba(255,45,120,${0.2+dHeartSmooth*0.7})`; dctx.fill();
    }

    requestAnimationFrame(dataLoop);
  }
  requestAnimationFrame(dataLoop);
})();

// ===== CO-CREATOR SECTION =====
(function() {
  // Tab switching
  document.querySelectorAll('.co-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.co-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.co-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById('cop-'+tab.dataset.cotab).classList.add('active');
    });
  });

  // ---- Collaborative Canvas ----
  const collabC = document.getElementById('collab-canvas');
  const cctx = collabC.getContext('2d');
  const cW = collabC.width, cH = collabC.height;
  cctx.fillStyle='#050505'; cctx.fillRect(0,0,cW,cH);
  let cmx=cW/2,cmy=cH/2,cpx=cW/2,cpy=cH/2;
  let cmxS=cW/2,cmyS=cH/2,cvx=0,cvy=0,cspeedS=0;
  let cLastT=performance.now(), cElapsed=0, cRunning=false, cDone=false;
  let cLastMoveT=performance.now();
  let cHue=0, cHueS=0;

  collabC.addEventListener('mousemove', e => {
    const r=collabC.getBoundingClientRect();
    cmx=(e.clientX-r.left)*(cW/r.width);
    cmy=(e.clientY-r.top)*(cH/r.height);
    if(!cRunning && !cDone) cRunning=true;
    cLastMoveT=performance.now();
  });

  document.getElementById('collab-reset').addEventListener('click', () => {
    cctx.fillStyle='#050505'; cctx.fillRect(0,0,cW,cH);
    cElapsed=0; cRunning=false; cDone=false;
    document.getElementById('collab-timer').textContent='Time: 0s / 60s';
  });

  function collabLoop(ts) {
    const dt=Math.min((ts-cLastT)/1000,0.05); cLastT=ts;
    if(cRunning && !cDone) cElapsed+=dt;
    if(cElapsed>=60) { cDone=true; cRunning=false; }

    const rawVx=(cmx-cpx)/(dt+0.001), rawVy=(cmy-cpy)/(dt+0.001);
    cpx=cmx; cpy=cmy;
    cvx+=(1-Math.exp(-dt/0.06))*(rawVx-cvx);
    cvy+=(1-Math.exp(-dt/0.06))*(rawVy-cvy);
    const cspeed=Math.sqrt(cvx*cvx+cvy*cvy);
    cspeedS+=(1-Math.exp(-dt/0.14))*(cspeed-cspeedS);
    cmxS+=(1-Math.exp(-dt/0.05))*(cmx-cmxS);
    cmyS+=(1-Math.exp(-dt/0.05))*(cmy-cmyS);
    const rawH=(Math.atan2(cvy,cvx)/(Math.PI*2)+1)%1*360;
    cHueS+=(1-Math.exp(-dt/0.25))*(rawH-cHueS);

    if(cRunning && !cDone){
      const size=1.5+Math.min(cspeedS/100,1)*14;
      const alpha=0.25+Math.min(cspeedS/600,0.55);
      cctx.globalAlpha=alpha;
      cctx.beginPath(); cctx.arc(cmxS,cmyS,size,0,Math.PI*2);
      cctx.fillStyle=`hsl(${cHueS},80%,65%)`; cctx.fill();
      cctx.globalAlpha=1;
    }
    if(cDone) {
      cctx.fillStyle='rgba(255,45,120,0.06)';
      cctx.fillRect(0,0,cW,cH);
      cctx.fillStyle='rgba(255,45,120,0.7)'; cctx.font='bold 18px sans-serif'; cctx.textAlign='center';
      cctx.fillText('THE WORK IS COMPLETE', cW/2, 28);
    }
    document.getElementById('collab-timer').textContent = `Time: ${Math.min(cElapsed,60).toFixed(1)}s / 60s${cDone?' — DONE':''}`;
    requestAnimationFrame(collabLoop);
  }
  requestAnimationFrame(collabLoop);

  // ---- Decision Narrative ----
  const narC = document.getElementById('narrative-canvas');
  const nctx = narC.getContext('2d');
  const nW=narC.width, nH=narC.height;
  let nmx=nW/2, nmy=nH/2, nmxS=nW/2;
  let nLastT=performance.now();
  const chapters = [
    { text:'A figure stands at the threshold.', left:'Enter alone', right:'Wait for another' },
    { text:'The room breathes.', left:'Follow the sound', right:'Move toward light' },
    { text:'Something shifts.', left:'Reach out', right:'Step back' },
    { text:'The moment holds.', left:'Speak', right:'Remain silent' },
    { text:'And then — everything changes.', left:'End', right:'Begin again' },
  ];
  let nChapter=0, nChoice=null, nChoiceT=null, nTransition=1;

  narC.addEventListener('mousemove', e => {
    const r=narC.getBoundingClientRect();
    nmx=(e.clientX-r.left)*(nW/r.width);
    nmy=(e.clientY-r.top)*(nH/r.height);
  });
  narC.addEventListener('click', () => {
    if(nChoice!==null) return;
    nChoice = nmxS < nW/2 ? 'left' : 'right';
    nChoiceT = performance.now();
  });
  document.getElementById('narrative-reset').addEventListener('click', () => {
    nChapter=0; nChoice=null; nChoiceT=null; nTransition=0;
  });

  function narrativeLoop(ts) {
    const dt=Math.min((ts-nLastT)/1000,0.05); nLastT=ts;
    nmxS+=(1-Math.exp(-dt/0.15))*(nmx-nmxS);
    nTransition+=(1-Math.exp(-dt/0.4))*(1-nTransition);

    nctx.fillStyle='rgba(5,5,5,0.18)'; nctx.fillRect(0,0,nW,nH);
    const ch=chapters[Math.min(nChapter, chapters.length-1)];

    // Side highlight
    const side = nmxS < nW/2 ? 'left' : 'right';
    if(!nChoice){
      nctx.fillStyle = side==='left' ? 'rgba(255,45,120,0.04)' : 'rgba(255,45,120,0.04)';
      const hx = side==='left' ? 0 : nW/2;
      nctx.fillRect(hx, 0, nW/2, nH);
      nctx.strokeStyle='rgba(255,45,120,0.15)'; nctx.lineWidth=1;
      nctx.beginPath(); nctx.moveTo(nW/2,20); nctx.lineTo(nW/2,nH-20); nctx.stroke();
    }

    nctx.globalAlpha=nTransition;
    nctx.fillStyle='#FFFFFF'; nctx.font=`italic ${18}px Georgia,serif`; nctx.textAlign='center';
    nctx.fillText(ch.text, nW/2, nH/2-30);

    if(!nChoice) {
      nctx.font='13px sans-serif';
      nctx.fillStyle=side==='left'?'#FF2D78':'rgba(255,255,255,0.3)';
      nctx.textAlign='center'; nctx.fillText('← '+ch.left, nW/4, nH*0.72);
      nctx.fillStyle=side==='right'?'#FF2D78':'rgba(255,255,255,0.3)';
      nctx.textAlign='center'; nctx.fillText(ch.right+' →', nW*0.75, nH*0.72);
      nctx.font='10px sans-serif'; nctx.fillStyle='rgba(255,255,255,0.2)';
      nctx.textAlign='center'; nctx.fillText('click to choose', nW/2, nH-20);
    } else {
      const elapsed=(ts-nChoiceT)/1000;
      if(elapsed>1.4 && nChapter<chapters.length-1){ nChapter++; nChoice=null; nChoiceT=null; nTransition=0; }
      nctx.font='12px sans-serif'; nctx.fillStyle='#FF2D78'; nctx.textAlign='center';
      nctx.fillText(`You chose: ${nChoice==='left'?ch.left:ch.right}`, nW/2, nH*0.72);
    }
    nctx.globalAlpha=1;
    nctx.fillStyle='rgba(255,255,255,0.15)'; nctx.font='9px monospace'; nctx.textAlign='right';
    nctx.fillText(`${nChapter+1}/${chapters.length}`, nW-12, nH-12);

    requestAnimationFrame(narrativeLoop);
  }
  requestAnimationFrame(narrativeLoop);

  // ---- Emergent System ----
  const emgC = document.getElementById('emergent-canvas');
  const ectx = emgC.getContext('2d');
  const eW=emgC.width, eH=emgC.height;
  const agents = [];
  let eLastT=performance.now();

  emgC.addEventListener('click', e => {
    if(agents.length>=8) return;
    const r=emgC.getBoundingClientRect();
    const x=(e.clientX-r.left)*(eW/r.width);
    const y=(e.clientY-r.top)*(eH/r.height);
    const hue=agents.length*45;
    agents.push({x,y,vx:(Math.random()-0.5)*1.5,vy:(Math.random()-0.5)*1.5,
      hue, trailX:x, trailY:y,
      smoothX:x, smoothY:y,
      size:8+agents.length*2});
    document.getElementById('emergent-count').textContent=`${agents.length}/8 agents`;
  });

  document.getElementById('emergent-reset').addEventListener('click', () => {
    agents.length=0;
    ectx.fillStyle='#050505'; ectx.fillRect(0,0,eW,eH);
    document.getElementById('emergent-count').textContent='0/8 agents';
  });
  ectx.fillStyle='#050505'; ectx.fillRect(0,0,eW,eH);

  function emergentLoop(ts) {
    const dt=Math.min((ts-eLastT)/1000,0.05); eLastT=ts;

    ectx.fillStyle='rgba(5,5,5,0.04)'; ectx.fillRect(0,0,eW,eH);

    agents.forEach((a,i) => {
      // Agent-agent forces
      agents.forEach((b,j) => {
        if(i===j) return;
        const dx=b.x-a.x, dy=b.y-a.y;
        const d=Math.sqrt(dx*dx+dy*dy)+0.01;
        const attract = d > 120 ? 0.08/d : 0;
        const repel = d < 60 ? -1.5/(d*d) : 0;
        const f = (attract+repel) * dt*60;
        a.vx += dx/d * f;
        a.vy += dy/d * f;
      });
      // Wall bounce
      if(a.x<10||a.x>eW-10) a.vx*=-0.85;
      if(a.y<10||a.y>eH-10) a.vy*=-0.85;
      a.vx*=0.97; a.vy*=0.97;
      a.x+=a.vx*dt*60; a.y+=a.vy*dt*60;
      a.x=Math.max(10,Math.min(eW-10,a.x));
      a.y=Math.max(10,Math.min(eH-10,a.y));
      // LagFilter agent smooth display
      a.smoothX+=(1-Math.exp(-dt/0.06))*(a.x-a.smoothX);
      a.smoothY+=(1-Math.exp(-dt/0.06))*(a.y-a.smoothY);

      // Draw connection lines
      agents.forEach((b,j)=>{
        if(j<=i) return;
        const dx=b.smoothX-a.smoothX, dy=b.smoothY-a.smoothY;
        const d=Math.sqrt(dx*dx+dy*dy);
        if(d<150){
          ectx.globalAlpha=(1-d/150)*0.35;
          ectx.strokeStyle=`hsl(${(a.hue+b.hue)/2},80%,55%)`;
          ectx.lineWidth=0.8;
          ectx.beginPath(); ectx.moveTo(a.smoothX,a.smoothY); ectx.lineTo(b.smoothX,b.smoothY); ectx.stroke();
        }
      });
      ectx.globalAlpha=1;

      // Trail
      ectx.beginPath(); ectx.arc(a.smoothX,a.smoothY,a.size*0.5,0,Math.PI*2);
      ectx.fillStyle=`hsla(${a.hue},80%,60%,0.12)`; ectx.fill();

      // Agent dot
      ectx.beginPath(); ectx.arc(a.smoothX,a.smoothY,a.size,0,Math.PI*2);
      ectx.fillStyle=`hsla(${a.hue},80%,60%,0.85)`; ectx.fill();
      ectx.beginPath(); ectx.arc(a.smoothX,a.smoothY,3,0,Math.PI*2);
      ectx.fillStyle='#FFFFFF'; ectx.fill();
    });

    if(agents.length===0){
      ectx.fillStyle='rgba(255,255,255,0.15)'; ectx.font='13px sans-serif'; ectx.textAlign='center';
      ectx.fillText('Click to plant agents', eW/2, eH/2);
    }

    requestAnimationFrame(emergentLoop);
  }
  requestAnimationFrame(emergentLoop);
})();
</script>
<!-- SECTION 8: ARTISTS -->
<section id="artists">
<div class="section-label">Key Practitioners</div>
<h2><strong>Artists</strong> of Interactive Art</h2>
<p>Eight figures who fundamentally changed the relationship between artwork and audience — making participation not a supplement, but the very substance of the work.</p>
<div class="artists-grid" id="artists-grid"></div>
</section>
<!-- SECTION 9: GLOSSARY -->
<section id="glossary">
<div class="section-label">Terminology</div>
<h2><strong>Glossary</strong></h2>
<p>Core vocabulary for understanding interactive, participatory, and responsive art systems.</p>
<div class="glossary-grid" id="glossary-grid"></div>
</section>
<footer>Interactive Art World  ·  Participatory &amp; Responsive Art  ·  Audience as Medium</footer>
<script>
// ===== ARTISTS SECTION =====
(function() {
  const artists = [
    {
      name: 'Nam June Paik',
      era: '1960s–2000s', medium: 'Video, Installation, Performance',
      works: ['TV Buddha (1974)', 'TV Garden (1974)', 'Electronic Superhighway (1995)'],
      philosophy: 'Television is the canvas of the 21st century. Paik made the viewer\'s reflection — literally and figuratively — central to his closed-circuit video works.',
      hues: [0, 330, 15],
    },
    {
      name: 'Yoko Ono',
      era: '1960s–present', medium: 'Instruction Art, Performance, Fluxus',
      works: ['Grapefruit (1964)', 'Cut Piece (1964)', 'Wish Tree (1996)'],
      philosophy: 'The artwork is an instruction; the participant is the performer. Ono distributed agency entirely to the audience, completing the work through their action.',
      hues: [300, 20, 340],
    },
    {
      name: 'Allan Kaprow',
      era: '1960s–2000s', medium: 'Happenings, Environmental Art',
      works: ['18 Happenings in 6 Parts (1959)', 'Yard (1961)', 'Fluids (1967)'],
      philosophy: 'The line between art and life must be kept fluid, even indistinct. Kaprow erased the audience-performer boundary, making everyday action into artistic event.',
      hues: [200, 170, 220],
    },
    {
      name: 'Rafael Lozano-Hemmer',
      era: '1990s–present', medium: 'Electronic Installation, Biometrics',
      works: ['Pulse Room (2006)', 'Body Movies (2001)', 'Vectorial Elevation (1999)'],
      philosophy: 'Presence activates the work. Lozano-Hemmer\'s installations use biometric data — heartbeats, breathing, shadows — to make the visitor\'s body the generator of the artwork.',
      hues: [350, 20, 330],
    },
    {
      name: 'teamLab',
      era: '2001–present', medium: 'Digital Installation, Immersive Environments',
      works: ['Crystal Universe (2015)', 'Borderless (2018)', 'Ever Blossoming Life Rock (2017)'],
      philosophy: 'The boundary between body and art dissolves. teamLab\'s digital ecologies change in real time in response to visitors — presence literally alters the living artwork.',
      hues: [220, 280, 160],
    },
    {
      name: 'Ryoji Ikeda',
      era: '1990s–present', medium: 'Data Art, Sound, Minimal Electronics',
      works: ['test pattern (2008)', 'data.tron (2008)', 'superposition (2012)'],
      philosophy: 'Data is the raw material of reality. Ikeda translates the invisible — binary code, mathematical constants — into overwhelming audiovisual experience, making pure information perceptible.',
      hues: [0, 0, 60],
    },
    {
      name: 'Olafur Eliasson',
      era: '1990s–present', medium: 'Large-Scale Installation, Environment',
      works: ['The Weather Project (2003)', 'Ice Watch (2014)', 'In Real Life (ongoing)'],
      philosophy: 'You are the co-producer of this reality. Eliasson\'s environments make the conditions of perception visible — light, atmosphere, movement — asking visitors to notice their own presence.',
      hues: [40, 15, 55],
    },
    {
      name: 'Random International',
      era: '2005–present', medium: 'Kinetic Installation, Robotic Systems',
      works: ['Rain Room (2012)', 'Swarm Study (2011)', 'Future Self (2012)'],
      philosophy: 'The machine responds to the human. Random International builds systems that sense, track, and react to individual bodies — creating an uncanny intimacy between visitor and mechanism.',
      hues: [210, 195, 240],
    },
  ];

  const grid = document.getElementById('artists-grid');
  artists.forEach(a => {
    const card = document.createElement('div');
    card.className = 'artist-card';

    // Geometric avatar canvas
    const av = document.createElement('canvas');
    av.className = 'artist-avatar';
    av.width = 240; av.height = 120;
    card.appendChild(av);

    const ctx = av.getContext('2d');
    // Draw abstract portrait
    ctx.fillStyle = '#1A1A1A'; ctx.fillRect(0,0,240,120);
    const [h1,h2,h3] = a.hues;
    const grd = ctx.createLinearGradient(0,0,240,120);
    grd.addColorStop(0,`hsla(${h1},70%,40%,0.6)`);
    grd.addColorStop(0.5,`hsla(${h2},80%,50%,0.4)`);
    grd.addColorStop(1,`hsla(${h3},60%,35%,0.6)`);
    ctx.fillStyle=grd; ctx.fillRect(0,0,240,120);

    // Geometric shapes
    ctx.strokeStyle='rgba(255,255,255,0.5)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.arc(120,60,35,0,Math.PI*2); ctx.stroke();
    ctx.strokeStyle='rgba(255,45,120,0.7)'; ctx.lineWidth=1.5;
    ctx.beginPath(); ctx.rect(88,28,64,64); ctx.stroke();
    ctx.strokeStyle='rgba(255,255,255,0.25)'; ctx.lineWidth=0.8;
    ctx.beginPath(); ctx.moveTo(55,10); ctx.lineTo(185,110); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(185,10); ctx.lineTo(55,110); ctx.stroke();
    ctx.fillStyle='rgba(255,45,120,0.8)';
    ctx.beginPath(); ctx.arc(120,60,6,0,Math.PI*2); ctx.fill();

    // Name initial
    ctx.fillStyle='rgba(255,255,255,0.15)';
    ctx.font='bold 42px Arial'; ctx.textAlign='center';
    ctx.fillText(a.name.split(' ').map(w=>w[0]).join(''), 120, 72);

    const body = document.createElement('div');
    body.className = 'artist-body';
    body.innerHTML = `
      <div class="artist-name">${a.name}</div>
      <div class="artist-era">${a.era}</div>
      <div class="artist-medium">${a.medium}</div>
      <div class="artist-works">${a.works.join(' · ')}</div>
      <div class="artist-philosophy">"${a.philosophy}"</div>`;
    card.appendChild(body);
    grid.appendChild(card);
  });
})();

// ===== GLOSSARY SECTION =====
(function() {
  const terms = [
    ['Affordance', 'The perceived properties of an object or system that suggest how it can be used. In interactive art, affordances invite participation.'],
    ['Agency', 'The capacity of an audience member to make meaningful choices that affect the artwork. A work has agency when choices produce real consequences.'],
    ['Audience', 'In participatory art, not a passive receiver but an active co-producer. The audience\'s presence, movement, or input generates the work.'],
    ['Biofeedback', 'Physiological data — heartrate, breathing, skin conductance — used as input to an artwork, making the body\'s invisible state visible.'],
    ['Co-creation', 'A mode of artistic production where audience participation is not incidental but constitutive — the work cannot exist without the participant.'],
    ['Embodiment', 'The grounding of perception and meaning in the physical body. Embodied interaction recognizes that the body, not just the mind, engages art.'],
    ['Emergence', 'Complex patterns or behaviors arising from simple rules and local interactions. Emergent artworks cannot be predicted from their components alone.'],
    ['Feedback Loop', 'A system in which output becomes input. Closed-circuit video, biometric response systems, and social dynamics all operate as feedback loops.'],
    ['Haptic', 'Relating to the sense of touch. Haptic interfaces communicate through physical sensation — vibration, pressure, temperature, texture.'],
    ['Immersion', 'A perceptual state where the environment feels total — surrounding, enveloping, or replacing ordinary reality. Immersion erases the frame of the artwork.'],
    ['Installation', 'An artwork defined by its occupation of a specific space. Viewers enter and move through an installation rather than viewing it from outside.'],
    ['Interactivity', 'A quality of systems that respond to input in meaningful, non-trivial ways. True interactivity requires that choices produce differentiated outcomes.'],
    ['Latency', 'The delay between an action and its response. In real-time interactive art, minimizing latency is crucial; perceptible lag breaks the sense of presence.'],
    ['Mapping', 'The relationship between input and output parameters. A mapping determines how a physical gesture becomes a visual or sonic event.'],
    ['Participatory', 'A mode of art production where audience action is required for the work to function. Participation is structural, not optional.'],
    ['Presence', 'The felt sense of "being there." In interactive art, presence refers both to the visitor\'s physical being and to the perceptual sense of inhabiting a virtual space.'],
    ['Proximity', 'Physical closeness as artistic input. Proximity sensors translate spatial relationship — near/far — into parameters that shape the work.'],
    ['Responsive', 'A system or environment that perceives and reacts to the actions or presence of participants. Responsiveness is the technical basis of interactivity.'],
    ['Sensor', 'A device that detects physical phenomena — motion, heat, pressure, sound, light — and converts them into data that can drive an artistic system.'],
    ['Social Practice', 'Art that engages communities and social structures as its primary medium, prioritizing relationships, dialogue, and collective action over objects.'],
    ['Telematics', 'The transmission of presence across distance. Telematic art connects participants in different locations through network systems, making geography irrelevant.'],
    ['Threshold', 'A boundary or limit within an interactive system. Crossing a threshold — spatial, temporal, or behavioral — triggers a change in the artwork\'s state.'],
  ];

  const glossGrid = document.getElementById('glossary-grid');
  terms.forEach(([term, def]) => {
    const item = document.createElement('div');
    item.className = 'gloss-item';
    item.innerHTML = `<div class="gloss-term">${term}</div><div class="gloss-def">${def}</div>`;
    glossGrid.appendChild(item);
  });
})();

// ===== INTERSECTION OBSERVER =====
(function() {
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.10 });

  document.querySelectorAll('section').forEach(s => {
    if (s.id !== 'hero') observer.observe(s);
    else s.classList.add('visible');
  });
})();
</script>
