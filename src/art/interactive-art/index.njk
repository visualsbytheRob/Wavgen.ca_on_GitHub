<p style="font-size:0.8rem;color:rgba(255,255,255,0.5);margin-bottom:0.75rem">Move your mouse slowly up and down at a breathing rhythm (~4s per cycle). The canvas atmosphere synchronizes to your breath.</p>
<div class="canvas-wrap">
<canvas height="300" id="breath-canvas" width="800"></canvas>
<div class="canvas-label">BREATH RESONANCE</div>
</div>
</div>
</section>
<script>
// ===== ENVIRONMENT BUILDER =====
(function() {
  const canvas = document.getElementById('env-canvas');
  const ctx = canvas.getContext('2d');
  const W = 600, H = 400;
  let mode = 'trigger';
  let respType = 'color';
  const triggers = [];
  const visitors = [];
  const particles = [];
  let simRunning = false;
  let interactionScore = 0;
  let lastT = performance.now();

  // Mode buttons
  document.querySelectorAll('[data-mode]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-mode]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      mode = btn.dataset.mode;
    });
  });
  document.querySelectorAll('[data-resp]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-resp]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      respType = btn.dataset.resp;
    });
  });

  canvas.addEventListener('click', e => {
    const r = canvas.getBoundingClientRect();
    const x = (e.clientX - r.left) * (W / r.width);
    const y = (e.clientY - r.top) * (H / r.height);
    if (mode === 'trigger') {
      triggers.push({ x, y, radius: 35, type: respType,
        activation: 0, activationSmooth: 0, heatmap: 0 });
      document.getElementById('env-zones').textContent = triggers.length;
    } else {
      visitors.push({ x: Math.random()*W, y: Math.random()*H,
        tx: x, ty: y, vx: 0, vy: 0, speed: 1.5+Math.random(),
        smoothX: Math.random()*W, smoothY: Math.random()*H });
    }
  });

  document.getElementById('env-simulate').addEventListener('click', () => {
    simRunning = !simRunning;
    document.getElementById('env-simulate').textContent = simRunning ? 'Pause Simulation' : 'Simulate Visitors';
    if (simRunning && visitors.length === 0) {
      for (let i = 0; i < 6; i++) {
        visitors.push({ x: Math.random()*W, y: Math.random()*H,
          tx: Math.random()*W, ty: Math.random()*H,
          vx: 0, vy: 0, speed: 1+Math.random()*1.5,
          smoothX: Math.random()*W, smoothY: Math.random()*H });
      }
    }
  });

  document.getElementById('env-clear').addEventListener('click', () => {
    triggers.length = 0; visitors.length = 0; particles.length = 0;
    interactionScore = 0; simRunning = false;
    document.getElementById('env-score').textContent = 0;
    document.getElementById('env-zones').textContent = 0;
    document.getElementById('env-simulate').textContent = 'Simulate Visitors';
  });

  document.getElementById('env-export').addEventListener('click', () => {
    const spec = {
      installation: { name: 'Custom Installation', date: new Date().toISOString(),
        triggers: triggers.map(t => ({ x: t.x.toFixed(0), y: t.y.toFixed(0), type: t.type, radius: t.radius })),
        visitors: visitors.length, totalInteractions: interactionScore }
    };
    const blob = new Blob([JSON.stringify(spec, null, 2)], { type: 'application/json' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
    a.download = 'installation_spec.json'; a.click();
  });

  const respColors = { color: '#FF2D78', particle: '#FF8EC8', light: '#FFFFFF', sound: '#FF2D78' };

  function envLoop(ts) {
    const dt = Math.min((ts - lastT) / 1000, 0.05);
    lastT = ts;

    ctx.fillStyle = 'rgba(10,10,10,0.35)';
    ctx.fillRect(0, 0, W, H);

    // Grid
    ctx.strokeStyle = 'rgba(255,45,120,0.05)'; ctx.lineWidth = 0.5;
    for (let x = 0; x <= W; x += 40) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }
    for (let y = 0; y <= H; y += 40) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }

    // Update triggers heatmap
    triggers.forEach(t => {
      t.activation = 0;
    });

    // Update visitors
    if (simRunning) {
      visitors.forEach(v => {
        if (Math.random() < 0.003) { v.tx = Math.random()*W; v.ty = Math.random()*H; }
        const dx = v.tx - v.x, dy = v.ty - v.y;
        const d = Math.sqrt(dx*dx+dy*dy);
        if (d < 8) { v.tx = Math.random()*W; v.ty = Math.random()*H; }
        else {
          v.vx += (dx/d * v.speed - v.vx) * 0.08;
          v.vy += (dy/d * v.speed - v.vy) * 0.08;
          v.x += v.vx; v.y += v.vy;
        }
        // LagFilter env visitor smooth position
        v.smoothX += (1 - Math.exp(-dt / 0.12)) * (v.x - v.smoothX);
        v.smoothY += (1 - Math.exp(-dt / 0.12)) * (v.y - v.smoothY);

        // Check triggers
        triggers.forEach(t => {
          const dd = Math.sqrt((v.x-t.x)**2+(v.y-t.y)**2);
          if (dd < t.radius) {
            t.activation = 1;
            t.heatmap = Math.min(t.heatmap + dt * 0.4, 1);
          }
        });
      });
    }

    // Draw trigger zones + responses
    triggers.forEach(t => {
      // LagFilter trigger activation
      t.activationSmooth += (1 - Math.exp(-dt / 0.18)) * (t.activation - t.activationSmooth);
      if (t.activation && !t._prevActive) { interactionScore++; document.getElementById('env-score').textContent = interactionScore; }
      t._prevActive = t.activation;

      const a = t.activationSmooth;
      // Heatmap ring
      ctx.beginPath(); ctx.arc(t.x, t.y, t.radius, 0, Math.PI*2);
      ctx.fillStyle = `rgba(255,45,120,${0.04 + t.heatmap * 0.12})`; ctx.fill();
      ctx.strokeStyle = `rgba(${respColors[t.type].slice(1).match(/../g).map(h=>parseInt(h,16)).join(',')},${0.3+a*0.6})`;
      ctx.lineWidth = 1+a; ctx.stroke();

      // Response visualization
      if (t.type === 'color' && a > 0.1) {
        ctx.fillStyle = `rgba(255,45,120,${a*0.3})`; ctx.fillRect(t.x-t.radius,t.y-t.radius,t.radius*2,t.radius*2);
      }
      if (t.type === 'light' && a > 0.1) {
        const grd = ctx.createRadialGradient(t.x,t.y,0,t.x,t.y,t.radius*1.5);
        grd.addColorStop(0,`rgba(255,255,255,${a*0.25})`); grd.addColorStop(1,'rgba(255,255,255,0)');
        ctx.fillStyle=grd; ctx.beginPath(); ctx.arc(t.x,t.y,t.radius*1.5,0,Math.PI*2); ctx.fill();
      }
      if (t.type === 'particle' && a > 0.5 && Math.random() < 0.4) {
        const ang = Math.random()*Math.PI*2;
        particles.push({x:t.x,y:t.y,vx:Math.cos(ang)*2,vy:Math.sin(ang)*2,life:0.8,size:3});
      }
      if (t.type === 'sound' && a > 0.1) {
        const rings = 3;
        for (let i=0;i<rings;i++) {
          const phase = ((ts/1000*0.8+i*0.33)%1);
          ctx.beginPath(); ctx.arc(t.x,t.y,phase*t.radius*1.3,0,Math.PI*2);
          ctx.strokeStyle=`rgba(255,45,120,${(1-phase)*a*0.5})`; ctx.lineWidth=0.8; ctx.stroke();
        }
      }

      // Label
      ctx.fillStyle = 'rgba(255,255,255,0.5)'; ctx.font = '8px sans-serif'; ctx.textAlign = 'center';
      ctx.fillText(t.type.toUpperCase(), t.x, t.y + 3);
    });

    // Particles
    for (let i=particles.length-1;i>=0;i--) {
      const p=particles[i]; p.x+=p.vx; p.y+=p.vy; p.life-=dt*1.5;
      if(p.life<=0){particles.splice(i,1);continue;}
      ctx.globalAlpha=p.life; ctx.fillStyle='#FF8EC8';
      ctx.beginPath();ctx.arc(p.x,p.y,p.size*p.life,0,Math.PI*2);ctx.fill();
    }
    ctx.globalAlpha=1;

    // Visitors
    visitors.forEach((v,i) => {
      ctx.beginPath(); ctx.arc(v.smoothX, v.smoothY, 5, 0, Math.PI*2);
      ctx.fillStyle = '#FFFFFF'; ctx.globalAlpha = 0.85; ctx.fill();
      ctx.beginPath(); ctx.arc(v.smoothX, v.smoothY, 8, 0, Math.PI*2);
      ctx.strokeStyle = 'rgba(255,255,255,0.3)'; ctx.lineWidth=0.8; ctx.stroke();
      ctx.globalAlpha=1;
    });

    requestAnimationFrame(envLoop);
  }
  requestAnimationFrame(envLoop);
})();

// ===== EMBODIMENT SECTION =====
(function() {
  // Tab switching
  document.querySelectorAll('.e-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.e-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.e-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById('ep-' + tab.dataset.tab).classList.add('active');
    });
  });

  // ---- Body as Brush ----
  const brushCanvas = document.getElementById('brush-canvas');
  const bctx = brushCanvas.getContext('2d');
  let bW = brushCanvas.width, bH = brushCanvas.height;
  bctx.fillStyle = '#050505'; bctx.fillRect(0,0,bW,bH);
  let bmx = bW/2, bmy = bH/2, bpx = bW/2, bpy = bH/2;
  let bmxS = bW/2, bmyS = bH/2; // smoothed
  let bvx = 0, bvy = 0, bspeed = 0, bspeedS = 0;
  let bhue = 0, bhuS = 0;
  let bLastT = performance.now();
  let brushActive = false;

  brushCanvas.addEventListener('mousemove', e => {
    const r = brushCanvas.getBoundingClientRect();
    bmx = (e.clientX - r.left) * (bW / r.width);
    bmy = (e.clientY - r.top) * (bH / r.height);
    brushActive = true;
  });
  brushCanvas.addEventListener('mouseleave', () => { brushActive = false; });

  document.getElementById('brush-clear').addEventListener('click', () => {
    bctx.fillStyle='#050505'; bctx.fillRect(0,0,bW,bH);
  });

  function brushLoop(ts) {
    const dt = Math.min((ts - bLastT)/1000, 0.05);
    bLastT = ts;
    if (!brushActive) { requestAnimationFrame(brushLoop); return; }

    const rawVx = (bmx - bpx) / (dt + 0.001);
    const rawVy = (bmy - bpy) / (dt + 0.001);
    bpx = bmx; bpy = bmy;
    // LagFilter brush velocity
    bvx += (1 - Math.exp(-dt / 0.06)) * (rawVx - bvx);
    bvy += (1 - Math.exp(-dt / 0.06)) * (rawVy - bvy);
    bspeed = Math.sqrt(bvx*bvx+bvy*bvy);
    // LagFilter brush speed
    bspeedS += (1 - Math.exp(-dt / 0.15)) * (bspeed - bspeedS);
    // LagFilter brush position
    bmxS += (1 - Math.exp(-dt / 0.05)) * (bmx - bmxS);
    bmyS += (1 - Math.exp(-dt / 0.05)) * (bmy - bmyS);

    const rawHue = (Math.atan2(bvy, bvx) / (Math.PI*2) + 1) % 1 * 360;
    // LagFilter hue
    bhuS += (1 - Math.exp(-dt / 0.3)) * (rawHue - bhuS);

    const size = 2 + Math.min(bspeedS / 80, 1) * 22;
    const alpha = 0.35 + Math.min(bspeedS / 600, 0.5);
    bctx.globalAlpha = alpha;
    bctx.beginPath();
    bctx.arc(bmxS, bmyS, size, 0, Math.PI*2);
    bctx.fillStyle = `hsl(${bhuS},90%,62%)`;
    bctx.fill();
    bctx.globalAlpha = 1;

    requestAnimationFrame(brushLoop);
  }
  requestAnimationFrame(brushLoop);

  // ---- Shadow Puppetry ----
  const shadowCanvas = document.getElementById('shadow-canvas');
  const sctx = shadowCanvas.getContext('2d');
  const sW = shadowCanvas.width, sH = shadowCanvas.height;
  let smx = sW/2, smy = sH*0.7;
  let smxS = sW/2, smyS = sH*0.7;
  let sLastT = performance.now();

  // Floating elements
  const floaters = Array.from({length:8}, (_,i) => ({
    x: 60 + i * 95, y: sH*0.3 + Math.sin(i)*30,
    baseY: sH*0.3 + Math.sin(i)*30,
    vx: 0, vy: 0, size: 12+i*4,
    phase: i * 0.7,
  }));

  shadowCanvas.addEventListener('mousemove', e => {
    const r = shadowCanvas.getBoundingClientRect();
    smx = (e.clientX - r.left) * (sW / r.width);
    smy = (e.clientY - r.top) * (sH / r.height);
  });

  function shadowLoop(ts) {
    const dt = Math.min((ts - sLastT)/1000, 0.05);
    sLastT = ts;
    const t = ts / 1000;
    // LagFilter shadow hand position
    smxS += (1 - Math.exp(-dt / 0.1)) * (smx - smxS);
    smyS += (1 - Math.exp(-dt / 0.1)) * (smy - smyS);

    sctx.fillStyle = 'rgba(5,5,5,0.55)'; sctx.fillRect(0,0,sW,sH);

    // Ambient light from top
    const grd = sctx.createLinearGradient(0,0,0,sH);
    grd.addColorStop(0,'rgba(255,45,120,0.06)');
    grd.addColorStop(1,'rgba(0,0,0,0)');
    sctx.fillStyle=grd; sctx.fillRect(0,0,sW,sH);

    // Ground / stage floor
    sctx.fillStyle='rgba(255,45,120,0.05)';
    sctx.fillRect(0, sH*0.72, sW, sH*0.28);
    sctx.strokeStyle='rgba(255,45,120,0.3)'; sctx.lineWidth=1;
    sctx.beginPath(); sctx.moveTo(0,sH*0.72); sctx.lineTo(sW,sH*0.72); sctx.stroke();

    // Floaters react to shadow hand
    floaters.forEach(f => {
      const dx = smxS - f.x, dy = smyS - f.y;
      const d = Math.sqrt(dx*dx+dy*dy);
      const repel = Math.max(0, 1 - d/90);
      f.vy += (-dy/Math.max(d,1) * repel * 3 - f.vy * 0.12);
      f.vx += (-dx/Math.max(d,1) * repel * 2 - f.vx * 0.1);
      f.y += f.vy * dt * 60;
      f.x += f.vx * dt * 60;
      f.y += (f.baseY + Math.sin(t*0.8+f.phase)*10 - f.y) * 0.04;
      f.x += (60 + floaters.indexOf(f)*95 - f.x) * 0.02;

      const shadowLen = Math.max(0, (sH*0.72 - f.y) * 0.3);
      const shadowAlpha = 0.12 * (1 - d/200);
      sctx.save();
      sctx.globalAlpha = Math.max(0.02, shadowAlpha);
      sctx.beginPath();
      sctx.ellipse(f.x, sH*0.72, f.size * 0.8, 4, 0, 0, Math.PI*2);
      sctx.fillStyle='rgba(0,0,0,0.6)'; sctx.fill();
      sctx.restore();

      sctx.globalAlpha = 0.7 + repel * 0.3;
      sctx.fillStyle = '#FFFFFF';
      sctx.beginPath(); sctx.arc(f.x, f.y, f.size, 0, Math.PI*2); sctx.fill();
      sctx.globalAlpha=1;
    });

    // Hand shadow
    const hx = smxS, hy = Math.min(smyS, sH*0.7);
    const fingers = 5;
    for (let fi = 0; fi < fingers; fi++) {
      const fa = -0.5 + fi * 0.26;
      const fLen = 30 + fi * 5;
      const fx = hx + Math.sin(fa) * fLen;
      const fy = hy - Math.cos(fa) * fLen;
      sctx.beginPath(); sctx.moveTo(hx, hy); sctx.lineTo(fx, fy);
      sctx.strokeStyle='rgba(10,10,10,0.9)'; sctx.lineWidth = 6-fi; sctx.stroke();
      sctx.beginPath(); sctx.arc(fx, fy, 4, 0, Math.PI*2);
      sctx.fillStyle='rgba(10,10,10,0.9)'; sctx.fill();
    }
    sctx.beginPath(); sctx.arc(hx, hy, 12, 0, Math.PI*2);
    sctx.fillStyle='rgba(10,10,10,0.85)'; sctx.fill();

    requestAnimationFrame(shadowLoop);
  }
  requestAnimationFrame(shadowLoop);

  // ---- Breath Sync ----
  const breathCanvas = document.getElementById('breath-canvas');
  const rctx = breathCanvas.getContext('2d');
  const rW = breathCanvas.width, rH = breathCanvas.height;
  let rmy = rH/2, rmyPrev = rH/2;
  let breathPhase = 0, breathPhaseS = 0;
  let breathVel = 0, breathVelS = 0;
  let bLastT2 = performance.now();

  breathCanvas.addEventListener('mousemove', e => {
    const r = breathCanvas.getBoundingClientRect();
    rmy = (e.clientY - r.top) * (rH / r.height);
  });

  function breathLoop(ts) {
    const dt = Math.min((ts - bLastT2)/1000, 0.05);
    bLastT2 = ts;
    const rawVel = (rmy - rmyPrev) / (dt + 0.001);
    rmyPrev = rmy;
    // LagFilter breath velocity
    breathVelS += (1 - Math.exp(-dt / 0.5)) * (rawVel - breathVelS);
    // Phase: moving up = exhale, down = inhale (map y to 0..1)
    const rawPhase = rmy / rH;
    // LagFilter breath phase
    breathPhaseS += (1 - Math.exp(-dt / 0.8)) * (rawPhase - breathPhaseS);

    rctx.fillStyle = 'rgba(5,5,5,0.08)'; rctx.fillRect(0,0,rW,rH);

    // Atmosphere pulse
    const pulse = breathPhaseS;
    const grd = rctx.createRadialGradient(rW/2,rH/2,0,rW/2,rH/2,rW*0.6);
    grd.addColorStop(0,`rgba(255,45,120,${0.04+pulse*0.12})`);
    grd.addColorStop(0.5,`rgba(255,142,200,${0.02+pulse*0.06})`);
    grd.addColorStop(1,'rgba(0,0,0,0)');
    rctx.fillStyle=grd; rctx.fillRect(0,0,rW,rH);

    // Breathing rings
    const numRings = 7;
    for(let i=0;i<numRings;i++){
      const r = 20 + i*28 + pulse*30;
      const a = 0.4 - i*0.05 + (1-pulse)*0.1;
      rctx.beginPath(); rctx.arc(rW/2,rH/2,r,0,Math.PI*2);
      rctx.strokeStyle=`rgba(255,${Math.round(45+pulse*130)},120,${Math.max(0,a)})`;
      rctx.lineWidth=1.5-i*0.15; rctx.stroke();
    }

    // Breath indicator dot
    const dotY = rH * breathPhaseS;
    rctx.beginPath(); rctx.arc(20, dotY, 5, 0, Math.PI*2);
    rctx.fillStyle='#FF2D78'; rctx.fill();
    rctx.fillStyle='rgba(255,255,255,0.3)'; rctx.font='9px monospace'; rctx.textAlign='left';
    rctx.fillText(pulse < 0.5 ? 'INHALE' : 'EXHALE', 32, dotY+4);

    requestAnimationFrame(breathLoop);
  }
  requestAnimationFrame(breathLoop);
})();
</script>
<!-- SECTION 6: IMMERSIVE INSTALLATION TYPES -->
