<script>
// ===== HERO CANVAS =====
(function() {
  const canvas = document.getElementById('hero-canvas');
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  // Mouse state
  let mxRaw = W/2, myRaw = H/2;
  let mx = W/2, my = H/2;           // LagFiltered position
  let mvx = 0, mvy = 0;             // LagFiltered velocity
  let prevMxRaw = W/2, prevMyRaw = H/2;
  let mSpeed = 0, mSpeedSmooth = 0; // LagFiltered speed
  let lastT = performance.now();

  canvas.addEventListener('mousemove', e => {
    const r = canvas.getBoundingClientRect();
    mxRaw = e.clientX - r.left;
    myRaw = e.clientY - r.top;
  });
  canvas.addEventListener('touchmove', e => {
    e.preventDefault();
    const r = canvas.getBoundingClientRect();
    mxRaw = e.touches[0].clientX - r.left;
    myRaw = e.touches[0].clientY - r.top;
  }, { passive: false });

  // Explosion particles
  const particles = [];
  canvas.addEventListener('click', e => {
    const r = canvas.getBoundingClientRect();
    const cx = e.clientX - r.left, cy = e.clientY - r.top;
    for (let i = 0; i < 48; i++) {
      const ang = Math.random() * Math.PI * 2;
      const spd = 2 + Math.random() * 7;
      particles.push({ x: cx, y: cy, vx: Math.cos(ang)*spd, vy: Math.sin(ang)*spd,
        life: 1, size: 2 + Math.random()*4, color: Math.random() > 0.5 ? '#FF2D78' : '#FFFFFF' });
    }
  });

  // Orbital shapes
  const NUM_SHAPES = 32;
  const shapes = Array.from({ length: NUM_SHAPES }, (_, i) => ({
    baseAngle: (i / NUM_SHAPES) * Math.PI * 2,
    angle: (i / NUM_SHAPES) * Math.PI * 2,
    orbitR: 60 + (i % 6) * 28,
    size: 3 + (i % 4) * 3,
    speed: 0.006 + (i % 5) * 0.003,
    x: W/2, y: H/2,
    targetX: W/2, targetY: H/2,
    smoothX: W/2, smoothY: H/2,   // LagFiltered shape position
    phase: Math.random() * Math.PI * 2,
    type: i % 3,  // 0=circle, 1=rect, 2=line
  }));

  // Ambient orbit center (LagFiltered toward cursor)
  let orbitCX = W/2, orbitCY = H/2;

  // Background pulse
  let bgAlpha = 0, bgAlphaTarget = 0;

  function draw(ts) {
    const dt = Math.min((ts - lastT) / 1000, 0.05);
    lastT = ts;
    const tau1 = 0.12, tau2 = 0.07, tau3 = 0.25;

    // LagFilter 1 & 2: smooth cursor position
    mx += (1 - Math.exp(-dt / tau1)) * (mxRaw - mx);
    my += (1 - Math.exp(-dt / tau1)) * (myRaw - my);

    // LagFilter 3 & 4: smooth velocity
    const rawVx = (mxRaw - prevMxRaw) / (dt + 0.001);
    const rawVy = (myRaw - prevMyRaw) / (dt + 0.001);
    mvx += (1 - Math.exp(-dt / tau2)) * (rawVx - mvx);
    mvy += (1 - Math.exp(-dt / tau2)) * (rawVy - mvy);
    prevMxRaw = mxRaw; prevMyRaw = myRaw;

    // Speed magnitude
    mSpeed = Math.sqrt(mvx*mvx + mvy*mvy);
    // LagFilter 5: smooth speed
    mSpeedSmooth += (1 - Math.exp(-dt / tau3)) * (mSpeed - mSpeedSmooth);

    // LagFilter 6 & 7: orbit center follows cursor
    orbitCX += (1 - Math.exp(-dt / 0.2)) * (mx - orbitCX);
    orbitCY += (1 - Math.exp(-dt / 0.2)) * (my - orbitCY);

    // Magenta brightness based on speed
    const speedNorm = Math.min(mSpeedSmooth / 600, 1);
    bgAlphaTarget = 0.05 + speedNorm * 0.35;
    // LagFilter 8: smooth bg brightness
    bgAlpha += (1 - Math.exp(-dt / 0.4)) * (bgAlphaTarget - bgAlpha);

    // Phosphor persistence
    ctx.fillStyle = 'rgba(0,0,0,0.04)';
    ctx.fillRect(0, 0, W, H);

    // Magenta field
    const grd = ctx.createRadialGradient(orbitCX, orbitCY, 0, orbitCX, orbitCY, Math.max(W,H)*0.6);
    grd.addColorStop(0, `rgba(255,45,120,${bgAlpha})`);
    grd.addColorStop(1, 'rgba(255,45,120,0)');
    ctx.fillStyle = grd;
    ctx.fillRect(0, 0, W, H);

    // Update & draw shapes
    shapes.forEach((s, i) => {
      s.angle += s.speed * (1 + speedNorm * 2.5);
      // Distort radius when still
      const stillFactor = 1 - speedNorm;
      const distort = Math.sin(s.phase + ts * 0.001 * (i % 3 + 1)) * stillFactor * 18;
      const r = s.orbitR + distort;
      s.targetX = orbitCX + Math.cos(s.angle) * r;
      s.targetY = orbitCY + Math.sin(s.angle) * r;
      // LagFilter 9 & 10: smooth shape position
      s.smoothX += (1 - Math.exp(-dt / 0.08)) * (s.targetX - s.smoothX);
      s.smoothY += (1 - Math.exp(-dt / 0.08)) * (s.targetY - s.smoothY);

      const alpha = 0.25 + speedNorm * 0.55;
      ctx.save();
      ctx.globalAlpha = alpha;
      if (s.type === 0) {
        ctx.beginPath();
        ctx.arc(s.smoothX, s.smoothY, s.size, 0, Math.PI * 2);
        ctx.strokeStyle = i % 4 === 0 ? '#FF2D78' : '#FFFFFF';
        ctx.lineWidth = 1;
        ctx.stroke();
      } else if (s.type === 1) {
        ctx.strokeStyle = '#FF8EC8';
        ctx.lineWidth = 1;
        ctx.strokeRect(s.smoothX - s.size/2, s.smoothY - s.size/2, s.size, s.size);
      } else {
        ctx.beginPath();
        ctx.moveTo(orbitCX, orbitCY);
        ctx.lineTo(s.smoothX, s.smoothY);
        ctx.strokeStyle = 'rgba(255,45,120,0.18)';
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }
      ctx.restore();
    });

    // Explosion particles
    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.x += p.vx; p.y += p.vy;
      p.vx *= 0.94; p.vy *= 0.94;
      p.life -= dt * 1.2;
      if (p.life <= 0) { particles.splice(i, 1); continue; }
      ctx.globalAlpha = p.life * 0.9;
      ctx.fillStyle = p.color;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;

    // Cursor dot
    ctx.beginPath();
    ctx.arc(mx, my, 4, 0, Math.PI * 2);
    ctx.fillStyle = '#FF2D78';
    ctx.fill();
    ctx.beginPath();
    ctx.arc(mx, my, 10 + speedNorm * 12, 0, Math.PI * 2);
    ctx.strokeStyle = 'rgba(255,45,120,0.5)';
    ctx.lineWidth = 1;
    ctx.stroke();

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();
</script>
