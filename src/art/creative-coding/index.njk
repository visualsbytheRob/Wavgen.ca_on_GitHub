<script>
/* ═══════════════════════════════════════════════════════════
   GLOBAL UTILITIES — LagFilter, helpers
   ═══════════════════════════════════════════════════════════ */
class LagFilter {
  constructor(tau = 0.15) { this.tau = tau; this.value = null; }
  update(target, dt) {
    if (this.value === null) { this.value = target; return this.value; }
    this.value += (1 - Math.exp(-dt / this.tau)) * (target - this.value);
    return this.value;
  }
  reset(v) { this.value = v; return v; }
  get() { return this.value; }
}

// Smooth 1-D noise (value noise interpolated)
function smoothNoise1D(x) {
  const ix = Math.floor(x); const fx = x - ix;
  const ux = fx * fx * (3 - 2 * fx);
  return lerp(hash1(ix), hash1(ix + 1), ux);
}
function hash1(n) {
  n = (n << 13) ^ n;
  return (1.0 - ((n * (n * n * 15731 + 789221) + 1376312589) & 0x7fffffff) / 1073741824.0) * 0.5 + 0.5;
}
function lerp(a, b, t) { return a + (b - a) * t; }
function clamp(v, lo, hi) { return v < lo ? lo : v > hi ? hi : v; }

/* ═══════════════════════════════════════════════════════════
   SECTION 1 — HERO: PARTICLE ATTRACTOR SYSTEM
   ═══════════════════════════════════════════════════════════ */
(function initHero() {
  const canvas = document.getElementById('heroCanvas');
  const ctx = canvas.getContext('2d');
  let W = 0, H = 0;

  function resize() {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
  }
  resize();
  new ResizeObserver(resize).observe(canvas);

  // LagFilter instances 1 & 2: mouse attractor smoothing
  const mxLag = new LagFilter(0.07);
  const myLag = new LagFilter(0.07);
  let rawMX = 0.5, rawMY = 0.4;

  document.addEventListener('mousemove', e => {
    const r = canvas.getBoundingClientRect();
    if (e.clientY >= r.top && e.clientY <= r.bottom) {
      rawMX = clamp((e.clientX - r.left) / W, 0.02, 0.98);
      rawMY = clamp((e.clientY - r.top)  / H, 0.02, 0.98);
    }
  });

  // 3 attractors (0 = mouse-driven, 1-2 = autonomous drift)
  const att = [
    { x: 0.5, y: 0.4, str: 0.00020 },
    { x: 0.3, y: 0.6, str: 0.00015 },
    { x: 0.7, y: 0.35, str: 0.00013 }
  ];

  // 800 particles
  const N = 800;
  const px = new Float32Array(N);
  const py = new Float32Array(N);
  const vx = new Float32Array(N);
  const vy = new Float32Array(N);
  for (let i = 0; i < N; i++) {
    px[i] = Math.random();
    py[i] = Math.random();
    vx[i] = (Math.random() - 0.5) * 0.004;
    vy[i] = (Math.random() - 0.5) * 0.004;
  }

  let t0 = 0, phase = 0;

  function heroLoop(ts) {
    const dt = Math.min((ts - t0) / 1000, 0.05); t0 = ts;
    phase += dt;

    // Phosphor persistence — canvas fade
    ctx.fillStyle = 'rgba(5,5,18,0.04)';
    ctx.fillRect(0, 0, W, H);

    // Update mouse attractor via LagFilter (instances 1 & 2)
    att[0].x = mxLag.update(rawMX, dt);
    att[0].y = myLag.update(rawMY, dt);

    // Drift attractors 1 and 2
    att[1].x = 0.5 + 0.33 * Math.sin(phase * 0.21);
    att[1].y = 0.5 + 0.28 * Math.cos(phase * 0.17 + 1.3);
    att[2].x = 0.5 + 0.29 * Math.sin(phase * 0.18 + 2.5);
    att[2].y = 0.5 + 0.26 * Math.cos(phase * 0.24 + 0.7);

    // Update each particle
    for (let i = 0; i < N; i++) {
      let ax = 0, ay = 0;
      for (let a = 0; a < 3; a++) {
        const dx = att[a].x - px[i];
        const dy = att[a].y - py[i];
        const d2 = dx * dx + dy * dy + 0.0008;
        const f  = att[a].str / d2;
        ax += dx * f; ay += dy * f;
      }
      vx[i] = (vx[i] + ax) * 0.983;
      vy[i] = (vy[i] + ay) * 0.983;
      px[i] += vx[i]; py[i] += vy[i];
      // Toroidal wrap
      if (px[i] < 0) px[i] += 1; if (px[i] > 1) px[i] -= 1;
      if (py[i] < 0) py[i] += 1; if (py[i] > 1) py[i] -= 1;
      // Color: slow = deep violet, fast = bright lavender
      const spd = Math.sqrt(vx[i] * vx[i] + vy[i] * vy[i]);
      const t   = Math.min(spd / 0.014, 1);
      const r   = Math.round(124 + t * 72);
      const g   = Math.round(58  + t * 123);
      const b   = Math.round(237 + t * 16);
      ctx.fillStyle = `rgba(${r},${g},${b},0.65)`;
      ctx.fillRect(px[i] * W, py[i] * H, 1.6, 1.6);
    }
    requestAnimationFrame(heroLoop);
  }
  requestAnimationFrame(heroLoop);
})();
</script>
