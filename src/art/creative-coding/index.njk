  });
});

// Mini canvas 1: Math → Beauty (Lissajous)
(function miniMath() {
  const c = document.getElementById('miniMath');
  const ctx = c.getContext('2d');
  let t = 0;
  function loop() {
    ctx.fillStyle = 'rgba(7,5,19,0.06)';
    ctx.fillRect(0, 0, c.width, c.height);
    ctx.beginPath();
    const cx = c.width / 2, cy = c.height / 2;
    const r = 52;
    for (let i = 0; i <= 360; i++) {
      const a = i * Math.PI / 180;
      const x = cx + r * Math.sin(3 * a + t);
      const y = cy + r * Math.sin(2 * a);
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.strokeStyle = `hsl(${260 + Math.sin(t) * 30},80%,72%)`;
    ctx.lineWidth = 1.2;
    ctx.stroke();
    t += 0.012;
    requestAnimationFrame(loop);
  }
  loop();
})();

// Mini canvas 2: Randomness → Texture (stipple)
(function miniRand() {
  const c = document.getElementById('miniRand');
  const ctx = c.getContext('2d');
  ctx.fillStyle = '#070513';
  ctx.fillRect(0, 0, c.width, c.height);
  let phase = 0;
  function loop() {
    ctx.fillStyle = 'rgba(7,5,19,0.018)';
    ctx.fillRect(0, 0, c.width, c.height);
    for (let i = 0; i < 30; i++) {
      const x = Math.random() * c.width;
      const y = Math.random() * c.height;
      const d = Math.sqrt((x - c.width/2)**2 + (y - c.height/2)**2);
      const prob = 1 - d / 90;
      if (Math.random() < prob) {
        const alpha = 0.4 + prob * 0.6;
        ctx.fillStyle = `rgba(167,139,250,${alpha})`;
        ctx.fillRect(x, y, 1, 1);
      }
    }
    phase += 0.02;
    requestAnimationFrame(loop);
  }
  loop();
})();

// Mini canvas 3: Iteration → Complexity (fractal-ish recursive circles)
(function miniIter() {
  const c = document.getElementById('miniIter');
  const ctx = c.getContext('2d');
  let t = 0;
  function drawCircles(x, y, r, depth, hue) {
    if (depth === 0 || r < 1) return;
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.strokeStyle = `hsla(${hue},75%,65%,${0.12 + depth * 0.08})`;
    ctx.lineWidth = 0.8;
    ctx.stroke();
    const angle = t * (1 + depth * 0.3);
    drawCircles(x + r * 0.62 * Math.cos(angle), y + r * 0.62 * Math.sin(angle), r * 0.42, depth - 1, hue + 25);
    drawCircles(x + r * 0.62 * Math.cos(angle + Math.PI), y + r * 0.62 * Math.sin(angle + Math.PI), r * 0.42, depth - 1, hue - 20);
  }
  function loop() {
    ctx.fillStyle = 'rgba(7,5,19,0.12)';
    ctx.fillRect(0, 0, c.width, c.height);
    drawCircles(c.width / 2, c.height / 2, 44, 5, 265);
    t += 0.008;
    requestAnimationFrame(loop);
  }
  loop();
})();
</script>
