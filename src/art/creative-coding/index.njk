<div class="sec hidden" id="patterns">
<p class="sl">Generative Systems</p>
<h2 class="st">Algorithmic Patterns Lab</h2>
<p class="sd">Eight classic pattern-generating algorithms, each tuneable in real time. Every slider uses exponential lag-smoothing for fluid control.</p>
<div class="pat-btns" id="patBtns">
<button class="pat-btn active" data-pat="lissajous">Lissajous</button>
<button class="pat-btn" data-pat="spirograph">Spirograph</button>
<button class="pat-btn" data-pat="voronoi">Voronoi</button>
<button class="pat-btn" data-pat="reactiondiff">Reaction-Diffusion</button>
<button class="pat-btn" data-pat="automata">Cellular Automata</button>
<button class="pat-btn" data-pat="truchet">Truchet</button>
<button class="pat-btn" data-pat="penrose">Penrose</button>
<button class="pat-btn" data-pat="wave">Wave Interference</button>
</div>
<div class="row" style="align-items:flex-start">
<div class="cw" style="flex:1;min-width:280px">
<canvas height="400" id="patCanvas" style="width:100%;display:block" width="600"></canvas>
</div>
<div id="patControls" style="min-width:200px;max-width:240px;display:flex;flex-direction:column;gap:.8rem"></div>
</div>
</div>
<script>
/* ═══════════════════════════════════════════════════════════
   SECTION 3 — ALGORITHMIC PATTERNS LAB
   ═══════════════════════════════════════════════════════════ */
(function initPatterns() {
  const canvas = document.getElementById('patCanvas');
  const ctx    = canvas.getContext('2d');
  const ctrlEl = document.getElementById('patControls');
  let W = canvas.width, H = canvas.height;
  new ResizeObserver(() => {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = Math.round(canvas.offsetWidth * 0.62);
  }).observe(canvas);

  let currentPat = 'lissajous';
  let animId = null;
  let patTime = 0;
  let lastTs  = 0;

  // ── LagFilter instances 3–12 (pattern sliders) ──
  const lags = {};
  function makeLag(key, tau) { lags[key] = new LagFilter(tau || 0.12); }

  // All pattern parameters (raw = slider value, smooth = lag output)
  const P = {
    // Lissajous
    lissA: 3, lissB: 2, lissPhase: 0.5,
    // Spirograph
    spiR: 80, spir: 30, spid: 50,
    // Voronoi
    vorN: 12, vorAnim: true,
    // Reaction-Diffusion
    rdFeed: 0.055, rdKill: 0.062,
    // Cellular automata
    caRule: 110, caSpeed: 0.18,
    // Truchet
    trDens: 0.5, trRotProb: 0.5,
    // Penrose
    penGen: 4,
    // Wave
    waveF1: 2, waveF2: 3, waveAmp: 0.5
  };

  // Smoothed copies
  const S = Object.assign({}, P);
  makeLag('lissA'); makeLag('lissB'); makeLag('lissPhase');
  makeLag('spiR'); makeLag('spir'); makeLag('spid');
  makeLag('vorN', 0.08);
  makeLag('rdFeed', 0.18); makeLag('rdKill', 0.18);
  makeLag('waveF1'); makeLag('waveF2'); makeLag('waveAmp');

  // ── Control builder ──
  function makeSlider(label, key, min, max, step, decimals) {
    const wrap = document.createElement('div');
    wrap.className = 'cg';
    const lbl = document.createElement('label');
    lbl.textContent = label;
    const inp = document.createElement('input');
    inp.type = 'range'; inp.min = min; inp.max = max; inp.step = step;
    inp.value = P[key];
    const val = document.createElement('span');
    val.className = 'val';
    val.textContent = parseFloat(P[key]).toFixed(decimals || 2);
    inp.addEventListener('input', () => {
      P[key] = parseFloat(inp.value);
      val.textContent = P[key].toFixed(decimals || 2);
    });
    wrap.appendChild(lbl); wrap.appendChild(inp); wrap.appendChild(val);
    return wrap;
  }
  function makeToggle(label, key) {
    const btn = document.createElement('button');
    btn.className = 'btn btn-g'; btn.textContent = label + (P[key] ? ' ON' : ' OFF');
    btn.addEventListener('click', () => {
      P[key] = !P[key];
      btn.textContent = label + (P[key] ? ' ON' : ' OFF');
      btn.classList.toggle('on', P[key]);
    });
    if (P[key]) btn.classList.add('on');
    return btn;
  }
  function makeReset(fn) {
    const btn = document.createElement('button');
    btn.className = 'btn btn-p'; btn.textContent = 'Reset';
    btn.addEventListener('click', fn);
    return btn;
  }

  // ── Control panels per pattern ──
  const panels = {
    lissajous: () => [
      makeSlider('Freq X', 'lissA', 1, 8, 0.1, 1),
      makeSlider('Freq Y', 'lissB', 1, 8, 0.1, 1),
      makeSlider('Phase δ', 'lissPhase', 0, Math.PI, 0.02, 2),
      makeReset(() => { patTime = 0; ctx.clearRect(0,0,W,H); })
    ],
    spirograph: () => [
      makeSlider('R (outer)', 'spiR', 30, 140, 1, 0),
      makeSlider('r (inner)', 'spir', 5, 80, 1, 0),
      makeSlider('d (offset)', 'spid', 0, 120, 1, 0),
      makeReset(() => { patTime = 0; ctx.clearRect(0,0,W,H); })
    ],
    voronoi: () => [
      makeSlider('Points N', 'vorN', 4, 30, 1, 0),
      makeToggle('Animate', 'vorAnim'),
      makeReset(() => {})
    ],
    reactiondiff: () => [
      makeSlider('Feed Rate', 'rdFeed', 0.01, 0.1, 0.001, 3),
      makeSlider('Kill Rate', 'rdKill', 0.04, 0.08, 0.001, 3),
      makeReset(() => { initRD(); })
    ],
    automata: () => [
      makeSlider('Rule #', 'caRule', 0, 255, 1, 0),
      makeSlider('Speed', 'caSpeed', 0.01, 1, 0.01, 2),
      makeReset(() => { caRow = 0; caInit(); })
    ],
    truchet: () => [
      makeSlider('Density', 'trDens', 0.1, 1, 0.05, 2),
      makeSlider('Rot Prob', 'trRotProb', 0, 1, 0.05, 2),
      makeReset(() => { drawTruchet(); })
    ],
    penrose: () => [
      makeSlider('Generations', 'penGen', 1, 6, 1, 0),
      makeReset(() => { drawPenrose(); })
    ],
    wave: () => [
      makeSlider('Freq 1', 'waveF1', 0.5, 6, 0.1, 1),
      makeSlider('Freq 2', 'waveF2', 0.5, 6, 0.1, 1),
      makeSlider('Amplitude', 'waveAmp', 0.1, 1, 0.05, 2),
      makeReset(() => { patTime = 0; })
    ]
  };

  function buildControls(pat) {
    ctrlEl.innerHTML = '';
    (panels[pat] || (() => []))().forEach(el => ctrlEl.appendChild(el));
  }

  // ── Pattern switcher ──
  document.getElementById('patBtns').querySelectorAll('.pat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.pat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentPat = btn.dataset.pat;
      patTime = 0;
      buildControls(currentPat);
      if (animId) cancelAnimationFrame(animId);
      ctx.clearRect(0,0,W,H);
      if (currentPat === 'automata') { caInit(); }
      if (currentPat === 'truchet')  { drawTruchet(); }
      if (currentPat === 'penrose')  { drawPenrose(); }
      if (currentPat === 'reactiondiff') { initRD(); }
      startLoop();
    });
  });
  buildControls('lissajous');

  // ── PATTERN RENDERERS ──

  // Lissajous
  function drawLissajous(dt) {
    S.lissA     = lags.lissA.update(P.lissA, dt);
    S.lissB     = lags.lissB.update(P.lissB, dt);
    S.lissPhase = lags.lissPhase.update(P.lissPhase, dt);
    ctx.fillStyle = 'rgba(5,5,18,0.04)';
    ctx.fillRect(0,0,W,H);
    ctx.beginPath();
    const r = Math.min(W,H) * 0.42;
    const cx = W/2, cy = H/2;
    const steps = 1200;
    for (let i = 0; i <= steps; i++) {
      const t = (i / steps) * Math.PI * 2;
      const x = cx + r * Math.sin(S.lissA * t + S.lissPhase + patTime * 0.15);
      const y = cy + r * Math.sin(S.lissB * t);
      i === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    const hue = 250 + Math.sin(patTime) * 30;
    ctx.strokeStyle = `hsl(${hue},80%,68%)`;
    ctx.lineWidth = 1.5; ctx.stroke();
    patTime += dt;
  }

  // Spirograph
  function drawSpirograph(dt) {
    S.spiR = lags.spiR.update(P.spiR, dt);
    S.spir = lags.spir.update(P.spir, dt);
    S.spid = lags.spid.update(P.spid, dt);
    ctx.fillStyle = 'rgba(5,5,18,0.03)';
    ctx.fillRect(0,0,W,H);
    const cx = W/2, cy = H/2;
    const steps = 800;
    ctx.beginPath();
    for (let i = 0; i <= steps; i++) {
      const t2 = (i / steps) * Math.PI * 2 * (S.spiR / (S.spiR - S.spir)) + patTime * 0.4;
      const x = cx + (S.spiR - S.spir) * Math.cos(t2) + S.spid * Math.cos((S.spiR - S.spir) / S.spir * t2);
      const y = cy + (S.spiR - S.spir) * Math.sin(t2) - S.spid * Math.sin((S.spiR - S.spir) / S.spir * t2);
      i===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    ctx.strokeStyle = `hsl(${270 + Math.sin(patTime*0.5)*40},80%,68%)`;
    ctx.lineWidth = 1.4; ctx.stroke();
    patTime += dt;
  }

  // Voronoi
  let vorPts = [];
  let vorVels = [];
  function initVor() {
    vorPts = []; vorVels = [];
    const n = Math.round(P.vorN);
    for (let i = 0; i < n; i++) {
      vorPts.push([Math.random()*W, Math.random()*H]);
      vorVels.push([(Math.random()-.5)*40, (Math.random()-.5)*40]);
    }
  }
  initVor();
  function drawVoronoi(dt) {
    if (P.vorAnim) {
      for (let i = 0; i < vorPts.length; i++) {
        vorPts[i][0] += vorVels[i][0]*dt;
        vorPts[i][1] += vorVels[i][1]*dt;
        if (vorPts[i][0]<0||vorPts[i][0]>W) vorVels[i][0]*=-1;
        if (vorPts[i][1]<0||vorPts[i][1]>H) vorVels[i][1]*=-1;
      }
    }
    const N2 = Math.round(P.vorN);
    if (N2 !== vorPts.length) initVor();
    const img = ctx.createImageData(W,H);
    const d = img.data;
    const cols = [[124,58,237],[167,139,250],[99,102,241],[139,92,246],[109,40,217],[196,181,253],[79,70,229],[168,85,247]];
    for (let y=0; y<H; y+=2) {
      for (let x=0; x<W; x+=2) {
        let best=Infinity, bidx=0;
        for (let k=0;k<vorPts.length;k++) {
          const dx=x-vorPts[k][0], dy=y-vorPts[k][1];
          const d2=dx*dx+dy*dy;
          if(d2<best){best=d2;bidx=k;}
        }
        const c=cols[bidx%cols.length];
        for(let dy2=0;dy2<2;dy2++) for(let dx2=0;dx2<2;dx2++) {
          const idx=((y+dy2)*W+(x+dx2))*4;
          d[idx]=c[0];d[idx+1]=c[1];d[idx+2]=c[2];d[idx+3]=220;
        }
      }
    }
    ctx.putImageData(img,0,0);
    // Draw site dots
    vorPts.forEach((p,i) => {
      ctx.beginPath(); ctx.arc(p[0],p[1],4,0,Math.PI*2);
      ctx.fillStyle='rgba(255,255,255,0.85)'; ctx.fill();
    });
  }

  // Reaction-Diffusion
  let rdA, rdB, rdW=120, rdH=80;
  function initRD() {
    rdA = new Float32Array(rdW*rdH).fill(1);
    rdB = new Float32Array(rdW*rdH).fill(0);
    for(let i=rdW/2-8;i<rdW/2+8;i++) for(let j=rdH/2-8;j<rdH/2+8;j++) {
      const idx=j*rdW+i;
      rdA[idx]=0.5+(Math.random()-.5)*.2;
      rdB[idx]=0.25+(Math.random()-.5)*.1;
    }
  }
  initRD();
  function drawRD(dt) {
    S.rdFeed = lags.rdFeed.update(P.rdFeed, dt);
    S.rdKill = lags.rdKill.update(P.rdKill, dt);
    const f=S.rdFeed, k=S.rdKill, da=1.0, db=0.5;
    const nA=new Float32Array(rdW*rdH);
    const nB=new Float32Array(rdW*rdH);
    for(let y=1;y<rdH-1;y++) for(let x=1;x<rdW-1;x++) {
      const i=y*rdW+x;
      const a=rdA[i], b=rdB[i];
      const lapA=rdA[i-1]+rdA[i+1]+rdA[i-rdW]+rdA[i+rdW]-4*a;
      const lapB=rdB[i-1]+rdB[i+1]+rdB[i-rdW]+rdB[i+rdW]-4*b;
      const abb=a*b*b;
      nA[i]=clamp(a+da*lapA-abb+f*(1-a),0,1);
      nB[i]=clamp(b+db*lapB+abb-(k+f)*b,0,1);
    }
    rdA=nA; rdB=nB;
    const img=ctx.createImageData(W,H);
    const px2=img.data;
    const scx=W/rdW, scy=H/rdH;
    for(let y=0;y<rdH;y++) for(let x=0;x<rdW;x++) {
      const v=clamp((rdA[y*rdW+x]-rdB[y*rdW+x])*.8+.5,0,1);
      const r=Math.round(clamp(v*124+(1-v)*196,0,255));
      const g=Math.round(clamp(v*58+(1-v)*181,0,255));
      const b2=Math.round(clamp(v*237+(1-v)*253,0,255));
      for(let dy2=0;dy2<scy;dy2++) for(let dx2=0;dx2<scx;dx2++) {
        const pi=((Math.floor(y*scy)+dy2)*W+Math.floor(x*scx)+dx2)*4;
        if(pi+3<px2.length){px2[pi]=r;px2[pi+1]=g;px2[pi+2]=b2;px2[pi+3]=255;}
      }
    }
    ctx.putImageData(img,0,0);
  }

  // Cellular Automata (1D)
  let caRow=0, caCells=[], caNext=[];
  function caInit() {
    caRow=0;
    caCells=new Uint8Array(Math.floor(W/3)+2);
    caCells[Math.floor(caCells.length/2)]=1;
    ctx.clearRect(0,0,W,H);
  }
  caInit();
  let caAccum=0;
  function drawCA(dt) {
    caAccum+=dt;
    if(caAccum<(1-P.caSpeed)*0.08+0.005) return;
    caAccum=0;
    const rule=Math.round(P.caRule), cw=3;
    const cols=caCells.length;
    const y=caRow*cw;
    if(y>=H) { ctx.clearRect(0,0,W,H); caInit(); return; }
    for(let x=0;x<cols;x++) {
      if(caCells[x]) {
        ctx.fillStyle='rgba(167,139,250,0.9)';
        ctx.fillRect(x*cw,y,cw,cw);
      }
    }
    const next=new Uint8Array(cols);
    for(let x=0;x<cols;x++) {
      const l=x>0?caCells[x-1]:0;
      const c2=caCells[x];
      const r2=x<cols-1?caCells[x+1]:0;
      const pattern=(l<<2)|(c2<<1)|r2;
      next[x]=(rule>>pattern)&1;
    }
    caCells=next; caRow++;
  }

  // Truchet tiles
  function drawTruchet() {
    const sz=40;
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#070513'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='rgba(124,58,237,0.8)'; ctx.lineWidth=2.5;
    const cols2=Math.ceil(W/sz), rows2=Math.ceil(H/sz);
    for(let r=0;r<rows2;r++) for(let c=0;c<cols2;c++) {
      if(Math.random()>P.trDens) continue;
      const x=c*sz, y2=r*sz;
      ctx.save(); ctx.translate(x,y2);
      if(Math.random()<P.trRotProb) ctx.rotate(Math.PI/2);
      ctx.beginPath(); ctx.arc(0,0,sz/2,0,Math.PI/2);
      ctx.stroke();
      ctx.beginPath(); ctx.arc(sz,sz,sz/2,Math.PI,Math.PI*1.5);
      ctx.stroke();
      ctx.restore();
    }
  }
  drawTruchet();

  // Penrose tiling (P3 — rhombs via substitution)
  function drawPenrose() {
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#070513'; ctx.fillRect(0,0,W,H);
    const cx2=W/2, cy2=H/2, gen=Math.round(P.penGen);
    const phi=(1+Math.sqrt(5))/2;
    let tris=[];
    for(let i=0;i<10;i++) {
      const a1=(2*i-1)*Math.PI/10;
      const a2=(2*i+1)*Math.PI/10;
      const scale=Math.min(W,H)*0.48;
      tris.push([1, [cx2,cy2], [cx2+scale*Math.cos(a1),cy2+scale*Math.sin(a1)], [cx2+scale*Math.cos(a2),cy2+scale*Math.sin(a2)]]);
    }
    for(let g=0;g<gen;g++) {
      const next=[];
      for(const [t,[ax,ay],[bx,by],[cx3,cy3]] of tris) {
        if(t===1) {
          const px2=ax+(bx-ax)/phi, py2=ay+(by-ay)/phi;
          next.push([1,[cx3,cy3],[px2,py2],[bx,by]]);
          next.push([0,[px2,py2],[cx3,cy3],[ax,ay]]);
        } else {
          const px2=bx+(ax-bx)/phi, py2=by+(ay-by)/phi;
          const qx=bx+(cx3-bx)/phi, qy=by+(cy3-by)/phi;
          next.push([0,[px2,py2],[qx,qy],[ax,ay]]);
          next.push([0,[qx,qy],[px2,py2],[cx3,cy3]]);
          next.push([1,[qx,qy],[bx,by],[px2,py2]]);
        }
      }
      tris=next;
    }
    tris.forEach(([t,[ax,ay],[bx,by],[cx3,cy3]]) => {
      ctx.beginPath(); ctx.moveTo(ax,ay); ctx.lineTo(bx,by); ctx.lineTo(cx3,cy3); ctx.closePath();
      ctx.fillStyle=t===1?'rgba(124,58,237,0.4)':'rgba(99,102,241,0.35)';
      ctx.fill();
      ctx.strokeStyle='rgba(167,139,250,0.5)'; ctx.lineWidth=0.8; ctx.stroke();
    });
  }
  drawPenrose();

  // Wave interference
  function drawWave(dt) {
    S.waveF1  = lags.waveF1.update(P.waveF1, dt);
    S.waveF2  = lags.waveF2.update(P.waveF2, dt);
    S.waveAmp = lags.waveAmp.update(P.waveAmp, dt);
    const img=ctx.createImageData(W,H);
    const d=img.data;
    const s1x=W*0.3, s1y=H*0.5;
    const s2x=W*0.7, s2y=H*0.5;
    for(let y=0;y<H;y+=2) for(let x=0;x<W;x+=2) {
      const d1=Math.sqrt((x-s1x)**2+(y-s1y)**2);
      const d2=Math.sqrt((x-s2x)**2+(y-s2y)**2);
      const v=Math.sin(d1*S.waveF1*0.1-patTime*3)*S.waveAmp
             +Math.sin(d2*S.waveF2*0.1-patTime*3)*S.waveAmp;
      const n=clamp((v+1)/2,0,1);
      const r2=Math.round(clamp(n*196+(1-n)*30,0,255));
      const g2=Math.round(clamp(n*181+(1-n)*5,0,255));
      const b2=Math.round(clamp(n*253+(1-n)*180,0,255));
      for(let dy2=0;dy2<2;dy2++) for(let dx2=0;dx2<2;dx2++) {
        const pi=((y+dy2)*W+(x+dx2))*4;
        if(pi+3<d.length){d[pi]=r2;d[pi+1]=g2;d[pi+2]=b2;d[pi+3]=255;}
      }
    }
    ctx.putImageData(img,0,0);
    patTime+=dt;
  }

  // ── Main loop ──
  function startLoop() {
    if(animId) cancelAnimationFrame(animId);
    function loop(ts) {
      const dt=Math.min((ts-lastTs)/1000,.05); lastTs=ts;
      switch(currentPat) {
        case 'lissajous':    drawLissajous(dt);   break;
        case 'spirograph':   drawSpirograph(dt);  break;
        case 'voronoi':      drawVoronoi(dt);     break;
        case 'reactiondiff': drawRD(dt);          break;
        case 'automata':     drawCA(dt);          break;
        case 'truchet':      /* static */         break;
        case 'penrose':      /* static */         break;
        case 'wave':         drawWave(dt);        break;
      }
      animId=requestAnimationFrame(loop);
    }
    animId=requestAnimationFrame(loop);
  }
  startLoop();
})();
</script>
<!-- ═══════════════════════════════════════════════════════ -->
<!-- SECTION 4 — COLOR & COMPOSITION TOOLS                  -->
<!-- ═══════════════════════════════════════════════════════ -->
<div class="sec hidden" id="color-composition">
<p class="sl">Visual Thinking</p>
<h2 class="st">Color &amp; Composition Tools</h2>
<p class="sd">Place geometric primitives on canvas, explore color harmonies, and get real-time compositional analysis.</p>
<div class="row" style="align-items:flex-start;gap:1.25rem">
<div style="flex:1;min-width:280px">
<div class="cw" id="ccWrap">
<canvas height="360" id="ccCanvas" style="width:100%;cursor:crosshair;display:block" width="540"></canvas>
</div>
<div class="controls" style="margin-top:.8rem">
<div class="cg">
<label>Shape</label>
<select id="ccShape">
<option value="circle">Circle</option>
<option value="rect">Rectangle</option>
<option value="triangle">Triangle</option>
<option value="line">Line</option>
</select>
</div>
<div class="cg">
<label>Color</label>
<input id="ccColor" style="width:48px;height:28px;border:none;border-radius:6px;cursor:pointer;background:transparent" type="color" value="#7c3aed"/>
</div>
<div class="cg">
<label>Size <span class="val" id="ccSizeVal">40</span></label>
<input id="ccSize" max="120" min="8" type="range" value="40"/>
</div>
<div class="cg">
<label>Opacity <span class="val" id="ccOpVal">0.85</span></label>
<input id="ccOp" max="1" min="0.1" step="0.05" type="range" value="0.85"/>
</div>
<button class="btn btn-g" id="ccRules">⅓ Grid</button>
<button class="btn btn-g" id="ccGolden">φ Spiral</button>
<button class="btn btn-p" id="ccClear">Clear</button>
<button class="btn btn-g" id="ccExport">Export PNG</button>
</div>
<div class="analysis-panel">
<h4>Composition Analysis</h4>
<div class="analysis-row"><span class="analysis-label">Shapes placed</span><span class="analysis-val" id="ccCount">0</span></div>
<div class="analysis-row"><span class="analysis-label">Visual balance</span><span class="analysis-val" id="ccBalance">—</span></div>
<div class="analysis-row"><span class="analysis-label">Color harmony</span><span class="analysis-val" id="ccHarmony">—</span></div>
<div class="analysis-row"><span class="analysis-label">Dominant hue</span><span class="analysis-val" id="ccDomHue">—</span></div>
</div>
</div>
<div style="min-width:200px;max-width:230px">
<div class="card" style="margin-bottom:1rem">
<p style="font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);margin-bottom:.6rem">Harmony Suggestions</p>
<div id="harmType" style="display:flex;flex-wrap:wrap;gap:.35rem;margin-bottom:.7rem">
<button class="btn btn-g" data-harm="complementary" style="font-size:.7rem;padding:.3rem .6rem">Complement</button>
<button class="btn btn-g" data-harm="triadic" style="font-size:.7rem;padding:.3rem .6rem">Triadic</button>
<button class="btn btn-g" data-harm="analogous" style="font-size:.7rem;padding:.3rem .6rem">Analogous</button>
<button class="btn btn-g" data-harm="split" style="font-size:.7rem;padding:.3rem .6rem">Split-comp</button>
</div>
<div class="harm-row" id="harmSwatches"></div>
</div>
<div class="card">
<p style="font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);margin-bottom:.6rem">Recently Used</p>
<div class="palette-row" id="ccPalette"></div>
</div>
</div>
</div>
</div>
<script>
/* ═══════════════════════════════════════════════════════════
   SECTION 4 — COLOR & COMPOSITION
   ═══════════════════════════════════════════════════════════ */
(function initCC() {
  const canvas = document.getElementById('ccCanvas');
  const ctx    = canvas.getContext('2d');
  let W = canvas.width, H = canvas.height;
  new ResizeObserver(() => {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = Math.round(canvas.offsetWidth * 0.66);
    redraw();
  }).observe(canvas);

  // LagFilter instance 13 — size smoothing
  const sizeLag = new LagFilter(0.1);
  // LagFilter instance 14 — opacity smoothing
  const opLag   = new LagFilter(0.1);

  const sizeInp  = document.getElementById('ccSize');
  const opInp    = document.getElementById('ccOp');
  const sizeVal  = document.getElementById('ccSizeVal');
  const opVal    = document.getElementById('ccOpVal');
  sizeInp.addEventListener('input', () => sizeVal.textContent = sizeInp.value);
  opInp.addEventListener('input',   () => opVal.textContent   = parseFloat(opInp.value).toFixed(2));

  const shapes = [];
  let showRules = false, showGolden = false;

  canvas.addEventListener('click', e => {
    const r = canvas.getBoundingClientRect();
    const x = (e.clientX - r.left) * (W / r.width);
    const y = (e.clientY - r.top)  * (H / r.height);
    const sz  = parseInt(sizeInp.value);
    const col = document.getElementById('ccColor').value;
    const op  = parseFloat(opInp.value);
    const sh  = document.getElementById('ccShape').value;
    shapes.push({ x, y, sz, col, op, sh });
    addPalette(col);
    updateAnalysis();
    redraw();
  });

  document.getElementById('ccRules').addEventListener('click', e => {
    showRules = !showRules;
    e.currentTarget.classList.toggle('on', showRules);
    redraw();
  });
  document.getElementById('ccGolden').addEventListener('click', e => {
    showGolden = !showGolden;
    e.currentTarget.classList.toggle('on', showGolden);
    redraw();
  });
  document.getElementById('ccClear').addEventListener('click', () => {
    shapes.length = 0;
    updateAnalysis();
    redraw();
  });
  document.getElementById('ccExport').addEventListener('click', () => {
    const a = document.createElement('a');
    a.href = canvas.toDataURL('image/png');
    a.download = 'composition.png';
    a.click();
  });

  function hexToHSL(hex) {
    let r = parseInt(hex.slice(1,3),16)/255;
    let g = parseInt(hex.slice(3,5),16)/255;
    let b = parseInt(hex.slice(5,7),16)/255;
    const max=Math.max(r,g,b), min=Math.min(r,g,b);
    let h=0, s=0, l=(max+min)/2;
    if(max!==min){
      const d=max-min; s=l>.5?d/(2-max-min):d/(max+min);
      switch(max){ case r:h=((g-b)/d+(g<b?6:0))/6;break; case g:h=((b-r)/d+2)/6;break; case b:h=((r-g)/d+4)/6;break; }
    }
    return [h*360,s*100,l*100];
  }
  function hslToHex(h,s,l) {
    s/=100;l/=100;
    const a=s*Math.min(l,1-l);
    const f=n=>{const k=(n+h/30)%12;const c=l-a*Math.max(-1,Math.min(k-3,9-k,1));return Math.round(255*c).toString(16).padStart(2,'0')};
    return`#${f(0)}${f(8)}${f(4)}`;
  }

  // Harmony generator
  document.getElementById('harmType').querySelectorAll('[data-harm]').forEach(btn => {
    btn.addEventListener('click', () => {
      const base = document.getElementById('ccColor').value;
      const [h,s,l] = hexToHSL(base);
      let cols = [base];
      switch(btn.dataset.harm) {
        case 'complementary': cols=[base,hslToHex((h+180)%360,s,l)]; break;
        case 'triadic':       cols=[base,hslToHex((h+120)%360,s,l),hslToHex((h+240)%360,s,l)]; break;
        case 'analogous':     cols=[hslToHex((h-30+360)%360,s,l),base,hslToHex((h+30)%360,s,l)]; break;
        case 'split':         cols=[base,hslToHex((h+150)%360,s,l),hslToHex((h+210)%360,s,l)]; break;
      }
      const sw = document.getElementById('harmSwatches');
      sw.innerHTML = '';
      cols.forEach(c => {
        const el=document.createElement('div');
        el.className='swatch'; el.style.background=c;
        el.title=c;
        el.addEventListener('click', () => document.getElementById('ccColor').value=c);
        sw.appendChild(el);
      });
    });
  });

  const recentCols = [];
  function addPalette(col) {
    if(!recentCols.includes(col)) { recentCols.unshift(col); if(recentCols.length>8) recentCols.pop(); }
    const p=document.getElementById('ccPalette'); p.innerHTML='';
    recentCols.forEach(c => {
      const el=document.createElement('div'); el.className='swatch'; el.style.background=c;
      el.addEventListener('click', () => document.getElementById('ccColor').value=c);
      p.appendChild(el);
    });
  }

  function updateAnalysis() {
    document.getElementById('ccCount').textContent = shapes.length;
    if(shapes.length===0){ document.getElementById('ccBalance').textContent='—'; document.getElementById('ccHarmony').textContent='—'; document.getElementById('ccDomHue').textContent='—'; return; }
    // Center of mass
    let cx2=0,cy2=0;
    shapes.forEach(s=>{cx2+=s.x/W;cy2+=s.y/H;});
    cx2/=shapes.length; cy2/=shapes.length;
    const dist=Math.sqrt((cx2-.5)**2+(cy2-.5)**2);
    document.getElementById('ccBalance').textContent = dist<.12?'✓ Balanced':dist<.25?'≈ Slight offset':'⚠ Off-center';
    // Hue variance
    const hues = shapes.map(s=>hexToHSL(s.col)[0]);
    const meanH = hues.reduce((a,b)=>a+b,0)/hues.length;
    const varH  = hues.reduce((a,b)=>a+(b-meanH)**2,0)/hues.length;
    document.getElementById('ccHarmony').textContent = varH<400?'Monochromatic':varH<3000?'Harmonious':'High contrast';
    document.getElementById('ccDomHue').textContent  = `${Math.round(meanH)}°`;
  }

  function drawShape(s) {
    ctx.save();
    ctx.globalAlpha = s.op;
    ctx.fillStyle   = s.col;
    ctx.strokeStyle = 'rgba(255,255,255,0.25)';
    ctx.lineWidth   = 1.5;
    switch(s.sh) {
      case 'circle':
        ctx.beginPath(); ctx.arc(s.x,s.y,s.sz/2,0,Math.PI*2);
        ctx.fill(); ctx.stroke(); break;
      case 'rect':
        ctx.fillRect(s.x-s.sz/2,s.y-s.sz/2,s.sz,s.sz);
        ctx.strokeRect(s.x-s.sz/2,s.y-s.sz/2,s.sz,s.sz); break;
      case 'triangle':
        ctx.beginPath();
        ctx.moveTo(s.x,s.y-s.sz*0.6);
        ctx.lineTo(s.x+s.sz*0.52,s.y+s.sz*0.4);
        ctx.lineTo(s.x-s.sz*0.52,s.y+s.sz*0.4);
        ctx.closePath(); ctx.fill(); ctx.stroke(); break;
      case 'line':
        ctx.beginPath();
        ctx.moveTo(s.x-s.sz/2,s.y); ctx.lineTo(s.x+s.sz/2,s.y);
        ctx.strokeStyle=s.col; ctx.lineWidth=3; ctx.globalAlpha=s.op;
        ctx.stroke(); break;
    }
    ctx.restore();
  }

  function redraw() {
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#070513'; ctx.fillRect(0,0,W,H);
    shapes.forEach(drawShape);
    if(showRules) {
      ctx.save(); ctx.strokeStyle='rgba(167,139,250,0.25)'; ctx.lineWidth=1; ctx.setLineDash([4,4]);
      [W/3,W*2/3].forEach(x=>{ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();});
      [H/3,H*2/3].forEach(y=>{ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();});
      ctx.restore();
    }
    if(showGolden) {
      ctx.save(); ctx.strokeStyle='rgba(196,181,253,0.3)'; ctx.lineWidth=1.2; ctx.setLineDash([]);
      let gx=0,gy=0,gw=W,gh=H;
      for(let g=0;g<6;g++) {
        const phi2=1.618;
        ctx.beginPath(); ctx.arc(gx+gw,gy+gh,Math.sqrt(gw*gw+gh*gh)*.382,Math.PI,Math.PI*1.5); ctx.stroke();
        const nw=gw/phi2;
        if(g%2===0){gx+=nw;gw-=nw;}else{gh-=gh/phi2;}
      }
      ctx.restore();
    }
  }
  redraw();
})();
</script>
