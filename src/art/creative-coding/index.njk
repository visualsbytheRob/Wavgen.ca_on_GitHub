<script>
/* ═══════════════════════════════════════════════════════════
   SECTION 6 — NOISE & RANDOMNESS
   ═══════════════════════════════════════════════════════════ */
(function initNoise() {

  // ── Noise primitives ──
  function fade(t){ return t*t*t*(t*(t*6-15)+10); }
  function grad2(hash2, x2, y2) {
    const h=hash2&3;
    const u=h<2?x2:y2, v=h<2?y2:x2;
    return ((h&1)?-u:u)+((h&2)?-v:v);
  }
  const perm=(()=>{const p=new Uint8Array(512);for(let i=0;i<256;i++)p[i]=p[i+256]=i;for(let i=255;i>0;i--){const j=Math.floor(Math.random()*(i+1));[p[i],p[j]]=[p[j],p[i]];}return p;})();

  function perlinNoise(x2,y2){
    const xi=Math.floor(x2)&255, yi=Math.floor(y2)&255;
    const xf=x2-Math.floor(x2), yf=y2-Math.floor(y2);
    const u=fade(xf), v=fade(yf);
    const aa=perm[perm[xi]+yi], ab=perm[perm[xi]+yi+1];
    const ba=perm[perm[xi+1]+yi], bb=perm[perm[xi+1]+yi+1];
    return lerp(lerp(grad2(aa,xf,yf),grad2(ba,xf-1,yf),u),lerp(grad2(ab,xf,yf-1),grad2(bb,xf-1,yf-1),u),v);
  }

  function valueNoise(x2,y2){
    const xi=Math.floor(x2), yi=Math.floor(y2);
    const xf=x2-xi, yf=y2-yi;
    const ux=fade(xf), uy=fade(yf);
    const h00=hash2D(xi,yi), h10=hash2D(xi+1,yi), h01=hash2D(xi,yi+1), h11=hash2D(xi+1,yi+1);
    return lerp(lerp(h00,h10,ux),lerp(h01,h11,ux),uy);
  }
  function hash2D(x2,y2){ let n=(x2*1619+y2*31337)^(x2*y2*4001); n=(n^(n>>8))&0xffff; return n/65535; }

  function worleyNoise(x2,y2,pts){
    let minD=Infinity;
    for(let dy=-1;dy<=1;dy++) for(let dx=-1;dx<=1;dx++){
      const cx2=Math.floor(x2)+dx, cy2=Math.floor(y2)+dy;
      const hx=frac(Math.sin(cx2*127.1+cy2*311.7)*43758.5453);
      const hy=frac(Math.sin(cx2*269.5+cy2*183.3)*43758.5453);
      const d=Math.sqrt((x2-cx2-hx)**2+(y2-cy2-hy)**2);
      minD=Math.min(minD,d);
    }
    return clamp(minD,0,1);
  }
  function frac(v){ return v-Math.floor(v); }

  function fbm(x2,y2,oct,pers,lac){
    let val=0,amp=0.5,freq=1,max=0;
    for(let i=0;i<oct;i++){
      val+=perlinNoise(x2*freq,y2*freq)*amp;
      max+=amp; amp*=pers; freq*=lac;
    }
    return val/max*0.5+0.5;
  }

  function domainWarp(x2,y2,scale2){
    const wx=fbm(x2+0.0,y2+0.0,4,0.5,2);
    const wy=fbm(x2+5.2,y2+1.3,4,0.5,2);
    return fbm(x2+scale2*wx,y2+scale2*wy,4,0.5,2);
  }

  // ── Lag filters 17–21 for noise controls ──
  const nScaleLag = new LagFilter(0.12);
  const nOctLag   = new LagFilter(0.12);
  const nPersLag  = new LagFilter(0.12);
  const nLacLag   = new LagFilter(0.12);
  const nAnimLag  = new LagFilter(0.12);

  const nScaleInp = document.getElementById('nScale');
  const nOctInp   = document.getElementById('nOct');
  const nPersInp  = document.getElementById('nPers');
  const nLacInp   = document.getElementById('nLac');
  const nAnimInp  = document.getElementById('nAnim');
  [['nScale','nScaleVal',2],['nOct','nOctVal',0],['nPers','nPersVal',2],['nLac','nLacVal',2],['nAnim','nAnimVal',2]].forEach(([id,vid,d])=>{
    document.getElementById(id).addEventListener('input',e=>{document.getElementById(vid).textContent=parseFloat(e.target.value).toFixed(d);});
  });

  // ── Render noise to canvas ──
  function renderNoise(canvas2, type, scale2, oct, pers, lac, tOff) {
    const ctx2 = canvas2.getContext('2d');
    const W2=canvas2.width, H2=canvas2.height;
    const img=ctx2.createImageData(W2,H2);
    const d=img.data;
    for(let y=0;y<H2;y++) for(let x=0;x<W2;x++){
      const nx=x/W2*scale2+tOff, ny=y/H2*scale2;
      let v;
      switch(type){
        case 'perlin': v=(perlinNoise(nx,ny)*0.5+0.5); break;
        case 'value':  v=valueNoise(nx,ny); break;
        case 'worley': v=1-worleyNoise(nx,ny,16); break;
        case 'fbm':    v=fbm(nx,ny,oct,pers,lac); break;
        case 'domain': v=domainWarp(nx,ny,scale2*0.3); break;
        case 'blue':   v=0; break; // handled separately
        default:       v=0.5;
      }
      const t=clamp(v,0,1);
      const r2=Math.round(30+t*166);
      const g2=Math.round(5+t*176);
      const b2=Math.round(100+t*153);
      const i=(y*W2+x)*4;
      d[i]=r2;d[i+1]=g2;d[i+2]=b2;d[i+3]=255;
    }
    ctx2.putImageData(img,0,0);
  }

  // Blue noise: Poisson disk sampling rendered as dots
  function renderBlue(canvas2) {
    const ctx2=canvas2.getContext('2d');
    const W2=canvas2.width, H2=canvas2.height;
    ctx2.fillStyle='#070513'; ctx2.fillRect(0,0,W2,H2);
    const minDist=12, pts2=[];
    function inBounds(px2,py2){return px2>=0&&py2>=0&&px2<W2&&py2<H2;}
    function tooClose(px2,py2){return pts2.some(([ox,oy])=>(px2-ox)**2+(py2-oy)**2<minDist*minDist);}
    let active=[[W2/2,H2/2]]; pts2.push([W2/2,H2/2]);
    while(active.length&&pts2.length<300){
      const idx=Math.floor(Math.random()*active.length);
      const [bx,by]=active[idx];
      let found=false;
      for(let k=0;k<30;k++){
        const a=Math.random()*Math.PI*2;
        const r=minDist*(1+Math.random());
        const cx2=bx+r*Math.cos(a), cy2=by+r*Math.sin(a);
        if(inBounds(cx2,cy2)&&!tooClose(cx2,cy2)){
          pts2.push([cx2,cy2]); active.push([cx2,cy2]); found=true; break;
        }
      }
      if(!found) active.splice(idx,1);
    }
    pts2.forEach(([px2,py2])=>{
      ctx2.beginPath(); ctx2.arc(px2,py2,2,0,Math.PI*2);
      ctx2.fillStyle='rgba(167,139,250,0.85)'; ctx2.fill();
    });
  }

  // ── Thumbnail canvases ──
  ['perlin','value','worley','fbm','domain'].forEach((t,i)=>{
    const c=document.getElementById(['nPerlin','nValue','nWorley','nFbm','nDomain','nBlue'][i]);
    renderNoise(c,t,4,4,0.5,2,0);
  });
  renderBlue(document.getElementById('nBlue'));

  // ── Focus canvas ──
  const focusCanvas=document.getElementById('noiseFocus');
  let noiseT=0, noiseLastTs=0;
  function focusLoop(ts){
    const dt=Math.min((ts-noiseLastTs)/1000,.05); noiseLastTs=ts;
    const scale2=nScaleLag.update(parseFloat(nScaleInp.value),dt);
    const oct   =Math.round(nOctLag.update(parseFloat(nOctInp.value),dt));
    const pers  =nPersLag.update(parseFloat(nPersInp.value),dt);
    const lac   =nLacLag.update(parseFloat(nLacInp.value),dt);
    const anim  =nAnimLag.update(parseFloat(nAnimInp.value),dt);
    const type  =document.getElementById('noiseType').value;
    noiseT+=dt*anim*0.3;
    if(type==='blue') {
      renderBlue(focusCanvas);
    } else {
      renderNoise(focusCanvas,type,scale2,oct,pers,lac,noiseT);
    }
    requestAnimationFrame(focusLoop);
  }
  requestAnimationFrame(focusLoop);

  document.getElementById('nRegen').addEventListener('click',()=>{ noiseT+=10; });

  // ── Quiz ──
  const noiseTypes=['perlin','value','worley','fbm','domain','blue'];
  const noiseNames=['Perlin-style','Value Noise','Worley/Cellular','fBm','Domain Warp','Blue Noise'];
  let quizAnswer='';
  const quizCanvas=document.getElementById('quizCanvas');

  function newQuiz(){
    const idx=Math.floor(Math.random()*noiseTypes.length);
    quizAnswer=noiseTypes[idx];
    if(quizAnswer==='blue') renderBlue(quizCanvas);
    else renderNoise(quizCanvas,quizAnswer,4,4,0.5,2,Math.random()*100);
    const opts=document.getElementById('quizOpts');
    opts.innerHTML='';
    document.getElementById('quizFeedback').textContent='';
    // Pick 3 wrong + 1 correct, shuffle
    const choices=[...noiseTypes].sort(()=>Math.random()-.5).slice(0,4);
    if(!choices.includes(quizAnswer)){ choices[3]=quizAnswer; }
    choices.sort(()=>Math.random()-.5);
    choices.forEach(t=>{
      const btn=document.createElement('button');
      btn.className='quiz-opt';
      btn.textContent=noiseNames[noiseTypes.indexOf(t)];
      btn.addEventListener('click',()=>{
        opts.querySelectorAll('.quiz-opt').forEach(b=>b.disabled=true);
        if(t===quizAnswer){
          btn.classList.add('correct');
          document.getElementById('quizFeedback').textContent='✓ Correct! '+noiseNames[noiseTypes.indexOf(quizAnswer)];
        } else {
          btn.classList.add('wrong');
          opts.querySelectorAll('.quiz-opt').forEach(b=>{ if(noiseTypes[noiseTypes.indexOf(b.textContent.replace('/','/'))]===quizAnswer) b.classList.add('correct'); });
          document.getElementById('quizFeedback').textContent='✗ That\'s '+noiseNames[noiseTypes.indexOf(quizAnswer)];
        }
      });
      opts.appendChild(btn);
    });
  }
  document.getElementById('quizNext').addEventListener('click',newQuiz);
  newQuiz();
})();
</script>
