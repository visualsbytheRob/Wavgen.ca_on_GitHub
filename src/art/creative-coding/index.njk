// ── Kinetic Type ──
(function initKinetic() {
  const canvas = document.getElementById('kineticCanvas');
  const ctx = canvas.getContext('2d');
  let W = canvas.width, H = canvas.height;
  new ResizeObserver(() => {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = Math.round(canvas.offsetWidth * 0.46);
  }).observe(canvas);

  // LagFilter instance 15 — kinetic speed smoothing
  const speedLag = new LagFilter(0.12);
  // LagFilter instance 16 — kinetic scale smoothing
  const scaleLag = new LagFilter(0.12);

  const speedInp = document.getElementById('ktSpeed');
  const scaleInp = document.getElementById('ktScale');
  speedInp.addEventListener('input', () => document.getElementById('ktSpeedVal').textContent = parseFloat(speedInp.value).toFixed(2));
  scaleInp.addEventListener('input', () => document.getElementById('ktScaleVal').textContent = parseFloat(scaleInp.value).toFixed(2));

  let kt = 0, lastTs2 = 0;
  function loop(ts) {
    const dt = Math.min((ts - lastTs2)/1000, .05); lastTs2 = ts;
    const sp  = speedLag.update(parseFloat(speedInp.value), dt);
    const sc  = scaleLag.update(parseFloat(scaleInp.value), dt);
    const text   = document.getElementById('ktText').value || 'CODE';
    const motion = document.getElementById('ktMotion').value;
    ctx.fillStyle = 'rgba(5,5,18,0.09)';
    ctx.fillRect(0,0,W,H);
    const cx2=W/2, cy2=H/2;
    const fs = Math.round(sc * Math.min(W,H) * 0.12);
    ctx.font = `900 ${fs}px 'Segoe UI',sans-serif`;
    ctx.textAlign='center'; ctx.textBaseline='middle';
    [...text].forEach((ch, i) => {
      const n = text.length;
      let x=cx2, y=cy2;
      const prog = i/n * Math.PI*2;
      switch(motion) {
        case 'orbit': {
          const r = Math.min(W,H)*0.3;
          x = cx2 + r * Math.cos(prog + kt*sp);
          y = cy2 + r * Math.sin(prog + kt*sp) * 0.55;
          break;
        }
        case 'wave': {
          const spacing = W/(n+1);
          x = spacing*(i+1);
          y = cy2 + Math.sin(i*0.7+kt*sp*3)*Math.min(W,H)*0.22;
          break;
        }
        case 'explode': {
          const r = (Math.sin(kt*sp*0.8+prog)*0.5+0.5) * Math.min(W,H)*0.35;
          x = cx2 + r * Math.cos(prog*2.3);
          y = cy2 + r * Math.sin(prog*2.3);
          break;
        }
        case 'breathe': {
          const spacing2 = W/(n+1);
          const sc2 = 0.7 + 0.3*Math.sin(kt*sp*1.5);
          x = cx2 + (spacing2*(i+1) - W/2)*sc2;
          y = cy2 + Math.sin(prog+kt*sp)*12;
          break;
        }
      }
      const hue = 245 + i/n * 60 + Math.sin(kt*sp+prog)*15;
      ctx.fillStyle = `hsl(${hue},75%,68%)`;
      ctx.save(); ctx.translate(x,y);
      if(motion==='orbit') ctx.rotate(Math.atan2(y-cy2,x-cx2)+Math.PI/2);
      ctx.fillText(ch,0,0);
      ctx.restore();
    });
    kt += dt;
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
})();

// ── Type Portrait ──
(function initPortrait() {
  const canvas = document.getElementById('portraitCanvas');
  const ctx = canvas.getContext('2d');
  let W = canvas.width, H = canvas.height;
  new ResizeObserver(() => {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = Math.round(canvas.offsetWidth * 0.53);
    generate();
  }).observe(canvas);

  function generate() {
    const text   = document.getElementById('ptText').value || 'CODE ';
    const dens   = parseFloat(document.getElementById('ptDens').value);
    const fs     = 11;
    ctx.fillStyle='#070513'; ctx.fillRect(0,0,W,H);
    ctx.font=`bold ${fs}px monospace`;
    ctx.textAlign='left'; ctx.textBaseline='top';
    let ci=0;
    const rx=W*0.18, ry=H*0.42;
    for(let y=0;y<H;y+=fs*0.95) {
      for(let x=0;x<W;x+=fs*0.58) {
        const nx=(x-W/2)/rx, ny=(y-H/2)/ry;
        const d=nx*nx+ny*ny;
        if(d>1) continue;
        const luminance=1-Math.sqrt(d);
        if(Math.random()>dens*luminance*1.3) continue;
        const hue=245+luminance*50;
        const lightness=50+luminance*30;
        ctx.fillStyle=`hsl(${hue},75%,${lightness}%)`;
        ctx.fillText(text[ci%text.length],x,y);
        ci++;
      }
    }
  }
  document.getElementById('ptGen').addEventListener('click', generate);
  document.getElementById('ptDens').addEventListener('input', e => {
    document.getElementById('ptDensVal').textContent = parseFloat(e.target.value).toFixed(2);
    generate();
  });
  generate();
})();

// ── ASCII Art ──
(function initASCII() {
  const canvas = document.getElementById('asciiCanvas');
  const ctx = canvas.getContext('2d');
  let W = canvas.width, H = canvas.height;
  new ResizeObserver(() => {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = Math.round(canvas.offsetWidth * 0.5);
    drawASCII();
  }).observe(canvas);

  const charsets = {
    dense:  ' .:-=+*#%@'.split(''),
    blocks: ['░','▒','▓','█'],
    braille:['⠀','⠁','⠃','⠇','⠏','⠟','⠿'],
    math:   ['∘','∙','●','◉','◎','⊙']
  };

  function shapeSDF(x, y, shape, W2, H2) {
    const nx=(x-W2/2)/(W2*0.44), ny=(y-H2/2)/(H2*0.44);
    switch(shape) {
      case 'circle':  return 1-Math.sqrt(nx*nx+ny*ny);
      case 'spiral': {
        const r=Math.sqrt(nx*nx+ny*ny);
        const a=Math.atan2(ny,nx)/(Math.PI*2)+0.5;
        return 1-Math.abs((r-(a+Math.floor(r*4)/4)*0.25)*4);
      }
      case 'heart': {
        const hx=nx, hy=-ny-.1;
        return 1-Math.sqrt(Math.max(0,(hx*hx+hy*hy-0.5)**3-hx*hx*hy*hy*hy));
      }
      case 'wave':
        return 0.5+0.5*Math.sin(nx*5)*Math.cos(ny*4)-Math.abs(ny)*0.8;
      default: return 1-Math.sqrt(nx*nx+ny*ny);
    }
  }

  function drawASCII() {
    const setKey = document.getElementById('asciiSet').value;
    const shape  = document.getElementById('asciiShape').value;
    const sz     = parseInt(document.getElementById('asciiSz').value);
    const chars  = charsets[setKey] || charsets.dense;
    ctx.fillStyle='#070513'; ctx.fillRect(0,0,W,H);
    ctx.font=`${sz}px monospace`; ctx.textAlign='left'; ctx.textBaseline='top';
    const cw2=sz*0.6, ch2=sz*1.1;
    for(let y=0;y<H;y+=ch2) {
      for(let x=0;x<W;x+=cw2) {
        const v=clamp(shapeSDF(x,y,shape,W,H),0,1);
        if(v<0.05) continue;
        const idx=Math.floor(v*(chars.length-1));
        const hue=245+v*55;
        ctx.fillStyle=`hsl(${hue},75%,${45+v*30}%)`;
        ctx.fillText(chars[idx],x,y);
      }
    }
  }

  document.getElementById('asciiShape').addEventListener('change', drawASCII);
  document.getElementById('asciiSet').addEventListener('change', drawASCII);
  document.getElementById('asciiSz').addEventListener('input', e => {
    document.getElementById('asciiSzVal').textContent = e.target.value;
    drawASCII();
  });
  drawASCII();
})();
</script>
