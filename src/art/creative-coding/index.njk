<script>
/* ═══════════════════════════════════════════════════════════
   SECTION 7 — INTERACTION PATTERNS
   ═══════════════════════════════════════════════════════════ */
(function initInteraction() {

  // LagFilter instances 22 & 23 — focus canvas controls
  const iSpeedLag = new LagFilter(0.1);
  const iDampLag  = new LagFilter(0.1);
  document.getElementById('iSpeed').addEventListener('input', e => document.getElementById('iSpeedVal').textContent = parseFloat(e.target.value).toFixed(2));
  document.getElementById('iDamp').addEventListener('input',  e => document.getElementById('iDampVal').textContent  = parseFloat(e.target.value).toFixed(2));

  const hints = {
    trails:   'Move mouse — particles follow with physics trails.',
    magnets:  'Move mouse — elements are repelled from cursor.',
    flocking: 'Move mouse — acts as predator to the boids.',
    gravity:  'Click to place gravity wells. Elements orbit them.',
    springs:  'Drag nodes — spring mesh reacts elastically.',
    ripple:   'Click anywhere to emit a ripple wave.'
  };

  // ── Tile thumbnails ──
  function makeThumbnail(id, drawFn) {
    const c = document.getElementById(id);
    const ctx2 = c.getContext('2d');
    let fr = null;
    function loop(ts) { drawFn(ctx2, c.width, c.height, ts/1000); fr = requestAnimationFrame(loop); }
    fr = requestAnimationFrame(loop);
    return () => { cancelAnimationFrame(fr); };
  }

  // Trails thumbnail
  const trailPts = Array.from({length:60},()=>({x:92,y:77,vx:(Math.random()-.5)*1.5,vy:(Math.random()-.5)*1.5}));
  makeThumbnail('iTrails',(ctx2,W2,H2,t)=>{
    ctx2.fillStyle='rgba(5,5,18,0.05)';ctx2.fillRect(0,0,W2,H2);
    const mx=W2/2+Math.cos(t*0.8)*W2*0.3, my=H2/2+Math.sin(t*1.1)*H2*0.25;
    trailPts.forEach(p=>{
      p.vx+=(mx-p.x)*0.002; p.vy+=(my-p.y)*0.002;
      p.vx*=0.95; p.vy*=0.95;
      p.x+=p.vx; p.y+=p.vy;
      ctx2.fillStyle='rgba(167,139,250,0.6)'; ctx2.fillRect(p.x,p.y,2,2);
    });
  });

  // Magnets thumbnail
  const magPts = Array.from({length:40},()=>({x:Math.random()*185,y:Math.random()*155,vx:0,vy:0}));
  makeThumbnail('iMagnets',(ctx2,W2,H2,t)=>{
    ctx2.fillStyle='rgba(5,5,18,0.07)';ctx2.fillRect(0,0,W2,H2);
    const mx=W2/2+Math.cos(t*0.7)*W2*0.28, my=H2/2+Math.sin(t*0.9)*H2*0.22;
    magPts.forEach(p=>{
      const dx=p.x-mx, dy=p.y-my, d2=dx*dx+dy*dy+1;
      p.vx+=dx*0.03/d2*400; p.vy+=dy*0.03/d2*400;
      p.vx*=0.88; p.vy*=0.88;
      p.x+=p.vx; p.y+=p.vy;
      if(p.x<0||p.x>W2)p.vx*=-1; if(p.y<0||p.y>H2)p.vy*=-1;
      ctx2.beginPath();ctx2.arc(p.x,p.y,3,0,Math.PI*2);
      ctx2.fillStyle='rgba(124,58,237,0.7)';ctx2.fill();
    });
  });

  // Flocking thumbnail (mini boids)
  const boids = Array.from({length:35},()=>({x:Math.random()*185,y:Math.random()*155,vx:(Math.random()-.5)*1.5,vy:(Math.random()-.5)*1.5}));
  makeThumbnail('iFlocking',(ctx2,W2,H2,t)=>{
    ctx2.fillStyle='rgba(5,5,18,0.06)';ctx2.fillRect(0,0,W2,H2);
    const px2=W2/2+Math.cos(t*0.6)*W2*0.35, py2=H2/2+Math.sin(t*0.8)*H2*0.28;
    boids.forEach(b=>{
      let ax=0,ay=0,sx=0,sy=0,cx2=0,cy2=0,cnt=0;
      boids.forEach(o=>{if(o===b)return;const dx=o.x-b.x,dy=o.y-b.y,d=Math.sqrt(dx*dx+dy*dy);if(d<30){ax-=dx/d;ay-=dy/d;}if(d<60){sx+=o.vx;sy+=o.vy;cx2+=o.x;cy2+=o.y;cnt++;}});
      if(cnt>0){sx/=cnt;sy/=cnt;cx2/=cnt;cy2/=cnt;ax+=(cx2-b.x)*0.01+(sx-b.vx)*0.05;ay+=(cy2-b.y)*0.01+(sy-b.vy)*0.05;}
      const dpx=b.x-px2,dpy=b.y-py2,dp=Math.sqrt(dpx*dpx+dpy*dpy)+1;
      ax+=dpx/dp*2;ay+=dpy/dp*2;
      b.vx=(b.vx+ax*0.1)*0.97;b.vy=(b.vy+ay*0.1)*0.97;
      const spd=Math.sqrt(b.vx*b.vx+b.vy*b.vy);
      if(spd>2){b.vx=b.vx/spd*2;b.vy=b.vy/spd*2;}
      b.x+=b.vx;b.y+=b.vy;
      if(b.x<0)b.x+=W2;if(b.x>W2)b.x-=W2;if(b.y<0)b.y+=H2;if(b.y>H2)b.y-=H2;
      ctx2.beginPath();ctx2.arc(b.x,b.y,2.5,0,Math.PI*2);
      ctx2.fillStyle='rgba(196,181,253,0.75)';ctx2.fill();
    });
  });

  // Gravity thumbnail
  const gPts = Array.from({length:50},()=>({x:Math.random()*185,y:Math.random()*155,vx:(Math.random()-.5)*.8,vy:(Math.random()-.5)*.8}));
  const gWells=[{x:60,y:60},{x:130,y:100}];
  makeThumbnail('iGravity',(ctx2,W2,H2,t)=>{
    ctx2.fillStyle='rgba(5,5,18,0.05)';ctx2.fillRect(0,0,W2,H2);
    gWells[0].x=W2*0.35+Math.cos(t*0.4)*W2*0.15; gWells[0].y=H2*0.45+Math.sin(t*0.5)*H2*0.2;
    gWells[1].x=W2*0.65+Math.cos(t*0.3+2)*W2*0.12; gWells[1].y=H2*0.5+Math.sin(t*0.4+1)*H2*0.15;
    gPts.forEach(p=>{
      gWells.forEach(w=>{const dx=w.x-p.x,dy=w.y-p.y,d2=dx*dx+dy*dy+4,f=600/d2;p.vx+=dx*f*0.001;p.vy+=dy*f*0.001;});
      p.vx*=0.985;p.vy*=0.985;
      p.x+=p.vx;p.y+=p.vy;
      if(p.x<0||p.x>W2)p.vx*=-0.8; if(p.y<0||p.y>H2)p.vy*=-0.8;
      ctx2.fillStyle='rgba(139,92,246,0.6)';ctx2.fillRect(p.x,p.y,1.5,1.5);
    });
    gWells.forEach(w=>{ctx2.beginPath();ctx2.arc(w.x,w.y,5,0,Math.PI*2);ctx2.fillStyle='rgba(196,181,253,0.9)';ctx2.fill();});
  });

  // Springs thumbnail
  const SCOUNT=16;
  const sNodes=Array.from({length:SCOUNT},(_,i)=>({x:30+(i%4)*42,y:30+Math.floor(i/4)*38,vx:0,vy:0,ox:30+(i%4)*42,oy:30+Math.floor(i/4)*38}));
  const sEdges=[];
  for(let i=0;i<SCOUNT;i++){if(i%4<3)sEdges.push([i,i+1]);if(i<12)sEdges.push([i,i+4]);}
  makeThumbnail('iSprings',(ctx2,W2,H2,t)=>{
    ctx2.fillStyle='rgba(5,5,18,0.08)';ctx2.fillRect(0,0,W2,H2);
    sNodes.forEach(n=>{n.x+=Math.sin(t*0.6+n.ox*0.1)*0.3;n.y+=Math.cos(t*0.5+n.oy*0.1)*0.25;});
    ctx2.strokeStyle='rgba(124,58,237,0.5)';ctx2.lineWidth=1;
    sEdges.forEach(([a,b])=>{ctx2.beginPath();ctx2.moveTo(sNodes[a].x,sNodes[a].y);ctx2.lineTo(sNodes[b].x,sNodes[b].y);ctx2.stroke();});
    sNodes.forEach(n=>{ctx2.beginPath();ctx2.arc(n.x,n.y,3,0,Math.PI*2);ctx2.fillStyle='rgba(167,139,250,0.85)';ctx2.fill();});
  });

  // Ripple thumbnail
  const ripples2=[];
  makeThumbnail('iRipple',(ctx2,W2,H2,t)=>{
    ctx2.fillStyle='rgba(5,5,18,0.06)';ctx2.fillRect(0,0,W2,H2);
    if(Math.random()<0.015)ripples2.push({x:Math.random()*W2,y:Math.random()*H2,r:0,a:0.8});
    for(let i=ripples2.length-1;i>=0;i--){
      const rp=ripples2[i]; rp.r+=1.2; rp.a-=0.012;
      if(rp.a<=0){ripples2.splice(i,1);continue;}
      ctx2.beginPath();ctx2.arc(rp.x,rp.y,rp.r,0,Math.PI*2);
      ctx2.strokeStyle=`rgba(167,139,250,${rp.a})`;ctx2.lineWidth=1.5;ctx2.stroke();
    }
  });

  // ── Focus canvas ──
  const focusCanvas = document.getElementById('iFocusCanvas');
  const fCtx        = focusCanvas.getContext('2d');
  let FW = focusCanvas.width, FH = focusCanvas.height;
  new ResizeObserver(()=>{FW=focusCanvas.width=focusCanvas.offsetWidth;FH=focusCanvas.height=Math.round(FW*0.63);}).observe(focusCanvas);

  let activeFocus = null, fAnimId = null, fLastTs = 0;
  let fMouseX=FW/2, fMouseY=FH/2;
  let gravWells=[], rippleList=[], springDrag=null;

  focusCanvas.addEventListener('mousemove',e=>{const r=focusCanvas.getBoundingClientRect();fMouseX=(e.clientX-r.left)*(FW/r.width);fMouseY=(e.clientY-r.top)*(FH/r.height);});
  focusCanvas.addEventListener('click',e=>{
    const r=focusCanvas.getBoundingClientRect();
    const x=(e.clientX-r.left)*(FW/r.width);
    const y=(e.clientY-r.top)*(FH/r.height);
    if(activeFocus==='gravity') gravWells.push({x,y});
    if(activeFocus==='ripple')  rippleList.push({x,y,r:0,a:0.9});
  });

  // Focus systems
  const fTrails=Array.from({length:120},()=>({x:FW/2,y:FH/2,vx:(Math.random()-.5)*2,vy:(Math.random()-.5)*2}));
  const fMag=Array.from({length:80},()=>({x:Math.random()*600,y:Math.random()*380,vx:0,vy:0}));
  const fBoids=Array.from({length:100},()=>({x:Math.random()*600,y:Math.random()*380,vx:(Math.random()-.5)*2,vy:(Math.random()-.5)*2}));
  const fGPts=Array.from({length:100},()=>({x:Math.random()*600,y:Math.random()*380,vx:(Math.random()-.5)*1.5,vy:(Math.random()-.5)*1.5}));
  // Spring network
  const SFULL=25, fSNodes=Array.from({length:SFULL},(_,i)=>({x:80+(i%5)*90,y:80+Math.floor(i/5)*75,vx:0,vy:0,locked:false}));
  const fSEdges=[];
  for(let i=0;i<SFULL;i++){if(i%5<4)fSEdges.push([i,i+1]);if(i<20)fSEdges.push([i,i+5]);}
  const restLengths=fSEdges.map(([a,b])=>Math.sqrt((fSNodes[a].x-fSNodes[b].x)**2+(fSNodes[a].y-fSNodes[b].y)**2));

  function runFocus(ts) {
    const dt=Math.min((ts-fLastTs)/1000,.04); fLastTs=ts;
    const sp=iSpeedLag.update(parseFloat(document.getElementById('iSpeed').value),dt);
    const dm=iDampLag.update(parseFloat(document.getElementById('iDamp').value),dt);
    fCtx.fillStyle='rgba(5,5,18,0.06)'; fCtx.fillRect(0,0,FW,FH);
    switch(activeFocus) {
      case 'trails':
        fTrails.forEach(p=>{
          p.vx+=(fMouseX-p.x)*0.003*sp; p.vy+=(fMouseY-p.y)*0.003*sp;
          p.vx*=dm; p.vy*=dm; p.x+=p.vx*sp; p.y+=p.vy*sp;
          const spd=Math.sqrt(p.vx*p.vx+p.vy*p.vy);
          const t2=Math.min(spd/3,1);
          fCtx.fillStyle=`rgba(${Math.round(124+t2*72)},${Math.round(58+t2*123)},${Math.round(237+t2*16)},0.7)`;
          fCtx.fillRect(p.x,p.y,2,2);
        }); break;
      case 'magnets':
        fMag.forEach(p=>{
          const dx=p.x-fMouseX,dy=p.y-fMouseY,d2=dx*dx+dy*dy+1,f=1800/d2;
          p.vx=(p.vx+dx*f*sp*0.001)*dm; p.vy=(p.vy+dy*f*sp*0.001)*dm;
          p.x+=p.vx; p.y+=p.vy;
          if(p.x<0||p.x>FW)p.vx*=-0.8;if(p.y<0||p.y>FH)p.vy*=-0.8;
          p.x=clamp(p.x,0,FW); p.y=clamp(p.y,0,FH);
          fCtx.beginPath();fCtx.arc(p.x,p.y,3.5,0,Math.PI*2);fCtx.fillStyle='rgba(124,58,237,0.8)';fCtx.fill();
        }); break;
      case 'flocking':
        fBoids.forEach(b=>{
          let ax=0,ay=0,n2=0;
          fBoids.forEach(o=>{if(o===b)return;const dx=o.x-b.x,dy=o.y-b.y,d=Math.sqrt(dx*dx+dy*dy);
            if(d<20&&d>0){ax-=dx/d*2;ay-=dy/d*2;}
            if(d<60&&d>0){ax+=(o.vx-b.vx)*.04+(o.x-b.x)*.008;ay+=(o.vy-b.vy)*.04+(o.y-b.y)*.008;n2++;}
          });
          const dPx=b.x-fMouseX,dPy=b.y-fMouseY,dP=Math.sqrt(dPx*dPx+dPy*dPy)+1;
          if(dP<100){ax+=dPx/dP*3;ay+=dPy/dP*3;}
          b.vx=(b.vx+ax*.1*sp)*dm; b.vy=(b.vy+ay*.1*sp)*dm;
          const spd2=Math.sqrt(b.vx*b.vx+b.vy*b.vy);
          if(spd2>3*sp){b.vx=b.vx/spd2*3*sp;b.vy=b.vy/spd2*3*sp;}
          b.x+=b.vx; b.y+=b.vy;
          if(b.x<0)b.x+=FW;if(b.x>FW)b.x-=FW;if(b.y<0)b.y+=FH;if(b.y>FH)b.y-=FH;
          fCtx.save();fCtx.translate(b.x,b.y);fCtx.rotate(Math.atan2(b.vy,b.vx));
          fCtx.beginPath();fCtx.moveTo(6,0);fCtx.lineTo(-4,3);fCtx.lineTo(-4,-3);fCtx.closePath();
          fCtx.fillStyle='rgba(196,181,253,0.75)';fCtx.fill();fCtx.restore();
        }); break;
      case 'gravity':
        fGPts.forEach(p=>{
          gravWells.forEach(w=>{const dx=w.x-p.x,dy=w.y-p.y,d2=dx*dx+dy*dy+4;p.vx+=dx*1200/d2*sp*0.001;p.vy+=dy*1200/d2*sp*0.001;});
          p.vx*=dm; p.vy*=dm;
          p.x+=p.vx; p.y+=p.vy;
          if(p.x<0||p.x>FW)p.vx*=-0.7;if(p.y<0||p.y>FH)p.vy*=-0.7;
          p.x=clamp(p.x,0,FW);p.y=clamp(p.y,0,FH);
          const spd3=Math.sqrt(p.vx*p.vx+p.vy*p.vy);
          const t3=Math.min(spd3/5,1);
          fCtx.fillStyle=`rgba(${Math.round(99+t3*97)},${Math.round(58+t3*81)},246,0.65)`;
          fCtx.fillRect(p.x,p.y,1.8,1.8);
        });
        gravWells.forEach(w=>{fCtx.beginPath();fCtx.arc(w.x,w.y,6,0,Math.PI*2);fCtx.fillStyle='rgba(196,181,253,0.95)';fCtx.fill();});
        break;
      case 'springs':
        for(let iter=0;iter<3;iter++) {
          fSEdges.forEach(([a,b],ei)=>{
            const dx=fSNodes[b].x-fSNodes[a].x,dy=fSNodes[b].y-fSNodes[a].y;
            const d=Math.sqrt(dx*dx+dy*dy)||1;
            const force=(d-restLengths[ei])*0.12*sp;
            fSNodes[a].vx+=dx/d*force;fSNodes[a].vy+=dy/d*force;
            fSNodes[b].vx-=dx/d*force;fSNodes[b].vy-=dy/d*force;
          });
          fSNodes.forEach(n=>{
            const dMx=n.x-fMouseX,dMy=n.y-fMouseY,dM=Math.sqrt(dMx*dMx+dMy*dMy);
            if(dM<25){n.vx+=(fMouseX-n.x)*0.08*sp;n.vy+=(fMouseY-n.y)*0.08*sp;}
            n.vx*=dm;n.vy*=dm;n.x+=n.vx;n.y+=n.vy;
            n.x=clamp(n.x,10,FW-10);n.y=clamp(n.y,10,FH-10);
          });
        }
        fCtx.strokeStyle='rgba(124,58,237,0.55)';fCtx.lineWidth=1.5;
        fSEdges.forEach(([a,b])=>{fCtx.beginPath();fCtx.moveTo(fSNodes[a].x,fSNodes[a].y);fCtx.lineTo(fSNodes[b].x,fSNodes[b].y);fCtx.stroke();});
        fSNodes.forEach(n=>{fCtx.beginPath();fCtx.arc(n.x,n.y,4.5,0,Math.PI*2);fCtx.fillStyle='rgba(167,139,250,0.9)';fCtx.fill();});
        break;
      case 'ripple':
        for(let i=rippleList.length-1;i>=0;i--){
          const rp=rippleList[i];rp.r+=sp*60*dt;rp.a-=dt*0.35;
          if(rp.a<=0){rippleList.splice(i,1);continue;}
          fCtx.beginPath();fCtx.arc(rp.x,rp.y,rp.r,0,Math.PI*2);
          fCtx.strokeStyle=`rgba(167,139,250,${rp.a})`;fCtx.lineWidth=2.5;fCtx.stroke();
          if(rp.r>30){fCtx.beginPath();fCtx.arc(rp.x,rp.y,rp.r*0.62,0,Math.PI*2);fCtx.strokeStyle=`rgba(124,58,237,${rp.a*.6})`;fCtx.lineWidth=1.5;fCtx.stroke();}
        } break;
    }
    fAnimId=requestAnimationFrame(runFocus);
  }

  // Tile click → expand
  document.getElementById('interactionTiles').querySelectorAll('.itile').forEach(tile=>{
    tile.addEventListener('click',()=>{
      document.querySelectorAll('.itile').forEach(t=>t.classList.remove('active'));
      tile.classList.add('active');
      activeFocus=tile.dataset.demo;
      document.getElementById('interactionFocus').style.display='';
      document.getElementById('iHint').textContent=hints[activeFocus]||'';
      gravWells=[];rippleList=[];
      if(fAnimId)cancelAnimationFrame(fAnimId);
      fCtx.clearRect(0,0,FW,FH);
      fCtx.fillStyle='#070513';fCtx.fillRect(0,0,FW,FH);
      fAnimId=requestAnimationFrame(runFocus);
    });
  });
  document.getElementById('iClose').addEventListener('click',()=>{
    activeFocus=null;
    document.getElementById('interactionFocus').style.display='none';
    document.querySelectorAll('.itile').forEach(t=>t.classList.remove('active'));
    if(fAnimId)cancelAnimationFrame(fAnimId);
  });
})();
</script>
