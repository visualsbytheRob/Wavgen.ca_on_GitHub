<script>
// ============================================================
// LAGFILTER UTILITY
// Exponential smoothing: value += (1 - exp(-dt/tau)) * (target - value)
// ============================================================
function lagStep(current, target, dt, tau) {
  return current + (1 - Math.exp(-dt / tau)) * (target - current);
}

// ============================================================
// SECTION 1: HERO — WebGL Latent Space Field
// ============================================================
(function() {
  const canvas = document.getElementById("heroCanvas");
  const W = canvas.offsetWidth, H = canvas.offsetHeight;
  canvas.width = W; canvas.height = H;

  const gl = canvas.getContext("webgl") || canvas.getContext("experimental-webgl");
  if (!gl) return;

  const vsrc = ;
  const fsrc = ;

  function compileShader(type, src) {
    const sh = gl.createShader(type);
    gl.shaderSource(sh, src);
    gl.compileShader(sh);
    return sh;
  }
  const prog = gl.createProgram();
  gl.attachShader(prog, compileShader(gl.VERTEX_SHADER, vsrc));
  gl.attachShader(prog, compileShader(gl.FRAGMENT_SHADER, fsrc));
  gl.linkProgram(prog);
  gl.useProgram(prog);

  const buf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, buf);
  gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1,1,-1,-1,1,1,1]), gl.STATIC_DRAW);
  const pLoc = gl.getAttribLocation(prog, "p");
  gl.enableVertexAttribArray(pLoc);
  gl.vertexAttribPointer(pLoc, 2, gl.FLOAT, false, 0, 0);

  const uTime = gl.getUniformLocation(prog, "time");
  const uDenoise = gl.getUniformLocation(prog, "denoise");
  const uMouse = gl.getUniformLocation(prog, "mouse");
  const uRes = gl.getUniformLocation(prog, "res");

  // LagFilter 1 & 2: hero mouse position
  let mouseX = W/2, mouseY = H/2;
  let smoothMouseX = W/2, smoothMouseY = H/2;
  // LagFilter 3: denoise level cycles slowly
  let denoiseTarget = 1.0, denoiseCurrent = 1.0;

  canvas.addEventListener("mousemove", e => {
    const r = canvas.getBoundingClientRect();
    mouseX = e.clientX - r.left;
    mouseY = r.height - (e.clientY - r.top);
  });

  let t0 = performance.now(), denoiseDir = -1;

  function frame(now) {
    const dt = Math.min((now - t0) / 1000, 0.1);
    t0 = now;

    // LagFilter 1: smooth mouse X (tau=0.18s)
    smoothMouseX = lagStep(smoothMouseX, mouseX, dt, 0.18);
    // LagFilter 2: smooth mouse Y
    smoothMouseY = lagStep(smoothMouseY, mouseY, dt, 0.22);

    denoiseTarget += denoiseDir * dt * 0.07;
    if (denoiseTarget <= 0.05) { denoiseTarget = 0.05; denoiseDir = 1; }
    if (denoiseTarget >= 1.0)  { denoiseTarget = 1.0;  denoiseDir = -1; }
    // LagFilter 3: smooth denoise
    denoiseCurrent = lagStep(denoiseCurrent, denoiseTarget, dt, 1.2);

    gl.viewport(0, 0, W, H);
    gl.uniform1f(uTime, now * 0.001);
    gl.uniform1f(uDenoise, denoiseCurrent);
    gl.uniform2f(uMouse, smoothMouseX, smoothMouseY);
    gl.uniform2f(uRes, W, H);
    gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();

// ============================================================
// SECTION 2: DIFFUSION PROCESS
// ============================================================
(function() {
  const canvas = document.getElementById("diffCanvas");
  const chart = document.getElementById("noiseChart");
  if (!canvas || !chart) return;

  function resize() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight || 260;
    chart.height = canvas.height;
  }
  resize();
  window.addEventListener("resize", resize);

  const ctx = canvas.getContext("2d");
  const cctx = chart.getContext("2d");
  const slider = document.getElementById("diffSlider");
  const valLabel = document.getElementById("diffVal");

  let tTarget = 800, tSmooth = 800; // LagFilter 4: diffusion timestep display
  let noiseSmooth = 0.8;            // LagFilter 5: noise level display

  // Simple hash for reproducible patterns
  function hash2(x, y, seed) {
    let v = (x * 1237 + y * 3571 + seed * 6997) & 0x7fffffff;
    v = ((v >> 16) ^ v) * 0x45d9f3b; v = ((v >> 16) ^ v) * 0x45d9f3b;
    return ((v >> 16) ^ v) / 0x7fffffff;
  }

  // Seed shapes (abstract blobs representing a latent image)
  const shapes = [
    {cx:0.35, cy:0.45, rx:0.12, ry:0.18, r:180, g:80, b:220},
    {cx:0.62, cy:0.38, rx:0.09, ry:0.14, r:20, g:180, b:240},
    {cx:0.50, cy:0.60, rx:0.16, ry:0.10, r:240, g:120, b:60},
    {cx:0.25, cy:0.65, rx:0.07, ry:0.10, r:100, g:220, b:180},
  ];

  let t0 = performance.now();
  function frame(now) {
    const dt = Math.min((now - t0) / 1000, 0.1); t0 = now;
    const tVal = parseFloat(slider.value);
    // LagFilter 4: smooth timestep display
    tSmooth = lagStep(tSmooth, tVal, dt, 0.08);
    valLabel.textContent = "t = " + Math.round(tSmooth);

    const noiseLevel = tSmooth / 1000;
    // LagFilter 5: smooth noise level
    noiseSmooth = lagStep(noiseSmooth, noiseLevel, dt, 0.15);

    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);

    // Draw underlying image shapes (fade in as noise decreases)
    const alpha = 1 - noiseSmooth;
    if (alpha > 0.01) {
      for (const s of shapes) {
        const gx = ctx.createRadialGradient(s.cx*W, s.cy*H, 0, s.cx*W, s.cy*H, s.rx*W);
        gx.addColorStop(0, "rgba(" + s.r + "," + s.g + "," + s.b + "," + (alpha*0.85) + ")");
        gx.addColorStop(1, "rgba(0,0,0,0)");
        ctx.fillStyle = gx;
        ctx.beginPath();
        ctx.ellipse(s.cx*W, s.cy*H, s.rx*W, s.ry*H, 0, 0, Math.PI*2);
        ctx.fill();
      }
    }

    // Overlay noise
    const frame_seed = Math.floor(now / 80);
    const blockSize = Math.max(2, Math.floor(noiseSmooth * 6 + 1));
    for (let y = 0; y < H; y += blockSize) {
      for (let x = 0; x < W; x += blockSize) {
        const nv = hash2(Math.floor(x/blockSize), Math.floor(y/blockSize), frame_seed);
        const nv2 = hash2(Math.floor(x/blockSize)+100, Math.floor(y/blockSize)+100, frame_seed+1);
        const alpha2 = noiseSmooth * 0.85;
        const gray = nv * 200 + 28;
        // Tint noise with violet/cyan
        const rv = gray * 0.7 + nv2 * 60;
        const gv = gray * 0.4;
        const bv = gray * 0.9 + nv * 40;
        ctx.fillStyle = "rgba(" + Math.round(rv) + "," + Math.round(gv) + "," + Math.round(bv) + "," + alpha2 + ")";
        ctx.fillRect(x, y, blockSize, blockSize);
      }
    }

    // Phosphor persistence (subtle)
    ctx.fillStyle = "rgba(6,0,18,0.04)";
    ctx.fillRect(0, 0, W, H);

    // Draw noise schedule chart
    const CW = chart.width, CH = chart.height;
    cctx.clearRect(0, 0, CW, CH);
    cctx.fillStyle = "#12001F";
    cctx.fillRect(0, 0, CW, CH);
    // Draw schedule curve
    cctx.beginPath();
    for (let i = 0; i <= 100; i++) {
      const tx = i / 100;
      const ny = 1 - tx * tx; // cosine-like schedule
      const px = 8 + tx * (CW - 16);
      const py = CH - 8 - ny * (CH - 20);
      i === 0 ? cctx.moveTo(px, py) : cctx.lineTo(px, py);
    }
    cctx.strokeStyle = "#7B2FFF";
    cctx.lineWidth = 2;
    cctx.stroke();
    // Current position marker
    const tx = tSmooth / 1000;
    const ny = 1 - tx * tx;
    const mx = 8 + tx * (CW - 16);
    const my = CH - 8 - ny * (CH - 20);
    cctx.beginPath();
    cctx.arc(mx, my, 5, 0, Math.PI*2);
    cctx.fillStyle = "#00E5FF";
    cctx.fill();
    // Labels
    cctx.fillStyle = "#8B6FB0";
    cctx.font = "10px monospace";
    cctx.fillText("Noise", 4, 14);
    cctx.fillText("t →", CW - 30, CH - 2);

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
<script>
// ============================================================
// SECTION 3: CLIP & SEMANTIC SPACE
// ============================================================
(function() {
  const canvas = document.getElementById("clipCanvas");
  if (!canvas) return;
  function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight || 340; }
  resize();
  window.addEventListener("resize", resize);
  const ctx = canvas.getContext("2d");

  // 20 concept nodes with cluster positions and relationships
  const concepts = [
    // Art styles cluster
    {label:"Impressionism", gx:0.15,gy:0.25, group:0},
    {label:"Cubism",        gx:0.22,gy:0.40, group:0},
    {label:"Surrealism",    gx:0.12,gy:0.55, group:0},
    {label:"Abstract",      gx:0.28,gy:0.62, group:0},
    {label:"Photorealism",  gx:0.20,gy:0.75, group:0},
    // Subject cluster
    {label:"Portrait",      gx:0.48,gy:0.20, group:1},
    {label:"Landscape",     gx:0.58,gy:0.32, group:1},
    {label:"Still Life",    gx:0.52,gy:0.48, group:1},
    {label:"Architecture",  gx:0.45,gy:0.62, group:1},
    {label:"Nature",        gx:0.60,gy:0.70, group:1},
    // Emotion cluster
    {label:"Melancholy",    gx:0.78,gy:0.18, group:2},
    {label:"Joy",           gx:0.88,gy:0.30, group:2},
    {label:"Sublime",       gx:0.80,gy:0.45, group:2},
    {label:"Eerie",         gx:0.72,gy:0.58, group:2},
    {label:"Serene",        gx:0.85,gy:0.65, group:2},
    // Technical cluster
    {label:"Geometric",     gx:0.35,gy:0.18, group:3},
    {label:"Organic",       gx:0.42,gy:0.30, group:3},
    {label:"Texture",       gx:0.32,gy:0.78, group:3},
    {label:"Contrast",      gx:0.70,gy:0.80, group:3},
    {label:"Gradient",      gx:0.55,gy:0.85, group:3},
  ];

  const groupColors = ["#7B2FFF","#00E5FF","#A855F7","#FF6B9D"];

  // Initialize node positions and spring velocities
  const nodes = concepts.map((c,i) => ({
    ...c, i,
    x: c.gx, y: c.gy,
    vx: 0, vy: 0,
    active: 0,  // LagFilter 6: node activation glow
    targetActive: 0
  }));

  // Similarity matrix (simplified — same group = high similarity)
  function similarity(a, b) {
    if (a.group === b.group) return 0.6 + Math.random() * 0.3;
    const dx = a.gx - b.gx, dy = a.gy - b.gy;
    const d = Math.sqrt(dx*dx + dy*dy);
    return Math.max(0, 0.4 - d);
  }

  let activeNode = null;
  canvas.addEventListener("click", e => {
    const r = canvas.getBoundingClientRect();
    const mx = (e.clientX - r.left) / canvas.offsetWidth;
    const my = (e.clientY - r.top) / canvas.offsetHeight;
    let closest = null, minD = Infinity;
    nodes.forEach(n => {
      const dx = n.x - mx, dy = n.y - my;
      const d = Math.sqrt(dx*dx + dy*dy);
      if (d < minD) { minD = d; closest = n; }
    });
    if (minD < 0.08) {
      activeNode = (activeNode === closest.i) ? null : closest.i;
      nodes.forEach(n => n.targetActive = 0);
      if (activeNode !== null) {
        nodes[activeNode].targetActive = 1;
        nodes.forEach((n,i) => {
          if (i !== activeNode) n.targetActive = similarity(nodes[activeNode], n);
        });
      }
    }
  });

  // Text similarity
  const w1 = document.getElementById("clipWord1");
  const w2 = document.getElementById("clipWord2");
  const distEl = document.getElementById("clipDistDisplay");

  function calcTextSim(a, b) {
    a = a.toLowerCase().trim(); b = b.toLowerCase().trim();
    if (!a || !b) return 0;
    if (a === b) return 1;
    let shared = 0;
    const aSet = new Set(a.split(""));
    b.split("").forEach(c => { if (aSet.has(c)) shared++; });
    const base = shared / Math.max(a.length, b.length);
    // Semantic hint based on known pairs
    const pairs = {"dream machine":0.55,"art ai":0.8,"color light":0.75,"human robot":0.65,"noise clarity":0.6};
    const key1 = a+" "+b, key2 = b+" "+a;
    return pairs[key1] || pairs[key2] || base * 0.7 + 0.1;
  }

  let simVal = 0, simTarget = 0; // LagFilter 7: similarity display

  function updateSim() {
    simTarget = calcTextSim(w1 ? w1.value : "", w2 ? w2.value : "");
  }
  if (w1) w1.addEventListener("input", updateSim);
  if (w2) w2.addEventListener("input", updateSim);
  updateSim();

  let t0 = performance.now();
  function frame(now) {
    const dt = Math.min((now - t0)/1000, 0.08); t0 = now;
    const W = canvas.width, H = canvas.height;

    // Phosphor persistence
    ctx.fillStyle = "rgba(6,0,18,0.15)";
    ctx.fillRect(0,0,W,H);

    // Update node springs and LagFilter activations
    nodes.forEach((n,i) => {
      // LagFilter 6: node activation (each node's glow — counts as N instances in loop)
      n.active = lagStep(n.active, n.targetActive, dt, 0.12);

      // Spring toward goal position
      const fx = (n.gx * W - n.x * W) * 0.8;
      const fy = (n.gy * H - n.y * H) * 0.8;
      n.vx = lagStep(n.vx, fx, dt, 0.15);
      n.vy = lagStep(n.vy, fy, dt, 0.15);
      n.x += n.vx * dt / W;
      n.y += n.vy * dt / H;
    });

    // LagFilter 7: similarity value
    simVal = lagStep(simVal, simTarget, dt, 0.2);
    if (distEl) {
      const pct = Math.round(simVal * 100);
      distEl.textContent = "Similarity: " + pct + "%";
      distEl.style.background = "rgba(" + Math.round(simVal*0) + "," + Math.round(simVal*180) + "," + Math.round(simVal*255) + ",0.15)";
    }

    // Draw connections for active node
    if (activeNode !== null) {
      nodes.forEach((n,i) => {
        if (i === activeNode) return;
        const strength = n.active;
        if (strength < 0.05) return;
        const an = nodes[activeNode];
        ctx.beginPath();
        ctx.moveTo(an.x * W, an.y * H);
        ctx.lineTo(n.x * W, n.y * H);
        ctx.strokeStyle = "rgba(0,229,255," + (strength * 0.6) + ")";
        ctx.lineWidth = strength * 3;
        ctx.stroke();
      });
    }

    // Draw nodes
    nodes.forEach((n,i) => {
      const px = n.x * W, py = n.y * H;
      const r = 18 + n.active * 10;
      const col = groupColors[n.group];

      // Glow
      if (n.active > 0.05) {
        const g = ctx.createRadialGradient(px,py,0,px,py,r+14);
        g.addColorStop(0, col + Math.round(n.active*200).toString(16).padStart(2,"0"));
        g.addColorStop(1, "rgba(0,0,0,0)");
        ctx.fillStyle = g;
        ctx.beginPath(); ctx.arc(px,py,r+14,0,Math.PI*2); ctx.fill();
      }

      // Node circle
      ctx.beginPath(); ctx.arc(px,py,r,0,Math.PI*2);
      ctx.fillStyle = i === activeNode ? "#7B2FFF" : ("rgba("+parseInt(col.slice(1,3),16)+","+parseInt(col.slice(3,5),16)+","+parseInt(col.slice(5,7),16)+","+(0.25+n.active*0.5)+")");
      ctx.fill();
      ctx.strokeStyle = n.active > 0.3 ? "#00E5FF" : col;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // Label
      ctx.fillStyle = "rgba(232,213,255," + (0.6 + n.active * 0.4) + ")";
      ctx.font = (n.active > 0.5 ? "bold " : "") + "10px sans-serif";
      ctx.textAlign = "center";
      ctx.fillText(n.label, px, py + r + 12);
    });

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
<script>
// ============================================================
// SECTION 4: CONTROLNET SYSTEMS
// ============================================================
(function() {
  const canvas = document.getElementById("ctrlCanvas");
  if (!canvas) return;
  function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight || 280; }
  resize();
  window.addEventListener("resize", resize);
  const ctx = canvas.getContext("2d");

  let ctrlType = "canny";
  let strTarget = 0.75, strSmooth = 0.75; // LagFilter 8: conditioning strength

  document.querySelectorAll("[data-ctrl]").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll("[data-ctrl]").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      ctrlType = btn.dataset.ctrl;
    });
  });

  const strSlider = document.getElementById("ctrlStrSlider");
  const strVal = document.getElementById("ctrlStrVal");
  if (strSlider) strSlider.addEventListener("input", () => {
    strTarget = parseFloat(strSlider.value) / 100;
  });

  // Utility: a simplified "face/figure" scene as line art
  function drawScene(cx, style) {
    const W = canvas.width, H = canvas.height;
    // Head oval
    cx.beginPath();
    cx.ellipse(W*0.5, H*0.32, W*0.12, H*0.18, 0, 0, Math.PI*2);
    cx.stroke();
    // Shoulders
    cx.beginPath();
    cx.moveTo(W*0.3, H*0.72);
    cx.bezierCurveTo(W*0.35, H*0.52, W*0.45, H*0.50, W*0.50, H*0.50);
    cx.bezierCurveTo(W*0.55, H*0.50, W*0.65, H*0.52, W*0.70, H*0.72);
    cx.stroke();
    // Eyes
    cx.beginPath();
    cx.ellipse(W*0.44, H*0.30, W*0.025, H*0.025, 0, 0, Math.PI*2);
    cx.stroke();
    cx.beginPath();
    cx.ellipse(W*0.56, H*0.30, W*0.025, H*0.025, 0, 0, Math.PI*2);
    cx.stroke();
    // Nose line
    cx.beginPath();
    cx.moveTo(W*0.50, H*0.32);
    cx.lineTo(W*0.50, H*0.40);
    cx.stroke();
    // Mouth
    cx.beginPath();
    cx.arc(W*0.50, H*0.42, W*0.04, 0, Math.PI);
    cx.stroke();
  }

  // Pose skeleton points
  const posePoints = [
    {x:0.50, y:0.28}, // head
    {x:0.50, y:0.42}, // neck
    {x:0.50, y:0.58}, // torso
    {x:0.36, y:0.43}, // L shoulder
    {x:0.28, y:0.56}, // L elbow
    {x:0.22, y:0.68}, // L wrist
    {x:0.64, y:0.43}, // R shoulder
    {x:0.72, y:0.56}, // R elbow
    {x:0.78, y:0.68}, // R wrist
    {x:0.44, y:0.72}, // L hip
    {x:0.40, y:0.85}, // L knee
    {x:0.56, y:0.72}, // R hip
    {x:0.60, y:0.85}, // R knee
  ];
  const poseBones = [[0,1],[1,2],[1,3],[3,4],[4,5],[1,6],[6,7],[7,8],[2,9],[9,10],[2,11],[11,12]];
  const poseColors = ["#FF6B6B","#FFD93D","#6BCB77","#4D96FF","#FF6BFF"];

  // Segmentation color map
  const segColors = {
    bg: "rgba(30,0,60,0.7)",
    face: "rgba(255,150,80,0.7)",
    hair: "rgba(80,40,20,0.7)",
    clothes: "rgba(60,80,200,0.7)",
    skin: "rgba(220,170,120,0.7)"
  };

  let t0 = performance.now(), noiseOff = 0;

  function drawCanny(W, H, alpha) {
    ctx.strokeStyle = "rgba(255,255,255," + alpha + ")";
    ctx.lineWidth = 1.5;
    drawScene(ctx, "canny");
    // Add some edge noise
    for (let i=0; i<20; i++) {
      const x = Math.random()*W, y = Math.random()*H;
      ctx.beginPath();
      ctx.moveTo(x, y);
      ctx.lineTo(x + (Math.random()-0.5)*30, y + (Math.random()-0.5)*20);
      ctx.strokeStyle = "rgba(255,255,255," + (alpha*0.15) + ")";
      ctx.stroke();
    }
  }

  function drawDepth(W, H) {
    // Grayscale depth gradient
    const g = ctx.createRadialGradient(W*0.5, H*0.35, 20, W*0.5, H*0.5, Math.max(W,H)*0.5);
    g.addColorStop(0, "rgba(220,220,220,0.85)");
    g.addColorStop(0.4, "rgba(140,140,160,0.6)");
    g.addColorStop(1, "rgba(30,30,50,0.9)");
    ctx.fillStyle = g;
    ctx.fillRect(0,0,W,H);
  }

  function drawPose(W, H, alpha) {
    poseBones.forEach((b,i) => {
      const p1 = posePoints[b[0]], p2 = posePoints[b[1]];
      ctx.beginPath();
      ctx.moveTo(p1.x*W, p1.y*H);
      ctx.lineTo(p2.x*W, p2.y*H);
      ctx.strokeStyle = poseColors[i % poseColors.length];
      ctx.lineWidth = 3;
      ctx.globalAlpha = alpha;
      ctx.stroke();
    });
    posePoints.forEach((p,i) => {
      ctx.beginPath();
      ctx.arc(p.x*W, p.y*H, 5, 0, Math.PI*2);
      ctx.fillStyle = i===0 ? "#FF6B6B" : "#FFD93D";
      ctx.globalAlpha = alpha;
      ctx.fill();
    });
    ctx.globalAlpha = 1;
  }

  function drawSeg(W, H, alpha) {
    ctx.globalAlpha = alpha;
    // BG
    ctx.fillStyle = segColors.bg; ctx.fillRect(0,0,W,H);
    // Hair
    ctx.fillStyle = segColors.hair;
    ctx.beginPath(); ctx.ellipse(W*0.5,H*0.22,W*0.13,H*0.12,0,0,Math.PI*2); ctx.fill();
    // Face
    ctx.fillStyle = segColors.face;
    ctx.beginPath(); ctx.ellipse(W*0.5,H*0.32,W*0.10,H*0.16,0,0,Math.PI*2); ctx.fill();
    // Clothes
    ctx.fillStyle = segColors.clothes;
    ctx.beginPath();
    ctx.moveTo(W*0.3,H*0.72); ctx.lineTo(W*0.36,H*0.50); ctx.lineTo(W*0.64,H*0.50);
    ctx.lineTo(W*0.70,H*0.72); ctx.closePath(); ctx.fill();
    ctx.globalAlpha = 1;
  }

  function drawNormal(W, H, alpha, t) {
    // RGB normal map visualization
    const id = ctx.createImageData(W, H);
    const data = id.data;
    for (let y=0; y<H; y++) {
      for (let x=0; x<W; x++) {
        const u = x/W*2-1, v = y/H*2-1;
        const d = Math.sqrt(u*u+v*v);
        const nx = Math.sin(u*3+t*0.5+v)*0.5+0.5;
        const ny = Math.cos(v*3+t*0.4)*0.5+0.5;
        const nz = 0.7+0.3*Math.cos(d*4+t*0.3);
        const i = (y*W+x)*4;
        data[i]   = Math.round(nx*255*alpha + 10*(1-alpha));
        data[i+1] = Math.round(ny*255*alpha + 10*(1-alpha));
        data[i+2] = Math.round(nz*255*alpha + 10*(1-alpha));
        data[i+3] = 255;
      }
    }
    ctx.putImageData(id, 0, 0);
  }

  function frame(now) {
    const dt = Math.min((now-t0)/1000, 0.08); t0 = now;
    // LagFilter 8: conditioning strength
    strSmooth = lagStep(strSmooth, strTarget, dt, 0.12);
    if (strVal) strVal.textContent = strSmooth.toFixed(2);

    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle = "#12001F";
    ctx.fillRect(0,0,W,H);

    // Phosphor persistence
    ctx.fillStyle = "rgba(6,0,18,0.04)";
    ctx.fillRect(0,0,W,H);

    const t = now * 0.001;

    if (ctrlType === "canny") drawCanny(W, H, strSmooth * 0.9 + 0.1);
    else if (ctrlType === "depth") drawDepth(W, H);
    else if (ctrlType === "pose") drawPose(W, H, strSmooth * 0.9 + 0.1);
    else if (ctrlType === "seg") drawSeg(W, H, strSmooth * 0.8 + 0.1);
    else if (ctrlType === "normal") drawNormal(W, H, strSmooth * 0.85 + 0.15, t);

    // Overlay: generated diffusion output (abstract)
    const diffAlpha = 1 - strSmooth;
    if (diffAlpha > 0.02) {
      const grd = ctx.createLinearGradient(0,0,W,H);
      grd.addColorStop(0, "rgba(123,47,255," + diffAlpha*0.3 + ")");
      grd.addColorStop(1, "rgba(0,229,255," + diffAlpha*0.2 + ")");
      ctx.fillStyle = grd;
      ctx.fillRect(0,0,W,H);
    }

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
<script>
// ============================================================
// SECTION 5: LORA & STYLE BLENDING
// ============================================================
(function() {
  const canvas = document.getElementById("loraCanvas");
  if (!canvas) return;
  function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight || 200; }
  resize();
  window.addEventListener("resize", resize);
  const ctx = canvas.getContext("2d");

  const loras = [
    {name:"Impressionist", hue:30,  sat:0.8, tex:0.7, weight:0, smoothW:0, targetW:0},
    {name:"Anime",         hue:200, sat:0.9, tex:0.2, weight:0, smoothW:0, targetW:0},
    {name:"Photorealistic",hue:25,  sat:0.3, tex:0.5, weight:0, smoothW:0, targetW:0},
    {name:"Watercolor",    hue:195, sat:0.7, tex:0.6, weight:0, smoothW:0, targetW:0},
    {name:"Oil Painting",  hue:40,  sat:0.6, tex:0.9, weight:0, smoothW:0, targetW:0},
    {name:"Pencil Sketch", hue:0,   sat:0.05,tex:0.3, weight:0, smoothW:0, targetW:0},
    {name:"Cyberpunk",     hue:280, sat:1.0, tex:0.4, weight:0, smoothW:0, targetW:0},
    {name:"Ukiyo-e",       hue:15,  sat:0.75,tex:0.5, weight:0, smoothW:0, targetW:0},
  ];
  // Set initial weights
  loras[0].targetW = 0.6; loras[6].targetW = 0.35;

  const grid = document.getElementById("loraGrid");
  if (grid) {
    loras.forEach((l, i) => {
      const card = document.createElement("div");
      card.className = "lora-card";
      card.innerHTML = '<div class="lora-name">' + l.name + '</div>' +
        '<div class="lora-row">' +
        '<input type="range" min="0" max="100" value="' + Math.round(l.targetW*100) + '" id="lora' + i + '">' +
        '<span class="lv" id="lorav' + i + '">' + l.targetW.toFixed(2) + '</span>' +
        '</div>';
      grid.appendChild(card);
      document.getElementById("lora" + i).addEventListener("input", e => {
        l.targetW = parseFloat(e.target.value) / 100;
      });
    });
  }

  const conflictFill = document.getElementById("conflictFill");
  const conflictVal = document.getElementById("conflictVal");
  let conflictSmooth = 0.3; // LagFilter 9

  function calcConflict() {
    const active = loras.filter(l => l.smoothW > 0.05);
    if (active.length < 2) return 0;
    let maxDiff = 0;
    for (let a = 0; a < active.length; a++) {
      for (let b = a+1; b < active.length; b++) {
        const hueDiff = Math.abs(active[a].hue - active[b].hue) / 360;
        const satDiff = Math.abs(active[a].sat - active[b].sat);
        const texDiff = Math.abs(active[a].tex - active[b].tex);
        const diff = (hueDiff + satDiff + texDiff) / 3 * active[a].smoothW * active[b].smoothW;
        maxDiff = Math.max(maxDiff, diff);
      }
    }
    return Math.min(1, maxDiff * 4);
  }

  let t0 = performance.now();
  function frame(now) {
    const dt = Math.min((now-t0)/1000, 0.08); t0 = now;
    const W = canvas.width, H = canvas.height;

    // Update LoRA weights (LagFilter 10-17: one per LoRA — 8 instances)
    loras.forEach((l, i) => {
      l.smoothW = lagStep(l.smoothW, l.targetW, dt, 0.15);
      const el = document.getElementById("lorav" + i);
      if (el) el.textContent = l.smoothW.toFixed(2);
    });

    // LagFilter 9: conflict meter
    const conflictTarget = calcConflict();
    conflictSmooth = lagStep(conflictSmooth, conflictTarget, dt, 0.2);
    if (conflictFill) conflictFill.style.width = Math.round(conflictSmooth * 100) + "%";
    if (conflictVal) {
      const pct = conflictSmooth;
      conflictVal.textContent = pct < 0.3 ? "Low conflict" : pct < 0.65 ? "Moderate conflict" : "High conflict — styles may clash";
      conflictVal.style.color = pct < 0.3 ? "#00E5FF" : pct < 0.65 ? "#A855F7" : "#FF6B6B";
    }

    // Draw blended style preview on canvas
    ctx.fillStyle = "#12001F";
    ctx.fillRect(0, 0, W, H);

    // Phosphor persistence
    ctx.fillStyle = "rgba(6,0,18,0.04)";
    ctx.fillRect(0, 0, W, H);

    const t = now * 0.001;
    const totalW = loras.reduce((s,l) => s + l.smoothW, 0) || 1;

    // Blend colors from active LoRAs
    loras.forEach((l) => {
      if (l.smoothW < 0.02) return;
      const w = l.smoothW / totalW;

      // Convert HSL hue to RGB for visualization
      const h = l.hue / 360;
      const s2 = l.sat * w;
      const blobR = 0.15 + l.tex * 0.1;
      const blobCount = Math.round(3 + l.tex * 4);

      for (let b = 0; b < blobCount; b++) {
        const angle = (b / blobCount) * Math.PI * 2 + t * (0.1 + l.tex * 0.15);
        const r = W * (0.15 + Math.sin(angle * 1.7 + t * 0.2) * 0.05);
        const bx = W * 0.5 + Math.cos(angle) * W * blobR;
        const by = H * 0.5 + Math.sin(angle) * H * (blobR * H/W);
        const gr = ctx.createRadialGradient(bx, by, 0, bx, by, r);
        // Simple HSL approximation
        const lightness = 0.5 + l.sat * 0.2;
        const C = (1 - Math.abs(2*lightness-1)) * l.sat;
        const X2 = C * (1 - Math.abs((h*6)%2-1));
        const m = lightness - C/2;
        let R,G,B;
        const hi = Math.floor(h*6);
        if (hi===0) {R=C;G=X2;B=0;} else if (hi===1) {R=X2;G=C;B=0;}
        else if (hi===2) {R=0;G=C;B=X2;} else if (hi===3) {R=0;G=X2;B=C;}
        else if (hi===4) {R=X2;G=0;B=C;} else {R=C;G=0;B=X2;}
        R=Math.round((R+m)*255); G=Math.round((G+m)*255); B=Math.round((B+m)*255);
        gr.addColorStop(0, "rgba("+R+","+G+","+B+","+(w*0.7)+")");
        gr.addColorStop(1, "rgba(0,0,0,0)");
        ctx.fillStyle = gr;
        ctx.beginPath(); ctx.arc(bx, by, r, 0, Math.PI*2); ctx.fill();
      }
    });

    // Texture overlay based on dominant LoRA
    const domLoRA = loras.reduce((a,b) => a.smoothW > b.smoothW ? a : b);
    if (domLoRA.tex > 0.5 && domLoRA.smoothW > 0.1) {
      for (let i=0; i<60; i++) {
        const x = Math.random()*W, y = Math.random()*H;
        const len = Math.random() * domLoRA.tex * 20 + 5;
        const ang = Math.random() * Math.PI;
        ctx.beginPath();
        ctx.moveTo(x, y);
        ctx.lineTo(x + Math.cos(ang)*len, y + Math.sin(ang)*len);
        ctx.strokeStyle = "rgba(255,255,255," + (domLoRA.smoothW*0.06) + ")";
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }
    }

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();

// ============================================================
// SECTION 6: SAMPLER & CFG LAB
// ============================================================
(function() {
  const canvas = document.getElementById("sampCanvas");
  if (!canvas) return;
  function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight || 280; }
  resize();
  window.addEventListener("resize", resize);
  const ctx = canvas.getContext("2d");

  let activeSampler = "ddpm";
  let cfgTarget = 7, cfgSmooth = 7;   // LagFilter 18: CFG scale
  let stepsTarget = 20, stepsSmooth = 20; // LagFilter 19: steps display

  document.querySelectorAll("[data-samp]").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll("[data-samp]").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      activeSampler = btn.dataset.samp;
      animStep = 0;
    });
  });

  const cfgSlider = document.getElementById("cfgSlider");
  const cfgVal = document.getElementById("cfgVal");
  const stepsSlider = document.getElementById("stepsSlider");
  const stepsVal = document.getElementById("stepsVal");
  if (cfgSlider) cfgSlider.addEventListener("input", () => { cfgTarget = parseFloat(cfgSlider.value); });
  if (stepsSlider) stepsSlider.addEventListener("input", () => { stepsTarget = parseInt(stepsSlider.value); });

  let animStep = 0;
  let t0 = performance.now();

  // Sampler trajectory generators (parametric 2D paths in latent space)
  function getPath(type, steps, cfg) {
    const pts = [];
    const scale = 0.35;
    const cfgStretch = 0.5 + cfg / 20;
    for (let i = 0; i <= steps; i++) {
      const u = i / steps;
      let x, y;
      if (type === "ddpm") {
        // Zigzag noisy path — many small steps
        x = -scale + u * scale * 2 * cfgStretch + Math.sin(u * steps * 0.8) * 0.04 * (1-u);
        y = scale * (1-u) * Math.cos(u * Math.PI * 1.5) + Math.sin(i*1.7)*0.03*(1-u);
      } else if (type === "ddim") {
        // Curved, fewer oscillations
        x = -scale + u * scale * 2 * cfgStretch + Math.sin(u * Math.PI * 2) * 0.08 * (1-u);
        y = scale * Math.cos(u * Math.PI) * (1-u*0.7);
      } else if (type === "dpm") {
        // Adaptive — non-uniform step sizes
        const adapt = Math.pow(u, 1.5);
        x = -scale + adapt * scale * 2 * cfgStretch + Math.sin(u * 12) * 0.025 * (1-u);
        y = Math.sin(u * Math.PI * 1.2) * scale * (1-u*0.6);
      } else { // euler
        // Simple linear interpolation with slight drift
        x = -scale + u * scale * 2 * cfgStretch + (Math.random()-0.5)*0.01*(1-u);
        y = scale*(1-u)*0.5 + Math.sin(u*Math.PI)*0.05;
      }
      pts.push({x, y});
    }
    return pts;
  }

  function frame(now) {
    const dt = Math.min((now-t0)/1000, 0.08); t0 = now;

    // LagFilter 18: CFG scale
    cfgSmooth = lagStep(cfgSmooth, cfgTarget, dt, 0.1);
    // LagFilter 19: steps display
    stepsSmooth = lagStep(stepsSmooth, stepsTarget, dt, 0.1);
    if (cfgVal) cfgVal.textContent = cfgSmooth.toFixed(1);
    if (stepsVal) stepsVal.textContent = Math.round(stepsSmooth);

    const W = canvas.width, H = canvas.height;
    const cx = W * 0.5, cy = H * 0.5;
    const scale = Math.min(W, H) * 0.42;

    // Phosphor persistence
    ctx.fillStyle = "rgba(6,0,18,0.04)";
    ctx.fillRect(0, 0, W, H);

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = "#12001F";
    ctx.fillRect(0, 0, W, H);

    // Draw latent space grid
    ctx.strokeStyle = "rgba(123,47,255,0.12)";
    ctx.lineWidth = 1;
    for (let i = -5; i <= 5; i++) {
      ctx.beginPath();
      ctx.moveTo(cx + i/5*scale, 8);
      ctx.lineTo(cx + i/5*scale, H-8);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(8, cy + i/5*scale);
      ctx.lineTo(W-8, cy + i/5*scale);
      ctx.stroke();
    }

    // Gaussian density blobs at target region
    const targetX = cx + scale * (0.3 + cfgSmooth/20 * 0.15);
    const targetY = cy - scale * 0.05;
    const g = ctx.createRadialGradient(targetX, targetY, 0, targetX, targetY, scale * 0.18);
    g.addColorStop(0, "rgba(0,229,255,0.25)");
    g.addColorStop(1, "rgba(0,0,0,0)");
    ctx.fillStyle = g;
    ctx.beginPath(); ctx.arc(targetX, targetY, scale*0.18, 0, Math.PI*2); ctx.fill();

    // Noise cloud at start
    const ng = ctx.createRadialGradient(cx - scale*0.3, cy, 0, cx - scale*0.3, cy, scale*0.22);
    ng.addColorStop(0, "rgba(123,47,255,0.2)");
    ng.addColorStop(1, "rgba(0,0,0,0)");
    ctx.fillStyle = ng;
    ctx.beginPath(); ctx.arc(cx - scale*0.3, cy, scale*0.22, 0, Math.PI*2); ctx.fill();

    // Animate path step
    animStep = (animStep + dt * 0.8) % 1;
    const steps = Math.round(stepsSmooth);
    const path = getPath(activeSampler, steps, cfgSmooth);

    // Draw full dim path
    ctx.beginPath();
    path.forEach((p, i) => {
      const px = cx + p.x * scale, py = cy + p.y * scale;
      i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    });
    ctx.strokeStyle = "rgba(168,85,247,0.25)";
    ctx.lineWidth = 1;
    ctx.stroke();

    // Draw animated portion
    const animIdx = Math.floor(animStep * steps);
    ctx.beginPath();
    path.slice(0, animIdx+1).forEach((p, i) => {
      const px = cx + p.x * scale, py = cy + p.y * scale;
      i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    });
    const grad = ctx.createLinearGradient(
      cx + path[0].x * scale, cy + path[0].y * scale,
      cx + path[Math.min(animIdx, steps)].x * scale, cy + path[Math.min(animIdx, steps)].y * scale
    );
    grad.addColorStop(0, "#7B2FFF");
    grad.addColorStop(1, "#00E5FF");
    ctx.strokeStyle = grad;
    ctx.lineWidth = 2.5;
    ctx.stroke();

    // Current point dot
    if (animIdx < path.length) {
      const cur = path[animIdx];
      ctx.beginPath();
      ctx.arc(cx + cur.x * scale, cy + cur.y * scale, 5, 0, Math.PI*2);
      ctx.fillStyle = "#00E5FF";
      ctx.fill();
    }

    // CFG label
    ctx.fillStyle = "rgba(139,111,176,0.8)";
    ctx.font = "11px monospace";
    ctx.textAlign = "left";
    ctx.fillText("CFG " + cfgSmooth.toFixed(1) + " | " + activeSampler.toUpperCase() + " | " + Math.round(stepsSmooth) + " steps", 14, H-10);

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
<script>
// ============================================================
// SECTION 7: AI AESTHETICS & ETHICS
// ============================================================
(function() {
  // --- Authorship Spectrum ---
  const authorSlider = document.getElementById("authorSlider");
  const authorVal = document.getElementById("authorVal");
  const authorMarker = document.getElementById("authorMarker");
  const ec1 = document.getElementById("ethicsCanvas1");

  let authorTarget = 50, authorSmooth = 50; // LagFilter 20

  if (authorSlider) authorSlider.addEventListener("input", () => {
    authorTarget = parseFloat(authorSlider.value);
  });

  // --- Mimicry Spectrum ---
  const mimicSlider = document.getElementById("mimicSlider");
  const mimicVal = document.getElementById("mimicVal");
  const mimicMarker = document.getElementById("mimicMarker");
  const ec3 = document.getElementById("ethicsCanvas3");

  let mimicTarget = 35, mimicSmooth = 35; // LagFilter 21

  if (mimicSlider) mimicSlider.addEventListener("input", () => {
    mimicTarget = parseFloat(mimicSlider.value);
  });

  // --- Training Data Canvas ---
  const ec2 = document.getElementById("ethicsCanvas2");

  function drawPie(canvas, segments) {
    if (!canvas) return;
    const W = canvas.width, H = canvas.height;
    const ctx = canvas.getContext("2d");
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = "#12001F";
    ctx.fillRect(0, 0, W, H);
    const cx = W * 0.45, cy = H * 0.55, r = Math.min(W, H) * 0.36;
    let angle = -Math.PI / 2;
    const colors = ["#7B2FFF", "#00E5FF", "#A855F7"];
    segments.forEach((seg, i) => {
      const sweep = seg.pct * Math.PI * 2;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, r, angle, angle + sweep);
      ctx.closePath();
      ctx.fillStyle = colors[i];
      ctx.fill();
      ctx.strokeStyle = "#060012";
      ctx.lineWidth = 2;
      ctx.stroke();
      // Label
      const midAngle = angle + sweep / 2;
      const lx = cx + Math.cos(midAngle) * r * 0.65;
      const ly = cy + Math.sin(midAngle) * r * 0.65;
      ctx.fillStyle = "#fff";
      ctx.font = "bold 11px sans-serif";
      ctx.textAlign = "center";
      ctx.fillText(Math.round(seg.pct * 100) + "%", lx, ly);
      angle += sweep;
    });
    // Legend
    ["Scraped Web", "Licensed", "Synthetic"].forEach((lbl, i) => {
      ctx.fillStyle = colors[i];
      ctx.fillRect(W*0.72, 20 + i * 24, 12, 12);
      ctx.fillStyle = "#8B6FB0";
      ctx.font = "10px sans-serif";
      ctx.textAlign = "left";
      ctx.fillText(lbl, W*0.72 + 16, 31 + i * 24);
    });
  }

  drawPie(ec2, [{pct:0.65},{pct:0.20},{pct:0.15}]);

  const authorLabels = ["Pure Machine","Mostly Machine","Machine-Assisted","Collaborative","Human-Directed","Mostly Human","Pure Human"];

  function drawAuthorship(canvas, val) {
    if (!canvas) return;
    const W = canvas.offsetWidth || canvas.width;
    canvas.width = W;
    const H = canvas.height;
    const ctx = canvas.getContext("2d");
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = "#0A0020";
    ctx.fillRect(0, 0, W, H);

    // Argument nodes
    const humanArgs = ["Intent","Emotion","Concept","Narrative","Curation"];
    const machineArgs = ["Scale","Variation","Pattern","Execution","Memory"];
    const u = val / 100;

    humanArgs.forEach((a, i) => {
      const x = W * 0.18, y = 14 + i * 20;
      const alpha = Math.max(0.2, 1 - u * 0.8);
      ctx.fillStyle = "rgba(0,229,255," + alpha + ")";
      ctx.font = "9px sans-serif";
      ctx.textAlign = "left";
      ctx.fillText("◆ " + a, x, y);
    });
    machineArgs.forEach((a, i) => {
      const x = W * 0.55, y = 14 + i * 20;
      const alpha = Math.max(0.2, u * 0.8 + 0.2);
      ctx.fillStyle = "rgba(123,47,255," + alpha + ")";
      ctx.textAlign = "left";
      ctx.fillText("◆ " + a, x, y);
    });

    // Connection lines
    for (let i = 0; i < 5; i++) {
      ctx.beginPath();
      ctx.moveTo(W*0.35, 10 + i*20);
      ctx.lineTo(W*0.55, 10 + i*20);
      ctx.strokeStyle = "rgba(168,85,247,0.25)";
      ctx.lineWidth = 1;
      ctx.stroke();
    }
  }

  const mimicLabels = ["Pure Tribute","Homage","Transformation","Stylization","Appropriation","Pastiche","Copying"];

  function drawMimicry(canvas, val) {
    if (!canvas) return;
    const W = canvas.offsetWidth || canvas.width;
    canvas.width = W;
    const H = canvas.height;
    const ctx = canvas.getContext("2d");
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = "#0A0020";
    ctx.fillRect(0, 0, W, H);

    const u = val / 100;
    // Feature bars
    const features = [
      {name:"Style elements",    orig: 0.9, ai: 0.7 + u*0.25},
      {name:"Composition",       orig: 0.7, ai: 0.4 + u*0.5},
      {name:"Color palette",     orig: 0.8, ai: 0.5 + u*0.4},
      {name:"Unique signature",  orig: 0.95,ai: 0.2 + u*0.75},
    ];
    features.forEach((f, i) => {
      const y = 14 + i * 22;
      ctx.fillStyle = "#1A0030";
      ctx.fillRect(W*0.28, y, W*0.65, 12);
      // Original artist bar
      ctx.fillStyle = "rgba(0,229,255,0.6)";
      ctx.fillRect(W*0.28, y, W*0.65*f.orig, 5);
      // AI bar
      const aiColor = u > 0.7 ? "rgba(255,107,107,0.7)" : "rgba(168,85,247,0.7)";
      ctx.fillStyle = aiColor;
      ctx.fillRect(W*0.28, y+7, W*0.65*Math.min(1, f.ai), 5);
      // Label
      ctx.fillStyle = "#8B6FB0";
      ctx.font = "9px sans-serif";
      ctx.textAlign = "right";
      ctx.fillText(f.name, W*0.27, y + 9);
    });
    // Legend
    ctx.fillStyle = "rgba(0,229,255,0.6)"; ctx.fillRect(W*0.28, H-14, 18, 5);
    ctx.fillStyle = "#8B6FB0"; ctx.font = "9px sans-serif"; ctx.textAlign = "left";
    ctx.fillText("Original", W*0.28+22, H-9);
    ctx.fillStyle = "rgba(168,85,247,0.7)"; ctx.fillRect(W*0.55, H-14, 18, 5);
    ctx.fillText("AI repro", W*0.55+22, H-9);
  }

  let t0 = performance.now();
  function frame(now) {
    const dt = Math.min((now-t0)/1000, 0.08); t0 = now;

    // LagFilter 20: authorship
    authorSmooth = lagStep(authorSmooth, authorTarget, dt, 0.12);
    if (authorMarker) authorMarker.style.left = authorSmooth + "%";
    if (authorVal) {
      const idx = Math.round(authorSmooth / 100 * (authorLabels.length - 1));
      authorVal.textContent = authorLabels[Math.min(idx, authorLabels.length-1)];
    }
    if (ec1) drawAuthorship(ec1, authorSmooth);

    // LagFilter 21: mimicry
    mimicSmooth = lagStep(mimicSmooth, mimicTarget, dt, 0.12);
    if (mimicMarker) mimicMarker.style.left = mimicSmooth + "%";
    if (mimicVal) {
      const idx = Math.round(mimicSmooth / 100 * (mimicLabels.length - 1));
      mimicVal.textContent = mimicLabels[Math.min(idx, mimicLabels.length-1)];
      mimicVal.style.color = mimicSmooth > 70 ? "#FF6B6B" : mimicSmooth > 40 ? "#A855F7" : "#00E5FF";
    }
    if (ec3) drawMimicry(ec3, mimicSmooth);

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();

