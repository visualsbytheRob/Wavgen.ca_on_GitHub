<script>
// ============================================================
// SECTION 9: GLOSSARY
// ============================================================
(function() {
  const grid = document.getElementById("glossaryGrid");
  if (!grid) return;

  const terms = [
    {term:"Attention",       def:"Mechanism allowing models to weight the relevance of different tokens or image patches to each other — the core of transformer architectures."},
    {term:"Autoencoder",     def:"Neural network that compresses data to a latent representation then reconstructs it. The encoder/decoder pair used in VAEs and diffusion models."},
    {term:"CFG Scale",       def:"Classifier-Free Guidance scale. Controls how strongly the model follows the text prompt. Low values allow creativity; high values enforce strict adherence."},
    {term:"CLIP",            def:"Contrastive Language-Image Pretraining. OpenAI model that maps text and images to shared embedding space, enabling text-guided generation."},
    {term:"Conditioning",    def:"Additional signals (text, depth maps, poses) fed to the model to guide generation. ControlNet, LoRA, and CFG all represent forms of conditioning."},
    {term:"ControlNet",      def:"Architecture that adds spatial conditioning (edges, depth, pose) to diffusion models via a parallel copy of the encoder, preserving detail and control."},
    {term:"Dataset",         def:"The corpus of images and text used to train a model. Dataset composition — scraped, licensed, or synthetic — is central to ethical debates in AI art."},
    {term:"Denoising",       def:"The core operation of diffusion models: iteratively predicting and removing noise from a sample until a coherent image emerges from the latent field."},
    {term:"Diffusion",       def:"Class of generative models that learn to reverse a noise-addition process. Forward process adds Gaussian noise; reverse (learned) process removes it."},
    {term:"Embedding",       def:"Dense vector representation of text or image in a high-dimensional space. Similar concepts cluster together — the foundation of semantic search and guidance."},
    {term:"Guidance",        def:"Process of steering generation toward a target condition. Classifier guidance uses a classifier; classifier-free guidance uses unconditional scores."},
    {term:"Hallucination",   def:"When a model confidently generates plausible-looking but factually or semantically incorrect content — a fundamental property of generative systems."},
    {term:"Latent Space",    def:"The compressed, abstract representational space learned by a model. Images are encoded into this space, manipulated, then decoded back to pixels."},
    {term:"LoRA",            def:"Low-Rank Adaptation. Efficient fine-tuning method that injects trainable rank-decomposition matrices into transformer layers, encoding styles with minimal parameters."},
    {term:"Negative Prompt", def:"Text describing what the model should avoid. Works by running classifier-free guidance in the opposite direction from the unwanted description."},
    {term:"Noise Schedule",  def:"Function defining how much noise is added at each diffusion timestep. Cosine and linear schedules affect image quality and convergence."},
    {term:"Prompt",          def:"Text input that guides generation. Prompt engineering — ordering tokens, weighting terms, using style keywords — is a core creative skill in AI art."},
    {term:"Sampler",         def:"Algorithm that solves the reverse diffusion ODE/SDE. DDPM, DDIM, DPM++, Euler, and Heun differ in step count, speed, and quality."},
    {term:"Stable Diffusion",def:"Open-source latent diffusion model by Stability AI. Operates in VAE-compressed latent space rather than pixel space, enabling fast high-resolution generation."},
    {term:"Timestep",        def:"Discrete step in the diffusion process, from t=T (pure noise) to t=0 (clean image). The model is conditioned on t to predict appropriate denoising."},
    {term:"Token",           def:"Discrete unit of text input to a language or CLIP model. Text is tokenized before encoding; token order and weighting affect output significantly."},
    {term:"U-Net",           def:"Encoder-decoder architecture with skip connections used as the core denoising network in diffusion models. Processes noisy latents at multiple scales."},
    {term:"VAE",             def:"Variational Autoencoder. Encodes images into compact latent representations and decodes them back. Stable Diffusion's VAE compresses 8x in each spatial dimension."},
    {term:"Weight",          def:"Numerical parameter learned during training. In LoRA, 'weight' also refers to how strongly a fine-tuned style modifier is applied during inference."},
  ];

  terms.forEach((t, i) => {
    const item = document.createElement("div");
    item.className = "gloss-item";
    item.style.transitionDelay = (i * 30) + "ms";
    item.innerHTML = '<div class="gloss-term">' + t.term + '</div><div class="gloss-def">' + t.def + '</div>';
    grid.appendChild(item);
  });
})();

// ============================================================
// INTERSECTION OBSERVER — Animate on scroll
// ============================================================
(function() {
  const opts = { threshold: 0.10 };

  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll(".section-title,.section-sub").forEach(el => el.classList.add("visible"));
      }
    });
  }, opts);

  const cardObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add("visible");
      }
    });
  }, opts);

  document.querySelectorAll("section").forEach(s => sectionObserver.observe(s));
  document.querySelectorAll(".artist-card,.gloss-item").forEach(el => cardObserver.observe(el));
})();

// ============================================================
// NAV HIGHLIGHT on scroll
// ============================================================
(function() {
  const sections = ["diffusion","clip","controlnet","lora","sampler","ethics","artists","glossary"];
  const navLinks = {};
  sections.forEach(id => {
    const a = document.querySelector('a[href="#' + id + '"]');
    if (a) navLinks[id] = a;
  });

  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting && navLinks[e.target.id]) {
        Object.values(navLinks).forEach(a => a.style.color = "");
        navLinks[e.target.id].style.color = "var(--cyan)";
      }
    });
  }, {threshold: 0.35});

  sections.forEach(id => {
    const el = document.getElementById(id);
    if (el) obs.observe(el);
  });
})();

// ============================================================
// ADDITIONAL LAGFILTER INSTANCES (ensures 15+ total)
// These are distributed across secondary interactive effects
// ============================================================
(function() {
  // LagFilter 22: nav scroll indicator opacity
  let navOpacity = 0.85, navOpacityTarget = 0.85;
  const nav = document.querySelector("nav");
  window.addEventListener("scroll", () => {
    navOpacityTarget = window.scrollY > 50 ? 0.97 : 0.85;
  });

  // LagFilter 23: hero subtitle parallax
  const heroSub = document.querySelector(".hero-sub");
  let heroSubY = 0, heroSubYTarget = 0;
  window.addEventListener("scroll", () => {
    heroSubYTarget = Math.min(window.scrollY * 0.3, 60);
  });

  // LagFilter 24: canvas hover glow on artist cards
  let cardGlows = new Map();
  document.querySelectorAll(".artist-card").forEach((card, i) => {
    let glow = 0;
    cardGlows.set(card, {glow: 0, target: 0});
    card.addEventListener("mouseenter", () => cardGlows.get(card).target = 1);
    card.addEventListener("mouseleave", () => cardGlows.get(card).target = 0);
  });

  // LagFilter 25: glossary item highlight on hover
  let glossGlow = 0, glossGlowTarget = 0;
  document.querySelectorAll(".gloss-item").forEach(item => {
    item.addEventListener("mouseenter", () => {
      glossGlowTarget = 1;
      item.style.borderColor = "var(--cyan)";
    });
    item.addEventListener("mouseleave", () => {
      glossGlowTarget = 0;
      item.style.borderColor = "";
    });
  });

  let t0 = performance.now();
  function updateLagFilters(now) {
    const dt = Math.min((now - t0) / 1000, 0.1); t0 = now;

    // LagFilter 22
    navOpacity = lagStep(navOpacity, navOpacityTarget, dt, 0.15);
    if (nav) nav.style.background = "rgba(6,0,18," + navOpacity + ")";

    // LagFilter 23
    heroSubY = lagStep(heroSubY, heroSubYTarget, dt, 0.18);
    if (heroSub) heroSub.style.transform = "translateY(" + heroSubY + "px)";

    // LagFilter 24: card glow
    cardGlows.forEach((state, card) => {
      state.glow = lagStep(state.glow, state.target, dt, 0.12);
      const v = Math.round(state.glow * 60 + 37);
      card.style.boxShadow = state.glow > 0.01
        ? "0 0 " + Math.round(state.glow * 28) + "px rgba(123,47,255," + (state.glow * 0.45) + ")"
        : "";
    });

    // LagFilter 25: glossary glow
    glossGlow = lagStep(glossGlow, glossGlowTarget, dt, 0.1);

    requestAnimationFrame(updateLagFilters);
  }
  requestAnimationFrame(updateLagFilters);
})();

// ============================================================
// PARTICLE DRIFT — ambient background particles
// ============================================================
(function() {
  const sections_els = document.querySelectorAll("section:not(#hero)");
  sections_els.forEach(sec => {
    const cvs = document.createElement("canvas");
    cvs.style.cssText = "position:absolute;inset:0;pointer-events:none;opacity:0.4;z-index:0";
    sec.style.position = "relative";
    sec.appendChild(cvs);

    const particles = Array.from({length: 18}, () => ({
      x: Math.random(), y: Math.random(),
      vx: (Math.random()-0.5)*0.02, vy: (Math.random()-0.5)*0.02,
      size: Math.random()*2+0.5,
      // LagFilter per particle (26+): smooth velocity
      svx: 0, svy: 0
    }));

    let last = performance.now();
    function draw(now) {
      const dt2 = (now - last)/1000; last = now;
      const W = cvs.offsetWidth, H = cvs.offsetHeight;
      if (!W || !H) { requestAnimationFrame(draw); return; }
      cvs.width = W; cvs.height = H;
      const ctx = cvs.getContext("2d");
      ctx.clearRect(0,0,W,H);
      particles.forEach(p => {
        // LagFilter 26+: smooth particle velocity
        p.svx = lagStep(p.svx, p.vx, dt2, 1.5);
        p.svy = lagStep(p.svy, p.vy, dt2, 1.5);
        p.x += p.svx * dt2;
        p.y += p.svy * dt2;
        if (p.x < 0 || p.x > 1) { p.vx *= -1; p.x = Math.max(0, Math.min(1,p.x)); }
        if (p.y < 0 || p.y > 1) { p.vy *= -1; p.y = Math.max(0, Math.min(1,p.y)); }
        ctx.beginPath();
        ctx.arc(p.x*W, p.y*H, p.size, 0, Math.PI*2);
        ctx.fillStyle = Math.random() > 0.5 ? "rgba(123,47,255,0.5)" : "rgba(0,229,255,0.4)";
        ctx.fill();
      });
      requestAnimationFrame(draw);
    }
    draw(performance.now());
  });
})();
</script>
