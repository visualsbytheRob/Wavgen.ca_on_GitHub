      const px = cx + Math.cos(angle) * dist;
      const py = cy + Math.sin(angle) * dist;
      const sz = 8 + (seed * (i+2) % 20);

      ctx.beginPath();
      if (i % 3 === 0) {
        ctx.arc(px, py, sz * 0.5, 0, Math.PI * 2);
      } else if (i % 3 === 1) {
        ctx.rect(px - sz*0.4, py - sz*0.4, sz*0.8, sz*0.8);
