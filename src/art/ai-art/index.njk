        ctx.lineTo(px + sz*0.45, py + sz*0.35);
        ctx.lineTo(px - sz*0.45, py + sz*0.35);
        ctx.closePath();
      }
      const alpha = 0.4 + (i/(shapes-1)) * 0.4;
      ctx.fillStyle = i % 2 === 0 ? artist.accent + Math.round(alpha*255).toString(16).padStart(2,"0") : "rgba("+Math.round(r*200)+","+Math.round(g2*180)+","+Math.round(b*255)+","+alpha+")";
      ctx.fill();
    }

    // Central circle (head)
    const hg = ctx.createRadialGradient(cx, cy-4, 0, cx, cy-4, 22);
    hg.addColorStop(0, artist.accent);
    hg.addColorStop(1, artist.accent + "20");
    ctx.fillStyle = hg;
    ctx.beginPath(); ctx.arc(cx, cy-4, 22, 0, Math.PI*2); ctx.fill();

    // Grid overlay
    ctx.strokeStyle = "rgba(255,255,255,0.05)";
    ctx.lineWidth = 0.5;
    for (let i = 0; i < W; i += 12) {
      ctx.beginPath(); ctx.moveTo(i,0); ctx.lineTo(i,H); ctx.stroke();
    }
    for (let j = 0; j < H; j += 12) {
      ctx.beginPath(); ctx.moveTo(0,j); ctx.lineTo(W,j); ctx.stroke();
