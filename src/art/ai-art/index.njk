  // Draw geometric portrait avatar on canvas
  function drawAvatar(canvas, artist) {
    const W = canvas.width, H = canvas.height;
    const ctx = canvas.getContext("2d");
    ctx.fillStyle = artist.bg;
    ctx.fillRect(0, 0, W, H);

    // Abstract geometric portrait
    const cx = W/2, cy = H/2;
    const seed = artist.name.charCodeAt(0) * 37 + artist.name.charCodeAt(1) * 13;
    const r = Math.sin(seed) * 0.5 + 0.5;
    const g2 = Math.sin(seed * 1.7) * 0.5 + 0.5;
    const b = Math.sin(seed * 2.3) * 0.5 + 0.5;

    // Background gradient
    const bg = ctx.createLinearGradient(0,0,W,H);
    bg.addColorStop(0, artist.bg);
    bg.addColorStop(1, artist.accent + "40");
    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, W, H);

    // Geometric shapes — unique to each artist
    const shapes = 5 + (seed % 4);
    for (let i = 0; i < shapes; i++) {
