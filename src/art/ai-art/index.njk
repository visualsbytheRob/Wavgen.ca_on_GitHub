<script>
// ============================================================
// PROMPT ENGINEERING LAB
// ============================================================
(function() {
  const canvas = document.getElementById("promptCanvas");
  if (!canvas) return;
  function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight || 220; }
  resize();
  window.addEventListener("resize", resize);
  const ctx = canvas.getContext("2d");

  const promptTokensEl = document.getElementById("promptTokens");
  const weightSlider = document.getElementById("tokenWeightSlider");
  const weightVal = document.getElementById("tokenWeightVal");
  const complexitySlider = document.getElementById("complexitySlider");
  const complexityVal = document.getElementById("complexityVal");

  const tokenBank = [
    {text:"masterpiece",      influence:0.9,  category:"quality",  hue:260},
    {text:"oil painting",     influence:0.75, category:"style",    hue:30},
    {text:"dramatic lighting",influence:0.8,  category:"lighting", hue:45},
    {text:"portrait",         influence:0.65, category:"subject",  hue:190},
    {text:"highly detailed",  influence:0.85, category:"quality",  hue:260},
    {text:"cinematic",        influence:0.7,  category:"mood",     hue:210},
    {text:"surrealism",       influence:0.6,  category:"style",    hue:280},
    {text:"golden hour",      influence:0.55, category:"lighting", hue:40},
    {text:"bokeh",            influence:0.5,  category:"technique",hue:200},
    {text:"8k resolution",    influence:0.45, category:"quality",  hue:260},
  ];

  // LagFilter per token (influence display)
  tokenBank.forEach(t => { t.smoothInf = t.influence; t.targetInf = t.influence; t.active = false; });

  let activeToken = null;
  let complexity = 5;
  let weightSmooth = 1.0, weightTarget = 1.0;    // LagFilter 28

  function buildTokens() {
    if (!promptTokensEl) return;
    promptTokensEl.innerHTML = "";
    tokenBank.slice(0, complexity).forEach((t, i) => {
      const chip = document.createElement("span");
      chip.className = "token-chip" + (activeToken === i ? " active" : "");
      chip.innerHTML = t.text + '<span class="token-weight">×' + t.targetInf.toFixed(2) + '</span>';
      chip.addEventListener("click", () => {
        activeToken = (activeToken === i) ? null : i;
        if (activeToken !== null && weightSlider) {
          weightSlider.value = Math.round(t.targetInf * 100);
          weightTarget = t.targetInf;
        }
        buildTokens();
      });
      promptTokensEl.appendChild(chip);
    });
  }

  if (weightSlider) weightSlider.addEventListener("input", () => {
    weightTarget = parseFloat(weightSlider.value) / 100;
    if (activeToken !== null) tokenBank[activeToken].targetInf = weightTarget;
    buildTokens();
  });

  if (complexitySlider) complexitySlider.addEventListener("input", () => {
    complexity = parseInt(complexitySlider.value);
    buildTokens();
  });

  buildTokens();

  let t0 = performance.now();
  function frame(now) {
    const dt = Math.min((now-t0)/1000, 0.08); t0 = now;
    const W = canvas.width, H = canvas.height;

    // LagFilter 28: weight display
    weightSmooth = lagStep(weightSmooth, weightTarget, dt, 0.1);
    if (weightVal) weightVal.textContent = weightSmooth.toFixed(2);
    if (complexityVal) complexityVal.textContent = complexity + " token" + (complexity>1?"s":"");

    // Update token influence smoothing (LagFilter 29-38: one per token)
    tokenBank.forEach(t => {
      t.smoothInf = lagStep(t.smoothInf, t.targetInf, dt, 0.15);
    });

    // Phosphor persistence
    ctx.fillStyle = "rgba(6,0,18,0.04)";
    ctx.fillRect(0, 0, W, H);
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = "#12001F";
    ctx.fillRect(0, 0, W, H);

    const activeTokens = tokenBank.slice(0, complexity);
    const totalInf = activeTokens.reduce((s,t) => s + t.smoothInf, 0.001);

    // Draw embedding space visualization
    const centerX = W * 0.5, centerY = H * 0.5;
    const t_anim = now * 0.001;

    // Background latent field
    for (let i = 0; i < 40; i++) {
      const angle = (i/40) * Math.PI * 2 + t_anim * 0.05;
      const r = 30 + Math.sin(i * 1.3 + t_anim * 0.2) * 15;
      const x = centerX + Math.cos(angle) * (W * 0.35);
      const y = centerY + Math.sin(angle) * (H * 0.32);
      ctx.beginPath();
      ctx.arc(x, y, 1.5, 0, Math.PI*2);
      ctx.fillStyle = "rgba(123,47,255,0.15)";
      ctx.fill();
    }

    // Draw token influence vectors
    activeTokens.forEach((t, i) => {
      const angle = (i / activeTokens.length) * Math.PI * 2 - Math.PI/2;
      const baseLen = (t.smoothInf / totalInf) * W * 0.35;
      const ex = centerX + Math.cos(angle) * baseLen;
      const ey = centerY + Math.sin(angle) * baseLen;
      const hue = t.hue;

      // Vector arrow
      ctx.beginPath();
      ctx.moveTo(centerX, centerY);
      ctx.lineTo(ex, ey);
      ctx.strokeStyle = "hsl(" + hue + ",80%,60%)";
      ctx.lineWidth = activeToken === i ? 3 : 1.5;
      ctx.globalAlpha = 0.7 + (activeToken === i ? 0.3 : 0);
      ctx.stroke();
      ctx.globalAlpha = 1;

      // Arrowhead
      const arrowLen = 8;
      const backAngle = angle + Math.PI;
      ctx.beginPath();
      ctx.moveTo(ex, ey);
      ctx.lineTo(ex + Math.cos(backAngle + 0.4) * arrowLen, ey + Math.sin(backAngle + 0.4) * arrowLen);
      ctx.lineTo(ex + Math.cos(backAngle - 0.4) * arrowLen, ey + Math.sin(backAngle - 0.4) * arrowLen);
      ctx.closePath();
      ctx.fillStyle = "hsl(" + hue + ",80%,60%)";
      ctx.fill();

      // Token label
      const lx = centerX + Math.cos(angle) * (baseLen + 16);
      const ly = centerY + Math.sin(angle) * (baseLen + 16);
      ctx.fillStyle = activeToken === i ? "var(--cyan)" : "rgba(232,213,255,0.7)";
      ctx.font = activeToken === i ? "bold 10px sans-serif" : "10px sans-serif";
      ctx.textAlign = lx > W*0.5 ? "left" : "right";
      ctx.fillText(t.text, lx, ly);
    });

    // Resultant vector (sum of all weighted token vectors)
    let rx = 0, ry = 0;
    activeTokens.forEach((t, i) => {
      const angle = (i / activeTokens.length) * Math.PI * 2 - Math.PI/2;
      rx += Math.cos(angle) * t.smoothInf;
      ry += Math.sin(angle) * t.smoothInf;
    });
    const rLen = Math.sqrt(rx*rx + ry*ry);
    if (rLen > 0.01) {
      const scale2 = Math.min(W * 0.3, rLen * 40);
      const rAngle = Math.atan2(ry, rx);
      const rEx = centerX + Math.cos(rAngle) * scale2;
      const rEy = centerY + Math.sin(rAngle) * scale2;
      ctx.beginPath();
      ctx.moveTo(centerX, centerY);
      ctx.lineTo(rEx, rEy);
      ctx.strokeStyle = "#00E5FF";
      ctx.lineWidth = 3;
      ctx.setLineDash([6, 3]);
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.beginPath();
      ctx.arc(rEx, rEy, 7, 0, Math.PI*2);
      ctx.fillStyle = "#00E5FF";
      ctx.fill();
    }

    // Center node
    const cg = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, 14);
    cg.addColorStop(0, "#A855F7");
    cg.addColorStop(1, "rgba(0,0,0,0)");
    ctx.fillStyle = cg;
    ctx.beginPath(); ctx.arc(centerX, centerY, 14, 0, Math.PI*2); ctx.fill();

    ctx.fillStyle = "rgba(139,111,176,0.6)";
    ctx.font = "10px monospace";
    ctx.textAlign = "left";
    ctx.fillText("⬡ Token embedding space — " + activeTokens.length + " active", 10, H-10);

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();

// ============================================================
// VAE LATENT EXPLORER
// ============================================================
(function() {
  const canvas = document.getElementById("vaeCanvas");
  const distCanvas = document.getElementById("vaeDistCanvas");
  if (!canvas) return;

  function resize() {
    canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight || 220;
    if (distCanvas) { distCanvas.width = distCanvas.offsetWidth; distCanvas.height = distCanvas.offsetHeight || 220; }
  }
  resize();
  window.addEventListener("resize", resize);

  const ctx = canvas.getContext("2d");
  const dctx = distCanvas ? distCanvas.getContext("2d") : null;

  const alphaSlider = document.getElementById("vaeAlphaSlider");
  const alphaVal = document.getElementById("vaeAlphaVal");

  // Two concept "images" as abstract patterns
  const conceptA = { hue: 280, tex: 0.8, complexity: 0.6, label: "Abstract" };
  const conceptB = { hue: 195, tex: 0.3, complexity: 0.9, label: "Portrait" };

  let alphaTarget = 0.5, alphaSmooth = 0.5;  // LagFilter 39: VAE interpolation

  if (alphaSlider) alphaSlider.addEventListener("input", () => {
    alphaTarget = parseFloat(alphaSlider.value) / 100;
  });

  // Pre-generate "latent" random seeds
  const latentsA = Array.from({length:20}, (_,i) => ({mu: Math.sin(i*1.7)*0.8, sigma: Math.abs(Math.cos(i*2.1))*0.3+0.1}));
  const latentsB = Array.from({length:20}, (_,i) => ({mu: Math.cos(i*2.3)*0.8, sigma: Math.abs(Math.sin(i*1.9))*0.3+0.1}));

  let t0 = performance.now();
  function frame(now) {
    const dt = Math.min((now-t0)/1000, 0.08); t0 = now;
    // LagFilter 39: alpha interpolation
    alphaSmooth = lagStep(alphaSmooth, alphaTarget, dt, 0.12);
    if (alphaVal) alphaVal.textContent = alphaSmooth.toFixed(2);

    const W = canvas.width, H = canvas.height;
    const t_anim = now * 0.001;

    // --- Main canvas: interpolated latent visualization ---
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = "#12001F";
    ctx.fillRect(0, 0, W, H);

    // Phosphor
    ctx.fillStyle = "rgba(6,0,18,0.04)";
    ctx.fillRect(0, 0, W, H);

    // Interpolated hue
    const hueA = conceptA.hue, hueB = conceptB.hue;
    const hue = hueA + (hueB - hueA) * alphaSmooth;
    const tex = conceptA.tex + (conceptB.tex - conceptA.tex) * alphaSmooth;
    const comp = conceptA.complexity + (conceptB.complexity - conceptA.complexity) * alphaSmooth;

    // Draw interpolated pattern
    const numBlobs = Math.round(4 + comp * 8);
    for (let i = 0; i < numBlobs; i++) {
      const angle = (i / numBlobs) * Math.PI * 2 + t_anim * (0.08 + tex * 0.12);
      const dist = W * (0.12 + Math.sin(i * 1.9 + t_anim * 0.15) * 0.06);
      const bx = W * 0.5 + Math.cos(angle) * dist;
      const by = H * 0.5 + Math.sin(angle) * dist;
      const br = W * (0.06 + tex * 0.04);
      const gr = ctx.createRadialGradient(bx, by, 0, bx, by, br);
      gr.addColorStop(0, "hsla(" + hue + ",75%,65%,0.6)");
      gr.addColorStop(0.5, "hsla(" + (hue+40) + ",60%,45%,0.3)");
      gr.addColorStop(1, "rgba(0,0,0,0)");
      ctx.fillStyle = gr;
      ctx.beginPath(); ctx.arc(bx, by, br, 0, Math.PI*2); ctx.fill();
    }

    // Center glow
    const cg = ctx.createRadialGradient(W*0.5, H*0.5, 0, W*0.5, H*0.5, W*0.18);
    cg.addColorStop(0, "hsla(" + hue + ",80%,70%,0.25)");
    cg.addColorStop(1, "rgba(0,0,0,0)");
    ctx.fillStyle = cg; ctx.beginPath(); ctx.arc(W*0.5,H*0.5,W*0.18,0,Math.PI*2); ctx.fill();

    // Label
    ctx.fillStyle = "rgba(232,213,255,0.7)";
    ctx.font = "11px sans-serif";
    ctx.textAlign = "center";
    ctx.fillText(conceptA.label + " ←  α=" + alphaSmooth.toFixed(2) + "  → " + conceptB.label, W*0.5, H-10);

    // --- Distribution canvas ---
    if (!dctx) { requestAnimationFrame(frame); return; }
    const DW = distCanvas.width, DH = distCanvas.height;
    dctx.clearRect(0,0,DW,DH);
    dctx.fillStyle = "#12001F";
    dctx.fillRect(0,0,DW,DH);

    // Grid
    dctx.strokeStyle = "rgba(123,47,255,0.12)";
    dctx.lineWidth = 0.5;
    for (let i = 0; i <= 10; i++) {
      const x = DW * 0.08 + i * DW * 0.84 / 10;
      dctx.beginPath(); dctx.moveTo(x,8); dctx.lineTo(x,DH-16); dctx.stroke();
    }

    // Draw latent distributions (interpolated)
    latentsA.forEach((la, i) => {
      const lb = latentsB[i];
      const mu = la.mu + (lb.mu - la.mu) * alphaSmooth;
      const sigma = la.sigma + (lb.sigma - la.sigma) * alphaSmooth;
      const x = DW * 0.5 + mu * DW * 0.38;
      const y = DH * 0.25 + (i / 20) * DH * 0.55;
      const sw = sigma * DW * 0.12;

      // Gaussian bell curve mini
      dctx.beginPath();
      for (let px = x-sw*3; px <= x+sw*3; px += 1.5) {
        const z = (px-x)/sw;
        const py = y - Math.exp(-0.5*z*z) * 20;
        px === x-sw*3 ? dctx.moveTo(px,py) : dctx.lineTo(px,py);
      }
      dctx.strokeStyle = "hsla(" + hue + ",70%,60%,0.6)";
      dctx.lineWidth = 1;
      dctx.stroke();

      // Mu point
      dctx.beginPath(); dctx.arc(x, y, 2, 0, Math.PI*2);
      dctx.fillStyle = "hsla(" + hue + ",80%,70%,0.8)"; dctx.fill();
    });

    dctx.fillStyle = "rgba(139,111,176,0.7)";
    dctx.font = "10px monospace";
    dctx.textAlign = "left";
    dctx.fillText("μ, σ distributions in latent space", 8, DH-4);

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
