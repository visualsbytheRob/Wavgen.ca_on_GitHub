<!-- ======================================================
     SECTION 9 - GLOSSARY
====================================================== -->
<section id="glossary">
<div class="section-title">Glossary</div>
<div class="section-subtitle">Key terms in procedural generation, from axioms to WFC entropy</div>
<div class="glossary-grid" id="glossary-grid"></div>
</section>
<script>
(function(){
  var terms=[
    {t:'Axiom',d:'The starting string in an L-system. The generator begins here and applies rewriting rules recursively each generation.'},
    {t:'BSP (Binary Space Partitioning)',d:'A recursive space division technique. A region is split in half, then each half is split again, until subregions are small enough to place rooms or geometry.'},
    {t:'Cellular Automata',d:'Grid-based simulation where each cell updates based on its neighbors. Conway's Game of Life and cave generation use CA rules to create organic patterns.'},
    {t:'Constraint Propagation',d:'The process in WFC of eliminating impossible tile options from neighboring cells whenever a cell collapses, spreading constraints through the grid.'},
    {t:'Determinism',d:'Producing the same output from the same seed. Deterministic PCG means worlds are reproducible and shareable with just a number.'},
    {t:'Diamond-Square',d:'A fractal terrain algorithm. Set corner heights, find midpoints by averaging corners plus random offset, halve offset each pass. Produces natural-looking heightmaps.'},
    {t:'Domain Warping',d:'Distorting a noise lookup by using noise to offset the sample coordinates: result = noise(p + noise(p)). Produces swirling, organic-looking patterns.'},
    {t:'Emergence',d:'Complex global behavior arising from many simple local interactions. No individual rule produces the pattern — it emerges from their interaction.'},
    {t:'Entropy (WFC)',d:'In Wave Function Collapse, the number of possible tile options remaining in a cell. Lower entropy = more constrained. WFC collapses lowest-entropy cells first.'},
    {t:'fBm (Fractal Brownian Motion)',d:'Summing multiple octaves of noise at increasing frequency and decreasing amplitude. Produces natural-looking terrain, clouds, and textures.'},
    {t:'Fractal',d:'A self-similar structure where patterns repeat at different scales. Koch snowflakes, fBm terrain, and L-system plants all exhibit fractal properties.'},
    {t:'Grammar',d:'In L-systems, a formal set of production rules that rewrite symbols. Each rule replaces one symbol with a string of symbols each generation.'},
    {t:'Heightmap',d:'A 2D array of values representing terrain elevation. Visualized as a grayscale image or color-coded by biome. Foundation for 3D terrain rendering.'},
    {t:'L-system',d:'Lindenmayer system. A formal grammar for modeling biological growth. An axiom is iteratively rewritten by rules, then interpreted geometrically by turtle graphics.'},
    {t:'Noise',d:'Structured pseudo-random signal. Unlike pure random values, noise is coherent — nearby points have similar values — making it suitable for smooth natural forms.'},
    {t:'Octave',d:'One layer in fractional Brownian motion. Each octave adds a higher-frequency, lower-amplitude contribution. More octaves = more detail.'},
    {t:'PCG (Procedural Content Generation)',d:'Automatic creation of game or simulation content using algorithms rather than manual authoring. Includes levels, textures, music, dialogue, and more.'},
    {t:'Persistence',d:'Controls how quickly amplitude decreases across fBm octaves. High persistence = rough, detailed surfaces. Low persistence = smooth, gentle forms.'},
    {t:'Seed',d:'An integer input to a deterministic random number generator. Same seed → same world. Enables reproducible generation and level sharing.'},
    {t:'Turtle Graphics',d:'A drawing model used to render L-systems. A virtual turtle has position and heading; commands F (forward), + (turn right), - (turn left) build geometry.'},
    {t:'Voronoi Diagram',d:'A partition of space into regions, each closest to one of N seed points (sites). Used for biome maps, city layouts, and natural-looking territory boundaries.'},
    {t:'WFC (Wave Function Collapse)',d:'Algorithm by Maxim Gumin. Each cell starts in superposition of all tile types. Cells collapse from lowest entropy first, propagating adjacency constraints through the grid.'},
    {t:'Hydraulic Erosion',d:'Simulation of water flowing over terrain. Droplets carry sediment downhill and deposit it in valleys, smoothing peaks and sharpening ridges over many passes.'},
    {t:'Lacunarity',d:'Controls how quickly frequency increases across fBm octaves. A lacunarity of 2 doubles frequency each octave. Affects the coarseness vs. fine detail ratio.'}
  ];

  var grid=document.getElementById('glossary-grid');
  terms.forEach(function(item){
    var div=document.createElement('div');div.className='gloss-item';
    div.innerHTML='<div class="gloss-term">'+item.t+'</div><div class="gloss-def">'+item.d+'</div>';
    grid.appendChild(div);
  });
})();
</script>
