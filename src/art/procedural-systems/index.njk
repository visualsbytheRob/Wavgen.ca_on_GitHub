<script>
(function(){
  // Tab switching
  document.querySelectorAll('#dungeon .tab').forEach(function(tab){
    tab.addEventListener('click',function(){
      document.querySelectorAll('#dungeon .tab').forEach(function(t){t.classList.remove('active')});
      tab.classList.add('active');
      ['bsp','caves','voronoi'].forEach(function(n){
        document.getElementById('dungeon-'+n).style.display=(n===tab.dataset.dtab?'block':'none');
      });
    });
  });

  // ── BSP Dungeon ──
  var LagBSP=new LagFilter(0.3); // LagFilter #14
  function bspGenerate(W,H,depth,minRoom,seed){
    var rng=seed;function rand(){rng=rng*1664525+1013904223;return((rng>>>0)/0xffffffff)}
    var tiles=new Uint8Array(W*H); // 0=wall,1=floor,2=corridor,3=door
    var rooms=[];
    function split(x,y,w,h,d){
      if(d===0||w<minRoom*2+2||h<minRoom*2+2){
        var rx=x+1+Math.floor(rand()*(w-minRoom-1)),ry=y+1+Math.floor(rand()*(h-minRoom-1));
        var rw=minRoom+Math.floor(rand()*(w-rx+x-minRoom-1));
        var rh=minRoom+Math.floor(rand()*(h-ry+y-minRoom-1));
        rw=Math.max(minRoom,Math.min(rw,w-2));rh=Math.max(minRoom,Math.min(rh,h-2));
        rooms.push({x:rx,y:ry,w:rw,h:rh});
        for(var ty=ry;ty<ry+rh;ty++)for(var tx=rx;tx<rx+rw;tx++)tiles[ty*W+tx]=1;
        return{cx:Math.floor(rx+rw/2),cy:Math.floor(ry+rh/2)};
      }
      var horiz=w>h?rand()>0.3:rand()<0.3;
      var c1,c2;
      if(horiz){var mid=Math.floor(w/2)+Math.floor(rand()*4)-2;c1=split(x,y,mid,h,d-1);c2=split(x+mid,y,w-mid,h,d-1);}
      else{var mid2=Math.floor(h/2)+Math.floor(rand()*4)-2;c1=split(x,y,w,mid2,d-1);c2=split(x,y+mid2,w,h-mid2,d-1);}
      if(c1&&c2){
        var sx=Math.min(c1.cx,c2.cx),ex=Math.max(c1.cx,c2.cx);
        var sy=Math.min(c1.cy,c2.cy),ey=Math.max(c1.cy,c2.cy);
        for(var tx2=sx;tx2<=ex;tx2++)if(tiles[c1.cy*W+tx2]===0)tiles[c1.cy*W+tx2]=2;
        for(var ty2=sy;ty2<=ey;ty2++)if(tiles[ty2*W+c2.cx]===0)tiles[ty2*W+c2.cx]=2;
      }
      return c1;
    }
    split(0,0,W,H,depth);
    return{tiles:tiles,rooms:rooms};
  }
  function drawBSP(){
    var cvs=document.getElementById('d-bsp');
    var W2=cvs.width,H2=cvs.height,ctx=cvs.getContext('2d');
    var seed=parseInt(document.getElementById('bsp-seed').value)||42;
    var minR=parseInt(document.getElementById('bsp-minr').value)||5;
    var dep=parseInt(document.getElementById('bsp-dep').value)||4;
    var GW2=80,GH2=44;
    var res=bspGenerate(GW2,GH2,dep,minR,seed);
    var cw=W2/GW2,ch=H2/GH2;
    ctx.fillStyle='#050310';ctx.fillRect(0,0,W2,H2);
    var palette={0:'#050310',1:'#2a2060',2:'#1a1040',3:'#a78bfa'};
    for(var ty=0;ty<GH2;ty++)for(var tx=0;tx<GW2;tx++){
      var t=res.tiles[ty*GW2+tx];
      if(t===0)continue;
      ctx.fillStyle=palette[t];ctx.fillRect(tx*cw,ty*ch,cw+0.5,ch+0.5);
    }
    // room borders
    ctx.strokeStyle='rgba(124,58,237,0.4)';ctx.lineWidth=1;
    res.rooms.forEach(function(r){ctx.strokeRect(r.x*cw,r.y*ch,r.w*cw,r.h*ch)});
    // ambient glow on floors
    ctx.fillStyle='rgba(124,58,237,0.04)';
    res.rooms.forEach(function(r){ctx.fillRect(r.x*cw,r.y*ch,r.w*cw,r.h*ch)});
  }
  document.getElementById('bsp-regen').onclick=drawBSP;
  document.getElementById('bsp-minr').oninput=function(){document.getElementById('bsp-mr').textContent=this.value;};
  document.getElementById('bsp-dep').oninput=function(){document.getElementById('bsp-dv').textContent=this.value;};
  drawBSP();

  // ── Cellular Automata Caves ──
  var LagCA=new LagFilter(0.3); // LagFilter #15
  function caGenerate(W2,H2,fill,birth,survive,passes,seed){
    var rng=seed;function rand(){rng=rng*1664525+1013904223;return((rng>>>0)/0xffffffff)}
    var map=new Uint8Array(W2*H2);
    for(var i=0;i<W2*H2;i++)map[i]=(rand()<fill/100?1:0);
    for(var p=0;p<passes;p++){
      var next=new Uint8Array(W2*H2);
      for(var ty=0;ty<H2;ty++)for(var tx=0;tx<W2;tx++){
        if(tx===0||ty===0||tx===W2-1||ty===H2-1){next[ty*W2+tx]=1;continue}
        var n2=0;
        for(var dy=-1;dy<=1;dy++)for(var dx=-1;dx<=1;dx++){if(dx===0&&dy===0)continue;n2+=map[(ty+dy)*W2+(tx+dx)];}
        next[ty*W2+tx]=(map[ty*W2+tx]?n2>=survive:n2>=birth)?1:0;
      }
      map=next;
    }
    return map;
  }
  function drawCaves(){
    var cvs=document.getElementById('d-caves');
    var W2=cvs.width,H2=cvs.height,ctx=cvs.getContext('2d');
    var fill=parseInt(document.getElementById('ca-fill').value)||45;
    var birth=parseInt(document.getElementById('ca-birth').value)||5;
    var surv=parseInt(document.getElementById('ca-surv').value)||4;
    var pass=parseInt(document.getElementById('ca-pass').value)||5;
    var GW3=140,GH3=76;
    var map=caGenerate(GW3,GH3,fill,birth,surv,pass,Date.now());
    var cw=W2/GW3,ch=H2/GH3;
    ctx.fillStyle='#050310';ctx.fillRect(0,0,W2,H2);
    for(var ty=0;ty<GH3;ty++)for(var tx=0;tx<GW3;tx++){
      if(!map[ty*GW3+tx]){
        var g=ctx.createRadialGradient(tx*cw+cw/2,ty*ch+ch/2,0,tx*cw+cw/2,ty*ch+ch/2,cw);
        g.addColorStop(0,'rgba(80,50,160,0.9)');g.addColorStop(1,'rgba(30,20,80,0.8)');
        ctx.fillStyle=g;ctx.fillRect(tx*cw,ty*ch,cw+0.5,ch+0.5);
      }
    }
  }
  document.getElementById('ca-regen').onclick=drawCaves;
  ['ca-fill','ca-birth','ca-surv','ca-pass'].forEach(function(id){
    document.getElementById(id).oninput=function(){
      var vid=id.replace('ca-','ca-')+' .val';
      var valId=id+'-v'.replace('--','-');
      // update display spans
      document.getElementById(id.replace(/(ca-[a-z]+)/,'$1v').replace(/v$/,'')+'v').textContent=this.value;
    };
  });
  // fix the span updates
  document.getElementById('ca-fill').oninput=function(){document.getElementById('ca-fv').textContent=this.value;};
  document.getElementById('ca-birth').oninput=function(){document.getElementById('ca-bv').textContent=this.value;};
  document.getElementById('ca-surv').oninput=function(){document.getElementById('ca-sv').textContent=this.value;};
  document.getElementById('ca-pass').oninput=function(){document.getElementById('ca-pv').textContent=this.value;};
  drawCaves();

  // ── Voronoi World ──
  var LagVOR=new LagFilter(0.3); // LagFilter #16
  function drawVoronoi(){
    var cvs=document.getElementById('d-voronoi');
    var W2=cvs.width,H2=cvs.height,ctx=cvs.getContext('2d');
    var n=parseInt(document.getElementById('vor-n').value)||18;
    var seed=parseInt(document.getElementById('vor-seed').value)||7;
    var rng=seed*997;function rand(){rng=rng*1664525+1013904223;return((rng>>>0)/0xffffffff)}
    var sites=[];
    for(var i=0;i<n;i++)sites.push({x:rand()*W2,y:rand()*H2});
    var BIOME_COLORS=['#1e3a5f','#2d6a4f','#52b788','#b7e4c7','#d4a373','#a0522d','#6d6875','#e9c46a'];
    var biomes=sites.map(function(s){
      var elev=fbm(s.x/W2*4+seed,s.y/H2*4+seed*.7,4,.5,2);
      var moist=fbm(s.x/W2*3+seed*2,s.y/H2*3+seed*.3,3,.5,2);
      var bi;
      if(elev>0.7)bi=6;
      else if(elev<0.25)bi=0;
      else if(moist>0.65)bi=2;
      else if(moist>0.45)bi=1;
      else if(moist>0.3)bi=7;
      else bi=4;
      return bi;
    });
    var img=ctx.createImageData(W2,H2);
    for(var py=0;py<H2;py++)for(var px=0;px<W2;px++){
      var minD=Infinity,nearest=0;
      for(var si=0;si<sites.length;si++){
        var dx=px-sites[si].x,dy=py-sites[si].y;
        var d=dx*dx+dy*dy;if(d<minD){minD=d;nearest=si}
      }
      var col=BIOME_COLORS[biomes[nearest]];
      var r=parseInt(col.slice(1,3),16),g=parseInt(col.slice(3,5),16),b=parseInt(col.slice(5,7),16);
      // elevation shading
      var elev2=fbm(px/W2*4+seed,py/H2*4+seed*.7,4,.5,2);
      var shade=0.6+elev2*0.8;
      var ii=(py*W2+px)*4;
      img.data[ii]=Math.min(255,r*shade);img.data[ii+1]=Math.min(255,g*shade);
      img.data[ii+2]=Math.min(255,b*shade);img.data[ii+3]=255;
    }
    ctx.putImageData(img,0,0);
    // draw site borders
    ctx.strokeStyle='rgba(255,255,255,0.15)';ctx.lineWidth=0.5;
    for(var py2=0;py2<H2;py2+=2)for(var px2=0;px2<W2;px2+=2){
      var minD2=Infinity,sec=Infinity,near2=0;
      for(var si2=0;si2<sites.length;si2++){
        var dx2=px2-sites[si2].x,dy2=py2-sites[si2].y,d2=dx2*dx2+dy2*dy2;
        if(d2<minD2){sec=minD2;minD2=d2;near2=si2}else if(d2<sec)sec=d2;
      }
      if(Math.sqrt(sec)-Math.sqrt(minD2)<2){
        ctx.fillStyle='rgba(255,255,255,0.15)';ctx.fillRect(px2,py2,2,2);
      }
    }
    // draw site markers
    sites.forEach(function(s,i){
      ctx.beginPath();ctx.arc(s.x,s.y,4,0,Math.PI*2);
      ctx.fillStyle='rgba(255,255,255,0.5)';ctx.fill();
    });
  }
  document.getElementById('vor-regen').onclick=drawVoronoi;
  document.getElementById('vor-n').oninput=function(){document.getElementById('vor-nv').textContent=this.value;};
  drawVoronoi();
})();
</script>
