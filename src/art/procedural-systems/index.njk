<script>
(function(){
  // Tab switching
  document.querySelectorAll('#emergence .tab').forEach(function(tab){
    tab.addEventListener('click',function(){
      document.querySelectorAll('#emergence .tab').forEach(function(t){t.classList.remove('active')});
      tab.classList.add('active');
      ['gol','ant','slime'].forEach(function(n){
        document.getElementById('emerge-'+n).style.display=(n===tab.dataset.etab?'block':'none');
      });
    });
  });

  /* ── GAME OF LIFE ── */
  (function(){
    var lagGOLspeed=new LagFilter(0.25); // LagFilter #17
    var cvs=document.getElementById('e-gol');
    var ctx=cvs.getContext('2d');
    var CW=cvs.width,CH=cvs.height,CS=8;
    var GW=Math.floor(CW/CS),GH=Math.floor(CH/CS);
    var grid=new Uint8Array(GW*GH);
    var next2=new Uint8Array(GW*GH);
    var running2=false,rafId=null;
    var targetSpeed=8,smoothSpeed=8;

    function idx(x,y){return((y+GH)%GH)*GW+((x+GW)%GW)}
    function count(x,y){
      var n=0;
      for(var dy=-1;dy<=1;dy++)for(var dx=-1;dx<=1;dx++){if(dx===0&&dy===0)continue;n+=grid[idx(x+dx,y+dy)];}
      return n;
    }
    function step(){
      for(var y=0;y<GH;y++)for(var x=0;x<GW;x++){
        var n=count(x,y),c=grid[idx(x,y)];
        next2[idx(x,y)]=(c?(n===2||n===3):n===3)?1:0;
      }
      var tmp=grid;grid=next2;next2=tmp;
    }
    function draw2(){
      ctx.fillStyle='rgba(10,8,24,0.25)';ctx.fillRect(0,0,CW,CH);
      for(var y=0;y<GH;y++)for(var x=0;x<GW;x++){
        if(grid[idx(x,y)]){
          ctx.fillStyle='#7c3aed';ctx.fillRect(x*CS+1,y*CS+1,CS-2,CS-2);
          ctx.fillStyle='rgba(167,139,250,0.5)';ctx.fillRect(x*CS+2,y*CS+2,2,2);
        }
      }
    }
    var lastGOL=0,accum=0;
    function loop2(ts){
      var dt=Math.min((ts-lastGOL)/1000,0.1);lastGOL=ts;
      smoothSpeed=lagGOLspeed.update(targetSpeed,dt);
      var interval=1/smoothSpeed;
      accum+=dt;
      while(accum>=interval){step();accum-=interval;}
      draw2();
      if(running2)rafId=requestAnimationFrame(loop2);
    }
    document.getElementById('gol-play').onclick=function(){
      if(!running2){running2=true;lastGOL=0;rafId=requestAnimationFrame(loop2);}
    };
    document.getElementById('gol-pause').onclick=function(){running2=false;};
    document.getElementById('gol-clear').onclick=function(){grid.fill(0);draw2();};
    document.getElementById('gol-rand').onclick=function(){
      for(var i=0;i<grid.length;i++)grid[i]=Math.random()<0.3?1:0;draw2();
    };
    document.getElementById('gol-speed').oninput=function(){
      targetSpeed=parseFloat(this.value);document.getElementById('gol-sv').textContent=Math.round(targetSpeed);
    };
    var PATTERNS={
      glider:[[1,0],[2,1],[0,2],[1,2],[2,2]],
      rpent:[[1,0],[2,0],[0,1],[1,1],[1,2]],
      pulsar:[[2,0],[3,0],[4,0],[8,0],[9,0],[10,0],[0,2],[5,2],[7,2],[12,2],
              [0,3],[5,3],[7,3],[12,3],[0,4],[5,4],[7,4],[12,4],[2,5],[3,5],[4,5],[8,5],[9,5],[10,5]],
      gun:[[24,0],[22,1],[24,1],[12,2],[13,2],[20,2],[21,2],[34,2],[35,2],
           [11,3],[15,3],[20,3],[21,3],[34,3],[35,3],[0,4],[1,4],[10,4],[16,4],[20,4],[21,4],
           [0,5],[1,5],[10,5],[14,5],[16,5],[17,5],[22,5],[24,5],[10,6],[16,6],[24,6],[11,7],[15,7],[12,8],[13,8]]
    };
    document.querySelectorAll('.gol-pat').forEach(function(btn){
      btn.onclick=function(){
        var pat=PATTERNS[btn.dataset.pat];if(!pat)return;
        var ox=Math.floor(GW/2),oy=Math.floor(GH/2);
        pat.forEach(function(p){grid[idx(ox+p[0]-5,oy+p[1]-5)]=1});draw2();
      };
    });
    // mouse draw
    var drawing=false;
    cvs.addEventListener('mousedown',function(e){drawing=true});
    cvs.addEventListener('mouseup',function(){drawing=false});
    cvs.addEventListener('mousemove',function(e){
      if(!drawing)return;
      var r=cvs.getBoundingClientRect();
      var scaleX=CW/r.width,scaleY=CH/r.height;
      var x=Math.floor((e.clientX-r.left)*scaleX/CS);
      var y=Math.floor((e.clientY-r.top)*scaleY/CS);
      if(x>=0&&x<GW&&y>=0&&y<GH){grid[idx(x,y)]=1;draw2();}
    });
    cvs.addEventListener('click',function(e){
      var r=cvs.getBoundingClientRect();
      var scaleX=CW/r.width,scaleY=CH/r.height;
      var x=Math.floor((e.clientX-r.left)*scaleX/CS);
      var y=Math.floor((e.clientY-r.top)*scaleY/CS);
      if(x>=0&&x<GW&&y>=0&&y<GH){grid[idx(x,y)]=grid[idx(x,y)]?0:1;draw2();}
    });
    draw2();
  })();

  /* ── LANGTON'S ANT ── */
  (function(){
    var lagANTspeed=new LagFilter(0.3); // LagFilter #18
    var cvs=document.getElementById('e-ant');
    var ctx=cvs.getContext('2d');
    var CW=cvs.width,CH=cvs.height,CS=4;
    var GW2=Math.floor(CW/CS),GH2=Math.floor(CH/CS);
    var cells=null,ants=null,rule='RL';
    var runningAnt=false,antRaf=null;
    var targetAntSpeed=10,smoothAntSpeed=10;

    function initAnt(){
      cells=new Uint8Array(GW2*GH2);
      rule=document.getElementById('ant-rule').value;
      var n=parseInt(document.getElementById('ant-count').value)||1;
      ants=[];
      for(var i=0;i<n;i++){
        ants.push({x:Math.floor(GW2/2)+(i-Math.floor(n/2))*4,y:Math.floor(GH2/2),dir:i%4});
      }
    }
    function stepAnt(stepsPerFrame){
      for(var s=0;s<stepsPerFrame;s++){
        for(var ai=0;ai<ants.length;ai++){
          var ant=ants[ai];
          var c=cells[ant.y*GW2+ant.x];
          var ruleLen=rule.length;
          var turn=rule[c%ruleLen]==='R'?1:-1;
          ant.dir=((ant.dir+turn)+4)%4;
          cells[ant.y*GW2+ant.x]=(c+1)%ruleLen;
          var dirs=[[0,-1],[1,0],[0,1],[-1,0]];
          ant.x=(ant.x+dirs[ant.dir][0]+GW2)%GW2;
          ant.y=(ant.y+dirs[ant.dir][1]+GH2)%GH2;
        }
      }
    }
    function drawAnt(){
      var img=ctx.createImageData(CW,CH);
      for(var y=0;y<GH2;y++)for(var x=0;x<GW2;x++){
        var c=cells[y*GW2+x];
        var r2=0,g2=0,b2=0;
        if(c>0){
          var hue=(c/rule.length)*300+200;
          // simple HSL->RGB
          var h=hue/360,l=0.4+c*0.1,ss=0.7;
          function hue2rgb(p,q,t2){if(t2<0)t2+=1;if(t2>1)t2-=1;if(t2<1/6)return p+(q-p)*6*t2;if(t2<1/2)return q;if(t2<2/3)return p+(q-p)*(2/3-t2)*6;return p}
          var q2=l<0.5?l*(1+ss):l+ss-l*ss,p2=2*l-q2;
          r2=Math.round(hue2rgb(p2,q2,h+1/3)*255);
          g2=Math.round(hue2rgb(p2,q2,h)*255);
          b2=Math.round(hue2rgb(p2,q2,h-1/3)*255);
        }
        for(var py=0;py<CS;py++)for(var px2=0;px2<CS;px2++){
          var ii=((y*CS+py)*CW+(x*CS+px2))*4;
          img.data[ii]=r2;img.data[ii+1]=g2;img.data[ii+2]=b2;img.data[ii+3]=255;
        }
      }
      ctx.putImageData(img,0,0);
      // draw ants
      ctx.fillStyle='#fff';
      ants.forEach(function(a){ctx.fillRect(a.x*CS,a.y*CS,CS,CS);});
    }
    var lastAnt=0;
    function antLoop(ts){
      var dt=Math.min((ts-lastAnt)/1000,0.1);lastAnt=ts;
      smoothAntSpeed=lagANTspeed.update(targetAntSpeed,dt);
      stepAnt(Math.max(1,Math.round(smoothAntSpeed)));
      drawAnt();
      if(runningAnt)antRaf=requestAnimationFrame(antLoop);
    }
    document.getElementById('ant-reset').onclick=function(){
      runningAnt=false;initAnt();drawAnt();runningAnt=true;lastAnt=0;antRaf=requestAnimationFrame(antLoop);
    };
    document.getElementById('ant-rule').onchange=function(){initAnt();};
    document.getElementById('ant-count').oninput=function(){document.getElementById('ant-cv').textContent=this.value;};
    document.getElementById('ant-speed').oninput=function(){
      targetAntSpeed=parseFloat(this.value);document.getElementById('ant-sv').textContent=Math.round(targetAntSpeed);
    };
    initAnt();drawAnt();
    runningAnt=true;requestAnimationFrame(function(ts){lastAnt=ts;antLoop(ts);});
  })();

  /* ── SLIME MOLD ── */
  (function(){
    var lagSLIME=new LagFilter(0.3); // LagFilter #19
    var cvs=document.getElementById('e-slime');
    var ctx=cvs.getContext('2d');
    var W2=cvs.width,H2=cvs.height;
    var trail=null,agents=null;
    var runningSlime=true;
    var targetDecay=0.97,smoothDecay=0.97;

    function initSlime(){
      trail=new Float32Array(W2*H2);
      var n=parseInt(document.getElementById('slime-n').value)||500;
      agents=[];
      for(var i=0;i<n;i++){
        var ang=Math.random()*Math.PI*2;
        var r=Math.min(W2,H2)*0.15*Math.random();
        agents.push({x:W2/2+Math.cos(ang)*r,y:H2/2+Math.sin(ang)*r,ang:ang});
      }
    }

    function sense(x,y,ang,dist,spread){
      var sx=Math.round(x+Math.cos(ang+spread)*dist);
      var sy=Math.round(y+Math.sin(ang+spread)*dist);
      sx=Math.max(0,Math.min(W2-1,sx));sy=Math.max(0,Math.min(H2-1,sy));
      return trail[sy*W2+sx];
    }

    function stepSlime(){
      var saDeg=parseFloat(document.getElementById('slime-sa').value)||30;
      var sa=saDeg*Math.PI/180;
      var dist=9;
      for(var i=0;i<agents.length;i++){
        var a=agents[i];
        var fwd=sense(a.x,a.y,a.ang,dist,0);
        var lft=sense(a.x,a.y,a.ang,dist,-sa);
        var rgt=sense(a.x,a.y,a.ang,dist,sa);
        if(fwd>lft&&fwd>rgt){}
        else if(lft>rgt)a.ang-=sa*0.3+Math.random()*sa*0.2;
        else if(rgt>lft)a.ang+=sa*0.3+Math.random()*sa*0.2;
        else a.ang+=(Math.random()-0.5)*sa;
        a.x+=Math.cos(a.ang)*1.2;a.y+=Math.sin(a.ang)*1.2;
        if(a.x<0||a.x>=W2){a.ang=Math.PI-a.ang;a.x=Math.max(0,Math.min(W2-1,a.x));}
        if(a.y<0||a.y>=H2){a.ang=-a.ang;a.y=Math.max(0,Math.min(H2-1,a.y));}
        var tx=Math.round(a.x),ty=Math.round(a.y);
        if(tx>=0&&tx<W2&&ty>=0&&ty<H2)trail[ty*W2+tx]=Math.min(1,trail[ty*W2+tx]+0.3);
      }
      // diffuse and decay
      var dec=smoothDecay;
      var tmp=new Float32Array(W2*H2);
      for(var y=1;y<H2-1;y++)for(var x=1;x<W2-1;x++){
        var avg=(trail[(y-1)*W2+x]+trail[(y+1)*W2+x]+trail[y*W2+x-1]+trail[y*W2+x+1]+trail[y*W2+x]*4)/8;
        tmp[y*W2+x]=avg*dec;
      }
      trail=tmp;
    }

    function drawSlime(){
      var img=ctx.createImageData(W2,H2);
      for(var i=0;i<W2*H2;i++){
        var v=trail[i];
        img.data[i*4]=Math.min(255,v*80+v*v*180);
        img.data[i*4+1]=Math.min(255,v*40+v*v*100);
        img.data[i*4+2]=Math.min(255,v*160+v*v*255);
        img.data[i*4+3]=255;
      }
      ctx.putImageData(img,0,0);
    }

    var lastSlime=0;
    function slimeLoop(ts){
      var dt=Math.min((ts-lastSlime)/1000,0.1);lastSlime=ts;
      var decSlider=parseInt(document.getElementById('slime-dec').value)||3;
      smoothDecay=lagSLIME.update(1-decSlider*0.003,dt);
      stepSlime();drawSlime();
      if(runningSlime)requestAnimationFrame(slimeLoop);
    }

    document.getElementById('slime-reset').onclick=function(){initSlime();};
    document.getElementById('slime-n').oninput=function(){document.getElementById('slime-nv').textContent=this.value;initSlime();};
    document.getElementById('slime-sa').oninput=function(){document.getElementById('slime-sav').textContent=this.value;};
    document.getElementById('slime-dec').oninput=function(){document.getElementById('slime-dv').textContent=(1-this.value*0.003).toFixed(3);};

    initSlime();
    requestAnimationFrame(function(ts){lastSlime=ts;slimeLoop(ts);});
  })();
})();
</script>
