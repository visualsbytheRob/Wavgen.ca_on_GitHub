<div class="controls">
<div class="ctrl-group"><label>Persist</label><input id="fb-per" max="9" min="1" type="range" value="5"/><span class="val" id="fb-pv">0.5</span></div>
<div class="ctrl-group"><label>Lacun</label><input id="fb-lac" max="30" min="10" type="range" value="20"/><span class="val" id="fb-lv">2.0</span></div>
</div>
</div>
<div class="canvas-panel">
<h3>Ridged Noise</h3>
<canvas class="pixel" height="200" id="n-ridged" width="200"></canvas>
<div class="controls">
<div class="ctrl-group"><label>Scale</label><input id="rn-scale" max="20" min="1" type="range" value="5"/><span class="val" id="rn-sv">5</span></div>
<div class="ctrl-group"><label>Oct</label><input id="rn-oct" max="6" min="1" type="range" value="4"/><span class="val" id="rn-ov">4</span></div>
</div>
</div>
<div class="canvas-panel">
<h3>Domain-Warped Noise</h3>
<canvas class="pixel" height="200" id="n-warp" width="200"></canvas>
<div class="controls">
<div class="ctrl-group"><label>Warp</label><input id="wn-str" max="50" min="1" type="range" value="20"/><span class="val" id="wn-sv">2.0</span></div>
<div class="ctrl-group"><label>Scale</label><input id="wn-scale" max="20" min="1" type="range" value="5"/><span class="val" id="wn-scv">5</span></div>
</div>
</div>
</div>
</section>
<script>
(function(){
  // LagFilters #2-#8 for noise sliders
  var lagVN=new LagFilter(0.3),lagGNs=new LagFilter(0.3),lagGNo=new LagFilter(0.3);
  var lagFBp=new LagFilter(0.3),lagFBl=new LagFilter(0.3);
  var lagRNs=new LagFilter(0.3),lagWNs=new LagFilter(0.3);
  var S=200;
  var targets={vnScale:8,gnScale:6,gnOct:4,fbPer:0.5,fbLac:2,rnScale:5,rnOct:4,wnStr:2,wnScale:5};
  var smooth={vnScale:8,gnScale:6,gnOct:4,fbPer:0.5,fbLac:2,rnScale:5,rnOct:4,wnStr:2,wnScale:5};
  var dirty={value:true,grad:true,fbm:true,ridged:true,warp:true};
  var ctxs={};
  ['value','grad','fbm','ridged','warp'].forEach(function(k){
    var idMap={value:'n-value',grad:'n-grad',fbm:'n-fbm',ridged:'n-ridged',warp:'n-warp'};
    ctxs[k]=document.getElementById(idMap[k]).getContext('2d');
  });

  function bind(id,key,valId,xform,dk){
    var el=document.getElementById(id);
    if(!el)return;
    el.addEventListener('input',function(){
      var raw=parseFloat(el.value);
      targets[key]=xform?xform(raw):raw;
      var disp=document.getElementById(valId);
      if(disp)disp.textContent=targets[key].toFixed(1);
      dirty[dk]=true;
    });
  }
  bind('vn-scale','vnScale','vn-sv',null,'value');
  bind('gn-scale','gnScale','gn-sv',null,'grad');
  bind('gn-oct','gnOct','gn-ov',null,'grad');
  bind('fb-per','fbPer','fb-pv',function(v){return v/10;},'fbm');
  bind('fb-lac','fbLac','fb-lv',function(v){return v/10;},'fbm');
  bind('rn-scale','rnScale','rn-sv',null,'ridged');
  bind('rn-oct','rnOct','rn-ov',null,'ridged');
  bind('wn-str','wnStr','wn-sv',function(v){return v/10;},'warp');
  bind('wn-scale','wnScale','wn-scv',null,'warp');

  function drawNoise(type,ctx,p){
    var img=ctx.createImageData(S,S);
    for(var y=0;y<S;y++){
      for(var x=0;x<S;x++){
        var nx=x/S,ny=y/S,v=0.5;
        if(type==='value') v=valueNoise(nx*p.vnScale,ny*p.vnScale);
        else if(type==='grad') v=gradNoise(nx*p.gnScale,ny*p.gnScale)*0.5
          +gradNoise(nx*p.gnScale*2,ny*p.gnScale*2)*0.3
          +gradNoise(nx*p.gnScale*4,ny*p.gnScale*4)*0.2;
        else if(type==='fbm') v=fbm(nx*5,ny*5,6,p.fbPer,p.fbLac);
        else if(type==='ridged') v=ridgedNoise(nx*p.rnScale,ny*p.rnScale,p.rnOct);
        else if(type==='warp') v=domainWarp(nx*p.wnScale,ny*p.wnScale,p.wnStr);
        v=Math.max(0,Math.min(1,v));
        var c=Math.round(v*255),i=(y*S+x)*4;
        img.data[i]=c;img.data[i+1]=c;img.data[i+2]=c;img.data[i+3]=255;
      }
    }
    ctx.putImageData(img,0,0);
  }

  var lastN=0;
  function noiseLoop(ts){
    var dt=Math.min((ts-lastN)/1000,0.05);lastN=ts;
    smooth.vnScale=lagVN.update(targets.vnScale,dt);
    smooth.gnScale=lagGNs.update(targets.gnScale,dt);
    smooth.gnOct  =lagGNo.update(targets.gnOct,dt);
    smooth.fbPer  =lagFBp.update(targets.fbPer,dt);
    smooth.fbLac  =lagFBl.update(targets.fbLac,dt);
    smooth.rnScale=lagRNs.update(targets.rnScale,dt);
    smooth.wnStr  =lagWNs.update(targets.wnStr,dt);
    if(dirty.value)  {drawNoise('value',ctxs.value,smooth);   dirty.value=false;}
    if(dirty.grad)   {drawNoise('grad',ctxs.grad,smooth);     dirty.grad=false;}
    if(dirty.fbm)    {drawNoise('fbm',ctxs.fbm,smooth);       dirty.fbm=false;}
    if(dirty.ridged) {drawNoise('ridged',ctxs.ridged,smooth); dirty.ridged=false;}
    if(dirty.warp)   {drawNoise('warp',ctxs.warp,smooth);     dirty.warp=false;}
    requestAnimationFrame(noiseLoop);
  }
  requestAnimationFrame(function(ts){lastN=ts;requestAnimationFrame(noiseLoop);});
})();
</script>
<!-- ======================================================
     SECTION 3 - L-SYSTEMS
====================================================== -->
<section id="l-systems">
<div class="section-title">L-Systems</div>
<div class="section-subtitle">Lindenmayer systems — biological growth rules turned into geometry</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
<div>
<div class="controls" style="margin-bottom:1rem">
<div class="ctrl-group"><label>Preset</label>
<select id="ls-preset">
<option value="0">Koch Snowflake</option>
<option value="1">Sierpinski Triangle</option>
<option value="2">Dragon Curve</option>
<option value="3">Barnsley Fern</option>
<option value="4">Bush Plant</option>
<option value="5">Stochastic Tree</option>
<option value="6">Hilbert Curve</option>
<option value="7">Branching Weed</option>
</select>
</div>
<button id="ls-random">Randomize Rules</button>
</div>
<div id="ls-info" style="background:var(--surface);border-radius:10px;padding:.8rem;font-size:.77rem;color:var(--muted);font-family:monospace;margin-bottom:1rem"></div>
<div class="controls">
<div class="ctrl-group"><label>Generations</label><input id="ls-gen" max="8" min="1" type="range" value="4"/><span class="val" id="ls-gv">4</span></div>
<div class="ctrl-group"><label>Length</label><input id="ls-len" max="40" min="1" type="range" value="10"/><span class="val" id="ls-lv">10</span></div>
<div class="ctrl-group"><label>Angle +/-</label><input id="ls-ang" max="30" min="0" type="range" value="0"/><span class="val" id="ls-av">0</span></div>
</div>
</div>
<div>
<canvas height="400" id="ls-canvas" style="background:#0d0b24;border-radius:12px;width:100%" width="440"></canvas>
</div>
</div>
</section>
<script>
(function(){
  var lagLen=new LagFilter(0.4); // LagFilter #9 - segment length
  var lagAng=new LagFilter(0.4); // LagFilter #10 - angle variation

  var presets=[
    {name:'Koch Snowflake',axiom:'F--F--F',rules:{F:'F+F--F+F'},angle:60,len:5,gen:4},
    {name:'Sierpinski',axiom:'F-G-G',rules:{F:'F-G+F+G-F',G:'GG'},angle:120,len:8,gen:5},
    {name:'Dragon Curve',axiom:'FX',rules:{X:'X+YF+',Y:'-FX-Y'},angle:90,len:8,gen:10},
    {name:'Barnsley Fern',axiom:'X',rules:{X:'F+[[X]-X]-F[-FX]+X',F:'FF'},angle:25,len:6,gen:6},
    {name:'Bush Plant',axiom:'F',rules:{F:'F[+F]F[-F]F'},angle:25.7,len:8,gen:5},
    {name:'Stochastic Tree',axiom:'F',rules:{F:'FF[+F][-F][*F][/F]'},angle:22,len:10,gen:4},
    {name:'Hilbert Curve',axiom:'A',rules:{A:'-BF+AFA+FB-',B:'+AF-BFB-FA+'},angle:90,len:8,gen:5},
    {name:'Branching Weed',axiom:'F',rules:{F:'F[+F[-F]]F[-F[+F]]'},angle:20,len:7,gen:4}
  ];

  var current=0;
  var targetLen=10,smoothLen=10,targetAng=0,smoothAng=0;
  var genTarget=4,customAxiom=null,customRules=null;

  var cvs=document.getElementById('ls-canvas');
  var ctx=cvs.getContext('2d');

  function expand(axiom,rules,gens){
    var s=axiom;
    for(var i=0;i<gens;i++){
      var ns='';
      for(var c=0;c<s.length;c++){ns+=(rules[s[c]]||s[c])}
      s=ns;
      if(s.length>80000)break;
    }
    return s
  }

  function drawLSystem(str,angle,len,startX,startY,startAng,angVar){
    ctx.clearRect(0,0,cvs.width,cvs.height);
    // phosphor persistence
    ctx.fillStyle='rgba(13,11,36,0.85)';
    ctx.fillRect(0,0,cvs.width,cvs.height);

    var x=startX,y=startY,ang=startAng;
    var stack=[];
    var rad=angle*Math.PI/180;
    var depth=0;
    ctx.lineWidth=1;

    for(var i=0;i<str.length;i++){
      var c=str[i];
      var jitter=(angVar>0)?(Math.random()-0.5)*angVar*Math.PI/180:0;
      if(c==='F'||c==='G'){
        var nx2=x+Math.cos(ang)*len,ny2=y+Math.sin(ang)*len;
        var alpha=Math.max(0.3,1-depth*0.08);
        var hue=200+depth*15;
        ctx.strokeStyle='hsla('+hue+',70%,70%,'+alpha+')';
        ctx.beginPath();ctx.moveTo(x,y);ctx.lineTo(nx2,ny2);ctx.stroke();
        x=nx2;y=ny2;
      }else if(c==='+'){ang+=rad+jitter}
      else if(c==='-'){ang-=rad+jitter}
      else if(c==='['){stack.push({x:x,y:y,ang:ang,d:depth});depth++}
      else if(c===']'){var st=stack.pop();x=st.x;y=st.y;ang=st.ang;depth=st.d}
      else if(c==='*'){ang+=rad*0.5+jitter}
      else if(c==='/'){ang-=rad*0.5+jitter}
    }
  }

  function getStartPos(str,angle,len){
    // auto-center by dry run
    var x=0,y=0,ang=-Math.PI/2;
    var rad=angle*Math.PI/180;
    var minX=0,maxX=0,minY=0,maxY=0;
    var stack=[];
    for(var i=0;i<Math.min(str.length,5000);i++){
      var c=str[i];
      if(c==='F'||c==='G'){x+=Math.cos(ang)*len;y+=Math.sin(ang)*len;
        minX=Math.min(minX,x);maxX=Math.max(maxX,x);minY=Math.min(minY,y);maxY=Math.max(maxY,y)}
      else if(c==='+')ang+=rad;else if(c==='-')ang-=rad;
      else if(c==='[')stack.push({x:x,y:y,ang:ang});
      else if(c===']'){var s=stack.pop();x=s.x;y=s.y;ang=s.ang}
    }
    var cx2=(minX+maxX)/2,cy2=(minY+maxY)/2;
    var scale=Math.min((cvs.width-40)/(maxX-minX+1),(cvs.height-40)/(maxY-minY+1));
    scale=Math.min(scale,1);
    return{sx:cvs.width/2-cx2*scale,sy:cvs.height/2-cy2*scale,sc:scale}
  }

  function regenerate(){
    var p=customAxiom?{axiom:customAxiom,rules:customRules,angle:25,len:smoothLen,gen:genTarget}
                     :presets[current];
    var gen=Math.round(genTarget);
    var info=document.getElementById('ls-info');
    info.innerHTML='<b style="color:#a78bfa">'+p.name+'</b><br>Axiom: '+p.axiom+'<br>'+
      Object.entries(p.rules).map(function(e){return 'Rule '+e[0]+' &rarr; '+e[1]}).join('<br>')+'<br>Angle: '+p.angle+'deg | Gen: '+gen;
    var str=expand(p.axiom,p.rules,gen);
    var pos=getStartPos(str,p.angle,smoothLen);
    drawLSystem(str,p.angle,smoothLen,pos.sx,pos.sy,-Math.PI/2,smoothAng);
  }

  document.getElementById('ls-preset').addEventListener('change',function(e){
    current=parseInt(e.target.value);customAxiom=null;customRules=null;
    genTarget=presets[current].gen;
    document.getElementById('ls-gen').value=Math.min(8,genTarget);
    document.getElementById('ls-gv').textContent=Math.round(genTarget);
    regenerate();
  });
  document.getElementById('ls-gen').addEventListener('input',function(){
    genTarget=parseFloat(this.value);document.getElementById('ls-gv').textContent=Math.round(genTarget);regenerate();
  });
  document.getElementById('ls-len').addEventListener('input',function(){
    targetLen=parseFloat(this.value);document.getElementById('ls-lv').textContent=Math.round(targetLen);
  });
  document.getElementById('ls-ang').addEventListener('input',function(){
    targetAng=parseFloat(this.value);document.getElementById('ls-av').textContent=Math.round(targetAng);
  });
  document.getElementById('ls-random').addEventListener('click',function(){
    var chars='F+-[]FFF';
    var rules={F:''};
    var rlen=4+Math.floor(Math.random()*8);
    for(var i=0;i<rlen;i++)rules.F+=chars[Math.floor(Math.random()*chars.length)];
    customAxiom='F';customRules=rules;
    var info=document.getElementById('ls-info');
    info.innerHTML='<b style="color:#a78bfa">Random Organism</b><br>Rule F &rarr; '+rules.F;
    genTarget=4;regenerate();
  });

  var lsLast=0;
  function lsLoop(ts){
    var dt=Math.min((ts-lsLast)/1000,0.05);lsLast=ts;
    var nl=lagLen.update(targetLen,dt);
    var na=lagAng.update(targetAng,dt);
    var changed=(Math.abs(nl-smoothLen)>0.3||Math.abs(na-smoothAng)>0.3);
    smoothLen=nl;smoothAng=na;
    if(changed)regenerate();
    requestAnimationFrame(lsLoop);
  }
  regenerate();
  requestAnimationFrame(function(ts){lsLast=ts;requestAnimationFrame(lsLoop);});
})();
</script>
