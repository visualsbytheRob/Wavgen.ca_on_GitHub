<div id="terrain-heightmap" style="display:block">
<div style="display:grid;grid-template-columns:1fr auto;gap:1rem;align-items:start">
<canvas height="320" id="t-hmap" style="border-radius:10px;width:100%;cursor:grab" width="600"></canvas>
<div>
<div class="controls" style="flex-direction:column;align-items:flex-start">
<div class="ctrl-group"><label>Scale</label><input id="hm-scale" max="20" min="1" type="range" value="5"/><span class="val" id="hm-sv">5</span></div>
<div class="ctrl-group"><label>Octaves</label><input id="hm-oct" max="8" min="1" type="range" value="5"/><span class="val" id="hm-ov">5</span></div>
<div class="ctrl-group"><label>Seed</label><input id="hm-seed" style="width:68px" type="number" value="42"/></div>
<button id="hm-regen" style="margin-top:.5rem">Regenerate</button>
<button class="secondary" id="hm-ascii" style="margin-top:.4rem">Export ASCII</button>
</div>
</div>
</div>
<pre class="ascii-out" id="hm-ascii-out" style="display:none"></pre>
</div>
<div id="terrain-diamond" style="display:none">
<canvas height="320" id="t-diam" style="border-radius:10px;width:100%" width="512"></canvas>
<div class="controls" style="margin-top:.8rem">
<div class="ctrl-group"><label>Roughness</label><input id="ds-rough" max="20" min="1" type="range" value="8"/><span class="val" id="ds-rv">0.8</span></div>
<div class="ctrl-group"><label>Seed</label><input id="ds-seed" style="width:68px" type="number" value="7"/></div>
<button id="ds-regen">Regenerate</button>
</div>
</div>
<div id="terrain-erosion" style="display:none">
<canvas height="320" id="t-eros" style="border-radius:10px;width:100%" width="600"></canvas>
<div class="controls" style="margin-top:.8rem">
<div class="ctrl-group"><label>Erosion Passes</label><input id="er-pass" max="50" min="0" type="range" value="0"/><span class="val" id="er-pv">0</span></div>
<div class="ctrl-group"><label>Inertia</label><input id="er-iner" max="9" min="1" type="range" value="5"/><span class="val" id="er-iv">0.5</span></div>
<button id="er-regen">New Terrain</button>
<button class="secondary" id="er-run">Run Erosion</button>
</div>
</div>
<div id="terrain-biome" style="display:none">
<canvas height="360" id="t-biome" style="border-radius:10px;width:100%" width="600"></canvas>
<div class="controls" style="margin-top:.8rem">
<div class="ctrl-group"><label>Scale</label><input id="bm-scale" max="15" min="2" type="range" value="6"/><span class="val" id="bm-sv">6</span></div>
<div class="ctrl-group"><label>Seed</label><input id="bm-seed" style="width:68px" type="number" value="99"/></div>
<button id="bm-regen">Regenerate</button>
</div>
</div>
</section>
<script>
(function(){
  var lagHMscale=new LagFilter(0.3); // LagFilter #11
  var lagDSrough=new LagFilter(0.3); // LagFilter #12
  var lagEROpass=new LagFilter(0.3); // LagFilter #13

  // Tab switching
  document.querySelectorAll('#terrain .tab').forEach(function(tab){
    tab.addEventListener('click',function(){
      document.querySelectorAll('#terrain .tab').forEach(function(t){t.classList.remove('active')});
      tab.classList.add('active');
      var name=tab.dataset.tab;
      ['heightmap','diamond','erosion','biome'].forEach(function(n){
        document.getElementById('terrain-'+n).style.display=(n===name?'block':'none');
      });
    });
  });

  // ── Heightmap ──
  var hmSeed=42,hmScale=5,hmOct=5;
  function biomeColor(h){
    if(h<0.3) return[20,50,120];
    if(h<0.37) return[40,80,160];
    if(h<0.41) return[210,195,140];
    if(h<0.55) return[80,140,60];
    if(h<0.65) return[55,100,40];
    if(h<0.78) return[100,80,60];
    if(h<0.88) return[130,120,115];
    return[235,240,245];
  }
  function drawHeightmap(cvs,seed,scale,oct){
    var W=cvs.width,H=cvs.height;
    var ctx=cvs.getContext('2d');
    var img=ctx.createImageData(W,H);
    for(var y=0;y<H;y++){
      for(var x=0;x<W;x++){
        var v=fbm(x/W*scale+seed,y/H*scale+seed*0.7,oct,0.5,2);
        v=Math.max(0,Math.min(1,v));
        var c=biomeColor(v);
        var i=(y*W+x)*4;
        img.data[i]=c[0];img.data[i+1]=c[1];img.data[i+2]=c[2];img.data[i+3]=255;
      }
    }
    ctx.putImageData(img,0,0);
  }
  var hmCvs=document.getElementById('t-hmap');
  drawHeightmap(hmCvs,42,5,5);
  document.getElementById('hm-regen').onclick=function(){
    hmSeed=parseInt(document.getElementById('hm-seed').value)||Math.floor(Math.random()*1000);
    document.getElementById('hm-seed').value=hmSeed;
    drawHeightmap(hmCvs,hmSeed,hmScale,hmOct);
  };
  document.getElementById('hm-scale').oninput=function(){
    hmScale=parseFloat(this.value);document.getElementById('hm-sv').textContent=hmScale;
    drawHeightmap(hmCvs,hmSeed,hmScale,hmOct);
  };
  document.getElementById('hm-oct').oninput=function(){
    hmOct=parseInt(this.value);document.getElementById('hm-ov').textContent=hmOct;
    drawHeightmap(hmCvs,hmSeed,hmScale,hmOct);
  };
  document.getElementById('hm-ascii').onclick=function(){
    var W=80,H=24;
    var chars=' .,:;+*#@';
    var rows=[];
    for(var y=0;y<H;y++){
      var row='';
      for(var x=0;x<W;x++){
        var v=fbm(x/W*hmScale+hmSeed,y/H*hmScale+hmSeed*0.7,hmOct,0.5,2);
        v=Math.max(0,Math.min(0.999,v));
        row+=chars[Math.floor(v*chars.length)];
      }
      rows.push(row);
    }
    var el=document.getElementById('hm-ascii-out');
    el.textContent=rows.join('\n');
    el.style.display='block';
  };

  // ── Diamond-Square ──
  var dsSize=257;
  var dsMap=null;
  function diamondSquare(size,rough,seed){
    var n=size;
    var map=new Float32Array(n*n);
    function idx(x,y){x=((x%n)+n)%n;y=((y%n)+n)%n;return y*n+x}
    function r(scale){return(nhash(seed++)-.5)*scale}
    map[idx(0,0)]=0.5;map[idx(n-1,0)]=0.5;map[idx(0,n-1)]=0.5;map[idx(n-1,n-1)]=0.5;
    var step=n-1,sc=rough/10;
    while(step>1){
      var half=step>>1;
      for(var y=0;y<n-1;y+=step)for(var x=0;x<n-1;x+=step){
        var avg=(map[idx(x,y)]+map[idx(x+step,y)]+map[idx(x,y+step)]+map[idx(x+step,y+step)])/4;
        map[idx(x+half,y+half)]=Math.max(0,Math.min(1,avg+r(sc)));
      }
      for(var y2=0;y2<n;y2+=half)for(var x2=(y2+half)%step;x2<n;x2+=step){
        var cnt=0,s=0;
        if(y2>=half){s+=map[idx(x2,y2-half)];cnt++}
        if(y2+half<n){s+=map[idx(x2,y2+half)];cnt++}
        if(x2>=half){s+=map[idx(x2-half,y2)];cnt++}
        if(x2+half<n){s+=map[idx(x2+half,y2)];cnt++}
        map[idx(x2,y2)]=Math.max(0,Math.min(1,s/cnt+r(sc)));
      }
      step=half;sc*=0.5;
    }
    return map;
  }
  function drawDiamondSquare(){
    var rough=parseFloat(document.getElementById('ds-rough').value);
    var seed=parseInt(document.getElementById('ds-seed').value)||7;
    dsMap=diamondSquare(dsSize,rough,seed*100);
    var cvs=document.getElementById('t-diam');
    var W=cvs.width,H=cvs.height;
    var ctx=cvs.getContext('2d');
    var img=ctx.createImageData(W,H);
    for(var y=0;y<H;y++)for(var x=0;x<W;x++){
      var mx=Math.floor(x/W*(dsSize-1)),my=Math.floor(y/H*(dsSize-1));
      var v=dsMap[my*dsSize+mx];
      var c=biomeColor(v);
      var i=(y*W+x)*4;img.data[i]=c[0];img.data[i+1]=c[1];img.data[i+2]=c[2];img.data[i+3]=255;
    }
    ctx.putImageData(img,0,0);
  }
  document.getElementById('ds-regen').onclick=drawDiamondSquare;
  document.getElementById('ds-rough').oninput=function(){
    document.getElementById('ds-rv').textContent=(this.value/10).toFixed(1);drawDiamondSquare();
  };

  // ── Erosion ──
  var erosMap=null,erosSize=200;
  function genErosBase(){
    erosMap=new Float32Array(erosSize*erosSize);
    for(var y=0;y<erosSize;y++)for(var x=0;x<erosSize;x++)
      erosMap[y*erosSize+x]=fbm(x/erosSize*6+33,y/erosSize*6+33,5,0.5,2);
  }
  function runErosion(passes,inertia){
    var m=erosMap,s=erosSize;
    for(var p=0;p<passes;p++){
      var px=Math.random()*(s-2)+1,py=Math.random()*(s-2)+1;
      var dx=0,dy=0,water=1,sediment=0;
      for(var step=0;step<60;step++){
        var ix=Math.floor(px),iy=Math.floor(py);
        if(ix<1||ix>=s-1||iy<1||iy>=s-1)break;
        var nx=px-ix,ny=py-iy;
        var h00=m[iy*s+ix],h10=m[iy*s+ix+1],h01=m[(iy+1)*s+ix],h11=m[(iy+1)*s+ix+1];
        var gx=(h10-h00)*(1-ny)+(h11-h01)*ny;
        var gy=(h01-h00)*(1-nx)+(h11-h10)*nx;
        dx=dx*inertia-gx*(1-inertia);
        dy=dy*inertia-gy*(1-inertia);
        var len=Math.sqrt(dx*dx+dy*dy);
        if(len<0.001)break;
        dx/=len;dy/=len;
        px+=dx;py+=dy;
        var drop=0.02;
        m[iy*s+ix]=Math.max(0,m[iy*s+ix]-drop*0.5);
        if(ix+1<s)m[iy*s+ix+1]=Math.max(0,m[iy*s+ix+1]-drop*0.25);
        if(iy+1<s)m[(iy+1)*s+ix]=Math.max(0,m[(iy+1)*s+ix]-drop*0.25);
        water*=0.97;if(water<0.01)break;
      }
    }
  }
  function drawErosion(){
    var cvs=document.getElementById('t-eros');
    var W=cvs.width,H=cvs.height,ctx=cvs.getContext('2d');
    var img=ctx.createImageData(W,H);
    for(var y=0;y<H;y++)for(var x=0;x<W;x++){
      var mx=Math.floor(x/W*(erosSize-1)),my=Math.floor(y/H*(erosSize-1));
      var v=Math.max(0,Math.min(1,erosMap[my*erosSize+mx]));
      var c=biomeColor(v);
      var i=(y*W+x)*4;img.data[i]=c[0];img.data[i+1]=c[1];img.data[i+2]=c[2];img.data[i+3]=255;
    }
    ctx.putImageData(img,0,0);
  }
  genErosBase();drawErosion();
  document.getElementById('er-regen').onclick=function(){genErosBase();drawErosion();};
  document.getElementById('er-pass').oninput=function(){document.getElementById('er-pv').textContent=this.value;};
  document.getElementById('er-iner').oninput=function(){document.getElementById('er-iv').textContent=(this.value/10).toFixed(1);};
  document.getElementById('er-run').onclick=function(){
    var passes=parseInt(document.getElementById('er-pass').value)*500;
    var iner=parseFloat(document.getElementById('er-iner').value)/10;
    runErosion(passes,iner);drawErosion();
  };

  // ── Biomes ──
  function drawBiome(){
    var scale=parseFloat(document.getElementById('bm-scale').value);
    var seed=parseInt(document.getElementById('bm-seed').value)||99;
    var cvs=document.getElementById('t-biome');
    var W=cvs.width,H=cvs.height,ctx=cvs.getContext('2d');
    var img=ctx.createImageData(W,H);
    var BIOMES=[
      {name:'Ice',c:[220,235,245]},{name:'Tundra',c:[170,185,180]},
      {name:'Taiga',c:[50,90,60]},{name:'Shrubland',c:[130,145,80]},
      {name:'Grassland',c:[100,160,60]},{name:'Forest',c:[40,100,45]},
      {name:'Tropical',c:[20,130,60]},{name:'Desert',c:[210,185,100]},
      {name:'Savanna',c:[160,150,70]},{name:'Swamp',c:[60,100,70]}
    ];
    for(var y=0;y<H;y++)for(var x=0;x<W;x++){
      var temp=fbm(x/W*scale+seed,y/H*scale+seed*1.3,4,0.5,2);
      var prec=fbm(x/W*scale+seed*2.1,y/H*scale+seed*0.7,4,0.5,2);
      var elev=fbm(x/W*scale*1.5+seed*3,y/H*scale*1.5+seed*0.4,5,0.5,2);
      var bi;
      if(elev>0.75)bi=0;
      else if(temp<0.25)bi=elev<0.5?1:0;
      else if(temp<0.45)bi=prec>0.5?2:3;
      else if(temp<0.65)bi=prec>0.6?5:prec>0.35?4:7;
      else bi=prec>0.65?6:prec>0.4?8:7;
      if(elev<0.3)bi=9;
      var c=BIOMES[bi].c;
      var lgt=0.7+elev*0.6;
      var i=(y*W+x)*4;
      img.data[i]=Math.min(255,c[0]*lgt);img.data[i+1]=Math.min(255,c[1]*lgt);
      img.data[i+2]=Math.min(255,c[2]*lgt);img.data[i+3]=255;
    }
    ctx.putImageData(img,0,0);
  }
  document.getElementById('bm-regen').onclick=drawBiome;
  document.getElementById('bm-scale').oninput=function(){document.getElementById('bm-sv').textContent=this.value;drawBiome();};
})();
</script>
<!-- ======================================================
     SECTION 5 - WAVE FUNCTION COLLAPSE
====================================================== -->
<section id="wfc">
<div class="section-title">Wave Function Collapse</div>
<div class="section-subtitle">Constraint propagation — generating valid tilings from local adjacency rules</div>
<div style="display:grid;grid-template-columns:auto 1fr;gap:2rem;align-items:start">
<div>
<canvas class="pixel" height="320" id="wfc-canvas" style="border-radius:10px;background:#0a0818;display:block" width="320"></canvas>
<div class="controls" style="margin-top:.8rem;flex-wrap:wrap">
<button id="wfc-step">Step</button>
<button id="wfc-run">Run</button>
<button class="secondary" id="wfc-reset">Reset</button>
<div class="ctrl-group"><label>Tileset</label>
<select id="wfc-tileset">
<option value="0">Dungeon Rooms</option>
<option value="1">Circuit Board</option>
<option value="2">Castle Walls</option>
<option value="3">Abstract</option>
</select>
</div>
</div>
<div id="wfc-status" style="font-size:.75rem;color:var(--muted);margin-top:.5rem">Ready — press Step or Run</div>
</div>
<div>
<h3 style="color:var(--accent);font-size:.9rem;margin-bottom:.8rem">Tile Palette</h3>
<div id="wfc-palette" style="display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:1rem"></div>
<div style="background:var(--surface);border-radius:10px;padding:1rem;font-size:.8rem;color:var(--muted);line-height:1.7">
<b style="color:var(--white)">How WFC Works</b><br/>
        1. Start: every cell can be any tile (superposition)<br/>
        2. Collapse: pick lowest-entropy cell, choose a tile randomly<br/>
        3. Propagate: remove tiles in neighbors that violate adjacency rules<br/>
        4. Repeat until all cells collapsed or contradiction found<br/>
        5. On contradiction: backtrack and retry
      </div>
</div>
</div>
</section>
<script>
(function(){
  var GW=16,GH=16,CS=20; // grid width/height, cell size in px

  var TILESETS=[
    { // Dungeon Rooms
      tiles:[
        {name:'Floor',   color:'#2a2060',edges:[0,0,0,0]},
        {name:'Wall N',  color:'#5b21b6',edges:[1,0,0,0]},
        {name:'Wall E',  color:'#4c1d95',edges:[0,1,0,0]},
        {name:'Wall S',  color:'#5b21b6',edges:[0,0,1,0]},
        {name:'Wall W',  color:'#4c1d95',edges:[0,0,0,1]},
        {name:'Corner',  color:'#7c3aed',edges:[1,1,0,0]},
        {name:'Door',    color:'#a78bfa',edges:[0,2,0,2]},
        {name:'Pillar',  color:'#312e81',edges:[1,1,1,1]}
      ]
    },
    { // Circuit Board
      tiles:[
        {name:'Empty',   color:'#0f172a',edges:[0,0,0,0]},
        {name:'H-Wire',  color:'#7c3aed',edges:[0,1,0,1]},
        {name:'V-Wire',  color:'#6d28d9',edges:[1,0,1,0]},
        {name:'Cross',   color:'#a78bfa',edges:[1,1,1,1]},
        {name:'T-Junc',  color:'#8b5cf6',edges:[0,1,1,1]},
        {name:'Bend',    color:'#4c1d95',edges:[1,1,0,0]},
        {name:'Node',    color:'#c4b5fd',edges:[2,2,2,2]},
        {name:'Gap',     color:'#1e1b4b',edges:[0,0,0,0]}
      ]
    },
    { // Castle Walls
      tiles:[
        {name:'Grass',   color:'#14532d',edges:[0,0,0,0]},
        {name:'Wall',    color:'#713f12',edges:[1,1,1,1]},
        {name:'Tower',   color:'#92400e',edges:[1,1,1,1]},
        {name:'Gate',    color:'#78350f',edges:[1,2,1,0]},
        {name:'Road',    color:'#a16207',edges:[0,2,0,2]},
        {name:'Moat',    color:'#1e40af',edges:[3,3,3,3]},
        {name:'Bridge',  color:'#854d0e',edges:[3,0,3,0]},
        {name:'Trees',   color:'#166534',edges:[0,0,0,0]}
      ]
    },
    { // Abstract
      tiles:[
        {name:'A',color:'#7c3aed',edges:[0,0,0,0]},
        {name:'B',color:'#a78bfa',edges:[1,1,0,0]},
        {name:'C',color:'#4c1d95',edges:[0,1,1,0]},
        {name:'D',color:'#c4b5fd',edges:[1,0,0,1]},
        {name:'E',color:'#6d28d9',edges:[0,0,1,1]},
        {name:'F',color:'#8b5cf6',edges:[1,1,1,1]},
        {name:'G',color:'#312e81',edges:[0,0,0,0]},
        {name:'H',color:'#ddd6fe',edges:[2,2,2,2]}
      ]
    }
  ];

  var curTileset=0;
  var grid=[];    // array of cell superpositions (sets of tile indices)
  var collapsed=[];
  var running=false;
  var rafId=null;

  var cvs=document.getElementById('wfc-canvas');
  var ctx=cvs.getContext('2d');

  function getTiles(){return TILESETS[curTileset].tiles}

  function compatible(tA,tB,dir){
    // dir: 0=N(A above B) 1=E(A left of B) 2=S(A below B) 3=W(A right of B)
    var opp=[2,3,0,1];
    var a=getTiles()[tA].edges[dir];
    var b=getTiles()[tB].edges[opp[dir]];
    return a===b;
  }

  function initGrid(){
    var n=getTiles().length;
    grid=[];collapsed=[];
    for(var i=0;i<GW*GH;i++){
      var opts=[];for(var t=0;t<n;t++)opts.push(t);
      grid.push(opts);collapsed.push(false);
    }
  }

  function entropy(cell){return grid[cell].length}

  function collapseCell(idx){
    var opts=grid[idx];
    if(opts.length===0)return false;
    var chosen=opts[Math.floor(Math.random()*opts.length)];
    grid[idx]=[chosen];collapsed[idx]=true;
    return propagate(idx);
  }

  function propagate(startIdx){
    var queue=[startIdx];
    var visited=new Set();
    while(queue.length>0){
      var ci=queue.shift();
      if(visited.has(ci))continue;visited.add(ci);
      var x=ci%GW,y=Math.floor(ci/GW);
      var neighbors=[[x,y-1,0],[x+1,y,1],[x,y+1,2],[x-1,y,3]];
      for(var ni=0;ni<neighbors.length;ni++){
        var nx2=neighbors[ni][0],ny2=neighbors[ni][1],dir=neighbors[ni][2];
        if(nx2<0||nx2>=GW||ny2<0||ny2>=GH)continue;
        var nci=ny2*GW+nx2;
        if(collapsed[nci])continue;
        var before=grid[nci].length;
        grid[nci]=grid[nci].filter(function(tb){
          return grid[ci].some(function(ta){return compatible(ta,tb,dir);});
        });
        if(grid[nci].length===0)return false; // contradiction
        if(grid[nci].length<before)queue.push(nci);
      }
    }
    return true;
  }

  function stepWFC(){
    // find min-entropy uncollapsed cell
    var minE=Infinity,minIdx=-1;
    for(var i=0;i<GW*GH;i++){
      if(!collapsed[i]&&grid[i].length<minE){minE=grid[i].length;minIdx=i;}
    }
    if(minIdx===-1){
      document.getElementById('wfc-status').textContent='Complete!';
      running=false;return false;
    }
    if(!collapseCell(minIdx)){
      document.getElementById('wfc-status').textContent='Contradiction — resetting...';
      setTimeout(function(){initGrid();drawWFC();document.getElementById('wfc-status').textContent='Ready';},800);
      return false;
    }
    var remaining=collapsed.filter(function(c){return!c}).length;
    document.getElementById('wfc-status').textContent='Collapsed '+(GW*GH-remaining)+'/'+GW*GH+' cells';
    return true;
  }

  function drawTile(ctx,tile,x,y,w,h,partial){
    var t=getTiles()[tile];
    ctx.fillStyle=t.color+(partial?'88':'');
    ctx.fillRect(x,y,w,h);
    // draw edge indicators
    ctx.strokeStyle='rgba(255,255,255,0.3)';ctx.lineWidth=1;
    var e=t.edges;
    if(e[0]>0){ctx.beginPath();ctx.moveTo(x,y);ctx.lineTo(x+w,y);ctx.stroke()}
    if(e[1]>0){ctx.beginPath();ctx.moveTo(x+w,y);ctx.lineTo(x+w,y+h);ctx.stroke()}
    if(e[2]>0){ctx.beginPath();ctx.moveTo(x,y+h);ctx.lineTo(x+w,y+h);ctx.stroke()}
    if(e[3]>0){ctx.beginPath();ctx.moveTo(x,y);ctx.lineTo(x,y+h);ctx.stroke()}
  }

  function drawWFC(){
    ctx.fillStyle='#0a0818';ctx.fillRect(0,0,cvs.width,cvs.height);
    for(var i=0;i<GW*GH;i++){
      var x=(i%GW)*CS,y=Math.floor(i/GW)*CS;
      if(collapsed[i]){
        drawTile(ctx,grid[i][0],x,y,CS,CS,false);
      } else {
        var entropy2=grid[i].length/getTiles().length;
        var g=Math.floor(entropy2*60);
        ctx.fillStyle='rgb('+g+','+Math.floor(g*0.7)+','+(g+40)+')';
        ctx.fillRect(x,y,CS,CS);
        ctx.fillStyle='rgba(167,139,250,0.4)';
        ctx.font='8px monospace';ctx.textAlign='center';
        ctx.fillText(grid[i].length,x+CS/2,y+CS/2+3);
      }
      ctx.strokeStyle='rgba(30,27,75,0.5)';ctx.lineWidth=0.5;
      ctx.strokeRect(x,y,CS,CS);
    }
  }

  function buildPalette(){
    var pal=document.getElementById('wfc-palette');
    pal.innerHTML='';
    var tiles=getTiles();
    tiles.forEach(function(t,i){
      var pc=document.createElement('canvas');pc.width=36;pc.height=36;
      pc.style.borderRadius='4px';pc.title=t.name;
      var pctx=pc.getContext('2d');
      drawTile(pctx,i,0,0,36,36,false);
      pctx.fillStyle='rgba(0,0,0,0.5)';pctx.fillRect(0,22,36,14);
      pctx.fillStyle='#fff';pctx.font='7px sans-serif';pctx.textAlign='center';
      pctx.fillText(t.name,18,33);
      pal.appendChild(pc);
    });
  }

  function resetWFC(){
    running=false;if(rafId)cancelAnimationFrame(rafId);
    initGrid();drawWFC();
    document.getElementById('wfc-status').textContent='Ready — press Step or Run';
  }

  document.getElementById('wfc-step').onclick=function(){running=false;stepWFC();drawWFC();};
  document.getElementById('wfc-reset').onclick=resetWFC;
  document.getElementById('wfc-run').onclick=function(){
    running=true;
    var last2=0;
    function loop(ts){
      if(!running)return;
      if(ts-last2>60){last2=ts;if(!stepWFC()){running=false;}drawWFC();}
      if(running)rafId=requestAnimationFrame(loop);
    }
    rafId=requestAnimationFrame(loop);
  };
  document.getElementById('wfc-tileset').onchange=function(){
    curTileset=parseInt(this.value);buildPalette();resetWFC();
  };

  buildPalette();resetWFC();
})();
</script>
