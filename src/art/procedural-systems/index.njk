<!-- ══════════════════════════════════════════
     SECTION 1 — HERO
══════════════════════════════════════════ -->
<section id="hero">
<canvas id="hero-canvas"></canvas>
<div class="hero-overlay">
<h1>Procedural Systems</h1>
<p>Infinite worlds from finite rules</p>
</div>
</section>
<script>
(function(){
  const cvs=document.getElementById('hero-canvas');
  const ctx=cvs.getContext('2d');
  let W,H,mouseX=0.5;
  const scrollLag=new LagFilter(0.6); // LagFilter #1
  let scrollX=0;
  const stars=[];
  function resize(){W=cvs.width=cvs.offsetWidth;H=cvs.height=cvs.offsetHeight}
  resize();window.addEventListener('resize',resize);
  cvs.addEventListener('mousemove',e=>{const r=cvs.getBoundingClientRect();mouseX=(e.clientX-r.left)/r.width});
  for(let i=0;i<130;i++)stars.push({x:Math.random(),y:Math.random()*0.55,r:Math.random()*1.4+0.3,tw:Math.random()*Math.PI*2,sp:Math.random()*2+1});

  function tH(x,seed,sc,amp,oct){
    let y=0,a=1,f=1;
    for(let i=0;i<oct;i++){y+=valueNoise((x+seed)*f*sc,seed*f*0.1)*a;a*=0.5;f*=2}
    return y*amp
  }
  function village(x0,horizon,seed){
    const n=5+Math.floor(nhash(seed)*4);
    for(let i=0;i<n;i++){
      const bx=x0+i*42+nhash(seed+i*7)*18;
      const bw=10+nhash(seed+i)*18,bh=18+nhash(seed+i*3)*44;
      ctx.fillStyle='rgba(20,18,60,0.88)';ctx.fillRect(bx-bw/2,horizon-bh,bw,bh);
      ctx.beginPath();ctx.moveTo(bx-bw/2-3,horizon-bh);
      ctx.lineTo(bx,horizon-bh-bh*0.35);ctx.lineTo(bx+bw/2+3,horizon-bh);
      ctx.fillStyle='rgba(49,46,129,0.92)';ctx.fill();
      if(nhash(seed+i*11)>0.35){ctx.fillStyle='rgba(167,139,250,0.5)';ctx.fillRect(bx-3,horizon-bh*0.55,6,7)}
    }
  }

  let last=0;
  function draw(ts){
    const dt=Math.min((ts-last)/1000,0.05);last=ts;
    const speed=scrollLag.update((mouseX-0.5)*65,dt);
    scrollX+=speed*dt;
    ctx.clearRect(0,0,W,H);
    const sky=ctx.createLinearGradient(0,0,0,H);
    sky.addColorStop(0,'#07041a');sky.addColorStop(0.55,'#1e1b4b');sky.addColorStop(1,'#312e81');
    ctx.fillStyle=sky;ctx.fillRect(0,0,W,H);
    const t=ts*0.001;
    for(const s of stars){
      const sx=((s.x+scrollX*s.sp*0.00025)%1+1)%1*W;
      const sy=s.y*H;
      const alpha=0.35+0.65*Math.sin(t*s.sp+s.tw);
      ctx.beginPath();ctx.arc(sx,sy,s.r,0,Math.PI*2);
      ctx.fillStyle='rgba(248,250,252,'+alpha.toFixed(2)+')';ctx.fill()
    }
    const horizon=H*0.67;
    // distant mountains
    ctx.beginPath();
    for(let px=0;px<=W;px+=4){
      const y=horizon-tH((px+scrollX*8)/W*3,100,0.7,horizon*0.32,3);
      px===0?ctx.moveTo(px,y):ctx.lineTo(px,y)
    }
    ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
    ctx.fillStyle='rgba(30,27,75,0.65)';ctx.fill();
    // midground
    ctx.beginPath();
    for(let px=0;px<=W;px+=3){
      const y=horizon-tH((px+scrollX*28)/W*5,200,0.85,horizon*0.2,4);
      px===0?ctx.moveTo(px,y):ctx.lineTo(px,y)
    }
    ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
    ctx.fillStyle='rgba(49,46,129,0.72)';ctx.fill();
    // village
    const vseed=Math.floor(scrollX*0.008)*17+42;
    const voff=-(scrollX*45%((W+280)))+W*0.25;
    village(voff,horizon,vseed);
    // near hills
    ctx.beginPath();
    for(let px=0;px<=W;px+=2){
      const y=horizon-tH((px+scrollX*65)/W*7,300,1.2,horizon*0.13,4)+horizon*0.04;
      px===0?ctx.moveTo(px,y):ctx.lineTo(px,y)
    }
    ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
    const fg=ctx.createLinearGradient(0,horizon-50,0,H);
    fg.addColorStop(0,'#312e81');fg.addColorStop(1,'#1e1b4b');
    ctx.fillStyle=fg;ctx.fill();
    // closest strip
    ctx.beginPath();
    for(let px=0;px<=W;px+=2){
      const y=H-tH((px+scrollX*130)/W*9,400,1.6,H*0.11,3);
      px===0?ctx.moveTo(px,y):ctx.lineTo(px,y)
    }
    ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
    ctx.fillStyle='#14123a';ctx.fill();
    // fog
    const fog=ctx.createLinearGradient(0,horizon-15,0,horizon+35);
    fog.addColorStop(0,'rgba(124,58,237,0)');fog.addColorStop(1,'rgba(124,58,237,0.1)');
    ctx.fillStyle=fog;ctx.fillRect(0,horizon-15,W,50);
    requestAnimationFrame(draw)
  }
  requestAnimationFrame(ts=>{last=ts;requestAnimationFrame(draw)})
})();
</script>
